            "source": "— Business Insider"
          }
        },
        {
          "type": "logo",
          "settings": {
            "logo_alt": "Well + Good"
          }
        },
        {
          "type": "logo",
          "settings": {
            "logo_alt": "Forbes"
          }
        },
        {
          "type": "logo",
          "settings": {
            "logo_alt": "The Wall Street Journal"
          }
        },
        {
          "type": "logo",
          "settings": {
            "logo_alt": "GQ"
          }
        },
        {
          "type": "logo",
          "settings": {
            "logo_alt": "WWD"
          }
        },
        {
          "type": "logo",
          "settings": {
            "logo_alt": "Vogue"
          }
        },
        {
          "type": "logo",
