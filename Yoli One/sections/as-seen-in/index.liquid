<link rel="stylesheet" href="{{ 'as-seen-in/styles.css' | asset_url }}">

<section 
  class="as-seen-in {{ section.settings.background_color | default: 'bg-white' }}"
  style="
    padding-top: 87.25px;
    padding-bottom: 0;
    background-color: #f5f3f0;
  "
>
  <div class="as-seen-in-container container">
    
    <!-- Heading -->
    {% if section.settings.heading != blank %}
    <div class="as-seen-in-heading mb-2xl text-center">
      <h2 class="{{ section.settings.heading_font_size | default: 'text-sm' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-black' }} leading-heading" style="letter-spacing: 1.6px;">
        {{ section.settings.heading }}
      </h2>
    </div>
    {% endif %}
    
    <!-- Testimonial Quotes (Static) -->
    {% if section.settings.show_quotes %}
    <div class="quotes-static-wrapper mb-2xl">
      <div class="quotes-static-grid">
        {% for block in section.blocks %}
          {% if block.type == 'quote' %}
          <div class="quote-item" {{ block.fluid_attributes }}>
            {% if block.settings.quote_text != blank %}
            <div class="quote-content">
              <div class="quote-text" style="color: #7e6860; font-size: 18px; line-height: 28px; text-align: center;">
                {{ block.settings.quote_text }}
              </div>
              {% if block.settings.source != blank %}
              <div class="quote-source" style="color: #7e6860; font-size: 18px; line-height: 28px; text-align: center; margin-top: 0;">
                {{ block.settings.source }}
              </div>
              {% endif %}
            </div>
            {% endif %}
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
    
    <!-- Logo Carousel -->
    {% if section.settings.show_logos %}
    <div class="logos-carousel-wrapper">
      <div class="logos-carousel-track">
        
        <!-- First Set of Logos -->
        <div class="logos-set">
          {% for block in section.blocks %}
            {% if block.type == 'logo' %}
            <div class="logo-item" {{ block.fluid_attributes }}>
              {% if block.settings.logo_image != blank %}
                <img src="{{ block.settings.logo_image | image_url: width: 200 }}" alt="{{ block.settings.logo_alt | default: 'Logo' }}" loading="lazy">
              {% else %}
                <img src="{{ 'placeholder-image.svg' | asset_url }}" alt="Logo placeholder" loading="lazy">
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}
        </div>
        
        <!-- Duplicate Set for Seamless Loop -->
        <div class="logos-set" aria-hidden="true">
          {% for block in section.blocks %}
            {% if block.type == 'logo' %}
            <div class="logo-item">
              {% if block.settings.logo_image != blank %}
                <img src="{{ block.settings.logo_image | image_url: width: 200 }}" alt="{{ block.settings.logo_alt | default: 'Logo' }}" loading="lazy">
              {% else %}
                <img src="{{ 'placeholder-image.svg' | asset_url }}" alt="Logo placeholder" loading="lazy">
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}
        </div>
        
      </div>
    </div>
    {% endif %}
    
  </div>
</section>

<style>
  .as-seen-in-section {
    --quotes-animation-speed: {{ section.settings.quotes_animation_speed | default: 40 }}s;
    --logos-animation-speed: {{ section.settings.logos_animation_speed | default: 30 }}s;
    --logo-height: {{ section.settings.logo_max_height | default: 100 }}px;
    --quote-width: {{ section.settings.quote_width | default: 448 }}px;
  }
</style>

{% schema %}
{
  "name": "As Seen In",
  "tag": "section",
  "class": "as-seen-in-section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEATURED IN"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading Font Size (Mobile)",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" }
      ],
      "default": "text-sm"
    },
    {
      "type": "select",
      "id": "heading_font_size_desktop",
      "label": "Heading Font Size (Desktop)",
      "options": [
        { "value": "lg:text-xs", "label": "Extra Small" },
        { "value": "lg:text-sm", "label": "Small" },
        { "value": "lg:text-base", "label": "Base" },
        { "value": "lg:text-lg", "label": "Large" }
      ],
      "default": "lg:text-base"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semibold" }
      ],
      "default": "font-semibold"
    },
    {
      "type": "select",
      "id": "heading_color",
      "label": "Heading Color",
      "options": [
        { "value": "text-primary", "label": "Primary Text" },
        { "value": "text-black", "label": "Black" },
        { "value": "text-neutral-dark", "label": "Neutral Dark" }
      ],
      "default": "text-primary"
    },
    {
      "type": "header",
      "content": "Display Options"
    },
    {
      "type": "checkbox",
      "id": "show_quotes",
      "label": "Show Testimonial Quotes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_logos",
      "label": "Show Logo Strip",
      "default": true
    },
    {
      "type": "header",
      "content": "Quotes Carousel Settings"
    },
    {
      "type": "range",
      "id": "quotes_animation_speed",
      "label": "Quotes Animation Speed (seconds)",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 40,
      "info": "Higher = slower scroll"
    },
    {
      "type": "range",
      "id": "quote_width",
      "label": "Quote Card Width (px)",
      "min": 300,
      "max": 600,
      "step": 20,
      "default": 448
    },
    {
      "type": "header",
      "content": "Logos Carousel Settings"
    },
    {
      "type": "range",
      "id": "logos_animation_speed",
      "label": "Logos Animation Speed (seconds)",
      "min": 15,
      "max": 60,
      "step": 5,
      "default": 30,
      "info": "Higher = slower scroll"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Logo Max Height (px)",
      "min": 60,
      "max": 140,
      "step": 10,
      "default": 100
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Section Background Color",
      "options": [
        { "value": "bg-primary", "label": "Primary Text" },
        { "value": "bg-secondary", "label": "Secondary Text" },
        { "value": "bg-secondary-light", "label": "Secondary Light" },
        { "value": "bg-accent-warm", "label": "Accent" },
        { "value": "bg-banner", "label": "Accent Alt" },
        { "value": "bg-success", "label": "Success" },
        { "value": "bg-error", "label": "Error" },
        { "value": "bg-white", "label": "White" },
        { "value": "bg-black", "label": "Black" },
        { "value": "bg-neutral", "label": "Neutral" },
        { "value": "bg-neutral-light", "label": "Neutral Light" },
        { "value": "bg-neutral-dark", "label": "Neutral Dark" }
      ],
      "default": "bg-page"
    },
    {
      "type": "select",
      "id": "section_padding_y_mobile",
      "label": "Section Padding Y (Mobile)",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "xs", "label": "Extra Small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "2xl", "label": "2X Large" },
        { "value": "3xl", "label": "3X Large" }
      ],
      "default": "2xl"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote Text",
          "default": "\"In a sea of generic supplement suppliers with just a packaging and marketing department, NOVOS' commitment to research is a clear outlier.\""
        },
        {
          "type": "text",
          "id": "source",
          "label": "Source (e.g., Forbes)",
          "default": "Lorem Ipsum"
        },
        {
          "type": "select",
          "id": "quote_font_size",
          "label": "Quote Font Size",
          "options": [
            { "value": "text-sm", "label": "Small" },
            { "value": "text-base", "label": "Base" },
            { "value": "text-lg", "label": "Large" }
          ],
          "default": "text-lg"
        },
        {
          "type": "select",
          "id": "quote_font_weight",
          "label": "Quote Font Weight",
          "options": [
            { "value": "font-normal", "label": "Normal" },
            { "value": "font-medium", "label": "Medium" }
          ],
          "default": "font-normal"
        },
        {
          "type": "select",
          "id": "quote_color",
          "label": "Quote Color",
          "options": [
            { "value": "text-black", "label": "Black" },
            { "value": "text-neutral-dark", "label": "Neutral Dark" },
            { "value": "text-neutral", "label": "Neutral" }
          ],
          "default": "text-primary"
        },
        {
          "type": "select",
          "id": "source_font_size",
          "label": "Source Font Size",
          "options": [
            { "value": "text-sm", "label": "Small" },
            { "value": "text-base", "label": "Base" },
            { "value": "text-lg", "label": "Large" }
          ],
          "default": "text-lg"
        },
        {
          "type": "select",
          "id": "source_font_weight",
          "label": "Source Font Weight",
          "options": [
            { "value": "font-normal", "label": "Normal" },
            { "value": "font-medium", "label": "Medium" }
          ],
          "default": "font-normal"
        },
        {
          "type": "select",
          "id": "source_color",
          "label": "Source Color",
          "options": [
            { "value": "text-black", "label": "Black" },
            { "value": "text-neutral-dark", "label": "Neutral Dark" },
            { "value": "text-neutral", "label": "Neutral" }
          ],
          "default": "text-primary"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Logo Alt Text",
          "default": "Publication logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "As Seen In",
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "quote_text": "\"In a sea of generic supplement suppliers with just a packaging and marketing department, NOVOS' commitment to research is a clear outlier.\"",
            "source": "— Forbes"
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote_text": "\"Novos are pioneers in consumer longevity and among the first to develop a comprehensive approach that targets 12 mechanisms of aging simultaneously.\"",
            "source": "— The Wall Street Journal"
