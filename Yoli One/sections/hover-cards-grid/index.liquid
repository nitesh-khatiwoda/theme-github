<link rel="stylesheet" href="{{ 'hover-cards-grid/styles.css' | asset_url }}">

<!-- Hover Cards Grid Section -->
<section class="hover-cards-grid {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="hover-cards-grid__inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header Row -->
      <div class="hover-cards-grid__header">
        
        <!-- Heading -->
        {% if section.settings.heading != blank %}
          <div class="hover-cards-grid__heading-wrapper">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-black' }}">
              {{ section.settings.heading }}
            </h2>
          </div>
        {% endif %}

        <!-- Description -->
        {% if section.settings.description != blank %}
          <div class="hover-cards-grid__description-wrapper">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
              {{ section.settings.description }}
            </p>
          </div>
        {% endif %}

      </div>

      <!-- Cards Grid -->
      {% if section.blocks.size > 0 %}
        <div class="hover-cards-grid__grid">
          {% for block in section.blocks %}
            {% if block.type == 'card' %}
              <a href="{{ block.settings.url | default: '#' }}" class="hover-cards-grid__card {{ section.settings.card_border_radius | default: 'rounded-xl' }}" {{ block.fluid_attributes }}>
                
                <!-- Card Background (Image + Solid Color) -->
                <div class="hover-cards-grid__card-bg {{ block.settings.card_color | default: 'bg-success' }}">
                  <!-- Background Image -->
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 600 }}" 
                         alt="{{ block.settings.image_alt | default: block.settings.title }}"
                         class="hover-cards-grid__card-image">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" 
                         alt="{{ block.settings.title | default: 'Card placeholder' }}"
                         class="hover-cards-grid__card-image">
                  {% endif %}
                  
                  <!-- Bottom Gradient Overlay -->
                  <div class="hover-cards-grid__card-gradient"></div>
                </div>

                <!-- Card Content (Animates on Hover) -->
                <div class="hover-cards-grid__card-content">
                  
                  <!-- Title -->
                  {% if block.settings.title != blank %}
                    <h3 class="hover-cards-grid__card-title {{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-3xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.card_title_font_weight | default: 'font-light' }} {{ section.settings.card_title_color | default: 'text-white' }}">
                      {{ block.settings.title }}
                    </h3>
                  {% endif %}

                  <!-- Description (Shown on Hover) -->
                  {% if block.settings.description != blank %}
                    <p class="hover-cards-grid__card-description {{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-lg' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_description_color | default: 'text-white' }}">
                      {{ block.settings.description }}
                    </p>
                  {% endif %}

                  <!-- Arrow Button (Shown on Hover) -->
                  <div class="hover-cards-grid__card-arrow">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>

                </div>

              </a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

    </div>
  </div>

</section>

