<link rel="stylesheet" href="{{ 'faq-accordion-2/styles.css' | asset_url }}">

<!-- FAQ Accordion 2 Section -->
<section class="faq-accordion-2 {{ section.settings.background_color | default: 'bg-primary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="faq-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="faq-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.heading != blank %}
      <div class="faq-heading heading-margin">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-white' }} leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- FAQ Items -->
      {% if section.blocks.size > 0 %}
      <div class="faq-wrapper" style="max-width: {{ section.settings.max_width | default: '1024' }}px; margin: 0 auto;">
        <div class="faq-list">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
          <div class="faq-item" {{ block.fluid_attributes }} data-faq-item>
            
            <!-- Question Button -->
            <button class="faq-question" aria-expanded="false" data-faq-button>
              <span class="{{ block.settings.question_font_family | default: 'font-body' }} {{ block.settings.question_font_size | default: 'text-lg' }} {{ block.settings.question_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.question_font_weight | default: 'font-normal' }} {{ block.settings.question_color | default: 'text-white' }}">
                {{ block.settings.question }}
              </span>
              
              <!-- Plus/Minus Icon -->
              <div class="faq-icon" aria-hidden="true">
                <span class="icon-horizontal" style="background-color: {{ section.settings.icon_color | default: '#f8da52' }};"></span>
                <span class="icon-vertical" style="background-color: {{ section.settings.icon_color | default: '#f8da52' }};"></span>
              </div>
            </button>
            
            <!-- Answer Panel -->
            <div class="faq-answer" data-faq-answer>
              <div class="faq-answer-content">
                <p class="{{ block.settings.answer_font_family | default: 'font-body' }} {{ block.settings.answer_font_size | default: 'text-base' }} {{ block.settings.answer_font_weight | default: 'font-normal' }} {{ block.settings.answer_color | default: 'text-white' }} leading-body">
                  {{ block.settings.answer }}
                </p>
              </div>
            </div>
            
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
    
    </div>
  </div>
  
</section>

<script>
  // FAQ Accordion Functionality
  (function() {
    const faqItems = document.querySelectorAll('[data-faq-item]');
    
    faqItems.forEach(item => {
      const button = item.querySelector('[data-faq-button]');
      const answer = item.querySelector('[data-faq-answer]');
      
      if (!button || !answer) return;
      
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        // Close all other items (accordion mode - only one open at a time)
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            const otherButton = otherItem.querySelector('[data-faq-button]');
            const otherAnswer = otherItem.querySelector('[data-faq-answer]');
            if (otherButton && otherAnswer) {
              otherButton.setAttribute('aria-expanded', 'false');
              otherAnswer.style.maxHeight = '0';
              otherItem.classList.remove('is-open');
            }
          }
        });
        
        // Toggle current item
        if (isExpanded) {
          button.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0';
          item.classList.remove('is-open');
        } else {
          button.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          item.classList.add('is-open');
        }
      });
    });
  })();
</script>

