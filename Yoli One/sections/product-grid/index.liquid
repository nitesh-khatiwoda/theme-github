<!-- Product Grid Section -->
<section class="product-grid {{ section.settings.background_color | default: 'bg-secondary-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-lg' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="products-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-grid-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.heading_text != blank %}
      <div class="product-grid-heading mb-2xl text-center">
        <h2 class="font-primary {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="letter-spacing: -0.03em; line-height: 1.1;">
          {{ section.settings.heading_text }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Product Grid -->
      {% if section.blocks.size > 0 %}
      <div class="products-grid">
        {% for block in section.blocks %}
          {% if block.type == 'product' %}
          
          <div class="product-card {{ section.settings.card_background | default: 'bg-secondary-light' }}" {{ block.fluid_attributes }} style="border-radius: {{ section.settings.card_border_radius | default: '12' }}px;">
            
            <!-- Product Image -->
            <a href="{{ block.settings.product_url | default: '#' }}" class="product-image-link">
              <div class="product-image" style="border-radius: {{ section.settings.image_border_radius | default: '8' }}px;">
                {% if block.settings.product_image != blank %}
                  <img src="{{ block.settings.product_image | image_url: width: 400 }}" alt="{{ block.settings.product_title | default: 'Product' }}" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy">
                {% endif %}
              </div>
            </a>
            
            <!-- Badge (Optional) -->
            {% if block.settings.show_badge and block.settings.badge_text != blank %}
            <div class="product-badge {{ section.settings.badge_background | default: 'bg-black' }}" style="border-radius: {{ section.settings.badge_border_radius | default: '20' }}px;">
              {% if block.settings.show_badge_icon %}
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.badge_icon_color | default: 'text-secondary' }}">
                <path d="M6.5 0L7.9135 4.5865L12.5 6L7.9135 7.4135L6.5 12L5.0865 7.4135L0.5 6L5.0865 4.5865L6.5 0Z" fill="currentColor"/>
              </svg>
              {% endif %}
              <span class="{{ block.settings.badge_font_size | default: 'text-sm' }} {{ block.settings.badge_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.badge_font_weight | default: 'font-normal' }} {{ section.settings.badge_text_color | default: 'text-white' }}">
                {{ block.settings.badge_text }}
              </span>
            </div>
            {% endif %}
            
            <!-- Star Rating -->
            {% if block.settings.show_rating %}
            <div class="product-rating">
              {% assign rating = block.settings.rating | default: 5 %}
              {% for i in (1..rating) %}
                <svg width="20" height="18" viewBox="0 0 20 18" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.star_color | default: 'text-quaternary' }}">
                  <path d="M10 0L12.2451 6.90983H19.5106L13.6327 11.1803L15.8779 18.0902L10 13.8197L4.12215 18.0902L6.36729 11.1803L0.489435 6.90983H7.75486L10 0Z" fill="currentColor"/>
                </svg>
              {% endfor %}
            </div>
            {% endif %}
            
            <!-- Product Title -->
            {% if block.settings.product_title != blank %}
            <div class="product-title">
              <h3 class="{{ block.settings.title_font_size | default: 'text-lg' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.title_font_weight | default: 'font-normal' }} {{ block.settings.title_color | default: 'text-black' }} text-center leading-heading">
                {{ block.settings.product_title }}
              </h3>
            </div>
            {% endif %}
            
            <!-- Product Price -->
            {% if block.settings.product_price != blank %}
            <div class="product-price mb-sm">
              <p class="{{ block.settings.price_font_size | default: 'text-base' }} {{ block.settings.price_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.price_font_weight | default: 'font-normal' }} {{ block.settings.price_color | default: 'text-black' }} text-center leading-body">
                {{ block.settings.product_price }}
              </p>
            </div>
            {% endif %}
            
            <!-- Add to Cart Button -->
            {% if block.settings.show_button %}
            <div class="product-button">
              <a href="{{ block.settings.product_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }} uppercase">
                {{ block.settings.button_text | default: 'ADD TO CART +' }}
              </a>
            </div>
            {% endif %}
            
          </div>
          
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

