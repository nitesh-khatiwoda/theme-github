<link rel="stylesheet" href="{{ 'video-carousel/styles.css' | asset_url }}">

<section 
  class="video-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="video-carousel-{{ section.id }}"
  style="--video-card-height-mobile: {{ section.settings.video_card_height_mobile | default: 300 }}px; --video-card-height-desktop: {{ section.settings.video_card_height_desktop | default: 600 }}px; --video-card-width-mobile: {{ section.settings.video_card_width_mobile | default: 175 }}px; --video-card-width-desktop: {{ section.settings.video_card_width_desktop | default: 350 }}px;"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="video-carousel-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-xl' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Title and Description -->
      {% if section.settings.title != blank or section.settings.description != blank %}
      <div class="video-carousel-header {{ section.settings.header_alignment | default: 'text-center' }}" style="max-width: {{ section.settings.carousel_max_width | default: 1408 }}px; margin: 0 auto;">
        {% if section.settings.title != blank %}
        <div class="video-carousel-title-wrapper mb-lg">
          <h2 class="video-carousel-title {{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-3xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-black' }}">
            {{ section.settings.title }}
          </h2>
        </div>
        {% endif %}
        
        {% if section.settings.description != blank %}
        <div class="video-carousel-description-wrapper mb-xl"> 
          <p class="video-carousel-description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
      </div>
      {% endif %}
      
      {% if section.blocks.size > 0 %}
      <div class="video-carousel-wrapper" style="max-width: {{ section.settings.carousel_max_width | default: 1408 }}px; margin: 0 auto;">
        
        <!-- Carousel Container -->
        <div class="video-carousel-container">
          
          <!-- Carousel Track -->
          <div class="video-carousel-track" data-carousel-item-tablet="{{ section.settings.videos_per_page_tablet}}" data-carousel-item-desktop="{{section.settings.videos_per_page_desktop}}">
            {% for block in section.blocks %}
              {% if block.type == 'video_item' %}
              <div class="video-carousel-item" {{ block.fluid_attributes }}>
                <div class="video-carousel-video-wrapper {{ section.settings.video_card_border_radius | default: 'rounded-lg' }}">
                  
                  <!-- Fluid Media Widget - handles rendering and click to open popover -->
                  <div class="video-carousel-media">
                    {% if block.settings.media_id != blank %}
                      <fluid-media-widget media-id="{{ block.settings.media_id }}" responsive="true" embed-type="popover"></fluid-media-widget>
                    {% else %}
                      <!-- Placeholder when no media ID provided -->
                      <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Add media ID to display content" class="video-carousel-thumbnail">
                    {% endif %}
                  </div>
                  
                </div>
              </div>
              {% endif %}
            {% endfor %}
          </div>
          
        </div>
        
        <!-- Navigation Controls (Below Carousel) -->
        <div class="video-carousel-controls {% if section.settings.controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
          <div class="video-carousel-nav-buttons">
            <button 
              class="video-carousel-nav-btn video-carousel-prev {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
              data-carousel-prev="{{ section.id }}"
              aria-label="Previous page">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            
            <button 
              class="video-carousel-nav-btn video-carousel-next {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
              data-carousel-next="{{ section.id }}"
              aria-label="Next page">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          
          <!-- Progress Indicator -->
          {% if section.settings.show_progress_dots %}
            {% assign slick_dots_class = "" %}
          {% else %}
             {% assign slick_dots_class = "hidden" %}
          {% endif %}
           <div class="video-carousel-progress {{slick_dots_class}}">
            <!-- Dots will be generated by JavaScript -->
          </div>
        </div>
        
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

 <script>
    function carousel() {
      var numSlick = 0;
      const carouselSelector = $('.video-carousel-track');

      // Destroy previous instance
      carouselSelector.each(function () {
        if ($(this).hasClass('slick-initialized')) {
          $(this).slick('unslick');
        }
      });


      $(carouselSelector).each(function(){
        var carousel_item_tablet = $(this).data('carousel-item-tablet')
        var carousel_item_desktop = $(this).data('carousel-item-desktop');
        numSlick++;
        $(this).closest(".video-carousel").find(".video-carousel-progress").addClass("video-carousel-progress-"+ numSlick);
        $(this).closest(".video-carousel").find(".video-carousel-prev").addClass("video-carousel-prev-"+ numSlick);
        $(this).closest(".video-carousel").find(".video-carousel-next").addClass("video-carousel-next-"+ numSlick);
        $(this).slick({
          infinite: true,
          slidesToShow: 1,
          slidesToScroll: 1,
          initialSlide: 0,
          dots: true,
          arrows: true,
          mobileFirst: true,
          // centerMode: true,
          // centerPadding: '60px',
          prevArrow: $('.video-carousel-prev-'+numSlick),
          nextArrow: $('.video-carousel-next-'+numSlick),
          appendDots: $('.video-carousel-progress-'+numSlick),
          infinite: false,
          responsive: [
            {
              breakpoint: 600,
              settings: {
               slidesToShow: 2,
              }
            },
            {
              breakpoint: 768,
              settings: {
                 // centerPadding: '120px',
                 slidesToShow: carousel_item_tablet
              }
            },
            {
              breakpoint: 1024,
              settings: {
                slidesToShow: carousel_item_desktop,
                // centerPadding: '200px'
              }
            }
          ]
        });
      });

    }
    document.addEventListener("DOMContentLoaded", function(){
      carousel();
    });


</script>

