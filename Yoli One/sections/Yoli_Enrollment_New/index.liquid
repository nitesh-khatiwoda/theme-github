                {% assign product_price = parts[1] | times: 1 %}
                {% assign product_retail = parts[2] | times: 1 %}
                {% assign product_qv = parts[3] | times: 1 %}
                {% assign product_category = parts[4] %}
                {% assign product_id = product_name | handleize %}
