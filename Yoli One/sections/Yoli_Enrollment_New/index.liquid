<link rel="stylesheet" href="{{ 'main_enrollment/styles.css' | asset_url }}">

<!-- Neora Brand Partner Enrollment Configurator -->
<section class="enrollment-configurator" id="enrollment-{{ section.id }}">
  
  {% assign membership_product = membership_products.first %}
  {% assign images_array = images_array | default: enrollment_pack.images_array %}
  
  <!-- Full-Width Split Screen Container -->
  <div class="enrollment-split-screen">
    
    <!-- LEFT COLUMN: Static Hero with Background Image (Sticky on Desktop) -->
    {% assign hero_bg_url = 'https://www.neora.com/-/media/Website/Images/PC_Upgrade_To_BP/Box' %}
    {% if section.settings.hero_bg_image != blank %}
      {% assign hero_bg_url = section.settings.hero_bg_image | image_url: width: 1400 %}
    {% endif %}
    <div class="enrollment-hero" id="enrollment-hero-{{ section.id }}" style="background-image: url('{{ hero_bg_url }}');">
      
      <!-- Gradient Overlay -->
      <div class="hero-gradient-overlay"></div>
      
      <!-- Hero Text Content -->
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-title">{{ section.settings.hero_title | default: 'TURN WHAT YOU LOVE INTO WHAT YOU DO' }}</h1>
          <p class="hero-subtitle">{{ section.settings.hero_subtitle | default: 'When you level up to Results + Perks as a Brand Partner, sharing Neora's clean-meets-performance skincare, hair care and wellness products can positively shape how you and your family live, grow and thrive. Start earning perks today!' }}</p>
          
          <!-- Value Props -->
          <ul class="value-props">
            {% for block in section.blocks %}
              {% if block.type == 'value_prop' %}
                <li class="value-prop" {{ block.fluid_attributes }}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span>{{ block.settings.text }}</span>
                </li>
              {% endif %}
            {% endfor %}
            {% assign value_prop_blocks = section.blocks | where: "type", "value_prop" %}
            {% if value_prop_blocks.size == 0 %}
              <li class="value-prop"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Deep product discounts</span></li>
              <li class="value-prop"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Earn commissions & perks</span></li>
              <li class="value-prop"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Access to your own storefront</span></li>
              <li class="value-prop"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Marketing materials included</span></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </div>
    
    <!-- RIGHT COLUMN: Scrollable Configurator Panel -->
    <div class="enrollment-panel" id="enrollment-panel-{{ section.id }}">
      
      <!-- Starter Kit Section - Nectar Style -->
      <div class="starter-kit-section" id="starter-kit-{{ section.id }}">
        <!-- Header -->
        <div class="starter-kit-header">
          <span class="starter-kit-value">{{ section.settings.starter_kit_price | default: '$20' }} Starter Kit Included</span>
        </div>
        
        <!-- Content: Image Left + Items Right -->
        <div class="starter-kit-content">
          <!-- Kit Image -->
          <div class="starter-kit-image">
            {% if section.settings.starter_kit_image != blank %}
              <img src="{{ section.settings.starter_kit_image | image_url: width: 300 }}" alt="Brand Partner Starter Kit">
            {% else %}
              <img src="https://www.neora.com/-/media/Shared/Products/Product-Images/Enrollment-Basic-Kit/US-DigitalEnrollmentKit.png?h=230" alt="Brand Partner Starter Kit">
            {% endif %}
          </div>
          
          <!-- Kit Items List -->
          <div class="starter-kit-items">
            {% assign kit_items = section.settings.starter_kit_includes | split: '|' %}
            {% if kit_items.size > 0 %}
              {% for item in kit_items %}
                <div class="starter-kit-item">
                  <div class="kit-item-info">
                    <span class="kit-item-name">{{ item | strip }}</span>
                  </div>
                  <div class="kit-item-status">
                    <span class="kit-item-included">Included</span>
                    <svg class="kit-item-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                </div>
              {% endfor %}
            {% else %}
              <div class="starter-kit-item">
                <div class="kit-item-info">
                  <span class="kit-item-name">Personal e-commerce website</span>
                </div>
                <div class="kit-item-status">
                  <span class="kit-item-included">Included</span>
                  <svg class="kit-item-check" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="16 10 11 15 8 12"></polyline>
                  </svg>
                </div>
              </div>
              <div class="starter-kit-item">
                <div class="kit-item-info">
                  <span class="kit-item-name">Marketing materials & training</span>
                </div>
                <div class="kit-item-status">
                  <span class="kit-item-included">Included</span>
                  <svg class="kit-item-check" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="16 10 11 15 8 12"></polyline>
                  </svg>
                </div>
              </div>
              <div class="starter-kit-item">
                <div class="kit-item-info">
                  <span class="kit-item-name">Back-office access</span>
                </div>
                <div class="kit-item-status">
                  <span class="kit-item-included">Included</span>
                  <svg class="kit-item-check" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="16 10 11 15 8 12"></polyline>
                  </svg>
                </div>
              </div>
              <div class="starter-kit-item">
                <div class="kit-item-info">
                  <span class="kit-item-name">Mobile app access</span>
                </div>
                <div class="kit-item-status">
                  <span class="kit-item-included">Included</span>
                  <svg class="kit-item-check" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="16 10 11 15 8 12"></polyline>
                  </svg>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
      
      <!-- STEP 1: Choose Your Launch Pack -->
      <div class="config-step" data-step="packs" id="step-packs-{{ section.id }}">
        <div class="step-header">
          <span class="step-number">1</span>
          <div class="step-header-text">
            <h2 class="step-title">{{ section.settings.packs_title | default: 'Choose your Launch Pack' }}</h2>
            <p class="step-description">
              {{ section.settings.packs_description | default: 'Select a discounted product bundle to jumpstart your business. One plan for you and your customers.' }}
              <button type="button" class="view-pack-contents-link" id="pack-details-trigger-{{ section.id }}">
                View full pack contents
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
            </p>
          </div>
        </div>
        
        <div class="step-content">
          
          <!-- Nectar-Style Pack Cards -->
          <div class="pack-cards-grid">
            {% for block in section.blocks %}
              {% if block.type == 'pack_option' %}
                <div class="pack-card-wrapper {% if block.settings.is_best_value %}has-badge{% endif %}">
                  <!-- Most Popular Badge (appears above card) -->
                  {% if block.settings.is_best_value %}
                    <div class="pack-popular-badge">MOST POPULAR</div>
                  {% endif %}
                  
                  <div class="pack-card {% if block.settings.is_selected %}selected{% endif %}" 
                       data-pack-id="{{ block.settings.pack_id }}" 
                       data-price="{{ block.settings.pack_price_value }}"
                       {{ block.fluid_attributes }}>
                    
                    <!-- Card Header: Name + Radio -->
                    <div class="pack-card-header">
                      <h3 class="pack-name">{{ block.settings.pack_name }}</h3>
                      <div class="pack-radio-wrapper">
                        <input type="radio" name="pack-selection" id="pack-{{ block.id }}" value="{{ block.settings.pack_id }}" {% if block.settings.is_selected %}checked{% endif %} class="pack-radio">
                        <span class="pack-radio-custom"></span>
                      </div>
                    </div>
                    
                    <!-- Pack Image -->
                    <div class="pack-image">
                      {% if block.settings.pack_image != blank %}
                        <img src="{{ block.settings.pack_image | image_url: width: 400 }}" alt="{{ block.settings.pack_name }}">
                      {% elsif block.settings.pack_id contains 'ultimate' %}
                        <img src="https://www.neora.com/-/media/Shared/Products/Product-Images/Ultimate-Launch-Pack---2509/US-EN_UltimatePack.png?h=230" alt="{{ block.settings.pack_name }}">
                      {% else %}
                        <img src="https://www.neora.com/-/media/Shared/Products/Product-Images/Premier-Launch-Pack---2306/US-EN_PremierPack.png?h=230" alt="{{ block.settings.pack_name }}">
                      {% endif %}
                    </div>
                    
                    <!-- Pack Features -->
                    <ul class="pack-features">
                      {% assign features = block.settings.pack_features | split: '|' %}
                      {% for feature in features limit: 3 %}
                        <li>
                          <svg class="feature-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                          <span>{{ feature | strip | upcase }}</span>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
            
            <!-- Default Neora Packs if no blocks -->
            {% assign pack_blocks = section.blocks | where: "type", "pack_option" %}
            {% if pack_blocks.size == 0 %}
              
              <!-- Premier Launch Pack -->
              <div class="pack-card-wrapper">
                <div class="pack-card" data-pack-id="premier-pack" data-price="500">
                  <div class="pack-card-header">
                    <h3 class="pack-name">Premier Launch Pack</h3>
                    <div class="pack-radio-wrapper">
                      <input type="radio" name="pack-selection" id="pack-premier" value="premier-pack" class="pack-radio">
                      <span class="pack-radio-custom"></span>
                    </div>
                  </div>
                  
                  <div class="pack-image">
                    <img src="https://www.neora.com/-/media/Shared/Products/Product-Images/Premier-Launch-Pack---2306/US-EN_PremierPack.png?h=230" alt="Premier Launch Pack">
                  </div>
                  
                  <ul class="pack-features">
                    <li><svg class="feature-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>10 PRODUCTS INCLUDED</span></li>
                    <li><svg class="feature-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>SAVE $516 OFF RETAIL</span></li>
                  </ul>
                </div>
              </div>
              
              <!-- Ultimate Launch Pack -->
              <div class="pack-card-wrapper has-badge">
                <div class="pack-popular-badge">MOST POPULAR</div>
                <div class="pack-card selected" data-pack-id="ultimate-pack" data-price="1000">
                  <div class="pack-card-header">
                    <h3 class="pack-name">Ultimate Launch Pack</h3>
                    <div class="pack-radio-wrapper">
                      <input type="radio" name="pack-selection" id="pack-ultimate" value="ultimate-pack" checked class="pack-radio">
                      <span class="pack-radio-custom"></span>
                    </div>
                  </div>
                  
                  <div class="pack-image">
                    <img src="https://www.neora.com/-/media/Shared/Products/Product-Images/Ultimate-Launch-Pack---2509/US-EN_UltimatePack.png?h=230" alt="Ultimate Launch Pack">
                  </div>
                  
                  <ul class="pack-features">
                    <li><svg class="feature-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>28 PRODUCTS INCLUDED</span></li>
                    <li><svg class="feature-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg><span>SAVE $1,245 OFF RETAIL</span></li>
                  </ul>
                </div>
              </div>
              
            {% endif %}
          </div>
          
          <!-- Pack Details Content (toggled by link in description) -->
          <div class="pack-details-content" id="pack-details-content-{{ section.id }}" style="display: none;">
              <div class="pack-details-grid">
                <!-- Premier Pack Details -->
                <div class="pack-detail-column" data-for-pack="premier-pack">
                  <h4>Premier Launch Pack Includes:</h4>
                  <p class="pack-detail-intro">Think of this as your "business in a box," setting you up perfectly to launch your business.</p>
                  
                  <div class="detail-category">
                    <h5>Skincare</h5>
                    <ul>
                      <li>4 Neo-FILLER Lift + Fill Corrective Elixirs</li>
                      <li>1 Age IQ Night Cream</li>
                      <li>1 Age IQ Day Cream</li>
                      <li>1 Age IQ Face Wash</li>
                      <li>1 Age IQ Eye Serum</li>
                      <li>1 Eye-V Hydrogel Patches</li>
                    </ul>
                  </div>
                  
                  <div class="detail-category">
                    <h5>Wellness</h5>
                    <ul>
                      <li>1 Youth Factor Powder</li>
                    </ul>
                  </div>
                </div>
                
                <!-- Ultimate Pack Details -->
                <div class="pack-detail-column" data-for-pack="ultimate-pack">
                  <h4>Ultimate Launch Pack Includes:</h4>
                  <p class="pack-detail-intro">Everything in the Premier Pack + products for your own personal transformation.</p>
                  
                  <div class="detail-category">
                    <h5>Skincare</h5>
                    <ul>
                      <li>4 Neo-FILLER Lift + Fill Corrective Elixirs</li>
                      <li>2 Age IQ Night Cream</li>
                      <li>2 Age IQ Day Cream</li>
                      <li>2 Eye-V Hydrogel Patches</li>
                      <li>1 Age IQ Face Wash</li>
                      <li>1 Age IQ Eye Serum</li>
                      <li>1 Invisi-Bloc Sunscreen Gel SPF40</li>
                      <li>1 IllumaBoost Brightening Vitamin C Serum</li>
                      <li>1 Firm Body Contour Cream</li>
                      <li>1 LashLush 3-in1 Lash & Brow Serum</li>
                    </ul>
                  </div>
                  
                  <div class="detail-category">
                    <h5>Wellness</h5>
                    <ul>
                      <li>1 EHT Brain Formula</li>
                      <li>1 Youth Factor Tablet</li>
                      <li>1 Youth Factor Powder</li>
                      <li>1 Sleep+ Wellness Chew</li>
                      <li>1 Energy+ Wellness Chew</li>
                    </ul>
                  </div>
                  
                  <div class="detail-category">
                    <h5>Weight Management</h5>
                    <ul>
                      <li>1 Slim + Skin Collagen Powder</li>
                      <li>1 Block + Balance Pre & Probiotic Powder</li>
                      <li>1 Cleanse + Calm Nightly Gentle Cleanse</li>
                    </ul>
                  </div>
                  
                  <div class="detail-category">
                    <h5>Hair Care</h5>
                    <ul>
                      <li>1 ProLuxe Rebalancing Shampoo</li>
                      <li>1 ProLuxe Rebalancing Conditioner</li>
                      <li>1 ProLuxe Hair Mask</li>
                      <li>1 ProLuxe Scalp Treatment</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          
        </div>
      </div>
      
      <!-- STEP 2: Choose Your SmartShop Order -->
      <div class="config-step" data-step="smartshop" id="step-smartshop-{{ section.id }}">
        <div class="step-header">
          <span class="step-number">2</span>
          <div class="step-header-text">
            <h2 class="step-title">{{ section.settings.smartshop_title | default: 'Choose your SmartShop Order' }}</h2>
            <p class="step-description">{{ section.settings.smartshop_description | default: 'Your Order. Your Way. Get the lowest prices on all Neora products with total flexibility—delay, change, or cancel anytime. Earn 3% free product credits as a Brand Partner.' }}</p>
          </div>
        </div>
        
        <div class="step-content">
          <!-- Product Category Tabs -->
          <div class="smartshop-tabs" id="smartshop-tabs-{{ section.id }}">
            <button type="button" class="tab-btn active" data-category="all">All Products</button>
            <button type="button" class="tab-btn" data-category="skincare">Skincare</button>
            <button type="button" class="tab-btn" data-category="wellness">Wellness</button>
            <button type="button" class="tab-btn" data-category="haircare">Hair Care</button>
            <button type="button" class="tab-btn" data-category="weight">Weight</button>
          </div>
          
          <!-- Search Bar -->
          <div class="smartshop-search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="smartshop-search-{{ section.id }}" placeholder="Search products..." class="search-input">
          </div>
          
          <!-- Product Grid -->
          <div class="smartshop-products-grid" id="products-grid-{{ section.id }}">
            
            {% comment %} 
              Use Fluid's global 'products' object to access all products.
              This works on enrollment_pack pages where collection context isn't available.
              
              Priority:
              1. Fluid 'products' global (all catalog products)
              2. Products from smartshop_product blocks  
              3. Fallback placeholder products
            {% endcomment %}
            
            {% assign smartshop_products_source = products %}
            
            {% if smartshop_products_source and smartshop_products_source.size > 0 %}
              {% comment %} PRODUCTS FROM SUBSCRIPTION OR COLLECTION {% endcomment %}
              {% for product in smartshop_products_source limit: section.settings.smartshop_products_limit | default: 20 %}
                {% comment %} Determine category from product tags {% endcomment %}
                {% assign product_category = 'skincare' %}
                {% if product.tags contains 'wellness' %}
                  {% assign product_category = 'wellness' %}
                {% elsif product.tags contains 'haircare' or product.tags contains 'hair' %}
                  {% assign product_category = 'haircare' %}
                {% elsif product.tags contains 'weight' or product.tags contains 'neorafit' %}
                  {% assign product_category = 'weight' %}
                {% endif %}
                
                {% comment %} Extract numeric price for data attribute - handle both formatted and numeric prices {% endcomment %}
                {% assign price_str = product.price | strip %}
                {% assign price_numeric = price_str | remove: '$' | remove: ',' | remove: ' ' | times: 1.0 %}
                {% comment %} If price is in cents (Shopify format), convert {% endcomment %}
                {% if price_numeric > 10000 %}
                  {% assign price_numeric = price_numeric | divided_by: 100.0 %}
                {% endif %}
                
                {% comment %} Calculate compare at price and savings {% endcomment %}
                {% assign compare_price_str = product.compare_at_price | default: product.retail_price | strip %}
                {% assign compare_numeric = compare_price_str | remove: '$' | remove: ',' | remove: ' ' | times: 1.0 %}
                {% if compare_numeric > 10000 %}
                  {% assign compare_numeric = compare_numeric | divided_by: 100.0 %}
                {% endif %}
                
                {% assign has_savings = false %}
                {% assign savings_percent = 0 %}
                {% assign savings_amount = 0 %}
                {% if compare_numeric > price_numeric %}
                  {% assign has_savings = true %}
                  {% assign savings_amount = compare_numeric | minus: price_numeric %}
                  {% assign savings_percent = savings_amount | times: 100 | divided_by: compare_numeric | round %}
                {% endif %}
                
                {% comment %} Calculate QV (typically same as price or custom field) {% endcomment %}
                {% assign qv_value = product.metafields.custom.qv | default: price_numeric | round %}
                
                <div class="smartshop-product-card" 
                     data-product-id="{{ product.id }}"
                     data-category="{{ product_category }}"
                     data-price="{{ price_numeric }}"
                     data-name="{{ product.title | downcase }}"
                     data-qty="0">
                  
                  <!-- Product Info (Left) -->
                  <div class="product-card-info">
                    {% comment %} Savings Badge {% endcomment %}
                    {% if has_savings and savings_percent > 0 %}
                      <span class="product-savings-badge">SAVE {{ savings_percent }}%</span>
                    {% endif %}
                    
                    <h4 class="product-card-name">{{ product.title }}</h4>
                    
                    <!-- Price & QV -->
                    <div class="product-pricing">
                      <span class="product-card-price">${{ price_numeric | round: 2 }} USD</span>
                      <span class="product-qv">{{ qv_value }} QV</span>
                    </div>
                    
                    <!-- Savings Info -->
                    {% if has_savings %}
                      <p class="product-savings-info">Save {{ savings_percent }}% (${{ compare_numeric | round: 2 }} USD Value)</p>
                    {% endif %}
                  </div>
                  
                  <!-- Product Image (Right) with Qty Controls -->
                  <div class="product-card-media">
                    <div class="product-card-image">
                      {%- assign product_image = product.images.first.src | default: product.featured_media.url | default: product.image -%}
                      {% if product_image != blank %}
                        <img src="{{ product_image }}" alt="{{ product.title }}" loading="lazy">
                      {% else %}
                        <div class="product-image-placeholder">
                          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                          </svg>
                        </div>
                      {% endif %}
                    </div>
                    
                    <!-- Qty Controls -->
                    <div class="qty-controls">
                      <!-- Add Button (shown when qty = 0) -->
                      <button type="button" class="qty-add-btn" aria-label="Add to order">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <line x1="12" y1="5" x2="12" y2="19"></line>
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                      </button>
                      
                      <!-- Qty Stepper (shown when qty > 0) -->
                      <div class="qty-stepper" style="display: none;">
                        <button type="button" class="qty-minus-btn" aria-label="Decrease quantity">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </button>
                        <span class="qty-value">0</span>
                        <button type="button" class="qty-plus-btn" aria-label="Increase quantity">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
              
            {% else %}
              {% comment %} PRODUCTS FROM SECTION BLOCKS {% endcomment %}
              {% for block in section.blocks %}
                {% if block.type == 'smartshop_product' %}
                  <div class="smartshop-product-card" 
                       data-product-id="{{ block.settings.product_id }}"
                       data-category="{{ block.settings.category }}"
                       data-price="{{ block.settings.price_value }}"
                       data-name="{{ block.settings.product_name | downcase }}"
                       data-qty="0"
                       {{ block.fluid_attributes }}>
                    <!-- Product Info (Left) -->
                    <div class="product-card-info">
                      <h4 class="product-card-name">{{ block.settings.product_name }}</h4>
                      <span class="product-card-price">{{ block.settings.price }}<span class="price-period">/mo</span></span>
                    </div>
                    
                    <!-- Product Image (Right) with Qty Controls -->
                    <div class="product-card-media">
                      <div class="product-card-image">
                        {% if block.settings.product_image != blank %}
                          <img src="{{ block.settings.product_image | image_url: width: 200 }}" alt="{{ block.settings.product_name }}" loading="lazy">
                        {% else %}
                          <div class="product-image-placeholder">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
