          <!-- Add-ons Product Grid -->
          <div class="addons-products-grid" id="addons-grid-{{ section.id }}">
            
            {% comment %} 
              Use Fluid's global 'products' object to access all products.
              This works on enrollment_pack pages where collection context isn't available.
              
              Priority:
              1. Fluid 'products' global (all catalog products)
              2. Products from addon_product blocks
              3. Fallback placeholder products
            {% endcomment %}
            
            {% assign addons_products_source = products %}
            
            {% if addons_products_source and addons_products_source.size > 0 %}
              {% comment %} PRODUCTS FROM SUBSCRIPTION OR COLLECTION {% endcomment %}
              {% for product in addons_products_source limit: section.settings.addons_products_limit | default: 12 %}
                {% comment %} Determine category from product tags {% endcomment %}
                {% assign addon_category = 'skincare' %}
                {% if product.tags contains 'wellness' %}
                  {% assign addon_category = 'wellness' %}
                {% elsif product.tags contains 'haircare' or product.tags contains 'hair' %}
                  {% assign addon_category = 'haircare' %}
                {% elsif product.tags contains 'weight' or product.tags contains 'neorafit' %}
                  {% assign addon_category = 'weight' %}
                {% endif %}
                
                {% comment %} Extract numeric price for data attribute - handle both formatted and numeric prices {% endcomment %}
                {% assign addon_price_str = product.price | strip %}
                {% assign addon_price_numeric = addon_price_str | remove: '$' | remove: ',' | remove: ' ' | times: 1.0 %}
                {% comment %} If price is in cents (Shopify format), convert {% endcomment %}
                {% if addon_price_numeric > 10000 %}
                  {% assign addon_price_numeric = addon_price_numeric | divided_by: 100.0 %}
                {% endif %}
                
                {% comment %} Calculate compare at price and savings for add-ons {% endcomment %}
                {% assign addon_compare_str = product.compare_at_price | default: product.retail_price | strip %}
                {% assign addon_compare_numeric = addon_compare_str | remove: '$' | remove: ',' | remove: ' ' | times: 1.0 %}
                {% if addon_compare_numeric > 10000 %}
                  {% assign addon_compare_numeric = addon_compare_numeric | divided_by: 100.0 %}
                {% endif %}
                
                {% assign addon_has_savings = false %}
                {% assign addon_savings_percent = 0 %}
                {% assign addon_savings_amount = 0 %}
                {% if addon_compare_numeric > addon_price_numeric %}
                  {% assign addon_has_savings = true %}
                  {% assign addon_savings_amount = addon_compare_numeric | minus: addon_price_numeric %}
                  {% assign addon_savings_percent = addon_savings_amount | times: 100 | divided_by: addon_compare_numeric | round %}
                {% endif %}
                
                {% comment %} Calculate QV for add-ons {% endcomment %}
                {% assign addon_qv_value = product.metafields.custom.qv | default: addon_price_numeric | round %}
                
                <div class="addon-product-card" 
                     data-product-id="{{ product.id }}"
                     data-category="{{ addon_category }}"
                     data-price="{{ addon_price_numeric }}"
                     data-name="{{ product.title | downcase }}"
                     data-qty="0">
                  
                  <!-- Product Info (Left) -->
                  <div class="addon-product-info">
                    {% comment %} Savings Badge {% endcomment %}
                    {% if addon_has_savings and addon_savings_percent > 0 %}
                      <span class="product-savings-badge">SAVE {{ addon_savings_percent }}%</span>
                    {% endif %}
                    
                    <h4 class="addon-product-name">{{ product.title }}</h4>
                    
                    <!-- Price & QV -->
                    <div class="product-pricing">
                      <span class="addon-product-price">${{ addon_price_numeric | round: 2 }} USD</span>
                      <span class="product-qv">{{ addon_qv_value }} QV</span>
                    </div>
                    
                    <!-- Savings Info -->
                    {% if addon_has_savings %}
                      <p class="product-savings-info">Save {{ addon_savings_percent }}% (${{ addon_compare_numeric | round: 2 }} USD Value)</p>
                    {% endif %}
                  </div>
                  
                  <!-- Product Image (Right) with Qty Controls -->
                  <div class="addon-product-media">
                    <div class="addon-product-image">
                      {%- assign addon_product_image = product.images.first.src | default: product.featured_media.url | default: product.image -%}
                      {% if addon_product_image != blank %}
                        <img src="{{ addon_product_image }}" alt="{{ product.title }}" loading="lazy">
                      {% else %}
                        <div class="addon-image-placeholder">
                          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                          </svg>
                        </div>
                      {% endif %}
                    </div>
                    
                    <!-- Qty Controls -->
                    <div class="qty-controls">
                      <button type="button" class="qty-add-btn" aria-label="Add to order">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <line x1="12" y1="5" x2="12" y2="19"></line>
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                      </button>
                      <div class="qty-stepper" style="display: none;">
                        <button type="button" class="qty-minus-btn" aria-label="Decrease quantity">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </button>
                        <span class="qty-value">0</span>
                        <button type="button" class="qty-plus-btn" aria-label="Increase quantity">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
              
            {% else %}
              {% comment %} PRODUCTS FROM SECTION BLOCKS {% endcomment %}
              {% for block in section.blocks %}
                {% if block.type == 'addon_product' %}
                  <div class="addon-product-card" 
                       data-product-id="{{ block.settings.product_id }}"
                       data-category="{{ block.settings.category }}"
                       data-price="{{ block.settings.price_value }}"
                       data-name="{{ block.settings.product_name | downcase }}"
                       data-qty="0"
                       {{ block.fluid_attributes }}>
                    <!-- Product Info (Left) -->
                    <div class="addon-product-info">
                      <h4 class="addon-product-name">{{ block.settings.product_name }}</h4>
                      <span class="addon-product-price">{{ block.settings.price }}</span>
                    </div>
                    
                    <!-- Product Image (Right) with Qty Controls -->
                    <div class="addon-product-media">
                      <div class="addon-product-image">
                        {% if block.settings.product_image != blank %}
                          <img src="{{ block.settings.product_image | image_url: width: 200 }}" alt="{{ block.settings.product_name }}" loading="lazy">
                        {% else %}
                          <div class="addon-image-placeholder">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                              <circle cx="8.5" cy="8.5" r="1.5"></circle>
                              <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                          </div>
                        {% endif %}
                      </div>
                      
                      <!-- Qty Controls -->
                      <div class="qty-controls">
                        <button type="button" class="qty-add-btn" aria-label="Add to order">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </button>
                        <div class="qty-stepper" style="display: none;">
                          <button type="button" class="qty-minus-btn" aria-label="Decrease quantity">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                              <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                          </button>
                          <span class="qty-value">0</span>
                          <button type="button" class="qty-plus-btn" aria-label="Increase quantity">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                              <line x1="12" y1="5" x2="12" y2="19"></line>
                              <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            {% endif %}
            
            {% comment %} Default placeholder add-ons if no subscription_products, collection, or blocks {% endcomment %}
            {% assign addon_blocks = section.blocks | where: "type", "addon_product" %}
            {% if addons_products_source == nil and addon_blocks.size == 0 %}
