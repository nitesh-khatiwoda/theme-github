<script>
document.addEventListener('DOMContentLoaded', function() {
  const sectionId = '{{ section.id }}';
  
  // State management
  const state = {
    starterKit: { price: 20, selected: true },
    selectedPack: { id: null, name: null, price: 0 },
    subscription: { enabled: false, items: [], frequency: 30 },
    addons: { items: [] }
  };
  
  // Initialize components
  initPackSelection(sectionId);
  initPackDetailsToggle(sectionId);
  initSmartShopBrowser(sectionId);
  initAddonsSection(sectionId);
  initOrderSummary(sectionId);
  initTooltips(sectionId);
  
  // Pack Selection (radio-style single selection like Eight Sleep)
  function initPackSelection(sectionId) {
    const packCards = document.querySelectorAll('.pack-card');
    
    // Initialize state from pre-selected pack
    const preSelectedCard = document.querySelector('.pack-card.selected');
    if (preSelectedCard) {
      updatePackState(preSelectedCard);
    }
    
    packCards.forEach(card => {
      // Click on card to select
      card.addEventListener('click', function(e) {
        // Deselect all cards
        packCards.forEach(c => c.classList.remove('selected'));
        
        // Select this card
        this.classList.add('selected');
        
        // Update radio button
        const radio = this.querySelector('input[type="radio"]');
        if (radio) {
          radio.checked = true;
        }
        
        // Update state
        updatePackState(this);
        updateOrderSummary(sectionId);
      });
    });
    
    // Radio button change (for keyboard navigation)
    document.querySelectorAll('.pack-radio').forEach(radio => {
      radio.addEventListener('change', function() {
        if (this.checked) {
          const card = this.closest('.pack-card');
          packCards.forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          updatePackState(card);
          updateOrderSummary(sectionId);
        }
      });
    });
  }
  
  function updatePackState(card) {
    if (!card) {
      state.selectedPack = { id: null, name: null, price: 0 };
      return;
    }
    
    const price = parseFloat(card.dataset.price) || 0;
    const name = card.querySelector('.pack-name')?.textContent || '';
    const id = card.dataset.packId || '';
    
    state.selectedPack = { id, name, price };
  }
  
  // Pack Details Toggle
  function initPackDetailsToggle(sectionId) {
    const trigger = document.getElementById('pack-details-trigger-' + sectionId);
    const content = document.getElementById('pack-details-content-' + sectionId);
    
    if (!trigger || !content) return;
    
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      const isOpen = content.style.display !== 'none';
      content.style.display = isOpen ? 'none' : 'block';
      
      // Toggle expanded class on the link for arrow rotation
      this.classList.toggle('expanded', !isOpen);
      
      // Update link text
      const linkText = isOpen ? 'View full pack contents' : 'Hide pack contents';
      this.innerHTML = linkText + ' <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>';
    });
  }
  
  // SmartShop Product Browser (Qty-based like DoorDash)
  function initSmartShopBrowser(sectionId) {
    const tabsContainer = document.getElementById('smartshop-tabs-' + sectionId);
    const searchInput = document.getElementById('smartshop-search-' + sectionId);
    const productsGrid = document.getElementById('products-grid-' + sectionId);
    
    if (!productsGrid) return;
    
    const productCards = productsGrid.querySelectorAll('.smartshop-product-card');
    
    // Category Tab Filtering
    if (tabsContainer) {
      const tabBtns = tabsContainer.querySelectorAll('.tab-btn');
      
      tabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          tabBtns.forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          const category = this.dataset.category;
          filterProducts(category, searchInput?.value || '');
        });
      });
    }
    
    // Search Filtering
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const activeTab = tabsContainer?.querySelector('.tab-btn.active');
        const category = activeTab?.dataset.category || 'all';
        filterProducts(category, this.value);
      });
    }
    
    function filterProducts(category, searchTerm) {
      const search = searchTerm.toLowerCase().trim();
      productCards.forEach(card => {
        const cardCategory = card.dataset.category;
        const cardName = card.dataset.name || '';
        const matchesCategory = category === 'all' || cardCategory === category;
        const matchesSearch = !search || cardName.includes(search);
        card.classList.toggle('hidden', !(matchesCategory && matchesSearch));
      });
    }
    
    // Qty-based Product Selection
    productCards.forEach(card => {
      const addBtn = card.querySelector('.qty-add-btn');
      const stepper = card.querySelector('.qty-stepper');
      const minusBtn = card.querySelector('.qty-minus-btn');
      const plusBtn = card.querySelector('.qty-plus-btn');
      const qtyValue = card.querySelector('.qty-value');
      
      if (!addBtn || !stepper) return;
      
      // Add button click
      addBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        let qty = parseInt(card.dataset.qty) || 0;
        qty = 1;
        card.dataset.qty = qty;
        qtyValue.textContent = qty;
        addBtn.style.display = 'none';
        stepper.style.display = 'flex';
        card.classList.add('selected');
        updateSmartShopState();
        updateOrderSummary(sectionId);
      });
      
      // Minus button click
      minusBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        let qty = parseInt(card.dataset.qty) || 0;
        qty = Math.max(0, qty - 1);
        card.dataset.qty = qty;
        qtyValue.textContent = qty;
        
        if (qty === 0) {
          addBtn.style.display = 'flex';
          stepper.style.display = 'none';
          card.classList.remove('selected');
        }
        updateSmartShopState();
        updateOrderSummary(sectionId);
      });
      
      // Plus button click
      plusBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        let qty = parseInt(card.dataset.qty) || 0;
        qty = qty + 1;
        card.dataset.qty = qty;
        qtyValue.textContent = qty;
        updateSmartShopState();
        updateOrderSummary(sectionId);
      });
    });
    
    function updateSmartShopState() {
      state.subscription.items = [];
      state.subscription.enabled = false;
      
      productCards.forEach(card => {
        const qty = parseInt(card.dataset.qty) || 0;
        if (qty > 0) {
          const price = parseFloat(card.dataset.price) || 0;
          const name = card.querySelector('.product-card-name')?.textContent || '';
          const id = card.dataset.productId || '';
          state.subscription.items.push({ id, name, price, qty });
          state.subscription.enabled = true;
        }
      });
    }
    
    }
  
  // Add-ons Section (Qty-based like DoorDash)
  function initAddonsSection(sectionId) {
    const tabsContainer = document.getElementById('addons-tabs-' + sectionId);
    const addonsGrid = document.getElementById('addons-grid-' + sectionId);
    
    if (!addonsGrid) return;
    
    const addonCards = addonsGrid.querySelectorAll('.addon-product-card');
    
    // Category Tab Filtering
    if (tabsContainer) {
      const tabBtns = tabsContainer.querySelectorAll('.tab-btn');
      
      tabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          tabBtns.forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          const category = this.dataset.category;
          filterAddons(category);
        });
      });
    }
    
    function filterAddons(category) {
      addonCards.forEach(card => {
        const cardCategory = card.dataset.category;
        const matchesCategory = category === 'all' || cardCategory === category;
        card.classList.toggle('hidden', !matchesCategory);
      });
    }
    
    // Qty-based Product Selection
    addonCards.forEach(card => {
      const addBtn = card.querySelector('.qty-add-btn');
      const stepper = card.querySelector('.qty-stepper');
      const minusBtn = card.querySelector('.qty-minus-btn');
      const plusBtn = card.querySelector('.qty-plus-btn');
      const qtyValue = card.querySelector('.qty-value');
      
      if (!addBtn || !stepper) return;
      
      // Add button click
      addBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        let qty = 1;
        card.dataset.qty = qty;
        qtyValue.textContent = qty;
        addBtn.style.display = 'none';
        stepper.style.display = 'flex';
        card.classList.add('selected');
        updateAddonsState();
        updateOrderSummary(sectionId);
      });
      
      // Minus button click
      minusBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        let qty = parseInt(card.dataset.qty) || 0;
        qty = Math.max(0, qty - 1);
        card.dataset.qty = qty;
        qtyValue.textContent = qty;
        
        if (qty === 0) {
          addBtn.style.display = 'flex';
          stepper.style.display = 'none';
          card.classList.remove('selected');
        }
        updateAddonsState();
        updateOrderSummary(sectionId);
      });
      
      // Plus button click
      plusBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        let qty = parseInt(card.dataset.qty) || 0;
        qty = qty + 1;
        card.dataset.qty = qty;
        qtyValue.textContent = qty;
        updateAddonsState();
        updateOrderSummary(sectionId);
      });
    });
    
    function updateAddonsState() {
      state.addons.items = [];
      
      addonCards.forEach(card => {
        const qty = parseInt(card.dataset.qty) || 0;
        if (qty > 0) {
          const price = parseFloat(card.dataset.price) || 0;
          const name = card.querySelector('.addon-product-name')?.textContent || '';
          const id = card.dataset.productId || '';
          state.addons.items.push({ id, name, price, qty });
        }
      });
    }
  }
  
  // Order Summary
  function initOrderSummary(sectionId) {
    const toggleBtn = document.getElementById('toggle-details-' + sectionId);
    const detailsPanel = document.getElementById('order-details-' + sectionId);
    
    if (toggleBtn && detailsPanel) {
      toggleBtn.addEventListener('click', function() {
        const isOpen = detailsPanel.style.display !== 'none';
        detailsPanel.style.display = isOpen ? 'none' : 'block';
        
        const icon = this.querySelector('svg');
        if (icon) {
          icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
        }
        
        this.querySelector('span') || this.childNodes[0];
        if (!isOpen) {
          this.innerHTML = 'Hide details <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>';
        } else {
          this.innerHTML = 'View details <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>';
        }
      });
    }
    
    // Initial update
    updateOrderSummary(sectionId);
  }
  
  function updateOrderSummary(sectionId) {
    // Calculate one-time total (starter kit + pack + add-ons with qty)
    let onetimeTotal = state.starterKit.price;
    if (state.selectedPack.price > 0) {
      onetimeTotal += state.selectedPack.price;
    }
    // Add one-time add-ons (multiply by qty)
    let addonsTotal = 0;
    if (state.addons.items.length > 0) {
      state.addons.items.forEach(i => addonsTotal += (i.price * (i.qty || 1)));
      onetimeTotal += addonsTotal;
    }
    
    // Calculate recurring total (multiply by qty)
    let recurringTotal = 0;
    if (state.subscription.enabled) {
      state.subscription.items.forEach(i => recurringTotal += (i.price * (i.qty || 1)));
    }
    
    // Update display
    const onetimeEl = document.getElementById('onetime-total');
    const recurringEl = document.getElementById('recurring-total');
    const dueTodayEl = document.getElementById('due-today');
    const onetimeSubtotalEl = document.getElementById('onetime-subtotal');
    const itemCountEl = document.getElementById('item-count');
    
    const formatPrice = (price) => '$' + price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    
    if (onetimeEl) onetimeEl.textContent = formatPrice(onetimeTotal);
    if (recurringEl) recurringEl.textContent = formatPrice(recurringTotal);
    if (dueTodayEl) dueTodayEl.textContent = formatPrice(onetimeTotal);
    if (onetimeSubtotalEl) onetimeSubtotalEl.textContent = formatPrice(onetimeTotal);
    
    // Update item count (total qty across all items)
    const addonsQty = state.addons.items.reduce((sum, i) => sum + (i.qty || 1), 0);
    const subscriptionQty = state.subscription.items.reduce((sum, i) => sum + (i.qty || 1), 0);
    const itemCount = 1 + (state.selectedPack.price > 0 ? 1 : 0) + addonsQty + subscriptionQty;
    if (itemCountEl) itemCountEl.textContent = itemCount + (itemCount === 1 ? ' item' : ' items');
    
    // Update order details list
    updateOrderDetailsList(sectionId);
    
    // Show/hide recurring in summary
    const recurringSummary = document.querySelector('.summary-column.recurring');
    if (recurringSummary) {
      recurringSummary.style.opacity = state.subscription.enabled && recurringTotal > 0 ? '1' : '0.5';
    }
    
    // Show/hide recurring section in order details panel
    const recurringSection = document.getElementById('recurring-section');
    if (recurringSection) {
      recurringSection.style.display = state.subscription.enabled && recurringTotal > 0 ? 'block' : 'none';
    }
  }
  
  function updateOrderDetailsList(sectionId) {
    const onetimeList = document.getElementById('onetime-items');
    const recurringList = document.getElementById('recurring-items');
    
    const formatPrice = (price) => '$' + price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    
    if (onetimeList) {
      let html = '<li><span>Brand Partner Starter Kit</span><span>' + formatPrice(state.starterKit.price) + '</span></li>';
      if (state.selectedPack.price > 0) {
        html += '<li><span>' + state.selectedPack.name + '</span><span>' + formatPrice(state.selectedPack.price) + '</span></li>';
      }
      // Add one-time add-ons to the list with qty
      state.addons.items.forEach(i => {
        const qty = i.qty || 1;
        const lineTotal = i.price * qty;
        const qtyLabel = qty > 1 ? qty + 'x ' : '';
        html += '<li><span>' + qtyLabel + i.name + '</span><span>' + formatPrice(lineTotal) + '</span></li>';
      });
      onetimeList.innerHTML = html;
    }
    
    if (recurringList && state.subscription.enabled) {
      let html = '';
      state.subscription.items.forEach(i => {
        const qty = i.qty || 1;
        const lineTotal = i.price * qty;
        const qtyLabel = qty > 1 ? qty + 'x ' : '';
        html += '<li><span>' + qtyLabel + i.name + '</span><span>' + formatPrice(lineTotal) + '/mo</span></li>';
      });
      recurringList.innerHTML = html || '<li><span>No subscription products selected</span><span>$0.00</span></li>';
    }
  }
  
  // Tooltips
  function initTooltips(sectionId) {
    const tooltipBtns = document.querySelectorAll('.info-tooltip');
    
    tooltipBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        const tooltipId = 'tooltip-' + this.dataset.tooltip;
        const tooltip = document.getElementById(tooltipId);
        
        if (tooltip) {
          // Position tooltip near button
          const rect = this.getBoundingClientRect();
          tooltip.style.top = (rect.bottom + 10) + 'px';
          tooltip.style.left = Math.max(20, rect.left - 100) + 'px';
          tooltip.style.display = 'block';
        }
      });
    });
    
    // Close tooltips
    document.querySelectorAll('.tooltip-close').forEach(btn => {
      btn.addEventListener('click', function() {
        this.closest('.tooltip-popover').style.display = 'none';
      });
    });
    
    // Close on click outside
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.tooltip-popover') && !e.target.closest('.info-tooltip')) {
        document.querySelectorAll('.tooltip-popover').forEach(t => t.style.display = 'none');
      }
    });
  }
  
  // Initialize shipping date
  function updateShippingDate(sectionId) {
    const chargeDateEl = document.getElementById('charge-date');
    if (chargeDateEl) {
      const nextMonth = new Date();
      nextMonth.setMonth(nextMonth.getMonth() + 1);
      chargeDateEl.textContent = nextMonth.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
    }
  }
  updateShippingDate(sectionId);
});
</script>
