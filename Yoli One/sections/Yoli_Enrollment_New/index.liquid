            <p class="step-description">{{ section.settings.addons_description | default: 'Add your add-on picks to today\'s order and elevate your skincare, hair care and wellness results! Visit your SmartShop Manager in your Back Office to add items monthly.' }}</p>
          </div>
        </div>
        
        <div class="step-content">
