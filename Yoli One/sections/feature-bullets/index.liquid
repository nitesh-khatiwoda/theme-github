<link rel="stylesheet" href="{{ 'feature-bullets/styles.css' | asset_url }}">

<!-- Feature Bullets Section -->
<section class="feature-bullets {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="feature-bullets-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Two Column Layout -->
      <div class="feature-bullets__content {% if section.settings.flip_layout %}feature-bullets__content--flipped{% endif %}">
        
        <!-- Left Column: Heading + Bullets + Button -->
        <div class="feature-bullets__left">
          
          <!-- Heading -->
          {% if section.settings.heading_part1 != blank or section.settings.heading_part2 != blank %}
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
              {% if section.settings.heading_part1 != blank %}
                <span>{{ section.settings.heading_part1 }}</span>
              {% endif %}
              {% if section.settings.heading_part2 != blank %}
                <br><span>{{ section.settings.heading_part2 }}</span>
              {% endif %}
            </h2>
          {% endif %}

          <!-- Bullet List -->
          {% if section.blocks.size > 0 %}
            <ul class="feature-bullets__list">
              {% for block in section.blocks %}
                {% if block.type == 'bullet_item' %}
                  <li class="feature-bullets__item" {{ block.fluid_attributes }}>
                    
                    <!-- Bullet Icon -->
                    <div class="feature-bullets__icon" style="color: {{ section.settings.bullet_icon_color | default: '#000000' }};">
                      {% if block.settings.icon %}
                        <img src="{{ block.settings.icon | image_url: width: 48 }}"
                             alt="{{ block.settings.icon_alt | default: 'Checkmark' }}"
                             loading="lazy"
                             style="box-shadow: none !important;">
                      {% else %}
                        <!-- Default checkmark SVG -->
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% endif %}
                    </div>

                    <!-- Bullet Text -->
                    {% if block.settings.text != blank %}
                      <div class="feature-bullets__text">
                        <p class="{{ section.settings.bullet_font_family | default: 'font-body' }} {{ section.settings.bullet_font_size | default: 'text-base' }} {{ section.settings.bullet_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.bullet_font_weight | default: 'font-normal' }} {{ section.settings.bullet_color | default: 'text-primary' }} leading-body">
                          {{ block.settings.text }}
                        </p>
                      </div>
                    {% endif %}

                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}

          <!-- CTA Button -->
          {% if section.settings.show_button %}
            <div class="feature-bullets__button-wrapper">
              <a href="{{ section.settings.button_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} {{ settings.button_border_radius | default: 'rounded-md' }}" 
                 style="white-space: nowrap;">
                {{ section.settings.button_text | default: 'Get started' }}
              </a>
            </div>
          {% endif %}

        </div>

        <!-- Right Column: Image -->
        <div class="feature-bullets__right">
          {% if section.settings.image %}
            <div class="feature-bullets__image-wrapper">
              <img src="{{ section.settings.image | image_url: width: 1200 }}"
                   alt="{{ section.settings.image_alt | default: section.settings.heading_part1 }}"
                   loading="lazy"
                   style="box-shadow: none !important;">
            </div>
          {% else %}
            <div class="feature-bullets__image-wrapper">
              <img src="{{ 'placeholder-image.png' | asset_url }}"
                   alt="Placeholder"
                   loading="lazy"
                   style="box-shadow: none !important;">
            </div>
          {% endif %}
        </div>

      </div>

    </div>
  </div>
</section>

