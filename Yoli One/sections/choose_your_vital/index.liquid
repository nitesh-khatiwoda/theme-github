<script>
  const PACK_MAPPING = {
    '3BJtX1Dn6UeiPWddbzPFqreS': 'launch-pack',
    'dga2t3w9PKQ38zcrCDXpX7gb': 'builder-pack',
    'mJMmCQspobm6z9jQYQNvpG6o': 'pro-builder-pack'
  };

  const PACK_LIMITS = {
    'launch-pack': 1,
    'builder-pack': 2,
    'pro-builder-pack': 4
  };

  const PACK_BASE_QUANTITIES = {
    favorites: { omegas: 9, passion: 3 },
    starter: { omegas: 2, alkalete: 2, pure: 2, passion: 2 },
    balance: { vitalBalance: 6, passion: 2 },
    favoritesInBalance: { omegas: 2, alkalete: 2, pure: 2, passion: 2 }
  };

  const state = {
    currentPackId: null,
    vitalOmegasQuantity: 0,
    vitalBalanceQuantity: 0
  };

  document.addEventListener('DOMContentLoaded', function () {
    const currentPack = window.location.pathname.split('/').pop();
    state.currentPackId = PACK_MAPPING[currentPack];

    if (state.currentPackId) {
      const button = document.getElementById(state.currentPackId);
      if (button) {
        document.querySelectorAll('.button-pack').forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');
      }
    }

    updateSectionTotals();
    updatePackDetails();
  });

  window.selectedProductsCart = {};

  function initializeAllProducts() {
    document.querySelectorAll('.product-item[data-variant-id]').forEach(item => {
      const variantId = item.getAttribute('data-variant-id');
      const quantity = parseInt(item.querySelector('.qty-number').textContent) || 0;
      
      window.selectedProductsCart[variantId] = {
        variant_id: variantId,
        quantity: quantity
      };
    });
    
    localStorage.setItem('selectedProductsCart', JSON.stringify(window.selectedProductsCart));
  }

  function saveProductToCart(variantId, quantity) {
    (quantity > 0) ? (window.selectedProductsCart[variantId] = { variant_id: variantId, quantity: quantity}) : delete window.selectedProductsCart[variantId];
    
    localStorage.setItem('selectedProductsCart', JSON.stringify(window.selectedProductsCart));
  }

  function toggleCustomize(type) {
    const productsDiv = document.querySelector(`#${type}-products`);
    const dropdownIcon = document.querySelector(`#${type}-dropdown-icon`);

    if (!productsDiv) return;

    const isHidden = productsDiv.style.display === 'none';
    productsDiv.style.display = isHidden ? 'block' : 'none';

    if (dropdownIcon) {
      dropdownIcon.classList.toggle('rotated', isHidden);
    }
  }

  function getTotalInSection(section) {
    return Array.from(section.querySelectorAll('.qty-number'))
      .reduce((total, el) => total + parseInt(el.textContent), 0);
  }

  function updateTotalColor(total) {
    const sectionTotal = document.getElementById('vital-total');
    if (sectionTotal) {
      sectionTotal.style.color = total > 0 ? '#0047A4' : '#A40000';
    }
  }

  function updateProductQuantity(productSection, newQty) {
    if (!productSection) return;

    if (productSection.id === 'omegas') {
      state.vitalOmegasQuantity = newQty;
    } else if (productSection.id === 'vital-balance') {
      state.vitalBalanceQuantity = newQty;
    }
  }

  function canChangeQuantity(change, currentQty, parentSection) {
    const limits = PACK_LIMITS[state.currentPackId];
    const totalInParent = getTotalInSection(parentSection);

    if (change > 0) return totalInParent < limits;
    if (change < 0) return currentQty > 0;

    return true;
  }

  function changeQuantity(button, change) {
    const container = button.parentElement;
    const qtyElement = container.querySelector('.qty-number');
    const parentSection = button.closest('#vital-selector');
    const productSection = button.closest('.product-list[id]');

    if (!parentSection) return;

    const currentQty = parseInt(qtyElement.textContent);

    if (!canChangeQuantity(change, currentQty, parentSection)) return;

    const newQty = Math.max(0, currentQty + change);

    if (newQty !== currentQty) {
      qtyElement.textContent = newQty;
      updateProductQuantity(productSection, newQty);
      updateTotalColor(getTotalInSection(parentSection));
      updateSectionTotals();
      updatePackDetails();

      const productItem = button.closest('.product-item');
      const variantId = productItem.getAttribute('data-variant-id');

      if (variantId) {
        saveProductToCart(variantId, newQty);
      }
    }
  }

  function updateSectionTotals() {
    const vitalSection = document.getElementById('vital-selector');
    if (!vitalSection) return;

    const limits = PACK_LIMITS[state.currentPackId];
    const totalSelected = getTotalInSection(vitalSection);

    updateTotalDisplay(totalSelected, limits);
    updateButtonStates(vitalSection, totalSelected, limits);
    const isComplete = totalSelected === limits;
    localStorage.setItem('packSelectionsComplete', JSON.stringify(isComplete));
    window.dispatchEvent(new CustomEvent('pack-selections-updated', { detail: { isComplete } }));
  }

  function updateTotalDisplay(totalSelected, limits) {
    const vitalTotalElement = document.getElementById('vital-total');
    if (vitalTotalElement) {
      vitalTotalElement.innerHTML = `<strong>${totalSelected} of ${limits} selected</strong>`;
    }
  }

  function updateButtonStates(vitalSection, totalSelected, limits) {
    vitalSection.querySelectorAll('.qty-btn.plus').forEach(btn => {
      btn.disabled = totalSelected >= limits;
      btn.classList.toggle('disabled', btn.disabled);
    });

    vitalSection.querySelectorAll('.qty-btn.minus').forEach(btn => {
      const qtyElement = btn.parentElement.querySelector('.qty-number');
      btn.disabled = parseInt(qtyElement.textContent) === 0;
      btn.classList.toggle('disabled', btn.disabled);
    });
  }

  function setElementText(elementId, text) {
    const element = document.getElementById(elementId);
    if (element) element.textContent = text;
  }

  function updateQuantityText(elementId, baseQuantity, multiplier = 1) {
    setElementText(elementId, `x${baseQuantity * multiplier} (total)`);
  }

  function updateOmegasQuantities() {
    const multiplier = state.vitalOmegasQuantity || 1;
    const quantities = PACK_BASE_QUANTITIES;

    updateQuantityText('favorites-omegas-quantity', quantities.favorites.omegas, multiplier);
    updateQuantityText('passion-sample-pack-quantity', quantities.favorites.passion, multiplier);
    updateQuantityText('starter-omegas-quantity', quantities.starter.omegas, multiplier);
    updateQuantityText('starter-alkalete-quantity', quantities.starter.alkalete, multiplier);
    updateQuantityText('starter-pure-quantity', quantities.starter.pure, multiplier);
    updateQuantityText('starter-passion-sample-pack-quantity', quantities.starter.passion, multiplier);
  }

  function updateBalanceQuantities() {
    const multiplier = state.vitalBalanceQuantity || 1;
    const quantities = PACK_BASE_QUANTITIES;

    updateQuantityText('balance-vital-balance-quantity', quantities.balance.vitalBalance, multiplier);
    updateQuantityText('balance-passion-sample-pack-quantity', quantities.balance.passion, multiplier);

    const balanceFavoritesOmegasQty = document.querySelector('#vital-balance-products #favorites-omegas-quantity');
    if (balanceFavoritesOmegasQty) {
      balanceFavoritesOmegasQty.textContent = `x${quantities.favoritesInBalance.omegas * multiplier} (total)`;
    }

    updateQuantityText('favorites-alkalete-quantity', quantities.favoritesInBalance.alkalete, multiplier);
    updateQuantityText('favorites-pure-quantity', quantities.favoritesInBalance.pure, multiplier);
    updateQuantityText('favorites-passion-sample-pack-quantity', quantities.favoritesInBalance.passion, multiplier);
  }

  function updatePackDetails() {
    updateOmegasQuantities();
    updateBalanceQuantities();
  }

  function getPackLimits() {
    return PACK_LIMITS[state.currentPackId] || 0;
  }
</script>