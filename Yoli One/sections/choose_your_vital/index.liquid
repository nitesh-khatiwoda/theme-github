<div class="choose-your-pack-section">
  {% if section.settings.show_title %}
  <h2 class="section-title {{ section.settings.title_font_family }} {{ section.settings.title_font_size }} {{ section.settings.title_font_size_mobile }} {{ section.settings.title_font_weight }} {{ section.settings.title_text_color }}">{{ section.settings.title | default: "Style Your Pack Your Way" }}</h2>
  {% endif %}
  {% if section.settings.show_subtitle %}
  <h4 class="section-subtitle {{ section.settings.subtitle_font_family }} {{ section.settings.subtitle_font_size }} {{ section.settings.subtitle_font_size_mobile }} {{ section.settings.subtitle_font_weight }} {{ section.settings.subtitle_text_color }}">{{ section.settings.subtitle | default: "Choose Vital Omegas+ or Vital Balance or mix and match with our 2 and 4 pack options." }}</h4>
  {% endif %}
  <div class="button-content eina-1-font">
    {% if section.settings.show_buttons %}
      <a href="/{{ share_guid }}/enrollments/3BJtX1Dn6UeiPWddbzPFqreS" class="button-pack {{ section.settings.launch_button_bg_color }} {{ section.settings.launch_button_text_color }}" id="launch-pack">
        <h4>1</h4>
        <h6 class="btn-label {{ section.settings.launch_button_font_family }} {{ section.settings.launch_button_font_size }} {{ section.settings.launch_button_font_size_mobile }} {{ section.settings.launch_button_font_weight }}">{{ section.settings.launch_button_text | default: 'Launch Pack' }}</h6>
      </a>
      <a href="/{{ share_guid }}/enrollments/dga2t3w9PKQ38zcrCDXpX7gb" class="button-pack {{ section.settings.builder_button_bg_color }} {{ section.settings.builder_button_text_color }}" id="builder-pack">
        <h4>2</h4>
        <h6 class="btn-label {{ section.settings.builder_button_font_family }} {{ section.settings.builder_button_font_size }} {{ section.settings.builder_button_font_size_mobile }} {{ section.settings.builder_button_font_weight }}">{{ section.settings.builder_button_text | default: 'Builder Pack' }}</h6>
      </a>
      <a href="/{{ share_guid }}/enrollments/mJMmCQspobm6z9jQYQNvpG6o" class="button-pack {{ section.settings.pro_button_bg_color }} {{ section.settings.pro_button_text_color }}" id="pro-builder-pack">
        <h4>3</h4>
        <h6 class="btn-label {{ section.settings.pro_button_font_family }} {{ section.settings.pro_button_font_size }} {{ section.settings.pro_button_font_size_mobile }} {{ section.settings.pro_button_font_weight }}">{{ section.settings.pro_button_text | default: 'ProBuilder Pack' }}</h6>
      </a>
    {% endif %}
  </div>

  <!-- Selector Groups -->
  <div class="selector-group">
    <!-- Dynamic Product List based on tags or variants -->
    <div class="product-list" id="vital-selector">
      <div class="product-include">
        <div class="total-box">
          <div class="total-row">
            <span class="section-total" id="vital-total" style="margin-left:8px; font-weight:700; font-size: 20px; color:#A40000">
              <strong></strong>
            </span>
          </div>
        </div>
      </div>

      <div class="product-list" id="omegas">
        {% for product in enrollment_pack.membership_products[0].product_bundles %}
          {% if product.title == 'Vital Omegas Launch Pack' %}
            <div class="product-item" data-variant-id="{{ product.bundled_variant_id }}">
              <div class="product-description-content">
                <img src="{{ product.image_url }}" alt="{{ product.title }}" class="yoli-icon">
                <div class="product-content-info">
                  <p class="product-title non-uppercase">{{ product.title }}</p>
                  <button class="product-button" onclick="toggleCustomize('omegas')">
                    <span class="dropdown-title">What's included</span>
                    <svg class="dropdown-icon" id="omegas-dropdown-icon" width="12" height="8" viewBox="0 0 12 8" fill="none">
                      <path d="M6 8L0 0H12L6 8Z" fill="currentColor"/>
                    </svg>
                  </button>
                </div>
              </div>
              <div class="quantity-controls">
                <button class="qty-btn minus" onclick="changeQuantity(this, -1)">−</button>
                <span class="qty-number">0</span>
                <button class="qty-btn plus" onclick="changeQuantity(this, 1)">+</button>
              </div>
            </div>
          {% endif %}
        {% endfor %}
        <div class="pack-list" id="omegas-products" style="display: none;">
          <div class="pack">
            <img src="https://ik.imagekit.io/fluid/980191045/images/UEU7JC/2d4174eb03ab953ad6e634af0912226b03f0faa8_elMvQc9oW.png" alt="" class="pack-image">
            <div class="pack-content">
              <h3 class="pack-title">Favorites Pack (x2)</h3>
              <div class="pack-description-content">
                <div class="pack-description">
                  <p>Vital Omegas+ </p> <p id="favorites-omegas-quantity">x9 (total) </p>
                </div>
                <div class="pack-description">
                  <p>Passion Sample Pack</p> <p id="passion-sample-pack-quantity">x3 (total)</p>
                </div>
              </div>
            </div>
          </div>
          <div class="pack">
            <img src="https://ik.imagekit.io/fluid/980191045/images/M6W4MX/b5434ef253576534bd2579188811458491ccbaeb_zkWg_32qQ.png" alt="" class="pack-image">
            <div class="pack-content">
              <h3 class="pack-title">Vital Omegas+ Starter Pack (x3)</h3>
              <div class="pack-description-content">
                <div class="pack-description">
                  <p>Vital Omegas+ </p> <p id="starter-omegas-quantity">x2 (total) </p>
                </div>
                <div class="pack-description">
                  <p>Alkalete</p> <p id="starter-alkalete-quantity">x2 (total)</p>
                </div>
                <div class="pack-description">
                  <p>Pure</p> <p id="starter-pure-quantity">x2 (total)</p>
                </div>
                <div class="pack-description">
                  <p>Passion Sample Pack</p> <p id="starter-passion-sample-pack-quantity">x2 (total)</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="product-list" id="vital-balance">
        {% for product in enrollment_pack.membership_products[0].product_bundles %}
          {% if product.title == 'Vital Balance Launch Pack' %}
            <div class="product-item" data-variant-id="{{ product.bundled_variant_id }}">
              <div class="product-description-content">
                <img src="{{ product.image_url }}" alt="{{ product.title }}" class="yoli-icon">
                <div class="product-content-info">
                  <p class="product-title non-uppercase">{{ product.title }}</p>
                  <button class="product-button" onclick="toggleCustomize('vital-balance')">
                    <span class="dropdown-title">What's included</span>
                    <svg class="dropdown-icon" id="vital-balance-dropdown-icon" width="12" height="8" viewBox="0 0 12 8" fill="none">
                      <path d="M6 8L0 0H12L6 8Z" fill="currentColor"/>
                    </svg>
                  </button>
                </div>
              </div>
              <div class="quantity-controls">
                <button class="qty-btn minus" onclick="changeQuantity(this, -1)">−</button>
                <span class="qty-number">0</span>
                <button class="qty-btn plus" onclick="changeQuantity(this, 1)">+</button>
              </div>
            </div>
          {% endif %}
        {% endfor %}
        <div class="pack-list" id="vital-balance-products" style="display: none;">
          <div class="pack">
            <img src="https://ik.imagekit.io/fluid/980191045/images/K4K65Y/a329794a47f7b6f041ba94861451bfcc1b2c604b_u8wRJWeqh.png" alt="" class="pack-image">
            <div class="pack-content">
              <h3 class="pack-title">Vital Balance Pack (x2)</h3>
              <div class="pack-description-content">
                <div class="pack-description">
                  <p>Vital Balance </p> <p id="balance-vital-balance-quantity">x6 (total) </p>
                </div>
                <div class="pack-description">
                  <p>Passion Sample Pack</p> <p id="balance-passion-sample-pack-quantity">x2 (total)</p>
                </div>
              </div>
            </div>
          </div>
          <div class="pack">
            <img src="https://ik.imagekit.io/fluid/980191045/images/M6W4MX/b5434ef253576534bd2579188811458491ccbaeb_zkWg_32qQ.png" alt="" class="pack-image">
            <div class="pack-content">
              <h3 class="pack-title">Favorites Pack (x2)</h3>
              <div class="pack-description-content">
                <div class="pack-description">
                  <p>Vital Omegas+ </p> <p id="favorites-omegas-quantity">x2 (total) </p>
                </div>
                <div class="pack-description">
                  <p>Alkalete</p> <p id="favorites-alkalete-quantity">x2 (total)</p>
                </div>
                <div class="pack-description">
                  <p>Pure</p> <p id="favorites-pure-quantity">x2 (total)</p>
                </div>
                <div class="pack-description">
                  <p>Passion Sample Pack</p> <p id="favorites-passion-sample-pack-quantity">x2 (total)</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>    
  </div>
</div>

