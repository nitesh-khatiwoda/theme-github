<link rel="stylesheet" href="{{ 'video-content-hero/styles.css' | asset_url }}">

<!-- Video Content Hero Section -->
<section 
  class="video-content-hero {{ section.settings.background_color | default: 'bg-black' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="video-content-hero-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}" style="background-image: url('{{ section.settings.background_image | image_url }}');"{% endif %}>
  
  <!-- Background Overlay -->
  {% if section.settings.background_image and section.settings.overlay_enabled %}
  <div class="video-content-hero-overlay" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.6 }});"></div>
  {% endif %}
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="video-content-hero-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}" style="background-image: url('{{ section.settings.container_background_image | image_url }}');"{% endif %}>
      
      <div class="video-content-hero-wrapper video-content-hero-align-{{ section.settings.content_alignment | default: 'center' }}">
        
        <!-- Text Content -->
        <div class="video-content-hero-text" {% if section.settings.text_max_width != blank and section.settings.text_max_width != 0 %}style="max-width: {{ section.settings.text_max_width }}px;"{% endif %}>
          
          {% if section.settings.heading != blank %}
          <div class="video-content-hero-heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }}">
            {{ section.settings.heading }}
          </div>
          {% endif %}
          
          {% if section.settings.description != blank %}
          <div class="video-content-hero-description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-white' }}">
            {{ section.settings.description }}
          </div>
          {% endif %}
          
        </div>
        
        <!-- Video Blocks -->
        {% if section.blocks.size > 0 %}
        <div class="video-content-hero-video-wrapper {{ section.settings.block_spacing_mobile | default: 'gap-xl' }} {{ section.settings.block_spacing_desktop | default: 'lg:gap-2xl' }}" {% if section.settings.video_max_width != blank and section.settings.video_max_width != 0 %}style="max-width: {{ section.settings.video_max_width }}px;"{% endif %}>
          {% for block in section.blocks %}
            {% if block.type == 'video' %}
            <div class="video-content-hero-video-container {{ block.settings.video_border_radius | default: 'rounded-lg' }}" 
                 style="border: {{ block.settings.video_border_width | default: 2 }}px solid {{ block.settings.video_border_color | default: '#e5ac40' }};" 
                 {{ block.fluid_attributes }}
                 data-video-container="{{ block.id }}"
                 {% if block.settings.video_url != blank %}data-video-url="{{ block.settings.video_url }}"{% endif %}
                 {% if block.settings.youtube_id != blank %}data-youtube-id="{{ block.settings.youtube_id }}"{% endif %}
                 {% if block.settings.vimeo_id != blank %}data-vimeo-id="{{ block.settings.vimeo_id }}"{% endif %}>
              
              <!-- Thumbnail State -->
              <div class="video-thumbnail-state" data-thumbnail-state="{{ block.id }}">
                {% if block.settings.video_thumbnail != blank %}
                <img 
                  src="{{ block.settings.video_thumbnail | image_url: width: 1200 }}" 
                  alt="{{ block.settings.video_alt | default: 'Video thumbnail' }}"
                  class="video-content-hero-thumbnail"
                  loading="lazy">
                {% else %}
                <img 
                  src="{{ 'placeholder-image.png' | asset_url }}" 
                  alt="Video thumbnail placeholder"
                  class="video-content-hero-thumbnail"
                  loading="lazy">
                {% endif %}
                
                {% if block.settings.show_play_button %}
                <div class="video-content-hero-play-wrapper">
                  <button class="video-content-hero-play-button" type="button" aria-label="Play video" data-play-button="{{ block.id }}">
                    <svg width="75" height="75" viewBox="0 0 75 75" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="37.5" cy="37.5" r="37.5" fill="white" fill-opacity="0.9"/>
                      <path d="M30 25L50 37.5L30 50V25Z" fill="currentColor"/>
                    </svg>
                  </button>
                </div>
                {% endif %}
              </div>
              
              <!-- Video Embed State (hidden by default) -->
              <div class="video-embed-state" data-embed-state="{{ block.id }}" style="display: none;">
                <!-- Video will be injected here via JavaScript -->
              </div>
              
            </div>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</section>

<style>
  .video-content-hero {
    position: relative;
  }
  
  .video-content-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
  }
  
  .video-content-hero-inner {
    position: relative;
    z-index: 2;
  }
  
  .video-content-hero-video-container {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    width: 100%;
  }
  
  .video-thumbnail-state {
    position: relative;
    width: 100%;
    height: 100%;
  }
  
  .video-content-hero-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .video-content-hero-play-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }
  
  .video-content-hero-play-button {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: transform 0.3s ease;
    color: #333;
  }
  
  .video-content-hero-play-button:hover {
    transform: scale(1.1);
  }
  
  .video-embed-state {
    width: 100%;
    height: 100%;
  }
  
  .video-embed-state iframe,
  .video-embed-state video {
    width: 100%;
    height: 100%;
    border: none;
  }
  
  /* Alignment classes */
  .video-content-hero-align-left {
    text-align: left;
  }
  
  .video-content-hero-align-left .video-content-hero-video-wrapper {
    margin-left: 0;
    margin-right: auto;
  }
  
  .video-content-hero-align-center {
    text-align: center;
  }
  
  .video-content-hero-align-center .video-content-hero-video-wrapper {
    margin-left: auto;
    margin-right: auto;
  }
  
  .video-content-hero-align-right {
    text-align: right;
  }
  
  .video-content-hero-align-right .video-content-hero-video-wrapper {
    margin-left: auto;
    margin-right: 0;
  }
  
  .video-content-hero-video-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  
  .video-content-hero-text {
    margin-bottom: 2rem;
  }
  
  .video-content-hero-heading {
    white-space: pre-line;
    margin-bottom: 1rem;
  }
</style>

<script>
(function() {
  const section = document.getElementById('video-content-hero-{{ section.id }}');
  if (!section) return;
  
  const playButtons = section.querySelectorAll('[data-play-button]');
  
  playButtons.forEach(button => {
    button.addEventListener('click', function() {
      const blockId = this.getAttribute('data-play-button');
      const container = section.querySelector(`[data-video-container="${blockId}"]`);
      const thumbnailState = section.querySelector(`[data-thumbnail-state="${blockId}"]`);
      const embedState = section.querySelector(`[data-embed-state="${blockId}"]`);
      
      if (!container || !thumbnailState || !embedState) return;
      
      const videoUrl = container.getAttribute('data-video-url');
      const youtubeId = container.getAttribute('data-youtube-id');
      const vimeoId = container.getAttribute('data-vimeo-id');
      
      let embedHtml = '';
      
      // Check for YouTube
      if (youtubeId) {
        embedHtml = `<iframe 
          src="https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
          title="YouTube video player"></iframe>`;
      }
      // Check for Vimeo
      else if (vimeoId) {
        embedHtml = `<iframe 
          src="https://player.vimeo.com/video/${vimeoId}?autoplay=1" 
          allow="autoplay; fullscreen; picture-in-picture" 
          allowfullscreen
          title="Vimeo video player"></iframe>`;
      }
      // Check for direct video URL (MP4, etc.)
      else if (videoUrl) {
        // Check if it's a YouTube URL
        const ytMatch = videoUrl.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
        if (ytMatch) {
          embedHtml = `<iframe 
            src="https://www.youtube.com/embed/${ytMatch[1]}?autoplay=1&rel=0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            title="YouTube video player"></iframe>`;
        }
        // Check if it's a Vimeo URL
        else if (videoUrl.includes('vimeo.com')) {
          const vimeoMatch = videoUrl.match(/vimeo\.com\/(\d+)/);
          if (vimeoMatch) {
            embedHtml = `<iframe 
              src="https://player.vimeo.com/video/${vimeoMatch[1]}?autoplay=1" 
              allow="autoplay; fullscreen; picture-in-picture" 
              allowfullscreen
              title="Vimeo video player"></iframe>`;
          }
        }
        // Direct video file (MP4, WebM, etc.)
        else {
          embedHtml = `<video autoplay controls playsinline>
            <source src="${videoUrl}" type="video/mp4">
            Your browser does not support the video tag.
          </video>`;
        }
      }
      
      if (embedHtml) {
        // Hide thumbnail, show embed
        thumbnailState.style.display = 'none';
        embedState.innerHTML = embedHtml;
        embedState.style.display = 'block';
      }
    });
  });
})();
</script>

