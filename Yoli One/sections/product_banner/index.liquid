<div class="product-banner-section">
  <div class="banner" id="product-banner-{{ section.id }}">
    <div class="pack-section-container">
      {% if section.settings.show_title %}
        <h2 class="pack-section-title {{ section.settings.title_font_size }} {{ section.settings.title_font_size_mobile }} {{ section.settings.title_font_weight }}">
          {{ section.settings.title }}
        </h2>
      {% endif %}
      {% if section.settings.show_subtitle %}
        <p class="pack-section-subtitle {{ section.settings.subtitle_font_size }} {{ section.settings.subtitle_font_size_mobile }} {{ section.settings.subtitle_font_weight }}">
          {{ section.settings.subtitle }}
        </p>
      {% endif %}
      {% if section.settings.show_packs %}
        <div class="packs-grid">
          {% for block in section.blocks %}
            {% if block.type == 'pack' %}
              <div class="pack-item" {{ block.fluid_attributes }}>
                {% if block.settings.image %}
                  <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.title }}" class="pack-image {{ block.settings.pack_image_border_radius }}">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="{{ block.settings.title }}" class="pack-image {{ block.settings.pack_image_border_radius }}">
                {% endif %}
                <div class="pack-title {{ block.settings.pack_title_font_size }} {{ block.settings.pack_title_font_size_mobile }} {{ block.settings.pack_title_font_weight }} {{ block.settings.pack_title_color }}">
                  {{ block.settings.title | default: "Pack Title" }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

