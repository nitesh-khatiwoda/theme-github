<link rel="stylesheet" href="{{ 'hero-split-content/styles.css' | asset_url }}">

<!-- Hero Split Content Section -->
<section class="hero-split-content {{ section.settings.background_color | default: 'bg-page' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="hero-split-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="hero-split-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="hero-split-grid {% if section.settings.flip_layout %}hero-split-grid--flipped{% endif %}">
        
        <!-- Content Column -->
        <div class="content-column {{ section.settings.content_bg | default: 'bg-card-primary' }}">
          
          <!-- Heading -->
          {% if section.settings.heading_part_1 != blank or section.settings.heading_part_2 != blank or section.settings.heading_part_3 != blank %}
          <div class="split-heading">
            <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} leading-heading">
              {% if section.settings.heading_part_1 != blank %}
              <span class="{{ section.settings.heading_color_1 | default: 'text-accent' }}">{{ section.settings.heading_part_1 }}</span>
              {% endif %}
              {% if section.settings.heading_part_2 != blank %}
              <span class="{{ section.settings.heading_color_2 | default: 'text-accent' }}">{{ section.settings.heading_part_2 }}</span>
              {% endif %}
              {% if section.settings.heading_part_3 != blank %}
              <span class="{{ section.settings.heading_color_3 | default: 'text-primary' }}">{{ section.settings.heading_part_3 }}</span>
              {% endif %}
            </h1>
          </div>
          {% endif %}
          
          <!-- Bullet Points -->
          {% if section.blocks.size > 0 %}
          <div class="bullet-list">
            {% for block in section.blocks %}
              {% if block.type == 'bullet_point' %}
              <div class="bullet-item" {{ block.fluid_attributes }}>
                <span class="bullet-dot">•</span>
                <p class="{{ section.settings.bullet_font_family | default: 'font-body' }} {{ section.settings.bullet_font_size | default: 'text-lg' }} {{ section.settings.bullet_color | default: 'text-primary' }} leading-body">
                  <strong>{{ block.settings.bold_text }}</strong>{{ block.settings.regular_text }}
                </p>
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button %}
          <div class="split-cta">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text | default: 'Join now' }}
            </a>
          </div>
          {% endif %}
          
          <!-- Disclaimer -->
          {% if section.settings.disclaimer_text != blank %}
          <div class="disclaimer">
            <p class="{{ section.settings.disclaimer_font_size | default: 'text-sm' }} {{ section.settings.disclaimer_color | default: 'text-muted' }} leading-body">
              {{ section.settings.disclaimer_text }}
            </p>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Image Column -->
        <div class="image-column">
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image_alt | default: 'Hero image' }}" loading="eager">
          {% else %}
            <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
          {% endif %}
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

