<link rel="stylesheet" href="{{ 'feature-highlights/styles.css' | asset_url }}">

<!-- Feature Highlights Section -->
<section class="feature-highlights {{ section.settings.background_color | default: 'bg-secondary-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="features-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="feature-highlights-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="features-wrapper">
        
        <!-- Content Column -->
        <div class="content-column">
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
          <div class="heading-wrapper">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.description != blank %}
          <div class="description-wrapper">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
              {{ section.settings.description }}
            </p>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Features Column -->
        {% if section.blocks.size > 0 %}
        <div class="features-column">
          <div class="features-grid">
            {% for block in section.blocks %}
              {% if block.type == 'feature_card' %}
              <div class="feature-card {{ section.settings.card_background | default: 'bg-neutral-light' }}" {{ block.fluid_attributes }}>
                
                <!-- Icon -->
                <div class="icon-wrapper">
                  {% if block.settings.icon != blank %}
                    <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.icon_alt | default: 'Feature icon' }}" loading="lazy">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Feature icon" loading="lazy">
                  {% endif %}
                </div>
                
                <!-- Text -->
                {% if block.settings.text != blank %}
                <div class="text-wrapper">
                  <p class="{{ block.settings.text_font_family | default: 'font-body' }} {{ block.settings.text_font_size | default: 'text-sm' }} {{ block.settings.text_font_size_desktop | default: 'lg:text-sm' }} {{ block.settings.text_font_weight | default: 'font-normal' }} {{ block.settings.text_color | default: 'text-primary' }} leading-body">
                    {{ block.settings.text }}
                  </p>
                </div>
                {% endif %}
                
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
  
</section>

