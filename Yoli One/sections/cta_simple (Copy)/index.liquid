<!-- Simple CTA Section -->
<section class="cta-simple {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image }}"{% endif %}>
      
      <div class="max-w-4xl mx-auto text-center">
        
        <!-- Main Content -->
        <div class="cta-content space-y-4xl">
          
          <!-- Main Heading + Accent Text -->
          {% if section.settings.show_heading %}
          <div class="heading-wrapper mb-2xl">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-black' }} leading-tight">
              {% assign heading_text = section.settings.heading | default: "Lorem ipsum dolor" %}
              {{ heading_text }}
              {% if section.settings.show_accent_text %}
              <br>
              <span class="{{ section.settings.accent_font_family | default: 'font-handwritten' }} {{ section.settings.accent_font_size | default: 'text-5xl' }} {{ section.settings.accent_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.accent_font_weight | default: 'font-bold' }} {{ section.settings.accent_color | default: 'text-black' }}">{{ section.settings.accent_text | default: "sit amet?" }}</span>
              {% endif %}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description Text -->
          {% if section.settings.show_description %}
          <div class="description-wrapper mb-2xl">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-lg' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }} leading-relaxed max-w-3xl mx-auto">
              {{ section.settings.description | default: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat." }}
            </p>
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_cta_button %}
          <div class="cta-button-wrapper">
            <a href="{{ section.settings.cta_button_url | default: '#' }}"
               class="btn btn-{{ section.settings.cta_button_style | default: 'filled' }}-{{ section.settings.cta_button_color | default: 'primary' }} {{ section.settings.cta_button_size | default: 'btn-lg' }} {{ settings.button_border_radius | default: 'rounded' }}">
              {{ section.settings.cta_button_text | default: "Click Here" }}
            </a>
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

