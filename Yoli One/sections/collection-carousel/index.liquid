<link rel="stylesheet" href="{{ 'collection-carousel/styles.css' | asset_url }}">

<!-- Collection Carousel Section -->

{%- comment -%} Find the collection first {%- endcomment -%}
{%- assign collection_name = section.settings.selected_collection | downcase | strip -%}
{%- assign current_collection = null -%}
{%- assign found_collection = false -%}

{%- for c in collections -%}
  {%- if c.title | downcase | strip == collection_name -%}
    {%- assign current_collection = c -%}
    {%- assign found_collection = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<section class="collection-carousel {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="collection-carousel__container">
      
      <!-- Split Layout -->
      <div class="collection-carousel__split">
        
        <!-- Left Info Card -->
        <div class="collection-carousel__info-card {{ section.settings.info_card_border_radius | default: 'rounded-lg' }}" style="position: relative; overflow: hidden;">
          
          {%- comment -%} Background Image (if enabled) {%- endcomment -%}
          {%- if section.settings.use_collection_image and current_collection and current_collection.image.src != blank -%}
            <div class="collection-carousel__info-card-bg" style="background-image: url('{{ current_collection.image.src | image_url: width: 800 }}');"></div>
            <div class="collection-carousel__info-card-overlay" style="background-color: {{ section.settings.overlay_color | default: 'rgba(0,0,0,0.5)' }};"></div>
          {%- elsif section.settings.use_collection_image == false or current_collection == null or current_collection.image.src == blank -%}
            <div class="collection-carousel__info-card-solid-bg {{ section.settings.info_card_background | default: 'bg-neutral-light' }}"></div>
          {%- endif -%}
          
          <div class="collection-carousel__info-content">
            
            <!-- Collection Title & Link -->
            <div class="collection-carousel__header">
              {%- if current_collection -%}
                <h2 class="collection-carousel__title {{ section.settings.title_font_family | default: 'font-serif' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-black' }}">
                  {{ current_collection.title }}
                </h2>
              {%- elsif section.settings.collection_title != blank -%}
                <h2 class="collection-carousel__title {{ section.settings.title_font_family | default: 'font-serif' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-black' }}">
                  {{ section.settings.collection_title }}
                </h2>
              {%- endif -%}
              
              {%- if section.settings.show_link -%}
                {%- if current_collection -%}
                  <a href="{{ current_collection.url | default: '#' }}" class="collection-carousel__link {{ section.settings.link_font_family | default: 'font-body' }} {{ section.settings.link_font_size | default: 'text-xs' }} {{ section.settings.link_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.link_font_weight | default: 'font-normal' }} {{ section.settings.link_color | default: 'text-primary' }}">
                    {{ section.settings.link_text | default: 'VIEW COLLECTION' }}
                  </a>
                {%- elsif section.settings.link_text != blank -%}
                  <a href="{{ section.settings.link_url | default: '#' }}" class="collection-carousel__link {{ section.settings.link_font_family | default: 'font-body' }} {{ section.settings.link_font_size | default: 'text-xs' }} {{ section.settings.link_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.link_font_weight | default: 'font-normal' }} {{ section.settings.link_color | default: 'text-primary' }}">
                    {{ section.settings.link_text }}
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>
            
            <!-- Description Section -->
            {%- if current_collection and current_collection.description != blank -%}
              <div class="collection-carousel__statistic">
                <div class="collection-carousel__statistic-separator"></div>
                
                <div class="collection-carousel__statistic-content">
                  <p class="collection-carousel__statistic-description {{ section.settings.statistic_description_font_family | default: 'font-body' }} {{ section.settings.statistic_description_font_size | default: 'text-sm' }} {{ section.settings.statistic_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.statistic_description_font_weight | default: 'font-light' }} {{ section.settings.statistic_description_color | default: 'text-black' }}">
                    {{ current_collection.description }}
                  </p>
                </div>
              </div>
            {%- elsif section.settings.show_statistic -%}
              <div class="collection-carousel__statistic">
                
                {% if section.settings.statistic_eyebrow != blank %}
                  <p class="collection-carousel__statistic-eyebrow {{ section.settings.statistic_eyebrow_font_family | default: 'font-body' }} {{ section.settings.statistic_eyebrow_font_size | default: 'text-xs' }} {{ section.settings.statistic_eyebrow_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.statistic_eyebrow_font_weight | default: 'font-normal' }} {{ section.settings.statistic_eyebrow_color | default: 'text-black' }}">
                    {{ section.settings.statistic_eyebrow }}
                  </p>
                {% endif %}
                
                <div class="collection-carousel__statistic-separator"></div>
                
                <div class="collection-carousel__statistic-content">
                  {% if section.settings.statistic_value != blank %}
                    <h3 class="collection-carousel__statistic-value {{ section.settings.statistic_value_font_family | default: 'font-body' }} {{ section.settings.statistic_value_font_size | default: 'text-2xl' }} {{ section.settings.statistic_value_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.statistic_value_font_weight | default: 'font-light' }} {{ section.settings.statistic_value_color | default: 'text-black' }}">
                      {{ section.settings.statistic_value }}
                    </h3>
                  {% endif %}
                  {% if section.settings.statistic_description != blank %}
                    <p class="collection-carousel__statistic-description {{ section.settings.statistic_description_font_family | default: 'font-body' }} {{ section.settings.statistic_description_font_size | default: 'text-sm' }} {{ section.settings.statistic_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.statistic_description_font_weight | default: 'font-light' }} {{ section.settings.statistic_description_color | default: 'text-black' }}">
                      {{ section.settings.statistic_description }}
                    </p>
                  {% endif %}
                </div>
                
              </div>
            {%- endif -%}
            
          </div>
          
        </div>
        
        <!-- Right Carousel -->
        <div class="collection-carousel__carousel-wrapper">
          <div class="collection-carousel__carousel-container">
            <div class="collection-carousel__track-container">
              <div class="collection-carousel__track" id="carousel-track-{{ section.id }}">
                
                {%- if current_collection and current_collection.products.size > 0 -%}
                  {%- for product in current_collection.products -%}
                    <div class="collection-carousel__product-card">
                      <a href="{{ product.url | default: '#' }}" class="collection-carousel__product-link">
                        
                        <!-- Product Image -->
                        <div class="collection-carousel__image-wrapper {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                          {%- if product.images.first.src != blank -%}
                            <img src="{{ product.images.first.src }}" 
                                 alt="{{ product.title | default: 'Product' }}"
                                 class="collection-carousel__image collection-carousel__image--default"
                                 loading="lazy">
                          {%- else -%}
                            <img src="{{ 'placeholder-image.png' | asset_url }}" 
                                 alt="Product placeholder"
                                 class="collection-carousel__image collection-carousel__image--default">
                          {%- endif -%}
                          
                          {%- if product.images[1].src != blank -%}
                            <img src="{{ product.images[1].src }}" 
                                 alt="{{ product.title | default: 'Product' }}"
                                 class="collection-carousel__image collection-carousel__image--hover"
                                 loading="lazy">
                          {%- endif -%}
                          
                          <!-- Optional: Show badge for first product or based on tags -->
                          {%- if section.settings.show_new_badge and forloop.first -%}
                            <div class="collection-carousel__badge {{ section.settings.badge_background | default: 'bg-success' }}">
                              <span class="{{ section.settings.badge_font_family | default: 'font-body' }} {{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.badge_font_weight | default: 'font-bold' }} {{ section.settings.badge_color | default: 'text-white' }}">
                                {{ section.settings.badge_text | default: 'NEW' }}
                              </span>
                            </div>
                          {%- endif -%}
                        </div>
                        
                        <!-- Product Info -->
                        <div class="collection-carousel__product-info">
                            <h3 class="collection-carousel__product-title {{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-sm' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_title_font_weight | default: 'font-medium' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                                {{ product.title | default: 'Product Title' }}
                            </h3>
                          
                            <p class="collection-carousel__product-price {{ section.settings.card_price_font_family | default: 'font-body' }} {{ section.settings.card_price_font_size | default: 'text-sm' }} {{ section.settings.card_price_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_price_font_weight | default: 'font-normal' }} {{ section.settings.card_price_color | default: 'text-black' }}">
                                {{ product.price | default: '$0.00' }}
                            </p>
                        </div>
                        
                      </a>
                    </div>
                  {%- endfor -%}
                  
                {%- elsif current_collection and current_collection.products.size == 0 -%}
                  <!-- No products in collection -->
                  <div class="collection-carousel__product-card">
                    <div class="collection-carousel__product-link">
                      <div class="collection-carousel__image-wrapper {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                        <img src="{{ 'placeholder-image.png' | asset_url }}" 
                             alt="No products"
                             class="collection-carousel__image">
                      </div>
                      <div class="collection-carousel__product-info">
                        <h3 class="collection-carousel__product-title {{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-sm' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_title_font_weight | default: 'font-medium' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                          No products found in this collection
                        </h3>
                      </div>
                    </div>
                  </div>
                  
                {%- else -%}
                  <!-- Collection not found -->
                  <div class="collection-carousel__product-card">
                    <div class="collection-carousel__product-link">
                      <div class="collection-carousel__image-wrapper {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                        <img src="{{ 'placeholder-image.png' | asset_url }}" 
                             alt="Collection not found"
                             class="collection-carousel__image">
                      </div>
                      <div class="collection-carousel__product-info">
                        <h3 class="collection-carousel__product-title {{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-sm' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_title_font_weight | default: 'font-medium' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                          Collection "{{ section.settings.selected_collection }}" not found
                        </h3>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
                
              </div>
            </div>
          </div>
          
          <!-- Navigation Button -->
          <button class="collection-carousel__nav-button collection-carousel__nav-button--next {{ section.settings.nav_button_background | default: 'bg-neutral-light' }}" id="carousel-next-{{ section.id }}" aria-label="Next products">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          
        </div>
        
      </div>
      
  </div>
</section>

<script>
(function() {
  // Initialize carousel on page load
  function initCarousel(sectionId) {
    const track = document.getElementById('carousel-track-' + sectionId);
    const nextButton = document.getElementById('carousel-next-' + sectionId);
    
    if (!track || !nextButton) return;
    
    const cards = track.querySelectorAll('.collection-carousel__product-card');
    let currentIndex = 0;
    const cardsToShow = 3;
    const totalPages = Math.ceil(cards.length / cardsToShow);
    
    function updateCarousel() {
      const cardWidth = cards[0]?.offsetWidth || 0;
      const gap = 18;
      const offset = currentIndex * cardsToShow * (cardWidth + gap);
      track.style.transform = `translateX(-${offset}px)`;
    }
    
    nextButton.addEventListener('click', function() {
      currentIndex = (currentIndex + 1) % totalPages;
      updateCarousel();
    });
    
    // Touch support
    let touchStartX = 0;
    let touchEndX = 0;
    
    track.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    });
    
    track.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      if (touchStartX - touchEndX > 50) {
        currentIndex = Math.min(currentIndex + 1, totalPages - 1);
        updateCarousel();
      } else if (touchEndX - touchStartX > 50) {
        currentIndex = Math.max(currentIndex - 1, 0);
        updateCarousel();
      }
    });
    
    updateCarousel();
  }
  
  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.collection-carousel').forEach(function(section) {
        const sectionId = section.querySelector('[id^="carousel-track-"]')?.id.replace('carousel-track-', '');
        if (sectionId) initCarousel(sectionId);
      });
    });
  } else {
    document.querySelectorAll('.collection-carousel').forEach(function(section) {
      const sectionId = section.querySelector('[id^="carousel-track-"]')?.id.replace('carousel-track-', '');
      if (sectionId) initCarousel(sectionId);
    });
  }
})();
</script>

