<link rel="stylesheet" href="{{ 'sticky-scroll-text-v2/styles.css' | asset_url }}">

<!-- Sticky Scroll Text V2 Section -->
{% if section.settings.background_image != blank %}
  {% assign bg_image_url = section.settings.background_image | image_url %}
  {% assign bg_image_fit = section.settings.background_image_fit | default: 'fill' %}
  {% if bg_image_fit == 'fit' %}
    {% assign bg_size = 'contain' %}
  {% else %}
    {% assign bg_size = 'cover' %}
  {% endif %}
{% endif %}
<section class="section sticky-scroll-text-v2 {% if section.settings.background_image == blank %}{{ section.settings.background_color | default: 'bg-white' }}{% endif %} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="sticky-scroll-text-v2-{% if section.id %}{{ section.id }}{% else %}default{% endif %}" {% if section.settings.background_image != blank %}data-bg="{{ bg_image_url }}" data-bg-fit="{{ bg_image_fit }}" style="background-image: url('{{ bg_image_url }}'); background-size: {{ bg_size }};"{% endif %} data-scroll-spacing="{{ section.settings.scroll_spacing | default: 0.2 }}" data-block-mode="{{ section.settings.block_mode | default: 'pushing' }}" data-block-gap="{{ section.settings.block_gap | default: 100 }}">
  
  <!-- Fixed Background Layer -->
  <div class="sticky-scroll-text-v2-background"></div>
  
  <!-- Content Container -->
  <div class="sticky-scroll-text-v2-content">
    <div class="{{section.settings.container_layout_width | default : 'container'}}">
      <div class="sticky-scroll-text-v2-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image != blank %}data-bg="{{ section.settings.container_background_image | image_url }}" style="background-image: url('{{ section.settings.container_background_image | image_url }}');"{% endif %}>
        
        <!-- Loop through blocks -->
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'sticky_text_block' %}
            <div class="sticky-scroll-text-v2-block" {{ block.fluid_attributes }}>
              <!-- Simple sticky text wrapper -->
              <div class="sticky-scroll-text-v2-wrapper" 
                   data-block-id="{{ block.id }}"
                   data-sticky-duration="{{ block.settings.sticky_duration | default: section.settings.sticky_duration | default: 500 }}">
                <div class="sticky-scroll-text-v2-content-wrapper" {% if block.settings.container_width %}style="max-width: {{ block.settings.container_width }}px;"{% endif %} data-block-gap="{{ section.settings.block_gap | default: 100 }}" data-block-mode="{{ section.settings.block_mode | default: 'pushing' }}">
                  {% assign font_family = block.settings.text_font_family | default: 'font-primary' %}
                  {% assign font_size_mobile = block.settings.text_font_size_mobile | default: 'text-3xl' %}
                  {% assign font_size_desktop = block.settings.text_font_size_desktop | default: 'lg:text-4xl' %}
                  {% assign text_color = block.settings.text_color | default: 'text-white' %}
                  <h1 class="sticky-scroll-text-v2-text {{ font_family }} {{ font_size_mobile }} {{ font_size_desktop }} {{ text_color }}" style="line-height: 1;">
                    {{ block.settings.text | default: 'Your text here' }}
                  </h1>
                </div>
              </div>
            </div>
            {% endif %}
          {% endfor %}
        {% else %}
          <!-- Fallback: Render default preset blocks so section is functional -->
          <div class="sticky-scroll-text-v2-block">
            <div class="sticky-scroll-text-v2-wrapper" data-sticky-duration="{{ section.settings.sticky_duration | default: 350 }}">
              <div class="sticky-scroll-text-v2-content-wrapper">
                <h1 class="sticky-scroll-text-v2-text font-primary text-3xl lg:text-4xl text-white" style="line-height: 1;">
                  Welcome to our <strong>amazing</strong> experience
                </h1>
              </div>
            </div>
          </div>
          <div class="sticky-scroll-text-v2-block">
            <div class="sticky-scroll-text-v2-wrapper" data-sticky-duration="{{ section.settings.sticky_duration | default: 350 }}">
              <div class="sticky-scroll-text-v2-content-wrapper">
                <h1 class="sticky-scroll-text-v2-text font-primary text-3xl lg:text-4xl text-white" style="line-height: 1;">
                  Discover something <strong>truly special</strong> today
                </h1>
              </div>
            </div>
          </div>
          <div class="sticky-scroll-text-v2-block">
            <div class="sticky-scroll-text-v2-wrapper" data-sticky-duration="{{ section.settings.sticky_duration | default: 350 }}">
              <div class="sticky-scroll-text-v2-content-wrapper">
                <h1 class="sticky-scroll-text-v2-text font-primary text-3xl lg:text-4xl text-white" style="line-height: 1;">
                  Join us on this <strong>incredible journey</strong>
                </h1>
              </div>
            </div>
          </div>
        {% endif %}
        
      </div>
    </div>
  </div>
  
</section>


<script>
(function() {
  'use strict';
  
  // Initialize sticky scroll text v2 when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    try {
      const section = document.getElementById('sticky-scroll-text-v2-{% if section.id %}{{ section.id }}{% else %}default{% endif %}');
      if (!section) return;
    
    // Set background image
    const bgImage = section.getAttribute('data-bg');
    const bgFit = section.getAttribute('data-bg-fit') || 'fill';
    if (bgImage) {
      const bgElement = section.querySelector('.sticky-scroll-text-v2-background');
      if (bgElement) {
        bgElement.style.backgroundImage = `url(${bgImage})`;
        bgElement.style.backgroundSize = bgFit === 'fit' ? 'contain' : 'cover';
      }
    }
    
    // Set container background image
    const container = section.querySelector('.sticky-scroll-text-v2-inner[data-bg]');
    if (container) {
      const containerBg = container.getAttribute('data-bg');
      if (containerBg) {
        container.style.backgroundImage = `url(${containerBg})`;
      }
    }
    
    // Initialize all sticky text blocks
    const wrappers = section.querySelectorAll('.sticky-scroll-text-v2-wrapper');
    const viewportHeight = window.innerHeight;
    
    // Get scroll spacing multiplier from section setting (default 0.2 = middle option)
    const scrollSpacing = parseFloat(section.getAttribute('data-scroll-spacing') || '0.2');
    
    // Helper function to convert sticky duration to pixels
    function getStickyDurationPixels(value) {
      const durationMap = {
        '200': 200,
        '350': 350,
        '500': 500
      };
      return durationMap[value] || 350; // Default to 350 (medium) if not found
    }
    
    function initializeBlock(wrapper) {
      const contentWrapper = wrapper.querySelector('.sticky-scroll-text-v2-content-wrapper');
      if (!contentWrapper) return;
      
      const stickyDurationValue = wrapper.getAttribute('data-sticky-duration') || '350';
      const stickyDuration = getStickyDurationPixels(stickyDurationValue);
      
      // Calculate wrapper height to ensure sticky works properly
      // For each block, we need enough space for the sticky effect
      // Scroll spacing controls how close blocks are together
      const wrapperHeight = (viewportHeight * scrollSpacing) + stickyDuration + (viewportHeight * scrollSpacing);
      wrapper.style.height = `${wrapperHeight}px`;
    }
    
    function updateAllWrapperHeights() {
      const newViewportHeight = window.innerHeight;
      const newScrollSpacing = parseFloat(section.getAttribute('data-scroll-spacing') || '0.2');
      wrappers.forEach(function(wrapper) {
        const contentWrapper = wrapper.querySelector('.sticky-scroll-text-v2-content-wrapper');
        if (!contentWrapper) return;
        
        const stickyDurationValue = wrapper.getAttribute('data-sticky-duration') || '350';
        const stickyDuration = getStickyDurationPixels(stickyDurationValue);
        const newWrapperHeight = (newViewportHeight * newScrollSpacing) + stickyDuration + (newViewportHeight * newScrollSpacing);
        wrapper.style.height = `${newWrapperHeight}px`;
      });
    }
    
    // Initialize all blocks
    wrappers.forEach(initializeBlock);
    
    // Apply block gap padding in pushing mode
    function applyBlockGap() {
      const blockMode = section.getAttribute('data-block-mode') || 'pushing';
      const blockGap = parseInt(section.getAttribute('data-block-gap') || '100', 10);
      const isPushing = blockMode === 'pushing';
      
      wrappers.forEach(function(wrapper, index) {
        const contentWrapper = wrapper.querySelector('.sticky-scroll-text-v2-content-wrapper');
        if (!contentWrapper) return;
        
        if (isPushing && blockGap > 0) {
          // Apply padding top and bottom for pushing mode
          // Horizontal padding from CSS is preserved
          contentWrapper.style.paddingTop = `${blockGap}px`;
          contentWrapper.style.paddingBottom = `${blockGap}px`;
        } else {
          // Remove vertical padding in stacking mode
          contentWrapper.style.paddingTop = '';
          contentWrapper.style.paddingBottom = '';
        }
      });
    }
    
    // Apply block gap on load
    applyBlockGap();
    
    // Function to update block opacity based on distance from center
    function updateBlockOpacity() {
      const scrollY = window.pageYOffset || window.scrollY;
      const blockMode = section.getAttribute('data-block-mode') || 'pushing';
      const isStacking = blockMode === 'stacking';
      
      // Find which block is currently centered (for stacking mode)
      let centeredBlockIndex = -1;
      if (isStacking) {
        wrappers.forEach(function(wrapper, index) {
          const contentWrapper = wrapper.querySelector('.sticky-scroll-text-v2-content-wrapper');
          if (!contentWrapper) return;
          
          const rect = contentWrapper.getBoundingClientRect();
          const contentCenter = rect.top + (rect.height / 2);
          const distanceFromCenter = Math.abs(contentCenter - (viewportHeight / 2));
          
          // If this block is close to center, it's the centered one
          if (distanceFromCenter < viewportHeight * 0.2) {
            centeredBlockIndex = index;
          }
        });
      }
      
      wrappers.forEach(function(wrapper, index) {
        const contentWrapper = wrapper.querySelector('.sticky-scroll-text-v2-content-wrapper');
        if (!contentWrapper) return;
        
        // Get the position of the content wrapper relative to viewport
        const rect = contentWrapper.getBoundingClientRect();
        const contentCenter = rect.top + (rect.height / 2);
        
        // Calculate distance from viewport center
        const distanceFromCenter = Math.abs(contentCenter - (viewportHeight / 2));
        
        let opacity = 1;
        
        if (isStacking) {
          // Stacking mode: only show blocks at or above the centered one
          if (centeredBlockIndex === -1) {
            // No block centered yet, show all
            opacity = 1;
          } else if (index <= centeredBlockIndex) {
            // This block is at or above the centered one - show it
            // If very close to center (within threshold), keep at full opacity
            const centerThreshold = 50; // pixels - if within 50px of center, stay at 100% opacity
            if (distanceFromCenter <= centerThreshold) {
              opacity = 1;
            } else {
              // Start fading after threshold
              const fadeRange = viewportHeight * 0.3;
              const adjustedDistance = distanceFromCenter - centerThreshold;
              opacity = Math.max(0, Math.min(1, 1 - (adjustedDistance / fadeRange)));
            }
          } else {
            // This block is below the centered one - hide it completely
            opacity = 0;
          }
        } else {
          // Pushing mode: fade based on distance from center
          // If very close to center (within threshold), keep at full opacity
          const centerThreshold = 50; // pixels - if within 50px of center, stay at 100% opacity
          if (distanceFromCenter <= centerThreshold) {
            opacity = 1;
          } else {
            // Start fading after threshold
            const fadeRange = viewportHeight * 0.3;
            const adjustedDistance = distanceFromCenter - centerThreshold;
            opacity = Math.max(0, Math.min(1, 1 - (adjustedDistance / fadeRange)));
          }
        }
        
        // Apply opacity with smooth transition
        contentWrapper.style.opacity = opacity;
      });
    }
    
    // Update opacity on scroll
    let scrollTicking = false;
    function onScroll() {
      if (!scrollTicking) {
        window.requestAnimationFrame(function() {
          updateBlockOpacity();
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    }
    
    window.addEventListener('scroll', onScroll, { passive: true });
    
    // Handle window resize
    window.addEventListener('resize', function() {
      updateAllWrapperHeights();
      applyBlockGap();
      updateBlockOpacity();
    });
    
    // Initial opacity update
    updateBlockOpacity();
    } catch (error) {
      console.error('Sticky Scroll Text V2 initialization error:', error);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Sticky Scroll Text V2",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Width (Container)"
    },
    {
      "type": "select",
      "id": "container_layout_width",
      "label": "Layout Width (Container)",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-full", "label": "Full Width (Container Full)" }
      ],
      "default": "container",
      "info": "Choose whether the container is constrained to the width of the page or full width"
    },
    {
      "type": "header",
      "content": "Sticky Settings"
    },
    {
      "type": "range",
      "id": "scroll_spacing",
      "label": "Scroll Spacing Between Blocks",
      "info": "Controls how much scrolling is needed between blocks. Lower = blocks closer together, Higher = more scroll distance.",
      "min": 0.1,
      "max": 0.5,
      "step": 0.05,
      "default": 0.2,
      "unit": "x"
    },
    {
      "type": "select",
      "id": "block_mode",
      "label": "Block Behavior",
      "info": "Pushing: Blocks push each other up as you scroll. Stacking: Blocks stack on top, only the top one is visible.",
      "options": [
        { "value": "pushing", "label": "Pushing (Default)" },
        { "value": "stacking", "label": "Stacking" }
      ],
      "default": "pushing"
    },
    {
      "type": "range",
      "id": "block_gap",
      "label": "Block Gap (Pushing Mode Only)",
      "info": "Extra vertical padding between blocks in pushing mode. Creates more space so text doesn't get too close.",
      "min": 0,
      "max": 300,
      "step": 10,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "sticky_duration",
      "label": "Default Sticky Duration",
      "info": "Default duration for all blocks. Can be overridden per block.",
      "options": [
        { "value": "200", "label": "Short" },
