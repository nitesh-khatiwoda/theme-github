<!-- Announcement Bar Section -->
<section class="announcement-bar {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.text_color | default: 'text-white' }} {{ section.settings.padding_y | default: 'py-sm' }}" id="announcement-bar-{{ section.id }}">
  <div class="container">
    <div class="announcement-content text-center {{ section.settings.text_font_size | default: 'text-sm' }} {{ section.settings.text_font_weight | default: 'font-normal' }}">
      {% if section.settings.announcement_text != blank %}
        {{ section.settings.announcement_text }}
      {% else %}
        Subscribe & Save 15% Free Shipping
      {% endif %}
      
      {% if section.settings.show_link and section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url | default: '#' }}" class="announcement-link ml-sm {{ section.settings.link_font_weight | default: 'font-semibold' }}">
          {{ section.settings.link_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Content"
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Lorem Ipsum Dolor Sit Amet",
      "info": "Main announcement message"
    },
    {
      "type": "select",
      "id": "text_font_size",
      "label": "Font Size",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" }
      ],
      "default": "text-sm"
    },
    {
      "type": "select",
      "id": "text_font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semibold" }
      ],
      "default": "font-normal"
    },
    {
      "type": "header",
      "content": "Link Settings"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Show Link",
      "default": false
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "select",
      "id": "link_font_weight",
      "label": "Link Font Weight",
      "options": [
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semibold" }
      ],
      "default": "font-semibold"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-black", "label": "Black" },
        { "value": "bg-primary", "label": "Primary Text" },
        { "value": "bg-secondary", "label": "Secondary Text" },
        { "value": "bg-accent-warm", "label": "Accent" },
        { "value": "bg-banner", "label": "Accent Alt" },
        { "value": "bg-neutral", "label": "Neutral" },
        { "value": "bg-neutral-light", "label": "Neutral Light" }
      ],
      "default": "bg-black"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "text-white", "label": "White" },
        { "value": "text-black", "label": "Black" },
        { "value": "text-primary", "label": "Primary Text" },
        { "value": "text-secondary", "label": "Secondary Text" },
        { "value": "text-neutral", "label": "Neutral" },
        { "value": "text-neutral-dark", "label": "Neutral Dark" }
      ],
      "default": "text-white"
    },
    {
      "type": "select",
      "id": "padding_y",
      "label": "Vertical Padding",
      "options": [
        { "value": "py-xs", "label": "Extra Small" },
        { "value": "py-sm", "label": "Small" },
        { "value": "py-md", "label": "Medium" },
        { "value": "py-lg", "label": "Large" }
      ],
      "default": "py-sm"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

