<link rel="stylesheet" href="{{ 'testimonial-carousel/styles.css' | asset_url }}">

<section 
  class="testimonial-carousel {{ section.settings.background_color | default: 'bg-secondary' }}"
  style="
    padding-top: var(--space-{{ section.settings.section_padding_y_mobile | default: '2xl' }});
    padding-bottom: var(--space-{{ section.settings.section_padding_y_mobile | default: '2xl' }});
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    {% if section.settings.section_border_radius != blank and section.settings.section_border_radius != 'rounded-none' %}
      border-radius: var(--radius-{{ section.settings.section_border_radius | remove: 'rounded-' }});
    {% endif %}
  "
>
  <div class="testimonial-container">
    
    <!-- Left Content Area -->
    <div class="testimonial-left font-primary">
      
      <!-- Heading -->
      {% if section.settings.heading != blank %}
      <div class="testimonial-heading mb-lg">
        <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading" style="line-height: 1.24;">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Review Stats -->
      {% if section.settings.show_review_stats %}
      <div class="review-stats mb-lg">
        <p class="{{ section.settings.stats_font_size | default: 'text-base' }} {{ section.settings.stats_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.stats_color | default: 'text-black' }} leading-body">
          {% if section.settings.rating != blank %}
            <span class="font-bold">{{ section.settings.rating }}</span>
          {% endif %}
          {% if section.settings.rating_label != blank %}
            <span class="font-normal">{{ section.settings.rating_label }}</span>
          {% endif %}
          {% if section.settings.review_count != blank %}
            <span class="font-bold">{{ section.settings.review_count }}</span>
          {% endif %}
          {% if section.settings.review_label != blank %}
            <span class="font-normal">{{ section.settings.review_label }}</span>
          {% endif %}
        </p>
      </div>
      {% endif %}
      
      <!-- CTA Button -->
      {% if section.settings.show_button and section.settings.button_text != blank %}
      <div class="testimonial-cta">
        <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'outline' }}-{{ section.settings.button_color | default: 'primary' }} btn-{{ section.settings.button_size | default: 'md' }}">
          {{ section.settings.button_text }}
        </a>
      </div>
      {% endif %}
      
    </div>
    
    <!-- Right Carousel Area -->
    <div class="testimonial-right">
      
      <!-- Carousel Container -->
      {% if section.blocks.size > 0 %}
      <div class="carousel-wrapper">
        
        <!-- Navigation Arrows -->
        <div class="carousel-nav">
          <button class="carousel-nav-btn carousel-prev {{ section.settings.nav_button_background | default: 'bg-primary' }}" aria-label="Previous testimonial">
            <svg width="10" height="17" viewBox="0 0 10 17" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-white' }}">
              <path d="M9.5 1L1.5 8.5L9.5 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="carousel-nav-btn carousel-next {{ section.settings.nav_button_background | default: 'bg-primary' }}" aria-label="Next testimonial">
            <svg width="10" height="17" viewBox="0 0 10 17" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-white' }}">
              <path d="M0.5 1L8.5 8.5L0.5 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        
        <div class="carousel-container">
          <div class="carousel-track">
          
          {% for block in section.blocks %}
            
            <!-- Text Review Card -->
            {% if block.type == 'text_review' %}
            <div class="testimonial-card text-review {{ section.settings.card_background | default: 'bg-white' }}" {{ block.fluid_attributes }}>
              
              <!-- Accent Bar -->
              <div class="card-accent {{ block.settings.accent_color | default: 'bg-primary' }}"></div>
              
              <!-- Card Content -->
              <div class="card-content">
                
                <!-- Star Rating -->
                {% if block.settings.show_stars %}
                <div class="card-stars mb-xs">
                  <span class="{{ block.settings.star_color | default: 'text-tertiary' }}" style="font-size: 20px; letter-spacing: 1px; line-height: 1.5;">★★★★★</span>
                </div>
                {% endif %}
                
                <!-- Review Title -->
                {% if block.settings.title != blank %}
                <div class="card-title mb-sm">
                  <h3 class="{{ block.settings.title_font_size | default: 'text-base' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.title_font_weight | default: 'font-bold' }} {{ block.settings.title_color | default: 'text-black' }} leading-heading" style="line-height: 1.6;">
                    {{ block.settings.title }}
                  </h3>
                </div>
                {% endif %}
                
                <!-- Review Text -->
                {% if block.settings.review_text != blank %}
                <div class="card-text mb-sm">
                  <p class="{{ block.settings.text_font_size | default: 'text-base' }} {{ block.settings.text_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.text_font_weight | default: 'font-normal' }} {{ block.settings.text_color | default: 'text-black' }} leading-body" style="line-height: 1.5;">
                    {{ block.settings.review_text }}
                  </p>
                </div>
                {% endif %}
                
              </div>
            </div>
            {% endif %}
            
            <!-- Video Review Card -->
            {% if block.type == 'video_review' %}
            <div class="testimonial-card video-review" {{ block.fluid_attributes }}>
              
              <!-- Video Poster/Thumbnail -->
              <div class="video-container">
                {% if block.settings.video_poster != blank %}
                  <img src="{{ block.settings.video_poster | image_url: width: 400 }}" alt="{{ block.settings.author_name }}" class="video-poster" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.svg' | asset_url }}" alt="Video thumbnail" class="video-poster" loading="lazy">
                {% endif %}
                
                <!-- Play Button Overlay -->
                <div class="video-play-overlay">
                  <div class="play-button {{ section.settings.play_button_background | default: 'bg-black' }}" style="backdrop-filter: blur(8.75px); background-color: rgba(10, 10, 10, 0.55);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.play_icon_color | default: 'text-white' }}">
                      <path d="M8 5.14v13.72L19 12L8 5.14z" fill="currentColor"/>
                    </svg>
                  </div>
                </div>
                
                <!-- Video Info Overlay -->
                <div class="video-info-overlay">
                  {% if block.settings.author_name != blank %}
                  <div class="video-author mb-xs">
                    <p class="{{ block.settings.author_font_size | default: 'text-base' }} {{ block.settings.author_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.author_font_weight | default: 'font-bold' }} {{ block.settings.author_color | default: 'text-white' }} leading-body" style="line-height: 1.5;">
                      {{ block.settings.author_name }}
                    </p>
                  </div>
                  {% endif %}
                  
                  {% if block.settings.video_caption != blank %}
                  <div class="video-caption">
                    <p class="{{ block.settings.caption_font_size | default: 'text-sm' }} {{ block.settings.caption_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.caption_font_weight | default: 'font-normal' }} {{ block.settings.caption_color | default: 'text-white' }} leading-body" style="line-height: 1.5;">
                      {{ block.settings.video_caption }}
                    </p>
                  </div>
                  {% endif %}
                </div>
                
              </div>
            </div>
            {% endif %}
            
          {% endfor %}
          
        </div>
      </div>
      
      </div>
      {% endif %}
      
    </div>
    
  </div>
</section>

<script>
(function() {
  const carousel = document.querySelector('.carousel-track');
  const prevBtn = document.querySelector('.carousel-prev');
  const nextBtn = document.querySelector('.carousel-next');
  
  if (!carousel || !prevBtn || !nextBtn) return;
  
  let scrollAmount = 0;
  const cardWidth = 270 + 24; // Card width + gap
  
  function updateButtons() {
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    prevBtn.style.opacity = scrollAmount <= 0 ? '0.4' : '1';
    nextBtn.style.opacity = scrollAmount >= maxScroll ? '0.4' : '1';
  }
  
  nextBtn.addEventListener('click', () => {
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    scrollAmount = Math.min(scrollAmount + cardWidth, maxScroll);
    carousel.style.transform = `translateX(-${scrollAmount}px)`;
    updateButtons();
  });
  
  prevBtn.addEventListener('click', () => {
    scrollAmount = Math.max(scrollAmount - cardWidth, 0);
    carousel.style.transform = `translateX(-${scrollAmount}px)`;
    updateButtons();
  });
  
  updateButtons();
})();
</script>

