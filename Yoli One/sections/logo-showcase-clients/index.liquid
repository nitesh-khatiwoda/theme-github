<link rel="stylesheet" href="{{ 'logo-showcase-clients/styles.css' | asset_url }}">

<!-- Logo Showcase Clients Section -->
<section class="logo-showcase-clients section {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header Section -->
      {% if section.settings.show_heading %}
      <div class="logo-showcase-clients-header">
        {% if section.settings.subtitle != blank %}
        <p class="logo-showcase-clients-subtitle {{ section.settings.subtitle_font_family | default: 'font-primary' }} {{ section.settings.subtitle_font_size | default: 'text-sm' }} {{ section.settings.subtitle_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.subtitle_font_weight | default: 'font-normal' }} {{ section.settings.subtitle_color | default: 'text-neutral-dark' }} {{ section.settings.subtitle_letter_spacing | default: 'tracking-wide' }}">
          {{ section.settings.subtitle | upcase }}
        </p>
        {% endif %}
        
        {% if section.settings.heading != blank %}
        <h2 class="logo-showcase-clients-title {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }} {{ section.settings.heading_line_height | default: 'leading-tight' }}">
          {{ section.settings.heading }}
        </h2>
        {% endif %}
        
        {% if section.settings.description != blank %}
        <p class="logo-showcase-clients-description {{ section.settings.description_font_family | default: 'font-primary' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
          {{ section.settings.description }}
        </p>
        {% endif %}
        
        {% if section.settings.show_separator %}
        <div class="logo-showcase-clients-separator"></div>
        {% endif %}
      </div>
      {% endif %}
      
      <!-- Logo Grid -->
      <div class="logo-showcase-clients-grid" 
           data-columns-mobile="{{ section.settings.grid_columns_mobile | default: '2' }}"
           data-columns-tablet="{{ section.settings.grid_columns_tablet | default: '3' }}"
           data-columns-desktop="{{ section.settings.grid_columns_desktop | default: '4' }}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'logo_item' %}
              <div class="logo-showcase-clients-item" {{ block.fluid_attributes }}>
                {% if block.settings.logo_image != blank %}
                  {% if block.settings.logo_link != blank %}
                    <a href="{{ block.settings.logo_link }}" class="logo-showcase-clients-link" target="_blank" rel="noopener">
                  {% endif %}
                  
                  <div class="logo-showcase-clients-box">
                    <img src="{{ block.settings.logo_image | image_url: width: 200 }}" 
                         alt="{{ block.settings.logo_alt | default: 'Company logo' }}"
                         class="logo-showcase-clients-logo {{ section.settings.logo_filter | default: 'grayscale' }}"
                         loading="lazy">
                  </div>
                  
                  {% if block.settings.logo_link != blank %}
                    </a>
                  {% endif %}
                {% else %}
                  <!-- Placeholder Image -->
                  <div class="logo-showcase-clients-box">
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="Logo placeholder"
                         class="logo-showcase-clients-logo placeholder"
                         loading="lazy">
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      
    </div>
  </div>
</section>

