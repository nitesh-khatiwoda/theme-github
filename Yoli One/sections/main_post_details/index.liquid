<section 
    class="post-details-{{ section.id }} {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
    {% if section.settings.background_image %}
      data-bg="{{ section.settings.background_image | image_url }}"
    {% endif %}
  >
    <div class="{{section.settings.container_layout_width | default : 'container'}}">
      {% if post %}
        <article class="post-details-wrapper">
          <!-- Post Header -->
          <div class="post-header mb-xl">
            {% if section.settings.show_category and post.category %}
              <div class="post-category mb-md">
                <a href="{{ post.category.preview_url | default: '#' }}" class="category-badge {{ section.settings.category_badge_background }} {{ section.settings.category_badge_border_radius | default: 'rounded-full' }} {{ section.settings.category_font_size | default: 'text-sm' }} {{ section.settings.category_font_weight | default: 'font-medium' }} {{ section.settings.category_color }}">
                  {{ post.category.title }}
                </a>
              </div>
            {% endif %}

            {% if section.settings.show_title %}
              <h1 class="post-title {{ section.settings.title_font_family }} {{ section.settings.title_font_size | default: 'text-3xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color }} mb-md">
                {{ post.title }}
              </h1>
            {% endif %}

            {% if section.settings.show_meta %}
              <div class="post-meta flex flex-wrap items-center gap-md {{ section.settings.meta_font_size | default: 'text-sm' }} {{ section.settings.meta_color }}">
                {% if section.settings.show_author and post.post_author %}
                  <div class="post-author flex items-center gap-sm">
                    {% if section.settings.show_author_icon %}
                      <div class="author-icon-wrapper">
                        <svg class="author-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                      </div>
                    {% endif %}
                    <span class="author-name">{{ post.post_author }}</span>
                  </div>
                {% endif %}

                {% assign display_date = post.post_date %}
                {% if display_date == blank or display_date == null %}
                  {% assign display_date = post.created_at %}
                {% endif %}
                
                {% if section.settings.show_date and display_date %}
                  <div class="post-date flex items-center gap-sm">
                    {% if section.settings.show_date_icon %}
                      <div class="date-icon-wrapper">
                        <svg class="date-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                    {% endif %}
                    <time datetime="{{ display_date | date: '%Y-%m-%d' }}" class="date-text">{{ display_date | date: section.settings.date_format | default: '%B %d, %Y' }}</time>
                  </div>
                {% endif %}

                {% if section.settings.show_updated_at and post.updated_at %}
                  <div class="post-updated flex items-center gap-sm">
                    <span>Updated: <time datetime="{{ post.updated_at | date: '%Y-%m-%d' }}">{{ post.updated_at | date: section.settings.date_format | default: '%B %d, %Y' }}</time></span>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>

          <!-- Post Featured Image -->
          {% if section.settings.show_featured_image %}
            {% assign image_url = '' %}
            {% if post.image_url %}
              {% assign image_url = post.image_url %}
            {% elsif post.image %}
              {% assign image_url = post.image | image_url %}
            {% elsif post.images.size > 0 %}
              {% assign image_url = post.images[0].src %}
            {% endif %}

            {% if image_url != '' %}
              <div class="post-featured-image-wrapper mb-xl">
                <div class="post-featured-image {{ section.settings.featured_image_border_radius | default: 'rounded-2xl' }} overflow-hidden">
                  <div class="image-container">
                    <img 
                      src="{{ image_url }}"
                      alt="{{ post.title }}"
                      loading="lazy"
                      class="featured-image" />
                    <div class="image-overlay"></div>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endif %}

          <!-- Post Summary -->
          {% if section.settings.show_summary and post.summary %}
            <div class="post-summary mb-xl">
              <div class="summary-card {{ section.settings.summary_background }} {{ section.settings.summary_padding | default: 'p-lg' }} {{ section.settings.summary_border_radius | default: 'rounded-xl' }}">
                <div class="summary-content {{ section.settings.summary_font_size | default: 'text-lg' }} {{ section.settings.summary_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.summary_font_weight | default: 'font-medium' }} {{ section.settings.summary_color }}">
                  {{ post.summary | unescape }}
                </div>
              </div>
            </div>
          {% endif %}

          <!-- Post Description/Content -->
          {% if section.settings.show_description and post.description %}
            <div class="post-content mb-xl">
              <div class="content-wrapper {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color }} trix-content">
                {{ post.description | unescape }}
              </div>
            </div>
          {% endif %}

          <!-- Post Collections -->
          {% if section.settings.show_collections and post.collections.size > 0 %}
            <div class="post-collections mb-xl">
              {% if section.settings.collections_title %}
                <h3 class="collections-title {{ section.settings.collections_title_font_size | default: 'text-xl' }} {{ section.settings.collections_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.collections_title_font_weight | default: 'font-semibold' }} {{ section.settings.collections_title_color }} mb-md">
                  {{ section.settings.collections_title }}
                </h3>
              {% endif %}
              <div class="collections-list flex flex-wrap gap-sm">
                {% for collection in post.collections %}
                  <a href="{{ collection.preview_url | default: '#' }}" class="collection-badge {{ section.settings.collection_badge_background }} {{ section.settings.collection_badge_border_radius | default: 'rounded-full' }} {{ section.settings.collection_font_size | default: 'text-sm' }} {{ section.settings.collection_font_weight | default: 'font-medium' }} {{ section.settings.collection_color }} {{ section.settings.collection_padding | default: 'px-md py-xs' }}">
                    {{ collection.title }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          <!-- Post Navigation -->
          {% if section.settings.show_post_navigation %}
            <div class="post-navigation mt-xl pt-xl border-t {{ section.settings.navigation_border_color | default: 'border-neutral-light' }}">
              <div class="post-navigation-wrapper">
                {% assign previous_post = post.previous_post %}
                {% assign next_post = post.next_post %}
                
                <!-- Previous Post -->
                {% if previous_post and previous_post.title %}
                  <a href="{{ previous_post.preview_url | default: '#' }}" class="post-nav-card post-nav-prev {{ section.settings.nav_button_font_family | default: 'font-body' }} {{ section.settings.nav_button_font_size | default: 'text-sm' }} {{ section.settings.nav_button_color | default: 'text-primary' }} {{ section.settings.nav_button_font_weight | default: 'font-medium' }}">
                    <div class="nav-icon-wrapper">
                      <svg width="20" height="20" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="nav-content">
                      <span class="nav-label">{{ section.settings.previous_label | default: 'Previous Post' }}</span>
                      <span class="nav-title">{{ previous_post.title }}</span>
                    </div>
                  </a>
                {% else %}
                  <span class="post-nav-card post-nav-prev post-nav-disabled {{ section.settings.nav_button_font_family | default: 'font-body' }} {{ section.settings.nav_button_font_size | default: 'text-sm' }} {{ section.settings.nav_button_color | default: 'text-primary' }} {{ section.settings.nav_button_font_weight | default: 'font-medium' }}">
                    <div class="nav-icon-wrapper">
                      <svg width="20" height="20" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
                      </svg>
                    </div>
                    <div class="nav-content">
                      <span class="nav-label">{{ section.settings.previous_label | default: 'Previous Post' }}</span>
                    </div>
                  </span>
                {% endif %}
                
                <!-- Next Post -->
                {% if next_post and next_post.title %}
                  <a href="{{ next_post.preview_url | default: '#' }}" class="post-nav-card post-nav-next {{ section.settings.nav_button_font_family | default: 'font-body' }} {{ section.settings.nav_button_font_size | default: 'text-sm' }} {{ section.settings.nav_button_color | default: 'text-primary' }} {{ section.settings.nav_button_font_weight | default: 'font-medium' }}">
                    <div class="nav-content">
                      <span class="nav-label">{{ section.settings.next_label | default: 'Next Post' }}</span>
                      <span class="nav-title">{{ next_post.title }}</span>
                    </div>
                    <div class="nav-icon-wrapper">
                      <svg width="20" height="20" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </a>
                {% else %}
                  <span class="post-nav-card post-nav-next post-nav-disabled {{ section.settings.nav_button_font_family | default: 'font-body' }} {{ section.settings.nav_button_font_size | default: 'text-sm' }} {{ section.settings.nav_button_color | default: 'text-primary' }} {{ section.settings.nav_button_font_weight | default: 'font-medium' }}">
                    <div class="nav-content">
                      <span class="nav-label">{{ section.settings.next_label | default: 'Next Post' }}</span>
                    </div>
                    <div class="nav-icon-wrapper">
                      <svg width="20" height="20" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
                      </svg>
                    </div>
                  </span>
                {% endif %}
              </div>
            </div>
          {% endif %}
          
          <!-- Post Footer -->
          {% if section.settings.show_post_footer %}
            <div class="post-footer mt-lg {{ section.settings.footer_font_size | default: 'text-sm' }} {{ section.settings.footer_color }}">
              {% if section.settings.show_social_share %}
                <div class="social-share text-center">
                  <span>{{ section.settings.social_share_label | default: 'Share:' }}</span>
                  <!-- Add social share buttons here if needed -->
                </div>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% else %}
        <div class="text-center py-2xl">
          <p class="text-gray-500">{{ section.settings.empty_state_text | default: 'Post not found' }}</p>
        </div>
      {% endif %}
    </div>
  </section>

