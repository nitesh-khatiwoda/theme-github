<link rel="stylesheet" href="{{ 'statistics-columns-2/styles.css' | asset_url }}">

<!-- Statistics Columns Section -->
<section class="statistics-columns-2 {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}}  {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="statistics-columns-2-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  {% assign layout_width = section.settings.layout_width | default: 'inline' %}
  {% if layout_width == 'full_width' %}
    <div class="statistics-columns-2-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} layout-full-width" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
  {% else %}
  <div class="container">
    <div class="statistics-columns-2-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
  {% endif %}
      
      <!-- Section Heading -->
      {% if section.settings.heading != blank %}
      <div class="section-heading text-{{ section.settings.heading_alignment | default: 'center' }} mb-xl lg:mb-2xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-primary' }}">
          {{ section.settings.heading }}
        </h2>
        {% if section.settings.description != blank %}
        <div class="section-description mt-md lg:mt-lg">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
      </div>
      {% endif %}
      
      <!-- Grid -->
      {% if section.blocks.size > 0 %}
      {% assign column_gap = section.settings.column_gap | default: 'xl' %}
      {% case column_gap %}
        {% when 'xs' %}{% assign gap_value = 'var(--space-xs)' %}
        {% when 'sm' %}{% assign gap_value = 'var(--space-sm)' %}
        {% when 'md' %}{% assign gap_value = 'var(--space-md)' %}
        {% when 'lg' %}{% assign gap_value = 'var(--space-lg)' %}
        {% when 'xl' %}{% assign gap_value = 'var(--space-xl)' %}
        {% when '2xl' %}{% assign gap_value = 'var(--space-2xl)' %}
        {% when '3xl' %}{% assign gap_value = 'var(--space-3xl)' %}
        {% else %}{% assign gap_value = 'var(--space-xl)' %}
      {% endcase %}
      <div class="cards-grid layout-columns {% if section.settings.content_based_height %}content-based-height{% endif %}" data-section-id="{{ section.id }}" style="--column-gap: {{ gap_value }}; gap: var(--column-gap);">
        {% for block in section.blocks reversed %}
          {% case block.type %}
            {% when 'featured_card' %}
              <!-- Featured Card -->
              {% assign border_radius = block.settings.border_radius | default: 'rounded-md' %}
              {% assign background_color = block.settings.background_color | default: 'bg-neutral-light' %}
              {% assign bg_image = '' %}
              {% if block.settings.background_image != blank %}
                {% assign bg_image = block.settings.background_image | image_url %}
              {% endif %}
              <div class="featured-card card-height-700 {{ background_color }} {{ border_radius }}" 
                   data-column="1" 
                   data-order="0"
                   {{ block.fluid_attributes }}>
                {% if bg_image != blank %}
                <div class="featured-card-background" style="background-image: url('{{ bg_image }}');"></div>
                {% endif %}
                {% if block.settings.show_overlay %}
                <div class="featured-card-overlay"></div>
                {% endif %}
                <div class="featured-card-content p-lg">
                {% if block.settings.show_icon and block.settings.icon_image != blank %}
                {% assign icon_size = block.settings.icon_size | default: 'md' %}
                  <div class="featured-card-icon icon-size-{{ icon_size }}">
                  <img src="{{ block.settings.icon_image | image_url }}" alt="{{ block.settings.icon_image.alt | default: 'Icon' }}" class="icon-image">
                </div>
                {% endif %}
                  {% if block.settings.show_title and block.settings.title != blank %}
                  <h2 class="{{ block.settings.title_font_family | default: 'font-handwritten' }} {{ block.settings.title_font_size | default: 'text-3xl' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-5xl' }} {{ block.settings.title_font_weight | default: 'font-bold' }} {{ block.settings.title_color | default: 'text-primary' }}">
                    {{ block.settings.title }}
                  </h2>
                  {% endif %}
                  {% if block.settings.show_text and block.settings.text != blank %}
                  <div class="featured-card-text {{ block.settings.text_font_family | default: 'font-body' }} {{ block.settings.text_font_size | default: 'text-base' }} {{ block.settings.text_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.text_font_weight | default: 'font-normal' }} {{ block.settings.text_color | default: 'text-primary' }}">
                    {{ block.settings.text }}
                </div>
                {% endif %}
                </div>
              </div>
            {% when 'split_card' %}
              <!-- Split Card -->
              {% assign border_radius = block.settings.border_radius | default: 'rounded-md' %}
              {% assign background_color = block.settings.background_color | default: 'bg-neutral-light' %}
              {% assign gap_size = block.settings.gap_size | default: '24' %}
              {% assign card_height = 700 | minus: gap_size | divided_by: 2 %}
              {% assign top_bg_image = '' %}
              {% assign bottom_bg_image = '' %}
              {% if block.settings.top_card_background_image != blank %}
                {% assign top_bg_image = block.settings.top_card_background_image | image_url %}
              {% endif %}
              {% if block.settings.bottom_card_background_image != blank %}
                {% assign bottom_bg_image = block.settings.bottom_card_background_image | image_url %}
              {% endif %}
              <div class="split-card card-height-700" 
                   data-column="1" 
                   data-order="0"
                   style="--split-gap: {{ gap_size }}px;"
                   {{ block.fluid_attributes }}>
                <div class="split-card-top {{ background_color }} {{ border_radius }}" style="height: {{ card_height }}px;">
                  {% if top_bg_image != blank %}
                  <div class="split-card-background" style="background-image: url('{{ top_bg_image }}');"></div>
                  {% endif %}
                  {% if block.settings.show_top_overlay %}
                  <div class="split-card-overlay"></div>
                  {% endif %}
                  <div class="split-card-content p-lg">
                    {% if block.settings.show_top_icon and block.settings.top_card_icon_image != blank %}
                    {% assign top_icon_size = block.settings.top_card_icon_size | default: 'md' %}
                    <div class="split-card-icon icon-size-{{ top_icon_size }}">
                      <img src="{{ block.settings.top_card_icon_image | image_url }}" alt="{{ block.settings.top_card_icon_image.alt | default: 'Icon' }}" class="icon-image">
                    </div>
                    {% endif %}
                    {% if block.settings.show_top_title and block.settings.top_card_title != blank %}
                    <h2 class="{{ block.settings.top_card_title_font_family | default: 'font-handwritten' }} {{ block.settings.top_card_title_font_size | default: 'text-3xl' }} {{ block.settings.top_card_title_font_size_desktop | default: 'lg:text-5xl' }} {{ block.settings.top_card_title_font_weight | default: 'font-bold' }} {{ block.settings.top_card_title_color | default: 'text-primary' }}">
                      {{ block.settings.top_card_title }}
                    </h2>
                    {% endif %}
                    {% if block.settings.show_top_text and block.settings.top_card_text != blank %}
                    <div class="split-card-text {{ block.settings.top_card_text_font_family | default: 'font-body' }} {{ block.settings.top_card_text_font_size | default: 'text-base' }} {{ block.settings.top_card_text_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.top_card_text_font_weight | default: 'font-normal' }} {{ block.settings.top_card_text_color | default: 'text-primary' }}">
                      {{ block.settings.top_card_text }}
                    </div>
                    {% endif %}
                  </div>
                </div>
                <div class="split-card-gap" style="height: {{ gap_size }}px;"></div>
                <div class="split-card-bottom {{ background_color }} {{ border_radius }}" style="height: {{ card_height }}px;">
                  {% if bottom_bg_image != blank %}
                  <div class="split-card-background" style="background-image: url('{{ bottom_bg_image }}');"></div>
                  {% endif %}
                  {% if block.settings.show_bottom_overlay %}
                  <div class="split-card-overlay"></div>
                  {% endif %}
                  <div class="split-card-content p-lg">
                    {% if block.settings.show_bottom_icon and block.settings.bottom_card_icon_image != blank %}
                    {% assign bottom_icon_size = block.settings.bottom_card_icon_size | default: 'md' %}
                    <div class="split-card-icon icon-size-{{ bottom_icon_size }}">
                      <img src="{{ block.settings.bottom_card_icon_image | image_url }}" alt="{{ block.settings.bottom_card_icon_image.alt | default: 'Icon' }}" class="icon-image">
                    </div>
                    {% endif %}
                    {% if block.settings.show_bottom_title and block.settings.bottom_card_title != blank %}
                    <h2 class="{{ block.settings.bottom_card_title_font_family | default: 'font-handwritten' }} {{ block.settings.bottom_card_title_font_size | default: 'text-3xl' }} {{ block.settings.bottom_card_title_font_size_desktop | default: 'lg:text-5xl' }} {{ block.settings.bottom_card_title_font_weight | default: 'font-bold' }} {{ block.settings.bottom_card_title_color | default: 'text-primary' }}">
                      {{ block.settings.bottom_card_title }}
                    </h2>
                    {% endif %}
                    {% if block.settings.show_bottom_text and block.settings.bottom_card_text != blank %}
                    <div class="split-card-text {{ block.settings.bottom_card_text_font_family | default: 'font-body' }} {{ block.settings.bottom_card_text_font_size | default: 'text-base' }} {{ block.settings.bottom_card_text_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.bottom_card_text_font_weight | default: 'font-normal' }} {{ block.settings.bottom_card_text_color | default: 'text-primary' }}">
                      {{ block.settings.bottom_card_text }}
                    </div>
                    {% endif %}
                  </div>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      {% endif %}
      
      {% if layout_width == 'full_width' %}
    </div>
  {% else %}
  </div>
  </div>
  {% endif %}
  
</section>

<script>
(function() {
  function distributeCardsHorizontally() {
    const sectionId = 'statistics-columns-2-{{ section.id }}';
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const cardsGrid = section.querySelector('.cards-grid.layout-columns');
    if (!cardsGrid) return;
    
    // Get all cards
    const cards = Array.from(cardsGrid.querySelectorAll('.testimonial-card, .video-card, .featured-card, .split-card'));
    if (cards.length === 0) return;
    
    // Determine column count based on screen size
    let columnCount = 3;
    if (window.innerWidth <= 1023) {
      columnCount = 1;
    }
    
    // Clear existing column structure if already processed
    if (cardsGrid.dataset.processed === 'true') {
      // Restore original cards
      cards.forEach(card => {
        cardsGrid.appendChild(card);
      });
    }
    
    // Helper function to get card height
    function getCardHeight(card) {
      // Check for card-height class (e.g., card-height-329, card-height-690)
      const heightClass = Array.from(card.classList).find(cls => cls.startsWith('card-height-'));
      if (heightClass) {
        return parseInt(heightClass.replace('card-height-', '')) || 0;
      }
      // For split-card, use computed height (includes both cards + gap)
      if (card.classList.contains('split-card')) {
        return card.offsetHeight || 0;
      }
      // Fallback to computed height if no class
      return card.offsetHeight || 0;
    }
    
    // Find the tallest card
    let tallestCard = cards[0];
    let tallestHeight = getCardHeight(cards[0]);
    
    cards.forEach(card => {
      const height = getCardHeight(card);
      if (height > tallestHeight) {
        tallestHeight = height;
        tallestCard = card;
      }
    });
    
    // Separate tallest card from the rest
    const remainingCards = cards.filter(card => card !== tallestCard);
    
    // Get gap value from CSS custom property or fallback to default
    const gapValue = getComputedStyle(cardsGrid).getPropertyValue('--column-gap') || 'var(--space-xl)';
    
    // Create column containers
    const columns = [];
    for (let i = 0; i < columnCount; i++) {
      const column = document.createElement('div');
      column.className = 'column-container';
      column.style.display = 'flex';
      column.style.flexDirection = 'column';
      column.style.gap = gapValue;
      column.style.flex = '1';
      column.style.minWidth = '0';
      columns.push(column);
    }
    
    // Clear grid and add columns
    cardsGrid.innerHTML = '';
    cardsGrid.style.display = 'flex';
    cardsGrid.style.flexDirection = 'row';
    cardsGrid.style.gap = gapValue;
    columns.forEach(column => cardsGrid.appendChild(column));
    
    // Place tallest card at the top of the left column (column 0)
    columns[0].appendChild(tallestCard);
    
    // Distribute remaining cards starting from column 1 (skip column 0)
    // Fill columns 1 and 2 first, then go back to column 0 if needed
    remainingCards.forEach((card, index) => {
      // Start from column 1, then column 2, then back to column 1, etc.
      // Only go to column 0 after columns 1 and 2 have been filled
      let columnIndex;
      if (columnCount === 1) {
        columnIndex = 0;
      } else {
        // For 2+ columns, fill columns 1 and 2 first (skip column 0)
        const availableColumns = columnCount - 1; // Exclude column 0
        columnIndex = (index % availableColumns) + 1; // Start from column 1
      }
      columns[columnIndex].appendChild(card);
    });
    
    // Mark as processed
    cardsGrid.dataset.processed = 'true';
  }
  
  // Run on load and resize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', distributeCardsHorizontally);
  } else {
    distributeCardsHorizontally();
  }
  
  // Debounced resize handler
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(distributeCardsHorizontally, 250);
  });
})();

// Parallax scroll effect for background images
(function() {
  const sectionId = 'statistics-columns-2-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const backgroundElements = Array.from(section.querySelectorAll('.featured-card-background, .split-card-background'));
  if (backgroundElements.length === 0) return;
  
  // Assign different parallax intensities to each card for variation
  // Reduced intensities for less movement
  const parallaxIntensities = [0.02, 0.03, 0.025, 0.035, 0.02, 0.04, 0.025, 0.03]; // Reduced variations
  backgroundElements.forEach((bg, index) => {
    bg.dataset.parallaxIntensity = parallaxIntensities[index % parallaxIntensities.length];
  });
  
  function updateParallax() {
    const scrollY = window.pageYOffset || document.documentElement.scrollTop;
    const windowHeight = window.innerHeight;
    
    backgroundElements.forEach(bg => {
      const card = bg.closest('.featured-card, .split-card-top, .split-card-bottom');
      if (!card) return;
      
      const rect = card.getBoundingClientRect();
      const cardTop = rect.top + scrollY;
      const cardHeight = rect.height;
      
      // Calculate how much of the card is visible
      const cardCenter = cardTop + cardHeight / 2;
      const viewportCenter = scrollY + windowHeight / 2;
      
      // Distance from viewport center to card center
      const distance = viewportCenter - cardCenter;
      
      // Get card-specific parallax intensity (reduced for less movement)
      const parallaxIntensity = parseFloat(bg.dataset.parallaxIntensity) || 0.025;
      
      // Initial offset to start images higher
      const initialOffset = -30;
      let translateY = initialOffset + (distance * parallaxIntensity);
      
      // Clamp to prevent too much downward movement - keep it within reasonable bounds
      translateY = Math.max(initialOffset, Math.min(initialOffset + 20, translateY));
      
      // Apply transform - base scale of 1.4 (140% zoom) + initial offset + subtle parallax translation
      // The scale is centered, so images stay properly positioned
      bg.style.transform = `scale(1.4) translate3d(0, ${translateY}px, 0)`;
    });
  }
  
  // Use requestAnimationFrame for smooth performance
  let ticking = false;
  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateParallax();
        ticking = false;
      });
      ticking = true;
    }
  }
  
  // Initial call
  updateParallax();
  
  // Listen to scroll events
  window.addEventListener('scroll', onScroll, { passive: true });
  
  // Update on resize
  window.addEventListener('resize', updateParallax, { passive: true });
})();

// Staggered fade-in and slide-up animation for cards
(function() {
  const sectionId = 'statistics-columns-2-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const cardsGrid = section.querySelector('.cards-grid.layout-columns');
  if (!cardsGrid) return;
  
  // Wait for cards to be distributed into columns
  function initAnimation() {
    const featuredCards = Array.from(cardsGrid.querySelectorAll('.featured-card'));
    const splitCards = Array.from(cardsGrid.querySelectorAll('.split-card'));
    
    // Collect all cards to animate (featured cards + split card parts)
    const allCardsToAnimate = [];
    
    // Add featured cards
    featuredCards.forEach(card => {
      allCardsToAnimate.push({ element: card, delay: 0 });
    });
    
    // Add split card top and bottom parts separately
    splitCards.forEach(splitCard => {
      const topCard = splitCard.querySelector('.split-card-top');
      const bottomCard = splitCard.querySelector('.split-card-bottom');
      
      if (topCard) {
        allCardsToAnimate.push({ element: topCard, delay: 0 });
      }
      if (bottomCard) {
        allCardsToAnimate.push({ element: bottomCard, delay: 0 });
      }
    });
    
    if (allCardsToAnimate.length === 0) return;
    
    // Intersection Observer to trigger animation when section comes into view
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1 // Trigger when 10% of section is visible
    };
    
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Stagger the animation for each card
          allCardsToAnimate.forEach((card, index) => {
            setTimeout(() => {
              card.element.classList.add('animate-in');
            }, index * 100); // 100ms delay between each card
          });
          
          // Unobserve after animation is triggered
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    
    // Start observing the section
    observer.observe(section);
  }
  
  // Wait for card distribution to complete, then initialize animation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(initAnimation, 500); // Wait for card distribution
    });
  } else {
    setTimeout(initAnimation, 500); // Wait for card distribution
  }
})();
</script>

{% schema %}
{
  "name": "Statistics Columns 2",
  "tag": "section",
  "class": "statistics-columns-2-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading Font Family",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-handwritten", "label": "Handwritten" },
        { "value": "font-serif", "label": "Serif" }
      ],
      "default": "font-primary"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading Font Size (Mobile)",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "text-xl", "label": "Extra Large" },
        { "value": "text-2xl", "label": "2X Large" },
        { "value": "text-3xl", "label": "3X Large" },
        { "value": "text-4xl", "label": "4X Large" },
        { "value": "text-5xl", "label": "5X Large" },
        { "value": "text-6xl", "label": "6X Large" },
        { "value": "text-7xl", "label": "7X Large" },
        { "value": "text-8xl", "label": "8X Large" },
        { "value": "text-9xl", "label": "9X Large" }
