<!-- Hero Product Showcase Section -->
<section class="hero-product-showcase {{ section.settings.background_color | default: 'bg-secondary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="hero-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="hero-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      <div class="hero-grid grid grid-cols-1 lg:grid-cols-2 gap-xl lg:gap-2xl items-center">
      
      <!-- Left Content -->
      <div class="hero-content font-body">
        
        <!-- Rating Badge -->
        {% if section.settings.show_rating %}
        <div class="rating-badge inline-flex items-center gap-sm mb-lg bg-secondary-light" style="padding: 7px 11px; border-radius: var(--radius-3xl);">
          <div class="stars flex" style="gap: 2px;">
            {% for i in (1..5) %}
              <svg width="15" height="15" viewBox="0 0 15 15" fill="currentColor" class="text-quaternary">
                <path d="M7.5 0L9.18382 5.18237H14.6329L10.2245 8.38525L11.9084 13.5676L7.5 10.3648L3.09161 13.5676L4.77544 8.38525L0.367076 5.18237H5.81618L7.5 0Z"/>
              </svg>
            {% endfor %}
          </div>
          {% if section.settings.rating_text != blank %}
            <span class="{{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.rating_font_weight | default: 'font-medium' }} {{ section.settings.rating_color | default: 'text-black' }}">
              {{ section.settings.rating_text }}
            </span>
          {% endif %}
        </div>
        {% endif %}
        
        <!-- Main Heading -->
        {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
        <div class="hero-heading-wrapper mb-lg">
          <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading uppercase text-center leading-heading">
            {% if section.settings.heading_line_1 != blank %}
              {{ section.settings.heading_line_1 }}<br>
            {% endif %}
            {% if section.settings.heading_line_2 != blank %}
              {{ section.settings.heading_line_2 }}
            {% endif %}
          </h1>
        </div>
        {% endif %}
        
        <!-- Benefits Badges -->
        {% if section.blocks.size > 0 %}
        <div class="benefits-grid flex flex-wrap gap-sm mb-lg justify-center">
          {% for block in section.blocks %}
            {% if block.type == 'benefit' %}
              <div class="benefit-badge flex items-center gap-xs justify-center bg-secondary-light" style="padding: 5px 8px; border-radius: var(--radius-xl); min-height: 28px;" {{ block.fluid_attributes }}>
                {% if block.settings.show_icon %}
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;" class="text-success">
                    <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M6 10L9 13L14 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% endif %}
                <span class="{{ block.settings.text_font_size | default: 'text-sm' }} {{ block.settings.text_font_size_desktop | default: 'lg:text-sm' }} {{ block.settings.text_font_weight | default: 'font-medium' }} {{ block.settings.text_color | default: 'text-black' }}">
                  {{ block.settings.text }}
                </span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        
        <!-- CTA Button -->
        {% if section.settings.show_button %}
        <div class="hero-cta mb-md" style="max-width: 529px; margin-left: auto; margin-right: auto; width: 100%;">
          <a href="{{ section.settings.button_url | default: '#' }}" 
             class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }} uppercase w-full">
            {{ section.settings.button_text | default: 'Try Lorem Risk-Free Today' }}
          </a>
        </div>
        {% endif %}
        
        <!-- Free Shipping Notice -->
        {% if section.settings.show_shipping_notice %}
        <div class="shipping-notice flex items-center justify-center gap-sm">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 10.5V6.75C6 6.33579 6.33579 6 6.75 6H12.75C13.1642 6 13.5 6.33579 13.5 6.75V14.25M13.5 14.25H15.75L17.25 11.25V14.25M13.5 14.25H12M17.25 14.25H18M12 14.25C12 15.0784 11.3284 15.75 10.5 15.75C9.67157 15.75 9 15.0784 9 14.25C9 13.4216 9.67157 12.75 10.5 12.75C11.3284 12.75 12 13.4216 12 14.25ZM18 14.25C18 15.0784 17.3284 15.75 16.5 15.75C15.6716 15.75 15 15.0784 15 14.25C15 13.4216 15.6716 12.75 16.5 12.75C17.3284 12.75 18 13.4216 18 14.25Z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="{{ section.settings.shipping_font_size | default: 'text-sm' }} {{ section.settings.shipping_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.shipping_font_weight | default: 'font-medium' }} {{ section.settings.shipping_color | default: 'text-black' }}">
            {{ section.settings.shipping_text | default: 'Free shipping on orders over $80*' }}
          </span>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Right Image -->
      <div class="hero-image relative">
        {% if section.settings.hero_image != blank %}
          <img 
            src="{{ section.settings.hero_image | image_url: width: 800 }}" 
            alt="{{ section.settings.hero_image_alt | default: section.settings.heading }}"
            class="w-full h-auto object-cover"
            loading="eager">
        {% else %}
          <img 
            src="{{ 'placeholder-image.png' | asset_url }}" 
            alt="Product showcase placeholder"
            class="w-full h-auto object-cover">
        {% endif %}
      </div>
      
      </div>
    </div>
  </div>
</section>

