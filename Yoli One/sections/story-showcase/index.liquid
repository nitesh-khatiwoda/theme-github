<link rel="stylesheet" href="{{ 'story-showcase/styles.css' | asset_url }}">

<!-- Story Showcase Section -->
<section 
  class="story-showcase {{ section.settings.background_color | default: 'bg-neutral-light' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="story-showcase-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="story-showcase-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="story-showcase-grid {% if section.settings.flip_layout %}story-showcase-grid--flipped{% endif %}">
        
        <!-- Left Column: Content + Image Card -->
        <div class="story-showcase-content-column">
          
          <!-- Main Heading -->
          {% if section.settings.heading != blank %}
          <div class="story-showcase-heading-wrapper mb-md">
            <h2 class="story-showcase-heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-5xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Body Text -->
          {% if section.settings.body_text != blank %}
          <div class="story-showcase-body-wrapper mb-lg">
            <div class="story-showcase-body {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-lg' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.body_font_weight | default: 'font-normal' }} {{ section.settings.body_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
              {{ section.settings.body_text }}
            </div>
          </div>
          {% endif %}
          
          <!-- Body Text 2 -->
          {% if section.settings.show_body_text_2 and section.settings.body_text_2 != blank %}
          <div class="story-showcase-body-wrapper mb-lg">
            <div class="story-showcase-body {{ section.settings.body_2_font_family | default: 'font-body' }} {{ section.settings.body_2_font_size | default: 'text-lg' }} {{ section.settings.body_2_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.body_2_font_weight | default: 'font-normal' }} {{ section.settings.body_2_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
              {{ section.settings.body_text_2 }}
            </div>
          </div>
          {% endif %}
          
          <!-- Image Card Block -->
          {% if section.settings.show_bio %}
          <div class="story-showcase-card-wrapper">
            <div class="story-showcase-card">
              
              {% assign card_width = section.settings.card_image_width | default: 240 %}
              {% assign card_height = section.settings.card_image_height | default: 240 %}
              
              {% assign card_br_tl = section.settings.card_border_radius_top_left | default: 'rounded-3xl' %}
              {% assign card_br_tr = section.settings.card_border_radius_top_right | default: 'rounded-sm' %}
              {% assign card_br_bl = section.settings.card_border_radius_bottom_left | default: 'rounded-sm' %}
              {% assign card_br_br = section.settings.card_border_radius_bottom_right | default: 'rounded-3xl' %}
              
              <!-- Card Image -->
              <div class="story-showcase-card-image" style="width: {{ card_width }}px; height: {{ card_height }}px;">
                <div class="story-showcase-card-image-inner" 
                     data-br-tl="{{ card_br_tl }}"
                     data-br-tr="{{ card_br_tr }}"
                     data-br-bl="{{ card_br_bl }}"
                     data-br-br="{{ card_br_br }}">
                  {% if section.settings.card_image != blank %}
                    <img 
                      src="{{ section.settings.card_image | image_url: width: 400 }}" 
                      alt="{{ section.settings.card_image_alt | default: section.settings.card_name }}"
                      loading="lazy"
                      class="story-showcase-card-img"
                      style="box-shadow: none !important;"
                    >
                  {% else %}
                    <div class="story-showcase-card-img story-showcase-card-img--placeholder"></div>
                  {% endif %}
                </div>
              </div>
              
              <!-- Card Content -->
              <div class="story-showcase-card-content">
                {% if section.settings.card_date != blank %}
                <div class="story-showcase-card-date mb-xs">
                  <p class="story-showcase-card-date-text {{ section.settings.card_date_font_family | default: 'font-body' }} {{ section.settings.card_date_font_size | default: 'text-sm' }} {{ section.settings.card_date_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_date_font_weight | default: 'font-bold' }} {{ section.settings.card_date_color | default: 'text-neutral-dark' }}" style="line-height: 1.4;">
                    {{ section.settings.card_date }}
                  </p>
                </div>
                {% endif %}
                
                {% if section.settings.card_name != blank %}
                <div class="story-showcase-card-name mb-xs">
                  <h3 class="story-showcase-card-name-text {{ section.settings.card_name_font_family | default: 'font-handwritten' }} {{ section.settings.card_name_font_size | default: 'text-2xl' }} {{ section.settings.card_name_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.card_name_font_weight | default: 'font-normal' }} {{ section.settings.card_name_color | default: 'text-neutral-dark' }}" style="line-height: 1.3;">
                    {{ section.settings.card_name }}
                  </h3>
                </div>
                {% endif %}
                
                {% if section.settings.card_bio != blank %}
                <div class="story-showcase-card-bio">
                  <p class="story-showcase-card-bio-text {{ section.settings.card_bio_font_family | default: 'font-body' }} {{ section.settings.card_bio_font_size | default: 'text-base' }} {{ section.settings.card_bio_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_bio_font_weight | default: 'font-normal' }} {{ section.settings.card_bio_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
                    {{ section.settings.card_bio }}
                  </p>
                </div>
                {% endif %}
              </div>
              
            </div>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Right Column: Large Video/Image -->
        <div class="story-showcase-media-column">
          {% assign media_width = section.settings.media_width | default: 100 %}
          {% assign media_height = section.settings.media_height | default: 400 %}
          {% assign media_border_radius = section.settings.media_border_radius | default: 'rounded-none' %}
          
          <div class="story-showcase-media-wrapper {{ section.settings.media_border_color | default: 'border-tertiary' }} {{ media_border_radius }}" style="width: {{ media_width }}%; max-height: {{ media_height }}px;">
            {% if section.settings.video_url != blank %}
              <!-- Background Video -->
              <video
                class="story-showcase-media-video"
                autoplay
                muted
                loop
                playsinline
                {% if section.settings.media_image %}poster="{{ section.settings.media_image | image_url: width: 1200 }}"{% endif %}
              >
                <source src="{{ section.settings.video_url }}" type="video/mp4">
              </video>
            {% endif %}
            {% if section.settings.media_image != blank %}
              <img 
                src="{{ section.settings.media_image | image_url: width: 1200 }}" 
                alt="{{ section.settings.media_image_alt | default: section.settings.heading }}"
                loading="lazy"
                class="story-showcase-media-image"
                style="box-shadow: none !important;"
              >
            {% else %}
              <div class="story-showcase-media-image story-showcase-media-image--placeholder"></div>
            {% endif %}
            
            <!-- Play Button Overlay (optional) -->
            {% if section.settings.show_play_button %}
             <div class="story-showcase-play-button" style="color: {{ section.settings.play_button_color}}">
               <a
              data-fancybox
              href="{{ section.settings.video_url | default: 'https://vimeo.com/1107268362?fl=pl&fe=cm' }}"
              class="play-icon"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="75" height="75" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-player-play">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                <path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z"></path>
              </svg>
            </a>
                        </div>
              
            <!-- <div class="story-showcase-play-button">
              <svg width="75" height="75" viewBox="0 0 75 75" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M37.5 0C16.8 0 0 16.8 0 37.5C0 58.2 16.8 75 37.5 75C58.2 75 75 58.2 75 37.5C75 16.8 58.2 0 37.5 0ZM30 52.5V22.5L52.5 37.5L30 52.5Z" fill="{{ section.settings.play_button_color | default: '#e5ac40' }}"/>
              </svg>
            </div> -->
            {% endif %}
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

