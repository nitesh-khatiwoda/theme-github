<!-- Email Signup Hero Section -->
<section class="email-signup-hero {{ section.settings.background_color | default: 'bg-secondary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="email-signup-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="signup-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="signup-grid {% if section.settings.flip_layout %}signup-grid--flipped{% endif %}">
        
        <!-- Content Column -->
        <div class="signup-content font-body">
          
          <!-- Heading -->
          {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
          <div class="signup-heading mb-sm">
            <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="line-height: 1.1; letter-spacing: -0.03em;">
              {% if section.settings.heading_line_1 != blank %}
                {{ section.settings.heading_line_1 }}<br>
              {% endif %}
              {% if section.settings.heading_line_2 != blank %}
                {{ section.settings.heading_line_2 }}
              {% endif %}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.description != blank %}
          <div class="signup-description mb-lg">
            <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }} leading-body">
              {{ section.settings.description }}
            </p>
          </div>
          {% endif %}
          
          <!-- Email Form -->
          <div class="signup-form">
            <form class="email-form bg-secondary-light" style="border: 1px solid {{ section.settings.form_border_color | default: '#000000' }}; border-radius: {{ section.settings.form_border_radius | default: '13' }}px; padding: 10px; display: flex; align-items: center; gap: 10px;">
              
              <!-- Email Input -->
              <input 
                type="email" 
                name="email" 
                placeholder="{{ section.settings.input_placeholder | default: 'Enter your email' }}"
                class="{{ section.settings.input_font_size | default: 'text-base' }} {{ section.settings.input_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.input_font_weight | default: 'font-normal' }} {{ section.settings.input_text_color | default: 'text-black' }}"
                style="flex: 1; background: transparent; border: none; outline: none; padding: 10px 15px;"
                required
              />
              
              <!-- Submit Button -->
              {% if section.settings.show_button %}
              <button 
                type="submit" 
                class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}"
                style="flex-shrink: 0;"
              >
                {{ section.settings.button_text | default: 'SUBMIT' }}
              </button>
              {% endif %}
              
            </form>
          </div>
          
        </div>
        
        <!-- Image Column -->
        <div class="signup-image">
          {% if section.settings.product_image != blank %}
            <img src="{{ section.settings.product_image | image_url: width: 800 }}" alt="{{ section.settings.image_alt | default: 'Product' }}" loading="lazy">
          {% else %}
            <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy">
          {% endif %}
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

