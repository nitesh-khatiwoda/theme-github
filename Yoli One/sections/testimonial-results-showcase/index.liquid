<!-- Testimonial Results Showcase Section -->
<section class="testimonial-results-showcase {{ section.settings.background_color | default: 'bg-neutral-light' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }} {% if section.settings.flip_layout %}testimonial-results-showcase--flipped{% endif %}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <!-- Content Column (centered with container) -->
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="testimonial-results-showcase__content-column">
          
          <!-- Icon -->
          {% if section.settings.icon %}
            <div class="testimonial-results-showcase__icon-wrapper mb-lg">
              <img src="{{ section.settings.icon | image_url: width: 144 }}"
                   alt="{{ section.settings.icon_alt | default: 'Icon' }}"
                   loading="lazy"
                   class="testimonial-results-showcase__icon">
            </div>
          {% else %}
            <div class="testimonial-results-showcase__icon-wrapper mb-lg">
              <img src="{{ 'placeholder-image.png' | asset_url }}"
                   alt="Placeholder icon"
                   loading="lazy"
                   class="testimonial-results-showcase__icon">
            </div>
          {% endif %}

          <!-- Heading -->
          {% if section.settings.heading != blank %}
            <div class="testimonial-results-showcase__heading-wrapper mb-lg">
              <h2 class="testimonial-results-showcase__heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}">
                {{ section.settings.heading }}
              </h2>
            </div>
          {% endif %}

          <!-- Description -->
          {% if section.settings.description != blank %}
            <div class="testimonial-results-showcase__description-wrapper mb-2xl">
              <p class="testimonial-results-showcase__description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
                {{ section.settings.description }}
              </p>
            </div>
          {% endif %}

          <!-- Button -->
          {% if section.settings.show_button %}
            <div class="testimonial-results-showcase__button-wrapper">
              <a href="{{ section.settings.button_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} font-body {{ settings.button_border_radius | default: 'rounded-full' }}">
                {{ section.settings.button_text | default: 'Join the 8 Percent group' }}
              </a>
            </div>
          {% endif %}

      </div>
      
    </div>
  </div>
  
  <!-- Cards Column (outside container, extends to edge) -->
  {% if section.blocks.size > 0 %}
  <div class="testimonial-results-showcase__cards-fullwidth">
    <div class="testimonial-results-showcase__cards-grid">
            {% for block in section.blocks %}
              {% if block.type == 'result_card' %}
              <div class="testimonial-results-showcase__card" {{ block.fluid_attributes }}>
                
                <!-- Card Image -->
                <div class="testimonial-results-showcase__card-image">
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}"
                         alt="{{ block.settings.image_alt | default: block.settings.line_1 | default: 'Result card' }}"
                         loading="lazy"
                         class="testimonial-results-showcase__card-img">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="Placeholder"
                         loading="lazy"
                         class="testimonial-results-showcase__card-img">
                  {% endif %}
                </div>

                <!-- Card Content Overlay -->
                <div class="testimonial-results-showcase__card-content">
                  {% if block.settings.line_1 != blank %}
                  <div class="testimonial-results-showcase__card-line-1">
                    <p class="{{ section.settings.card_text_font_family | default: 'font-body' }} {{ section.settings.card_text_font_size | default: 'text-base' }} {{ section.settings.card_text_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_text_font_weight | default: 'font-bold' }} {{ section.settings.card_text_color | default: 'text-white' }}">
                      {{ block.settings.line_1 }}
                    </p>
                  </div>
                  {% endif %}
                  
                  {% if block.settings.line_2 != blank %}
                  <div class="testimonial-results-showcase__card-line-2">
                    <p class="{{ section.settings.card_text_font_family | default: 'font-body' }} {{ section.settings.card_text_font_size | default: 'text-base' }} {{ section.settings.card_text_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_text_font_weight | default: 'font-bold' }} {{ section.settings.card_text_color | default: 'text-white' }}">
                      {{ block.settings.line_2 }}
                    </p>
                  </div>
                  {% endif %}
                </div>

              </div>
              {% endif %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
  
</section>

