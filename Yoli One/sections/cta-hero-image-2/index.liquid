<!-- CTA Hero Image 2 - Centered with Background -->
<section class="cta-hero-image-2 {{ section.settings.background_color | default: 'bg-secondary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="cta-hero-2-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="cta-hero-2-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="cta-hero-2-content-wrapper">
        
        <!-- Content Column (Centered) -->
        <div class="cta-hero-2-content">
          
          <!-- Heading -->
          {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
          <div class="cta-hero-2-heading mb-sm">
            <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="line-height: 1.1; letter-spacing: -0.03em;">
              {% if section.settings.heading_line_1 != blank %}
                {{ section.settings.heading_line_1 }}<br>
              {% endif %}
              {% if section.settings.heading_line_2 != blank %}
                {{ section.settings.heading_line_2 }}
              {% endif %}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.description != blank %}
          <div class="cta-hero-2-description mb-lg">
            <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }} leading-body">
              {{ section.settings.description }}
            </p>
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button %}
          <div class="cta-hero-2-button mb-sm">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text | default: 'Shop Now' }}
            </a>
          </div>
          {% endif %}
          
          <!-- Subtext/Notice -->
          {% if section.settings.show_subtext and section.settings.subtext != blank %}
          <div class="cta-hero-2-subtext">
            <p class="{{ section.settings.subtext_font_size | default: 'text-sm' }} {{ section.settings.subtext_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.subtext_font_weight | default: 'font-normal' }} {{ section.settings.subtext_color | default: 'text-black' }} leading-body">
              {{ section.settings.subtext }}
            </p>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Background Product Image (Optional) -->
        {% if section.settings.show_background_product and section.settings.product_image != blank %}
        <div class="cta-hero-2-background-image">
          <img src="{{ section.settings.product_image | image_url: width: 800 }}" alt="{{ section.settings.image_alt | default: 'Product' }}" loading="lazy">
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
  
</section>

