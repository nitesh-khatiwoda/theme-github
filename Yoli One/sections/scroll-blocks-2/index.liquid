<!-- Scroll Blocks 2 Section -->
<section class="scroll-blocks-2 {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="scroll-blocks-2-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% else %}data-bg="{{ 'placeholder-image.png' | asset_url }}"{% endif %}>
  
  <!-- Fixed Background Layer -->
  <div class="scroll-blocks-2-background"></div>
  
  <!-- Content Container -->
  <div class="scroll-blocks-2-content">
    <div class="container">
      <div class="scroll-blocks-2-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
        
        <!-- Section Heading -->
        {% if section.settings.heading != blank %}
        <div class="scroll-blocks-2-heading mb-xl text-center">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }}" style="line-height: 1;">
            {{ section.settings.heading }}
          </h2>
        </div>
        {% endif %}
        
        <!-- Scroll Blocks -->
        {% if section.blocks.size > 0 %}
        <div class="scroll-blocks-2-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'scroll_block' %}
            
            <div class="scroll-block-2-item" {{ block.fluid_attributes }} data-block-index="{{ forloop.index0 }}">
              
              <!-- Block Heading -->
              {% if block.settings.heading != blank %}
              <div class="scroll-block-2-heading mb-md">
                <h3 class="{{ block.settings.heading_font_family | default: 'font-primary' }} {{ block.settings.heading_font_size | default: 'text-2xl' }} {{ block.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ block.settings.heading_font_weight | default: 'font-bold' }} {{ block.settings.heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ block.settings.heading }}
                </h3>
              </div>
              {% endif %}
              
              <!-- Block Content -->
              {% if block.settings.content != blank %}
              <div class="scroll-block-2-content">
                <div class="{{ block.settings.content_font_family | default: 'font-body' }} {{ block.settings.content_font_size | default: 'text-base' }} {{ block.settings.content_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.content_font_weight | default: 'font-normal' }} {{ block.settings.content_color | default: 'text-white' }}">
                  {{ block.settings.content }}
                </div>
              </div>
              {% endif %}
              
            </div>
            
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
  
</section>

<style>
/* Scroll Blocks 2 Section Styles */
.scroll-blocks-2 {
  position: relative;
  overflow: hidden;
}

/* Fixed Background */
.scroll-blocks-2-background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 0;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  will-change: transform;
}

/* Content Container */
.scroll-blocks-2-content {
  position: relative;
  z-index: 1;
}

.scroll-blocks-2-inner {
  position: relative;
  width: 100%;
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}

/* Scroll Blocks Wrapper */
.scroll-blocks-2-wrapper {
  position: relative;
  min-height: 100vh;
}

/* Individual Block Items - sticky scroll effect */
.scroll-block-2-item {
  position: relative;
  width: 100%;
  max-width: 800px;
  margin: 0 auto;
  padding: var(--space-2xl) 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

/* Sticky behavior - activates when block reaches center */
.scroll-block-2-item.is-sticky {
  position: sticky;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
}

.scroll-block-2-heading {
  margin-bottom: var(--space-md);
}

.scroll-block-2-content {
  line-height: 1.6;
}

/* Responsive Styles */
@media (min-width: 1024px) {
  .scroll-blocks-2-heading h2 {
    line-height: 1.2;
  }
  
  .scroll-block-2-heading h3 {
    line-height: 1.2;
  }
}

/* Container Background Image Overlay */
.scroll-blocks-2-inner[data-bg]::after {
  content: "";
  position: absolute;
  inset: 0;
  height: 100%;
  width: 100%;
  z-index: -1;
  background-color: rgba(0, 0, 0, 0.4);
  pointer-events: none;
}

.scroll-blocks-2-inner[data-bg] {
  background-size: cover;
  background-position: center;
}
</style>

<script>
(function() {
  'use strict';
  
  // Initialize scroll blocks 2 when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('scroll-blocks-2-{{ section.id }}');
    if (!section) return;
    
    // Set background image
    const bgImage = section.getAttribute('data-bg');
    if (bgImage) {
      const bgElement = section.querySelector('.scroll-blocks-2-background');
      if (bgElement) {
        bgElement.style.backgroundImage = `url(${bgImage})`;
      }
    }
    
    // Set container background image
    const container = section.querySelector('.scroll-blocks-2-inner[data-bg]');
    if (container) {
      const containerBg = container.getAttribute('data-bg');
      if (containerBg) {
        container.style.backgroundImage = `url(${containerBg})`;
      }
    }
    
    // Sticky scroll effect - blocks stick when they reach center and get pushed up
    const blockItems = section.querySelectorAll('.scroll-block-2-item');
    if (blockItems.length === 0) return;
    
    // Use IntersectionObserver to detect when blocks reach center of viewport
    const observerOptions = {
      root: null,
      rootMargin: '-50% 0px -50% 0px',
      threshold: [0, 0.25, 0.5, 0.75, 1]
    };
    
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        const blockItem = entry.target;
        const blockIndex = parseInt(blockItem.getAttribute('data-block-index') || '0');
        
        // When block reaches center of viewport, make it sticky
        // Only the topmost block that's in the center should be sticky
        if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
          // Check if any block above this one is also sticky
          let shouldBeSticky = true;
          for (let i = 0; i < blockIndex; i++) {
            if (blockItems[i] && blockItems[i].classList.contains('is-sticky')) {
              shouldBeSticky = false;
              break;
            }
          }
          
          if (shouldBeSticky) {
            blockItem.classList.add('is-sticky');
          }
        } else {
          // Remove sticky when block exits center zone
          blockItem.classList.remove('is-sticky');
        }
      });
    }, observerOptions);
    
    // Observe all block items
    blockItems.forEach(function(item) {
      observer.observe(item);
    });
    
    // Parallax effect for background (optional subtle movement)
    let parallaxTicking = false;
    
    function updateParallax() {
      const scrolled = window.pageYOffset;
      const sectionTop = section.offsetTop;
      const sectionHeight = section.offsetHeight;
      const windowHeight = window.innerHeight;
      
      // Only apply parallax when section is in view
      if (scrolled + windowHeight > sectionTop && scrolled < sectionTop + sectionHeight) {
        const bgElement = section.querySelector('.scroll-blocks-2-background');
        if (bgElement) {
          const offset = (scrolled - sectionTop) * 0.3;
          bgElement.style.transform = `translateY(${offset}px)`;
        }
      }
      
      parallaxTicking = false;
    }
    
    function requestParallaxTick() {
      if (!parallaxTicking) {
        window.requestAnimationFrame(updateParallax);
        parallaxTicking = true;
      }
    }
    
    window.addEventListener('scroll', requestParallaxTick, { passive: true });
  });
})();
</script>

