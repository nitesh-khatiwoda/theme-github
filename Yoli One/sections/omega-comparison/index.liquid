<link rel="stylesheet" href="{{ 'omega-comparison/styles.css' | asset_url }}">

<!-- Omega Comparison Section -->
<section class="omega-comparison {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %} id="section-{{ section.id }}">
  <div class="{{section.settings.container_layout_width | default: 'container')}}">
    <div class="omega-comparison-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Top Content Section -->
      <div class="omega-comparison-header mb-2xl lg:mb-3xl">
        
        <!-- Main Heading -->
        {% if section.settings.heading != blank %}
        <div class="omega-comparison-heading mb-lg">
          <h1 class="{{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
            {{ section.settings.heading }}
          </h1>
        </div>
        {% endif %}
        
        <!-- Description -->
        {% if section.settings.description != blank %}
        <div class="omega-comparison-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Comparison Container -->
      {% if section.blocks.size > 0 %}
      {% assign layout_style = section.settings.layout_style | default: 'default' %}
      <div class="omega-comparison-wrapper {% if layout_style == 'sticky_labels' %}omega-comparison-wrapper--sticky-labels{% endif %}">
        
        <!-- Comparison Box (White Container with Border) -->
        <div class="comparison-box {% if layout_style == 'sticky_labels' %}comparison-box--sticky-layout{% endif %}">
          
          {% if layout_style == 'sticky_labels' %}
            <!-- Sticky Labels Layout -->
            <div class="comparison-sticky-layout">
              
              <!-- Navigation Controls - Top Right -->
              {% if section.settings.show_comparison_header %}
              <div class="comparison-controls comparison-controls--sticky-top {% if section.settings.controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
                <div class="comparison-navigation flex gap-sm">
                  <button class="comparison-nav-btn comparison-nav-prev" aria-label="Previous products" style="cursor: pointer;" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-neutral-dark' }}">
                      <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="comparison-nav-btn comparison-nav-next" aria-label="Next products" style="cursor: pointer;" type="button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-neutral-dark' }}">
                      <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
                {% if section.settings.show_progress_dots %}
                <div class="comparison-progress" data-comparison-progress="{{ section.id }}">
                  <!-- Dots will be generated by JavaScript -->
                </div>
                {% endif %}
              </div>
              {% endif %}
              <div class="omega-table-wrapper">
              
                <!-- Left Sidebar: Header, Icon, and Labels -->
                <div class="comparison-sticky-sidebar">
                  
                  <!-- Comparison Header and Icon -->
                  {% if section.settings.show_comparison_header %}
                  <div class="comparison-sticky-header">
                    <!-- Icon -->
                    {% if section.settings.show_sticky_icon != false %}
                      {% if section.settings.comparison_icon != blank %}
                      <div class="comparison-icon comparison-icon--sticky" style="--sticky-icon-width-mobile: {{ section.settings.sticky_icon_width_mobile | default: '80' }}px; --sticky-icon-width-desktop: {{ section.settings.sticky_icon_width_desktop | default: '160' }}px;">
                        <img src="{{ section.settings.comparison_icon | image_url: width: 400 }}"
                             alt="{{ section.settings.comparison_icon_alt | default: 'Comparison icon' }}"
                             loading="lazy"
                             style="box-shadow: none !important;">
                      </div>
                      {% else %}
                      <div class="comparison-icon comparison-icon--sticky" style="--sticky-icon-width-mobile: {{ section.settings.sticky_icon_width_mobile | default: '80' }}px; --sticky-icon-width-desktop: {{ section.settings.sticky_icon_width_desktop | default: '160' }}px;">
                        <img src="{{ 'placeholder-image.png' | asset_url }}"
                             alt="Placeholder"
                             loading="lazy"
                             style="box-shadow: none !important;">
                      </div>
                      {% endif %}
                    {% endif %}
                    
                    <!-- Title -->
                    {% if section.settings.comparison_title != blank %}
                    <h2 class="comparison-sticky-title {{ section.settings.comparison_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-lg' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.comparison_title_font_weight | default: 'font-bold' }} {{ section.settings.comparison_title_color | default: 'text-neutral-dark' }}">
                      {{ section.settings.comparison_title }}
                    </h2>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  <!-- Spacer to match card header height -->
                  <div class="comparison-sticky-header-spacer"></div>
                  
                  <!-- Sticky Labels Column -->
                  <div class="comparison-sticky-labels" style="--spec-row-padding-y: {{ section.settings.spec_row_spacing | default: '10' }}px;">
                    {% assign first_block = section.blocks[0] %}
                    {% if first_block.type == 'comparison_card' %}
                      {% for i in (1..10) %}
                        {% assign label_key = 'spec_' | append: i | append: '_label' %}
                        {% assign label = first_block.settings[label_key] %}
                        
                        {% if label != blank %}
                        <div class="comparison-sticky-label-row">
                          <div class="spec-label-sticky {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-bold' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                            {{ label }}
                          </div>
                        </div>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </div>
                  
                </div>
                
                <!-- Right Side: Cards Container -->
                <div class="comparison-sticky-content">
                  
                  <!-- Comparison Cards Container -->
                  <div class="comparison-cards-container" data-carousel="{{ section.id }}">
                    <div class="comparison-cards-track">
                      {% for block in section.blocks %}
                        {% if block.type == 'comparison_card' %}
                        <div class="comparison-card {% if block.settings.is_highlighted %}comparison-card--highlighted{% endif %} {{ section.settings.card_border_radius | default: 'rounded-md' }}" style="width: {{ section.settings.card_width | default: '259' }}px; min-width: {{ section.settings.card_width | default: '259' }}px;" {{ block.fluid_attributes }}>
                          
                          <!-- Card Header -->
                          <div class="comparison-card-header mb-sm">
                            <!-- Product Image -->
                            <div class="comparison-card-image" 
                                 style="--image-width-mobile: {{ section.settings.image_width_mobile | default: '180' }}px; --image-height-mobile: {{ section.settings.image_height_mobile | default: '142' }}px; --image-width-desktop: {{ section.settings.image_width_desktop | default: '157' }}px; --image-height-desktop: {{ section.settings.image_height_desktop | default: '153' }}px;">
                              {% if block.settings.product_image != blank %}
                              <img src="{{ block.settings.product_image | image_url: width: 400 }}"
                                   alt="{{ block.settings.product_image_alt | default: block.settings.product_name }}"
                                   loading="lazy"
                                   style="box-shadow: none !important;">
                              {% else %}
                              <img src="{{ 'placeholder-image.png' | asset_url }}"
                                   alt="Placeholder"
                                   loading="lazy"
                                   style="box-shadow: none !important;">
                              {% endif %}
                            </div>
                            
                            {% if block.settings.product_name != blank %}
                            <h3 class="{{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-lg' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }} text-center mt-sm">
                              {{ block.settings.product_name }}
                            </h3>
                            {% endif %}
                          </div>
                          
                          <!-- Card Specifications (Values Only) -->
                          <div class="comparison-card-specs comparison-card-specs--sticky" style="--spec-row-padding-y: {{ section.settings.spec_row_spacing | default: '10' }}px;">
                            {% for i in (1..10) %}
                              {% assign label_key = 'spec_' | append: i | append: '_label' %}
                              {% assign value_key = 'spec_' | append: i | append: '_value' %}
                              {% assign label = block.settings[label_key] %}
                              {% assign value = block.settings[value_key] %}
                              
                              {% if label != blank or value != blank %}
                              <div class="comparison-spec-row comparison-spec-row--sticky">
                                {% if value != blank %}
                                <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-neutral-dark' }}">
                                  {{ value }}
                                </div>
                                {% endif %}
                              </div>
                              {% endif %}
                            {% endfor %}
                          </div>
                          
                        </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                  
                </div>
              </div>
            </div>
            
          {% else %}
            <!-- Default Layout -->
          
          <!-- Comparison Header -->
          {% if section.settings.show_comparison_header %}
          <div class="comparison-header mb-lg">
            <div class="comparison-header-left flex items-center gap-md">
              <!-- Icon -->
              {% if section.settings.show_comparison_icon %}
                {% if section.settings.comparison_icon %}
                <div class="comparison-icon">
                  <img src="{{ section.settings.comparison_icon | image_url: width: 54 }}"
                       alt="{{ section.settings.comparison_icon_alt | default: 'Comparison icon' }}"
                       loading="lazy"
                       style="box-shadow: none !important;">
                </div>
                {% else %}
                <div class="comparison-icon">
                  <img src="{{ 'placeholder-image.png' | asset_url }}"
                       alt="Placeholder"
                       loading="lazy"
                       style="box-shadow: none !important;">
                </div>
                {% endif %}
              {% endif %}
              
              <!-- Title -->
              {% if section.settings.comparison_title != blank %}
              <h2 class="{{ section.settings.comparison_title_font_family | default: 'font-body' }} {{ section.settings.comparison_title_font_size | default: 'text-2xl' }} {{ section.settings.comparison_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.comparison_title_font_weight | default: 'font-bold' }} {{ section.settings.comparison_title_color | default: 'text-neutral-dark' }}">
                {{ section.settings.comparison_title }}
              </h2>
              {% endif %}
            </div>
            
            <!-- Navigation Controls -->
            <div class="comparison-controls {% if section.settings.controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
              <div class="comparison-navigation flex gap-sm">
                <button class="comparison-nav-btn comparison-nav-prev" aria-label="Previous products" style="cursor: pointer;" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-neutral-dark' }}">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button class="comparison-nav-btn comparison-nav-next" aria-label="Next products" style="cursor: pointer;" type="button">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-neutral-dark' }}">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
              {% if section.settings.show_progress_dots %}
              <div class="comparison-progress" data-comparison-progress="{{ section.id }}">
                <!-- Dots will be generated by JavaScript -->
              </div>
              {% endif %}
            </div>
          </div>
          {% endif %}
          
          <!-- Comparison Cards Container -->
          <div class="comparison-cards-container" data-carousel="{{ section.id }}">
            <div class="comparison-cards-track">
              {% for block in section.blocks %}
                {% if block.type == 'comparison_card' %}
                <div class="comparison-card {% if block.settings.is_highlighted %}comparison-card--highlighted{% endif %} {{ section.settings.card_border_radius | default: 'rounded-md' }}" style="width: {{ section.settings.card_width | default: '259' }}px; min-width: {{ section.settings.card_width | default: '259' }}px;" {{ block.fluid_attributes }}>
                  
                  <!-- Card Header -->
                  <div class="comparison-card-header mb-sm">
                    <!-- Product Image -->
                      <div class="comparison-card-image" 
                         style="--image-width-mobile: {{ section.settings.image_width_mobile | default: '180' }}px; --image-height-mobile: {{ section.settings.image_height_mobile | default: '142' }}px; --image-width-desktop: {{ section.settings.image_width_desktop | default: '157' }}px; --image-height-desktop: {{ section.settings.image_height_desktop | default: '153' }}px;">
                        {% if block.settings.product_image != blank %}
                      <img src="{{ block.settings.product_image | image_url: width: 400 }}"
                           alt="{{ block.settings.product_image_alt | default: block.settings.product_name }}"
                           loading="lazy"
                           style="box-shadow: none !important;">
                      {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Placeholder"
                           loading="lazy"
                           style="box-shadow: none !important;">
                      {% endif %}
                    </div>
                      
                      {% if block.settings.product_name != blank %}
                      <h3 class="{{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-lg' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }} text-center mt-sm">
                        {{ block.settings.product_name }}
                      </h3>
                      {% endif %}
                  </div>
                  
                  <!-- Card Specifications -->
                  <div class="comparison-card-specs" style="--spec-row-padding-y: {{ section.settings.spec_row_spacing | default: '10' }}px; --label-value-gap: {{ section.settings.label_value_gap | default: '-2' }}px;">
                    {% for i in (1..10) %}
                      {% assign label_key = 'spec_' | append: i | append: '_label' %}
                      {% assign value_key = 'spec_' | append: i | append: '_value' %}
                      {% assign label = block.settings[label_key] %}
                      {% assign value = block.settings[value_key] %}
                      
                      {% if label != blank or value != blank %}
                      <div class="comparison-spec-row">
                        {% if label != blank %}
                        <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-bold' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                          {{ label }}
                        </div>
                        {% endif %}
                        {% if value != blank %}
                        <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-neutral-dark' }}">
                          {{ value }}
                        </div>
                        {% endif %}
                      </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                  
                </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          
          <!-- Footer Notes -->
          {% if section.settings.footer_note_1 != blank or section.settings.footer_note_2 != blank %}
          <div class="comparison-footer-notes mt-lg">
            {% if section.settings.footer_note_1 != blank %}
            <p class="{{ section.settings.footer_note_font_family | default: 'font-body' }} {{ section.settings.footer_note_font_size | default: 'text-xs' }} {{ section.settings.footer_note_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.footer_note_font_weight | default: 'font-normal' }} {{ section.settings.footer_note_color | default: 'text-neutral-dark' }}">
              {{ section.settings.footer_note_1 }}
            </p>
            {% endif %}
            {% if section.settings.footer_note_2 != blank %}
            <p class="{{ section.settings.footer_note_font_family | default: 'font-body' }} {{ section.settings.footer_note_font_size | default: 'text-xs' }} {{ section.settings.footer_note_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.footer_note_font_weight | default: 'font-normal' }} {{ section.settings.footer_note_color | default: 'text-neutral-dark' }}">
              {{ section.settings.footer_note_2 }}
            </p>
            {% endif %}
          </div>
            {% endif %}
            
          {% endif %}
          
        </div>
        
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const carousel = document.querySelector('[data-carousel="{{ section.id }}"]');
  if (!carousel) return;
  
  const wrapper = carousel.closest('.omega-comparison-wrapper');
  if (!wrapper) return;
  
  const track = carousel.querySelector('.comparison-cards-track');
  const prevBtn = wrapper.querySelector('.comparison-nav-prev');
  const nextBtn = wrapper.querySelector('.comparison-nav-next');
  const progressContainer = wrapper.querySelector('[data-comparison-progress]');
  
  if (!track || !prevBtn || !nextBtn) return;
  
  const cards = track.querySelectorAll('.comparison-card');
  let currentIndex = 0;
  
  // For sticky layout, we need to scroll the container, not the track
  const isStickyLayout = wrapper.classList.contains('omega-comparison-wrapper--sticky-labels');
  const scrollContainer = isStickyLayout ? carousel : track;
  
  // Function to align specification rows across all cards
  function alignSpecRows() {
    const cards = track.querySelectorAll('.comparison-card');
    if (cards.length === 0) return;
    
    // Check if we're in sticky labels layout
    const isStickyLayout = wrapper.classList.contains('omega-comparison-wrapper--sticky-labels');
    const stickyLabelRows = isStickyLayout ? wrapper.querySelectorAll('.comparison-sticky-label-row') : null;
    
    // Get all spec rows from all cards
    const allSpecRows = Array.from(cards).map(card => {
      return Array.from(card.querySelectorAll('.comparison-spec-row'));
    });
    
    // Find the maximum number of rows
    const maxRows = Math.max(...allSpecRows.map(rows => rows.length));
    
    // For each row index, find the tallest row and apply that height to all rows at that index
    for (let rowIndex = 0; rowIndex < maxRows; rowIndex++) {
      let maxHeight = 0;
      
      // First pass: find the maximum height for this row index (including sticky labels if applicable)
      allSpecRows.forEach(rows => {
        if (rows[rowIndex]) {
          // Reset height to auto to get natural height
          rows[rowIndex].style.height = 'auto';
          const height = rows[rowIndex].offsetHeight;
          if (height > maxHeight) {
            maxHeight = height;
          }
        }
      });
      
      // Also check sticky label row height if in sticky layout
      if (isStickyLayout && stickyLabelRows && stickyLabelRows[rowIndex]) {
        stickyLabelRows[rowIndex].style.height = 'auto';
        const stickyHeight = stickyLabelRows[rowIndex].offsetHeight;
        if (stickyHeight > maxHeight) {
          maxHeight = stickyHeight;
        }
      }
      
      // Second pass: apply the max height to all rows at that index (including sticky labels)
      if (maxHeight > 0) {
        allSpecRows.forEach(rows => {
          if (rows[rowIndex]) {
            rows[rowIndex].style.height = maxHeight + 'px';
          }
        });
        
        // Also apply to sticky label row if in sticky layout
        if (isStickyLayout && stickyLabelRows && stickyLabelRows[rowIndex]) {
          stickyLabelRows[rowIndex].style.height = maxHeight + 'px';
        }
      }
    }
  }
  
  // Function to align sticky header spacer with card header
  function alignStickySpacer() {
    const isStickyLayout = wrapper.classList.contains('omega-comparison-wrapper--sticky-labels');
    if (!isStickyLayout) return;
    
    const spacer = wrapper.querySelector('.comparison-sticky-header-spacer');
    const firstCard = track.querySelector('.comparison-card');
    const cardHeader = firstCard ? firstCard.querySelector('.comparison-card-header') : null;
    const cardSpecs = firstCard ? firstCard.querySelector('.comparison-card-specs') : null;
    const navButtons = wrapper.querySelector('.comparison-navigation--sticky');
    const cardsContainer = wrapper.querySelector('.comparison-cards-container');
    
    if (spacer && cardHeader && firstCard && cardSpecs) {
      // Reset spacer height
      spacer.style.height = 'auto';
      spacer.style.minHeight = '0';
      
      // Get the exact position where the first spec row starts
      const firstSpecRow = cardSpecs.querySelector('.comparison-spec-row');
      if (!firstSpecRow) return;
      
      // Get card's top position relative to its container
      const cardRect = firstCard.getBoundingClientRect();
      const specsRect = firstSpecRow.getBoundingClientRect();
      
      // Get the first spec row's padding-top
      const specRowStyles = window.getComputedStyle(firstSpecRow);
      const specRowPaddingTop = parseFloat(specRowStyles.paddingTop) || 0;
      
      // Calculate the distance from card top to first spec row (before padding)
      const distanceFromCardTop = specsRect.top - cardRect.top - specRowPaddingTop;
      
      // Get header height (icon + title)
      const stickyHeader = wrapper.querySelector('.comparison-sticky-header');
      let headerHeight = 0;
      if (stickyHeader) {
        headerHeight = stickyHeader.offsetHeight;
      }
      
      // Spacer should match the distance, accounting for header
      // Navigation buttons are now at the top right, not in the sidebar
      // We've already subtracted the spec row padding-top so labels align with content
      const spacerHeight = distanceFromCardTop - headerHeight;
      
      spacer.style.height = Math.max(0, spacerHeight) + 'px';
      spacer.style.minHeight = Math.max(0, spacerHeight) + 'px';
      
      // Ensure sidebar doesn't extend beyond cards container height
      if (cardsContainer && window.innerWidth >= 1024) {
        const sidebar = wrapper.querySelector('.comparison-sticky-sidebar');
        const stickyContent = wrapper.querySelector('.comparison-sticky-content');
        if (sidebar && stickyContent) {
          const cardsHeight = cardsContainer.offsetHeight;
          const contentPadding = parseFloat(window.getComputedStyle(stickyContent).paddingTop) + 
                                parseFloat(window.getComputedStyle(stickyContent).paddingBottom);
          const maxSidebarHeight = cardsHeight + contentPadding;
          sidebar.style.maxHeight = maxSidebarHeight + 'px';
        }
      }
    }
  }
  
  // Function to check if cards are scrolling underneath sidebar
  function checkCardsUnderSidebar() {
    const isStickyLayout = wrapper.classList.contains('omega-comparison-wrapper--sticky-labels');
    if (!isStickyLayout) return;
    
    // Only check on desktop (where sidebar is sticky)
    if (window.innerWidth < 1024) {
      const sidebar = wrapper.querySelector('.comparison-sticky-sidebar');
      if (sidebar) sidebar.classList.remove('has-cards-underneath');
      return;
    }
    
    const sidebar = wrapper.querySelector('.comparison-sticky-sidebar');
    const cardsContainer = wrapper.querySelector('.comparison-cards-container');
    
    if (!sidebar || !cardsContainer) return;
    
    // Check if cards container has visible cards
    const hasCards = track.querySelectorAll('.comparison-card').length > 0;
    const cardsRect = cardsContainer.getBoundingClientRect();
    const isCardsVisible = cardsRect.width > 0 && cardsRect.height > 0 && 
                          cardsRect.top < window.innerHeight && 
                          cardsRect.bottom > 0;
    
    // Add class if cards exist and container is visible
    if (hasCards && isCardsVisible) {
      sidebar.classList.add('has-cards-underneath');
    } else {
      sidebar.classList.remove('has-cards-underneath');
    }
  }
  
  // Align rows on load
  alignSpecRows();
  alignStickySpacer();
  checkCardsUnderSidebar();
  
  // Check for cards under sidebar on scroll
  const cardsContainer = wrapper.querySelector('.comparison-cards-container');
  if (cardsContainer) {
    cardsContainer.addEventListener('scroll', checkCardsUnderSidebar);
  }
  
  // Also check on window scroll (in case cards container comes into view)
  window.addEventListener('scroll', checkCardsUnderSidebar, { passive: true });
  
  // Re-align rows on window resize
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function() {
      // Reset heights first
      track.querySelectorAll('.comparison-spec-row').forEach(row => {
        row.style.height = 'auto';
      });
      const wrapper = carousel.closest('.omega-comparison-wrapper');
      if (wrapper) {
        wrapper.querySelectorAll('.comparison-sticky-label-row').forEach(row => {
          row.style.height = 'auto';
        });
      }
      alignSpecRows();
      alignStickySpacer();
      checkCardsUnderSidebar();
    }, 100);
  });
  
  function getCardWidth() {
    const firstCard = track.querySelector('.comparison-card');
    return firstCard ? firstCard.offsetWidth : 259;
  }
  
  function getGap() {
    const computedStyle = window.getComputedStyle(track);
    const gap = computedStyle.gap || computedStyle.columnGap || '16px';
    // Convert gap to pixels
    if (gap && gap.includes('px')) {
      return parseFloat(gap);
    }
    // If gap is a CSS variable or other value, calculate from first two cards
    const firstCard = track.querySelector('.comparison-card');
    const secondCard = firstCard ? firstCard.nextElementSibling : null;
    if (firstCard && secondCard) {
      const firstCardRight = firstCard.getBoundingClientRect().right;
      const secondCardLeft = secondCard.getBoundingClientRect().left;
      return secondCardLeft - firstCardRight;
    }
    // Fallback to default gap
    return 16;
  }
  
  function scrollToCard(direction) {
    const cardWidth = getCardWidth();
    const gap = getGap();
    const scrollAmount = cardWidth + gap;
    const currentScroll = scrollContainer.scrollLeft;
    const maxScroll = scrollContainer.scrollWidth - scrollContainer.offsetWidth;
    
    let targetScroll;
    if (direction === 'next') {
      targetScroll = Math.min(maxScroll, currentScroll + scrollAmount);
      if (currentIndex < cards.length - 1) currentIndex++;
    } else {
      targetScroll = Math.max(0, currentScroll - scrollAmount);
      if (currentIndex > 0) currentIndex--;
    }
    
    scrollContainer.scrollTo({ left: targetScroll, behavior: 'smooth' });
    updateProgressDots();
  }
  
  function scrollToIndex(index) {
    const cardWidth = getCardWidth();
    const gap = getGap();
    const maxScroll = scrollContainer.scrollWidth - scrollContainer.offsetWidth;
    const targetScroll = Math.min(maxScroll, index * (cardWidth + gap));
    
    currentIndex = index;
    scrollContainer.scrollTo({ left: targetScroll, behavior: 'smooth' });
    updateButtons();
    updateProgressDots();
  }
  
  function updateProgressDots() {
    if (!progressContainer) return;
    
    progressContainer.innerHTML = '';
    
    // Create one dot per card
    for (let i = 0; i < cards.length; i++) {
      const dot = document.createElement('button');
      dot.className = 'comparison-progress-dot';
      if (i === currentIndex) {
        dot.classList.add('is-active');
      }
      dot.setAttribute('data-index', i);
      dot.setAttribute('aria-label', `Go to card ${i + 1}`);
      dot.style.cursor = 'pointer';
      dot.addEventListener('click', function() {
        scrollToIndex(i);
      });
      progressContainer.appendChild(dot);
    }
  }
  
  function updateButtons() {
    const maxScroll = scrollContainer.scrollWidth - scrollContainer.offsetWidth;
    const currentScroll = scrollContainer.scrollLeft;
    
    prevBtn.style.opacity = currentScroll <= 0 ? '0.5' : '1';
    prevBtn.disabled = currentScroll <= 0;
    nextBtn.style.opacity = currentScroll >= maxScroll - 1 ? '0.5' : '1';
    nextBtn.disabled = currentScroll >= maxScroll - 1;
  }
  
  prevBtn.addEventListener('click', function() {
    if (prevBtn.disabled) return;
    scrollToCard('prev');
  });
  
  nextBtn.addEventListener('click', function() {
    if (nextBtn.disabled) return;
    scrollToCard('next');
  });
  
  scrollContainer.addEventListener('scroll', function() {
    // Update currentIndex based on scroll position
    const cardWidth = getCardWidth();
    const gap = getGap();
    const scrollPos = scrollContainer.scrollLeft;
    const newIndex = Math.round(scrollPos / (cardWidth + gap));
    if (newIndex !== currentIndex && newIndex >= 0 && newIndex < cards.length) {
      currentIndex = newIndex;
      updateProgressDots();
    }
    updateButtons();
  });
  
  window.addEventListener('resize', function() {
    updateButtons();
    updateProgressDots();
  });
  
  updateButtons();
  updateProgressDots();
});
</script>

