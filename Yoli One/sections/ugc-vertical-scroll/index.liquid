<link rel="stylesheet" href="{{ 'ugc-vertical-scroll/styles.css' | asset_url }}">

<!-- UGC Vertical Scroll Section -->
<section class="ugc-vertical {{ section.settings.background_color | default: 'bg-page' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }}" id="ugc-vert-{{ section.id }}">
  
  <div class="{{section.settings.container_layout_width | default:'container'}}">
    <div class="ugc-vert-inner font-body {{ section.settings.container_background_color }}">
      
      <!-- Stars & Heading -->
      {% if section.settings.show_stars or section.settings.heading != blank %}
      <div class="ugc-header">
        {% if section.settings.show_stars %}
        <div class="stars-row">
          {% for i in (1..5) %}
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" class="star-icon">
              <path d="M10 1l2.5 6.5L19 8.5l-5.5 4.5L15 20l-5-3.5L5 20l1.5-7L1 8.5l6.5-1L10 1z"/>
            </svg>
          {% endfor %}
        </div>
        {% endif %}
        
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} text-3xl lg:text-4xl font-semibold {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
          {{ section.settings.heading | default: 'Customer testimonials' }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Testimonials Grid -->
      {% if section.blocks.size > 0 %}
      <div class="testimonials-grid">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
          <div class="testimonial-card {{ section.settings.card_bg | default: 'bg-card-primary' }}" {{ block.fluid_attributes }}>
            
            <!-- Quote Mark -->
            <div class="quote-mark">
              <svg width="16" height="11" viewBox="0 0 16 11" fill="currentColor" class="{{ section.settings.quote_mark_color | default: 'text-primary' }}">
                <path d="M0 10.664h4V6.664c0-2.2 1.8-4 4-4V0C3.6 0 0 3.6 0 8v2.664zm8 0h4V6.664c0-2.2 1.8-4 4-4V0c-4.4 0-8 3.6-8 8v2.664z"/>
              </svg>
            </div>
            
            <!-- Quote Text -->
            <div class="quote-text">
              <p class="{{ section.settings.quote_font_family | default: 'font-serif' }} {{ section.settings.quote_font_size | default: 'text-base' }} {{ section.settings.quote_color | default: 'text-primary' }} leading-body">
                {{ block.settings.quote }}
              </p>
            </div>
            
            <!-- Author Info -->
            <div class="author-section">
              <div class="author-photo">
                {% if block.settings.photo %}
                <img src="{{ block.settings.photo | image_url: width: 120 }}" alt="{{ block.settings.author }}">
                {% endif %}
              </div>
              <div class="author-details">
                <!-- Star Rating -->
                <div class="author-stars">
                  {% for i in (1..5) %}
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" class="small-star">
                      <path d="M6 1l1.5 3.5L11 5l-3 2.5L9 11l-3-2-3 2 1-3.5L1 5l3.5-.5L6 1z"/>
                    </svg>
                  {% endfor %}
                </div>
                <p class="author-name text-sm font-normal {{ section.settings.author_color | default: 'text-primary' }}">{{ block.settings.author }}</p>
                <p class="verified-badge text-xs font-semibold {{ section.settings.badge_color | default: 'text-muted' }}">VERIFIED CUSTOMER</p>
              </div>
            </div>
            
          </div>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

{% schema %}
{
  "name": "UGC Vertical Scroll",
  "tag": "section",
  "class": "ugc-vertical-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Width (Container)"
    },
    {
      "type": "select",
      "id": "container_layout_width",
      "label": "Layout Width (Container)",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-full", "label": "Full Width (Container Full)" }
      ],
      "default": "container",
      "info": "Choose whether the container is constrained to the width of the page or full width"
    },
    {
      "type": "header",
      "content": "Stars & Heading"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show Star Rating",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Lorem platform has helped 75,000+ people take control of their health goals"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading Font",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-serif", "label": "Serif" }
      ],
      "default": "font-serif"
    },
    {
      "type": "select",
      "id": "heading_color",
      "label": "Heading Color",
      "options": [
        { "value": "text-primary", "label": "Primary Text" },
        { "value": "text-black", "label": "Black" }
      ],
      "default": "text-primary"
    },
    {
      "type": "header",
      "content": "Card Styling"
    },
    {
      "type": "select",
      "id": "card_bg",
      "label": "Card Background",
      "options": [
        { "value": "bg-card-primary", "label": "Card Primary" },
        { "value": "bg-card-secondary", "label": "Card Secondary" },
        { "value": "bg-page", "label": "Page" }
      ],
      "default": "bg-card-primary"
    },
    {
      "type": "select",
      "id": "quote_font_family",
      "label": "Quote Font",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-serif", "label": "Serif" }
      ],
      "default": "font-serif"
    },
    {
      "type": "select",
      "id": "quote_font_size",
      "label": "Quote Size",
      "options": [
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" }
      ],
      "default": "text-base"
    },
    {
      "type": "select",
      "id": "quote_color",
      "label": "Quote Color",
      "options": [
        { "value": "text-primary", "label": "Primary Text" },
        { "value": "text-black", "label": "Black" }
      ],
      "default": "text-primary"
    },
    {
      "type": "select",
      "id": "quote_mark_color",
      "label": "Quote Mark Color",
      "options": [
        { "value": "text-primary", "label": "Primary Text" },
        { "value": "text-accent", "label": "Accent" }
      ],
      "default": "text-primary"
    },
    {
      "type": "select",
      "id": "author_color",
      "label": "Author Color",
      "options": [
        { "value": "text-primary", "label": "Primary Text" },
        { "value": "text-black", "label": "Black" }
      ],
      "default": "text-primary"
    },
    {
      "type": "select",
      "id": "badge_color",
      "label": "Badge Color",
      "options": [
        { "value": "text-muted", "label": "Muted" },
        { "value": "text-secondary", "label": "Secondary Text" }
      ],
      "default": "text-muted"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background",
      "options": [
        { "value": "bg-page", "label": "Page" },
        { "value": "bg-white", "label": "White" }
      ],
      "default": "bg-page"
    },
    {
      "type": "select",
      "id": "container_background_color",
      "label": "Container Background",
      "options": [
        { "value": "", "label": "None" },
        { "value": "bg-card-primary", "label": "Card Primary" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "section_padding_y_mobile",
      "label": "Padding (Mobile)",
      "options": [
        { "value": "py-lg", "label": "Large" },
        { "value": "py-xl", "label": "Extra Large" },
        { "value": "py-2xl", "label": "2X Large" }
      ],
      "default": "py-xl"
    },
    {
      "type": "select",
      "id": "section_padding_y_desktop",
      "label": "Padding (Desktop)",
      "options": [
        { "value": "lg:py-xl", "label": "Extra Large" },
        { "value": "lg:py-2xl", "label": "2X Large" },
        { "value": "lg:py-3xl", "label": "3X Large" }
      ],
      "default": "lg:py-3xl"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Lorem ipsum dolor sit amet."
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Customer Photo"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "Customer Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Vertical Scroll",
      "settings": {
        "heading": "The Lorem platform has helped 75,000+ people take control of their health goals",
        "show_stars": true
      },
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "I am so thankful for Lorem's treatment plan and guidance... Lorem's approach felt much more comprehensive and I finally have relief after years of struggling.", "author": "Graciela" }},
        { "type": "testimonial", "settings": { "quote": "Lorem actually saved my life. I couldn't be more happy with the detailed test results, relevant and cutting-edge information, and immense support.", "author": "Pia" }},
        { "type": "testimonial", "settings": { "quote": "The level of detail in test results is unlike anything I could ever access through my doctor's office... and [Lorem] dramatically changed my health.", "author": "T" }},
        { "type": "testimonial", "settings": { "quote": "For the first time since developing symptoms, I felt heard, understood, and cared for. I could cry from happiness!", "author": "Hannah" }}
      ]
    }
  ]
}
{% endschema %}

