<link rel="stylesheet" href="{{ 'results-carousel/styles.css' | asset_url }}">

<section 
  class="results-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}}  {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="results-carousel-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="results-carousel-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="results-carousel-content-container" style="max-width: {{ section.settings.carousel_max_width | default: 1200 }}px;">
        
      <!-- Title and Description -->
      {% if section.settings.title != blank or section.settings.description != blank %}
        {% assign header_alignment = section.settings.header_alignment | default: 'text-left' %}
        <div class="results-carousel-header {{ header_alignment }}">
        {% if section.settings.title != blank %}
        <div class="results-carousel-title-wrapper mb-lg">
          <h2 class="results-carousel-title {{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-3xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-black' }}">
            {{ section.settings.title }}
          </h2>
        </div>
        {% endif %}
        
        {% if section.settings.description != blank %}
        <div class="results-carousel-description-wrapper mb-xl">
          <p class="results-carousel-description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
      </div>
      {% endif %}
  
  <!-- Carousel Full Width Container (Outside Container Padding) -->
  {% if section.blocks.size > 0 %}
  <div class="results-carousel-fullwidth">
          <div class="results-carousel-wrapper">
      
      <!-- Carousel Container -->
      <div class="results-carousel-container" data-carousel-container="{{ section.id }}">
        
        <!-- Carousel Track -->
        <div class="results-carousel-track" data-carousel-track="{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'image_item' %}
            <div class="results-carousel-item" data-image-item="{{ section.id }}-{{ forloop.index0 }}" {{ block.fluid_attributes }}>
              <div class="results-carousel-image-wrapper {{ section.settings.image_card_border_radius | default: 'rounded-lg' }}" style="{% if section.settings.card_height == 'custom' %}height: {{ section.settings.card_height_custom | default: 400 }}px;{% else %}aspect-ratio: {{ section.settings.card_height | default: '9/16' }};{% endif %}">
                {% if block.settings.image != blank %}
                  <img
                    class="results-carousel-image"
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.image.alt | default: block.settings.description | default: block.settings.name }}"
                    loading="lazy">
                {% else %}
                  <img
                    class="results-carousel-image"
                    src="{{ 'placeholder-image.png' | asset_url }}"
                    alt="Placeholder"
                    loading="lazy">
                {% endif %}
                
                <!-- Gradient Overlay -->
                {% unless section.settings.hide_gradient_overlay %}
                <div class="results-carousel-gradient-overlay"></div>
                {% endunless %}
                
                <!-- Text Content Overlay -->
                <div class="results-carousel-content-overlay">
                  {% if section.settings.show_card_description and block.settings.description != blank %}
                  <div class="results-carousel-item-description {{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-sm' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_description_color | default: 'text-white' }}">
                    {{ block.settings.description }}
                  </div>
                  {% endif %}
                  
                  {% if section.settings.show_card_name and block.settings.name != blank %}
                  <div class="results-carousel-item-name {{ section.settings.card_name_font_family | default: 'font-primary' }} {{ section.settings.card_name_font_size | default: 'text-base' }} {{ section.settings.card_name_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_name_font_weight | default: 'font-semibold' }} {{ section.settings.card_name_color | default: 'text-white' }}">
                    {{ block.settings.name }}
                  </div>
                  {% endif %}
                </div>
              </div>
            </div>
            {% endif %}
          {% endfor %}
        </div>
        
      </div>
      
          </div>
        
        <!-- Navigation Controls (Below Carousel) -->
        <div class="results-carousel-controls {% if section.settings.controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
          <div class="results-carousel-nav-buttons">
            <button 
              class="results-carousel-nav-btn results-carousel-prev {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
              data-carousel-prev="{{ section.id }}"
              aria-label="Previous page">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            
            <button 
              class="results-carousel-nav-btn results-carousel-next {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
              data-carousel-next="{{ section.id }}"
              aria-label="Next page">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          
          <!-- Progress Indicator -->
          {% if section.settings.show_progress_dots %}
          <div class="results-carousel-progress" data-carousel-progress="{{ section.id }}">
            <!-- Dots will be generated by JavaScript -->
          </div>
          {% endif %}
        </div>
        
        </div>
        {% endif %}
      
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const container = document.querySelector(`[data-carousel-container="${sectionId}"]`);
  const track = document.querySelector(`[data-carousel-track="${sectionId}"]`);
  const prevBtn = document.querySelector(`[data-carousel-prev="${sectionId}"]`);
  const nextBtn = document.querySelector(`[data-carousel-next="${sectionId}"]`);
  const progressContainer = document.querySelector(`[data-carousel-progress="${sectionId}"]`);
  
  if (!container || !track || !prevBtn || !nextBtn) return;
  
  const imageItems = track.querySelectorAll('.results-carousel-item');
  if (imageItems.length === 0) return;
  
  let currentIndex = 0;
  let currentPage = 0;
  let imagesPerPage = parseInt('{{ section.settings.images_per_page_desktop | default: 3 }}');
  
  // Calculate images per page based on screen size
  function updateImagesPerPage() {
    if (window.innerWidth >= 1024) {
      imagesPerPage = parseInt('{{ section.settings.images_per_page_desktop | default: 3 }}');
    } else if (window.innerWidth >= 640) {
      imagesPerPage = parseInt('{{ section.settings.images_per_page_tablet | default: 2 }}');
    } else {
      imagesPerPage = parseInt('{{ section.settings.images_per_page_mobile | default: 1 }}');
    }
  }
  
  // Update item widths based on images per page
  function updateItemWidths() {
    const containerWidth = container.offsetWidth || 1;
    const gap = parseInt(getComputedStyle(track).gap) || 16;
    const totalGapWidth = (imagesPerPage - 1) * gap;
    const itemWidth = Math.floor((containerWidth - totalGapWidth) / imagesPerPage);
    
    imageItems.forEach((item) => {
      item.style.width = `${itemWidth}px`;
      item.style.flexShrink = '0';
      item.style.flexGrow = '0';
    });
    
    const totalWidth = (itemWidth * imageItems.length) + (gap * (imageItems.length - 1));
    track.style.width = `${totalWidth}px`;
  }
  
  // Animate to specific card index
  function animateToIndex(newIndex) {
    const maxIndex = imageItems.length - imagesPerPage;
    if (newIndex < 0 || newIndex > maxIndex) return;
    
    currentIndex = newIndex;
    const containerWidth = container.offsetWidth || 1;
    const gap = parseInt(getComputedStyle(track).gap) || 16;
    const totalGapWidth = (imagesPerPage - 1) * gap;
    const itemWidth = (containerWidth - totalGapWidth) / imagesPerPage;
    const targetX = -currentIndex * (itemWidth + gap);
    
    track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
    track.style.transform = `translateX(${targetX}px)`;
    
    currentPage = Math.floor(currentIndex / imagesPerPage);
    
    updateButtons();
    updateProgressDots();
  }
  
  function updateButtons() {
    const maxIndex = imageItems.length - imagesPerPage;
    
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex >= maxIndex;
    
    if (currentIndex === 0) {
      prevBtn.style.opacity = '0.4';
      prevBtn.style.cursor = 'not-allowed';
    } else {
      prevBtn.style.opacity = '0.7';
      prevBtn.style.cursor = 'pointer';
    }
    
    if (currentIndex >= maxIndex) {
      nextBtn.style.opacity = '0.4';
      nextBtn.style.cursor = 'not-allowed';
    } else {
      nextBtn.style.opacity = '0.7';
      nextBtn.style.cursor = 'pointer';
    }
  }
  
  function updateProgressDots() {
    if (!progressContainer) return;
    
    progressContainer.innerHTML = '';
    
    // Create one dot per image item
    for (let i = 0; i < imageItems.length; i++) {
      const dot = document.createElement('button');
      dot.className = 'results-carousel-progress-dot';
      // The active dot is the one representing the first visible card
      if (i === currentIndex) {
        dot.classList.add('is-active');
      }
      dot.setAttribute('data-index', i);
      dot.setAttribute('aria-label', `Go to image ${i + 1}`);
      dot.style.cursor = 'pointer';
      dot.addEventListener('click', function() {
        // Clamp to max scrollable index
        const maxIndex = imageItems.length - imagesPerPage;
        const targetIndex = Math.min(i, maxIndex);
        animateToIndex(targetIndex);
      });
      progressContainer.appendChild(dot);
    }
  }
  
  // Navigation event listeners
  prevBtn.addEventListener('click', function() {
    if (currentIndex > 0) {
      animateToIndex(currentIndex - 1);
    }
  });
  
  nextBtn.addEventListener('click', function() {
    const maxIndex = imageItems.length - imagesPerPage;
    if (currentIndex < maxIndex) {
      animateToIndex(currentIndex + 1);
    }
  });
  
  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  track.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  
  track.addEventListener('touchend', function(e) {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  }, { passive: true });
  
  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    const maxIndex = imageItems.length - imagesPerPage;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0 && currentIndex < maxIndex) {
        animateToIndex(currentIndex + 1);
      } else if (diff < 0 && currentIndex > 0) {
        animateToIndex(currentIndex - 1);
      }
    }
  }
  
  // Handle resize
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function() {
      updateImagesPerPage();
      updateItemWidths();
      const maxIndex = imageItems.length - imagesPerPage;
      if (currentIndex > maxIndex) {
        currentIndex = Math.max(0, maxIndex);
      }
      updateProgressDots();
      animateToIndex(currentIndex);
    }, 250);
  });
  
  // Initialize
  updateImagesPerPage();
  updateItemWidths();
  updateButtons();
  updateProgressDots();
  animateToIndex(0);
})();
</script>

