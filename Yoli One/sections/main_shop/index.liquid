<section class="product-collection-section {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }} shop-product-{{ section.id }}">
    <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}">
      <div class="header-section ">
        <div class="wrapper flex flex-wrap align-end justify-between gap-lg">
          <div class="desc">
            {% if section.settings.show_subheading %}
               <h6 class="section-tagline {{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-base' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-lg' }} font-{{ section.settings.subheading_font_weight | default: 'medium' }} {{ section.settings.subheading_color | default: 'text-primary' }}">
                {% if section.settings.subheading contains 'shop_page.' or section.settings.subheading contains 'shared.' %}
                  {{ section.settings.subheading | t }}
                {% else %}
                  {{ section.settings.subheading }}
                {% endif %}
              </h6>
            {% endif %}
            
            <div class="section-heading {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} font-{{ section.settings.heading_font_weight | default: 'bold' }} {{ section.settings.heading_color | default: 'text-primary' }} py-3 sm-desktop-py-4">
              {% if section.settings.heading contains 'shop_page.' or section.settings.heading contains 'shared.' %}
                {{ section.settings.heading | t }}
              {% else %}
                {{ section.settings.heading }}
              {% endif %}
            </div>
            
            {% if section.settings.show_body_text %}
              <p class="section-description {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} font-{{ section.settings.body_font_weight | default: 'normal' }} {{ section.settings.body_color | default: 'text-primary' }}">
                {% if section.settings.body_text contains 'shop_page.' or section.settings.body_text contains 'shared.' %}
                  {{ section.settings.body_text | t }}
                {% else %}
                  {{ section.settings.body_text }}
                {% endif %}
              </p>
            {% endif %}
          </div>
          
          {% if section.settings.show_button %}
            <div class="btn-section text-right ">
              <a href="{{ section.settings.button_url | default: '#' }}" class="view-all-button btn-{{ section.settings.button_style | default: 'outline' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} font-{{ section.settings.button_font_weight | default: 'medium' }}">
                {% if section.settings.button_text contains 'shop_page.' or section.settings.button_text contains 'shared.' %}
                  {{ section.settings.button_text | t }}
                {% else %}
                  {{ section.settings.button_text }}
                {% endif %}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
  
      <div class="product-list-section py-xl">
         <ul class="grid grid-cols-1 {{ section.settings.products_per_row | default: 'lg:grid-cols-3' }} gap-x-8 gap-y-12">
          {% for product in collection.products limit: section.settings.products_limit %}
            <li>
              <a href="{{ product.url }}" class="product-card {{ section.settings.card_background | default: 'bg-neutral-light' }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}">
                <div class="product-image-link">
                  <div class="product-image {{ section.settings.image_border_radius | default: 'rounded-xl' }}">
                  <img
                    src="{{ product.featured_media.url }}"
                    alt="{{ product.title }}"
                    class="image-cover"
                  />
                  </div>
                </div>
                 <div class="desc py-sm">
                   <div class="product-title {{ section.settings.product_title_font_family | default: 'font-primary' }} {{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-lg' }} font-{{ section.settings.product_title_font_weight | default: 'semibold' }} {{ section.settings.product_title_color | default: 'text-primary' }}">
                     {{ product.title }}
                   </div>
                   {% if section.settings.show_product_variant %}
                     <p class="product-variant {{ section.settings.product_variant_font_family | default: 'font-body' }} {{ section.settings.product_variant_font_size | default: 'text-sm' }} {{ section.settings.product_variant_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.product_variant_font_weight | default: 'normal' }} {{ section.settings.product_variant_color | default: 'text-primary' }} py-sm">
                       {{ product.selected_or_first_available_variant.title }}
                     </p>
                   {% endif %}
                   {% unless product.price == 0 or section.settings.hide_price %}
                     <div class="product-price {{ section.settings.product_price_font_family | default: 'font-primary' }} {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} font-{{ section.settings.product_price_font_weight | default: 'bold' }} {{ section.settings.product_price_color | default: 'text-primary' }} py-sm">
                       {{ product.price }}
                     </div>
                   {% endunless %}
                 </div>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>
  
