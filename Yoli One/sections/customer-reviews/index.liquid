<link rel="stylesheet" href="{{ 'customer-reviews/styles.css' | asset_url }}">

<!-- Customer Reviews Section -->
<section class="customer-reviews {{ section.settings.background_color | default: 'bg-page' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="reviews-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="reviews-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.heading != blank %}
      <div class="reviews-header">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} text-xl lg:text-2xl font-semibold leading-heading {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Manual Reviews -->
      {% if section.blocks.size > 0 %}
    <div class="reviews-wrapper">
      <div class="reviews-list">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
          <div class="review-item" {{ block.fluid_attributes }}>
            
            <!-- Review Header -->
            <div class="review-header">
              <div class="review-author">
                <div class="author-avatar">
                  <span class="text-sm font-medium">{{ block.settings.author_initials | default: 'AA' }}</span>
                </div>
                <div class="author-info">
                  <p class="text-base font-medium leading-body">{{ block.settings.author_name }}</p>
                  {% if block.settings.verified %}
                  <span class="verified-badge text-sm">✓ Verified buyer</span>
                  {% endif %}
                </div>
              </div>
              
              <div class="review-meta">
                <div class="review-rating">
                  {% for i in (1..5) %}
                    {% if i <= block.settings.rating %}
                      <span class="star star-filled">★</span>
                    {% else %}
                      <span class="star star-empty">☆</span>
                    {% endif %}
                  {% endfor %}
                </div>
                <span class="review-date text-sm">{{ block.settings.date }}</span>
              </div>
            </div>
            
            <!-- Review Content -->
            <div class="review-content">
              {% if block.settings.title != blank %}
              <h3 class="text-lg font-semibold leading-heading">{{ block.settings.title }}</h3>
              {% endif %}
              
              {% if block.settings.review_text != blank %}
              <p class="text-base font-normal leading-body">{{ block.settings.review_text }}</p>
              {% endif %}
            </div>
            
            <!-- Review Footer -->
            <div class="review-footer">
              {% if block.settings.show_recommend %}
              <span class="recommend-badge text-sm">👍 Would recommend</span>
              {% endif %}
            </div>
            
          </div>
          {% endif %}
        {% endfor %}
      </div>
      
      <!-- Load More Button -->
      {% if section.settings.show_load_more %}
      <div class="load-more-wrapper">
        <a href="{{ section.settings.load_more_url | default: '#reviews' }}" class="btn btn-{{ section.settings.load_more_button_style | default: 'filled' }}-{{ section.settings.load_more_button_color | default: 'primary' }} {{ section.settings.load_more_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
          {{ section.settings.load_more_text | default: 'See more reviews' }}
        </a>
      </div>
      {% endif %}
    </div>
    {% endif %}
    
    </div>
  </div>
  
</section>

