                    {% endif %}
                    {% if block.settings.spec_omega3_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_omega3_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_other_omega3_label != blank or block.settings.spec_other_omega3_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_other_omega3_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_other_omega3_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_other_omega3_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_other_omega3_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_epa_label != blank or block.settings.spec_epa_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_epa_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_epa_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_epa_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_epa_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_dha_label != blank or block.settings.spec_dha_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_dha_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_dha_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_dha_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_dha_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_vitamin_d3_label != blank or block.settings.spec_vitamin_d3_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_vitamin_d3_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_vitamin_d3_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_vitamin_d3_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_vitamin_d3_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_source_label != blank or block.settings.spec_source_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_source_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_source_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_source_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_source_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_test_kit_label != blank or block.settings.spec_test_kit_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_test_kit_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_test_kit_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_test_kit_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_test_kit_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_guarantee_label != blank or block.settings.spec_guarantee_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_guarantee_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_guarantee_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_guarantee_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
