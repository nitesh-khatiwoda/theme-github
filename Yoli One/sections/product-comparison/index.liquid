<link rel="stylesheet" href="{{ 'product-comparison/styles.css' | asset_url }}">

<!-- Product Comparison Section -->
<section class="product-comparison {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %} id="section-{{ section.id }}">
  <div class="container">
    <div class="product-comparison-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Top Content Section -->
      <div class="product-comparison-header mb-2xl lg:mb-3xl">
        
        <!-- Main Heading -->
        {% if section.settings.heading != blank %}
        <div class="product-comparison-heading mb-lg">
          <h1 class="{{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-black' }}" style="line-height: 1;">
            {{ section.settings.heading }}
          </h1>
        </div>
        {% endif %}
        
        <!-- Description -->
        {% if section.settings.description != blank %}
        <div class="product-comparison-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Product Comparison Section -->
      {% if section.blocks.size > 0 %}
      <div class="product-comparison-wrapper">
        
        <!-- Comparison Header -->
        {% if section.settings.show_comparison_header %}
        <div class="comparison-header mb-lg">
          <div class="comparison-header-left flex items-center gap-md">
            <!-- Icon -->
            {% if section.settings.show_comparison_icon %}
              {% if section.settings.comparison_icon %}
              <div class="comparison-icon">
                <img src="{{ section.settings.comparison_icon | image_url: width: 54 }}"
                     alt="{{ section.settings.comparison_icon_alt | default: 'Comparison icon' }}"
                     loading="lazy"
                     style="box-shadow: none !important;">
              </div>
              {% else %}
              <div class="comparison-icon">
                <img src="{{ 'placeholder-image.png' | asset_url }}"
                     alt="Placeholder"
                     loading="lazy"
                     style="box-shadow: none !important;">
              </div>
              {% endif %}
            {% endif %}
            
            <!-- Title -->
            {% if section.settings.comparison_title != blank %}
            <h2 class="{{ section.settings.comparison_title_font_family | default: 'font-body' }} {{ section.settings.comparison_title_font_size | default: 'text-2xl' }} {{ section.settings.comparison_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.comparison_title_font_weight | default: 'font-bold' }} {{ section.settings.comparison_title_color | default: 'text-black' }}">
              {{ section.settings.comparison_title }}
            </h2>
            {% endif %}
          </div>
          
          <!-- Navigation Arrows -->
          <div class="comparison-navigation flex gap-sm">
            <button class="comparison-nav-btn comparison-nav-prev" aria-label="Previous products" style="cursor: pointer;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-black' }}">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="comparison-nav-btn comparison-nav-next" aria-label="Next products" style="cursor: pointer;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-black' }}">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
        {% endif %}
        
      </div>
      {% endif %}
      
    </div>
  </div>
  
  <!-- Comparison Cards Full Width Container (Outside Container Padding) -->
  {% if section.blocks.size > 0 %}
  <div class="comparison-cards-fullwidth">
    <div class="comparison-cards-container" data-carousel="{{ section.id }}">
      <div class="comparison-cards-track">
            {% for block in section.blocks %}
              {% if block.type == 'comparison_card' %}
              <div class="comparison-card {% if block.settings.is_highlighted %}comparison-card--highlighted{% endif %} {{ section.settings.card_border_radius | default: 'rounded-md' }}" style="width: {{ section.settings.card_width | default: '259' }}px; min-width: {{ section.settings.card_width | default: '259' }}px;" {{ block.fluid_attributes }}>
                
                <!-- Card Header -->
                <div class="comparison-card-header mb-sm">
                  {% if block.settings.product_name != blank %}
                  <h3 class="{{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-lg' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-black' }} text-center">
                    {{ block.settings.product_name }}
                  </h3>
                  {% endif %}
                  
                  <!-- Product Image -->
                  <div class="comparison-card-image mt-sm">
                    {% if block.settings.product_image %}
                    <img src="{{ block.settings.product_image | image_url: width: 400 }}"
                         alt="{{ block.settings.product_image_alt | default: block.settings.product_name }}"
                         loading="lazy"
                         style="box-shadow: none !important;">
                    {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="Placeholder"
                         loading="lazy"
                         style="box-shadow: none !important;">
                    {% endif %}
                  </div>
                </div>
                
                <!-- Card Specifications -->
                <div class="comparison-card-specs" style="--spec-row-padding-y: {{ section.settings.spec_row_spacing | default: '10' }}px;">
                  {% if block.settings.spec_full_spectrum_label != blank or block.settings.spec_full_spectrum_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_full_spectrum_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_full_spectrum_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_full_spectrum_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_full_spectrum_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_form_label != blank or block.settings.spec_form_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_form_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_form_label }}
                    </div>
                    {% endif %}
                    {% if block.settings.spec_form_value != blank %}
                    <div class="spec-value {{ section.settings.spec_value_font_family | default: 'font-body' }} {{ section.settings.spec_value_font_size | default: 'text-base' }} {{ section.settings.spec_value_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.spec_value_font_weight | default: 'font-normal' }} {{ section.settings.spec_value_color | default: 'text-black' }}">
                      {{ block.settings.spec_form_value }}
                    </div>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if block.settings.spec_omega3_label != blank or block.settings.spec_omega3_value != blank %}
                  <div class="comparison-spec-row">
                    {% if block.settings.spec_omega3_label != blank %}
                    <div class="spec-label {{ section.settings.spec_label_font_family | default: 'font-body' }} {{ section.settings.spec_label_font_size | default: 'text-xs' }} {{ section.settings.spec_label_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.spec_label_font_weight | default: 'font-medium' }} {{ section.settings.spec_label_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.spec_omega3_label }}
