          </div>
        </div>
      </div>
      {% endif %}
      
      <!-- Footer Disclaimer -->
      {% if section.settings.disclaimer_text != blank %}
      <div class="container">
        <div class="product-comparison-inner">
          <div class="comparison-disclaimer mt-lg">
