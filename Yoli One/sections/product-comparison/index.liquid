              {{ section.settings.disclaimer_text }}
            </p>
          </div>
        </div>
      </div>
      {% endif %}
      
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const carousel = document.querySelector('[data-carousel="{{ section.id }}"]');
  if (!carousel) return;
  
  const wrapper = carousel.closest('.product-comparison-wrapper');
  if (!wrapper) return;
  
  const track = carousel.querySelector('.comparison-cards-track');
  const prevBtn = wrapper.querySelector('.comparison-nav-prev');
  const nextBtn = wrapper.querySelector('.comparison-nav-next');
  
  if (!track || !prevBtn || !nextBtn) return;
  
  const firstCard = track.querySelector('.comparison-card');
  const cardWidth = firstCard ? firstCard.offsetWidth : 259;
  const gap = 16;
  let scrollPosition = 0;
  
  function updateButtons() {
    const maxScroll = track.scrollWidth - track.offsetWidth;
    prevBtn.style.opacity = scrollPosition <= 0 ? '0.5' : '1';
    prevBtn.disabled = scrollPosition <= 0;
    nextBtn.style.opacity = scrollPosition >= maxScroll ? '0.5' : '1';
    nextBtn.disabled = scrollPosition >= maxScroll;
  }
  
  prevBtn.addEventListener('click', function() {
    if (prevBtn.disabled) return;
    scrollPosition = Math.max(0, scrollPosition - (cardWidth + gap));
    track.scrollTo({ left: scrollPosition, behavior: 'smooth' });
  });
  
  nextBtn.addEventListener('click', function() {
    if (nextBtn.disabled) return;
    const maxScroll = track.scrollWidth - track.offsetWidth;
    scrollPosition = Math.min(maxScroll, scrollPosition + (cardWidth + gap));
    track.scrollTo({ left: scrollPosition, behavior: 'smooth' });
  });
  
  track.addEventListener('scroll', function() {
    scrollPosition = track.scrollLeft;
    updateButtons();
  });
  
  // Handle window resize
  window.addEventListener('resize', function() {
    updateButtons();
  });
  
  updateButtons();
});
</script>

{% schema %}
{
  "name": "Product Comparison",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Main Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "A Smarter, Stronger Omega Formula. Backed by real science and not just a supplement label."
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Font Family",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-handwritten", "label": "Handwritten" },
        { "value": "font-serif", "label": "Serif" }
      ],
      "default": "font-handwritten"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Font Size (Mobile)",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "text-xl", "label": "Extra Large" },
        { "value": "text-2xl", "label": "2X Large" },
        { "value": "text-3xl", "label": "3X Large" },
        { "value": "text-4xl", "label": "4X Large" },
        { "value": "text-5xl", "label": "5X Large" },
        { "value": "text-6xl", "label": "6X Large" },
        { "value": "text-7xl", "label": "7X Large" },
        { "value": "text-8xl", "label": "8X Large" },
        { "value": "text-9xl", "label": "9X Large" }
      ],
      "default": "text-4xl"
    },
    {
      "type": "select",
      "id": "heading_font_size_desktop",
      "label": "Font Size (Desktop)",
      "options": [
        { "value": "lg:text-xs", "label": "Extra Small" },
        { "value": "lg:text-sm", "label": "Small" },
        { "value": "lg:text-base", "label": "Base" },
        { "value": "lg:text-lg", "label": "Large" },
        { "value": "lg:text-xl", "label": "Extra Large" },
        { "value": "lg:text-2xl", "label": "2X Large" },
        { "value": "lg:text-3xl", "label": "3X Large" },
        { "value": "lg:text-4xl", "label": "4X Large" },
        { "value": "lg:text-5xl", "label": "5X Large" },
        { "value": "lg:text-6xl", "label": "6X Large" },
        { "value": "lg:text-7xl", "label": "7X Large" },
        { "value": "lg:text-8xl", "label": "8X Large" },
        { "value": "lg:text-9xl", "label": "9X Large" }
      ],
      "default": "lg:text-5xl"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semi Bold" },
        { "value": "font-bold", "label": "Bold" }
      ],
      "default": "font-normal"
    },
    {
      "type": "select",
      "id": "heading_color",
      "label": "Text Color",
      "options": [
        { "value": "text-white", "label": "White" },
        { "value": "text-black", "label": "Black" },
