<link rel="stylesheet" href="{{ 'content-statistics-split/styles.css' | asset_url }}">

<section 
  class="content-statistics-split {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="section-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="content-statistics-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Main Heading -->
      {% if section.settings.main_heading != blank %}
      <div class="main-heading-wrapper mb-xl lg:mb-2xl">
        <h2 class="main-heading {{ section.settings.main_heading_font_family | default: 'font-handwritten' }} {{ section.settings.main_heading_font_size | default: 'text-4xl' }} {{ section.settings.main_heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.main_heading_font_weight | default: 'font-normal' }} {{ section.settings.main_heading_color | default: 'text-neutral-dark' }}">
          {{ section.settings.main_heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Blocks: Two Column Content -->
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'statistics_block' %}
              <div class="content-statistics-grid" {{ block.fluid_attributes }}>
                
                <!-- Left Column: Text Content -->
                <div class="content-column">
                  
                  <!-- Subheading -->
                  {% if block.settings.subheading != blank %}
                  <div class="subheading-wrapper mb-md">
                    <h3 class="subheading {{ block.settings.subheading_font_family | default: 'font-body' }} {{ block.settings.subheading_font_size | default: 'text-2xl' }} {{ block.settings.subheading_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.subheading_font_weight | default: 'font-bold' }} {{ block.settings.subheading_color | default: 'text-tertiary' }}">
                      {{ block.settings.subheading }}
                    </h3>
                  </div>
                  {% endif %}
                  
                  <!-- Body Text -->
                  {% if block.settings.body_text != blank %}
                  <div class="body-text-wrapper mb-md">
                    <div class="body-text {{ block.settings.body_text_font_family | default: 'font-body' }} {{ block.settings.body_text_font_size | default: 'text-base' }} {{ block.settings.body_text_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.body_text_font_weight | default: 'font-normal' }} {{ block.settings.body_text_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.body_text }}
                    </div>
                  </div>
                  {% endif %}
                  
                  <!-- Source Citation -->
                  {% if block.settings.source_citation != blank %}
                  <div class="source-citation-wrapper">
                    <div class="source-citation {{ block.settings.source_citation_font_family | default: 'font-body' }} {{ block.settings.source_citation_font_size | default: 'text-xs' }} {{ block.settings.source_citation_font_size_desktop | default: 'lg:text-xs' }} {{ block.settings.source_citation_font_weight | default: 'font-normal' }} {{ block.settings.source_citation_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.source_citation }}
                    </div>
                  </div>
                  {% endif %}
                  
                </div>
                
                <!-- Right Column: Image -->
                <div class="image-column">
                  {% if block.settings.content_image != blank %}
                  <div class="image-wrapper">
                    <img 
                      src="{{ block.settings.content_image | image_url: width: 800 }}" 
                      alt="{{ block.settings.image_alt | default: block.settings.subheading }}"
                      class="content-image"
                      loading="lazy">
                  </div>
                  {% else %}
                  <div class="image-wrapper">
                    <img 
                      src="{{ 'placeholder-image.png' | asset_url }}" 
                      alt="Placeholder"
                      class="content-image"
                      loading="lazy">
                  </div>
                  {% endif %}
                </div>
                
              </div>
          {% endcase %}
        {% endfor %}
      {% endif %}
      
    </div>
  </div>
</section>

