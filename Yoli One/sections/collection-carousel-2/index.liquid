<link rel="stylesheet" href="{{ 'collection-carousel-2/styles.css' | asset_url }}">

{%- comment -%} Find collection by title {%- endcomment -%}
{%- assign current_collection = null -%}
{%- if section.settings.selected_collection != blank -%}
  {%- for c in collections -%}
    {%- assign c_title_stripped = c.title | strip | downcase -%}
    {%- assign selected_stripped = section.settings.selected_collection | strip | downcase -%}
    {%- if c_title_stripped == selected_stripped -%}
      {%- assign current_collection = c -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

<!-- Collection Carousel 2 Section -->
<section class="collection-carousel-2 {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-lg' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
    
    <!-- Carousel Wrapper -->
    <div class="collection-carousel-2__wrapper">
      
      <!-- Horizontal Scrolling Track -->
      <div class="collection-carousel-2__track-container">
        <div class="collection-carousel-2__track" id="collection-carousel-2-track-{{ section.id }}">
        
        {%- comment -%} Featured Card (Block-based or Collection-based) {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'featured_card' -%}
            {%- comment -%} Determine if we're using collection data or manual data {%- endcomment -%}
            {%- assign use_collection_data = block.settings.use_collection_data | default: false -%}
            {%- assign featured_title = block.settings.title -%}
            {%- assign featured_description = block.settings.description -%}
            {%- assign featured_image = block.settings.background_image -%}
            {%- assign featured_url = block.settings.button_url -%}
            
            {%- if use_collection_data and current_collection != null -%}
              {%- assign featured_title = current_collection.title -%}
              {%- assign featured_description = current_collection.description -%}
              {%- assign featured_image = current_collection.image -%}
              {%- assign featured_url = current_collection.url -%}
            {%- endif -%}
            
            <!-- Featured Card (with background image) -->
            <div class="collection-carousel-2__card collection-carousel-2__card--featured {{ section.settings.featured_card_border_radius | default: 'rounded-xl' }}" {{ block.fluid_attributes }}>
              
              <!-- Background Image -->
              {%- if featured_image != blank -%}
                <div class="collection-carousel-2__featured-bg" style="background-image: url('{{ featured_image | image_url: width: 800 }}');"></div>
              {%- else -%}
                <div class="collection-carousel-2__featured-bg" style="background-image: url('{{ 'placeholder-image.png' | asset_url }}');"></div>
              {%- endif -%}
              
              <!-- Content Overlay -->
              <div class="collection-carousel-2__featured-content">
                
                <!-- Badge -->
                {%- if block.settings.show_badge and block.settings.badge_text != blank -%}
                  <div class="collection-carousel-2__badge {{ section.settings.badge_background | default: 'bg-success' }}">
                    <span class="{{ section.settings.badge_font_family | default: 'font-body' }} {{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.badge_font_weight | default: 'font-normal' }} {{ section.settings.badge_color | default: 'text-black' }}">
                      {{ block.settings.badge_text }}
                    </span>
                  </div>
                {%- endif -%}
                
                <!-- Title -->
                {%- if featured_title != blank -%}
                  <h2 class="collection-carousel-2__featured-title {{ section.settings.featured_title_font_family | default: 'font-body' }} {{ section.settings.featured_title_font_size | default: 'text-2xl' }} {{ section.settings.featured_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.featured_title_font_weight | default: 'font-normal' }} {{ section.settings.featured_title_color | default: 'text-white' }}">
                    {{ featured_title }}
                  </h2>
                {%- endif -%}
                
                <!-- Description -->
                {%- if featured_description != blank -%}
                  <p class="collection-carousel-2__featured-description {{ section.settings.featured_description_font_family | default: 'font-body' }} {{ section.settings.featured_description_font_size | default: 'text-sm' }} {{ section.settings.featured_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.featured_description_font_weight | default: 'font-normal' }} {{ section.settings.featured_description_color | default: 'text-white' }}">
                    {{ featured_description }}
                  </p>
                {%- endif -%}
                
                <!-- CTA Button -->
                {%- if block.settings.show_button and block.settings.button_text != blank -%}
                  <div class="collection-carousel-2__featured-button-wrapper">
                    <a href="{{ featured_url | default: '#' }}" 
                       class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'white' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                      {{ block.settings.button_text }}
                    </a>
                  </div>
                {%- endif -%}
                
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
        
        {%- comment -%} Dynamic Product Cards from Database {%- endcomment -%}
        {%- if current_collection != null and current_collection.products.size > 0 -%}
          {%- assign products_limit = section.settings.products_limit | default: 10 -%}
          {%- for product in current_collection.products limit: products_limit -%}
            
            <!-- Standard Product Card (from Database) -->
            <div class="collection-carousel-2__card collection-carousel-2__card--product {{ section.settings.card_background | default: 'bg-success' }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}">
              
              <div class="collection-carousel-2__product-content">
                
                <!-- Product Title -->
                <h3 class="collection-carousel-2__product-title {{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.product_title_font_weight | default: 'font-normal' }} {{ section.settings.product_title_color | default: 'text-black' }}">
                  {{ product.title | default: 'Product' }}
                </h3>
                
                <!-- Subtitle (optional) - using product type or vendor -->
                {%- if section.settings.show_product_subtitle and product.type != blank -%}
                  <p class="collection-carousel-2__product-subtitle {{ section.settings.product_subtitle_font_family | default: 'font-body' }} {{ section.settings.product_subtitle_font_size | default: 'text-base' }} {{ section.settings.product_subtitle_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_subtitle_font_weight | default: 'font-normal' }} {{ section.settings.product_subtitle_color | default: 'text-neutral-dark' }}">
                    {{ product.type }}
                  </p>
                {%- endif -%}
                
                <!-- Product Image -->
                <div class="collection-carousel-2__product-image-wrapper">
                  {%- if product.images.first.src != blank -%}
                    <img src="{{ product.images.first.src | image_url: width: 800 }}" 
                         alt="{{ product.title | default: 'Product' }}"
                         class="collection-carousel-2__product-image"
                         loading="lazy">
                  {%- else -%}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" 
                         alt="Product placeholder"
                         class="collection-carousel-2__product-image">
                  {%- endif -%}
                </div>
                
                <!-- Action Buttons -->
                <div class="collection-carousel-2__product-actions">
                  <!-- Learn More Button -->
                  {%- if section.settings.show_product_button -%}
                    <a href="{{ product.url | default: '#' }}" 
                       class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'white' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                      {{ section.settings.product_button_text | default: 'Learn More' }}
                    </a>
                  {%- endif -%}
                </div>
                
              </div>
            </div>
            
          {%- endfor -%}
        {%- elsif section.settings.selected_collection == blank -%}
          <!-- No Collection Selected -->
          <div class="collection-carousel-2__card collection-carousel-2__card--product {{ section.settings.card_background | default: 'bg-success' }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}">
            <div class="collection-carousel-2__product-content">
              <h3 class="collection-carousel-2__product-title {{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.product_title_font_weight | default: 'font-normal' }} {{ section.settings.product_title_color | default: 'text-black' }}">
                No collection selected
              </h3>
              <p class="collection-carousel-2__product-subtitle {{ section.settings.product_subtitle_font_family | default: 'font-body' }} {{ section.settings.product_subtitle_font_size | default: 'text-base' }} {{ section.settings.product_subtitle_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_subtitle_font_weight | default: 'font-normal' }} {{ section.settings.product_subtitle_color | default: 'text-neutral-dark' }}">
                Select a collection in section settings
              </p>
            </div>
          </div>
        {%- else -%}
          <!-- Collection Not Found or No Products -->
          <div class="collection-carousel-2__card collection-carousel-2__card--product {{ section.settings.card_background | default: 'bg-success' }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}">
            <div class="collection-carousel-2__product-content">
              <h3 class="collection-carousel-2__product-title {{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.product_title_font_weight | default: 'font-normal' }} {{ section.settings.product_title_color | default: 'text-black' }}">
                No products found
              </h3>
              <p class="collection-carousel-2__product-subtitle {{ section.settings.product_subtitle_font_family | default: 'font-body' }} {{ section.settings.product_subtitle_font_size | default: 'text-base' }} {{ section.settings.product_subtitle_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_subtitle_font_weight | default: 'font-normal' }} {{ section.settings.product_subtitle_color | default: 'text-neutral-dark' }}">
                Collection "{{ section.settings.selected_collection }}" not found or has no products
              </p>
            </div>
          </div>
        {%- endif -%}
        
        </div>
      </div>
      
    </div>
    
    </div>
  </div>
</section>

<script>
(function() {
  // Smooth horizontal scrolling for collection carousel 2
  function initCollectionCarousel2() {
    const tracks = document.querySelectorAll('[id^="collection-carousel-2-track-"]');
    
    tracks.forEach(function(track) {
      let isDown = false;
      let startX;
      let scrollLeft;
      
      track.addEventListener('mousedown', function(e) {
        isDown = true;
        track.style.cursor = 'grabbing';
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      });
      
      track.addEventListener('mouseleave', function() {
        isDown = false;
        track.style.cursor = 'grab';
      });
      
      track.addEventListener('mouseup', function() {
        isDown = false;
        track.style.cursor = 'grab';
      });
      
      track.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 2;
        track.scrollLeft = scrollLeft - walk;
      });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCollectionCarousel2);
  } else {
    initCollectionCarousel2();
  }
})();
</script>

