                    <h1 class="journey-hero__heading {{ block.settings.heading_font_family | default: 'font-handwritten' }} {{ block.settings.heading_font_size | default: 'text-5xl' }} {{ block.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ block.settings.heading_font_weight | default: 'font-normal' }} {{ block.settings.heading_color | default: 'text-white' }}">
                      {{ block.settings.heading }}
                    </h1>
                  </div>
                {% endif %}

                <!-- Description -->
                {% if block.settings.description != blank %}
                  <div class="journey-hero__description-wrapper mb-xl">
