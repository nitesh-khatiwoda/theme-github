          {% assign has_content_image = false %}
          {% if block.settings.content_image and block.settings.show_content_image %} {% assign has_content_image = true %} {% endif %}
          {% assign image_position = block.settings.content_image_position | default: 'right' %}
          
          <div class="journey-hero__content-wrapper {% if has_content_image %}journey-hero__content-wrapper--has-image{% endif %}">
            
            <div class="journey-hero__content text-{{ block.settings.content_alignment | default: 'left' }} {{ block.settings.block_padding_top_mobile | default: 'pt-lg' }} {{ block.settings.block_padding_top_desktop | default: 'lg:pt-xl' }} {{ block.settings.block_padding_bottom_mobile | default: 'pb-lg' }} {{ block.settings.block_padding_bottom_desktop | default: 'lg:pb-xl' }} {{ block.settings.block_padding_x_mobile | default: 'px-lg' }} {{ block.settings.block_padding_x_desktop | default: 'lg:px-3xl' }}" {% if has_content_image == false %}style="--content-width-mobile: {{ block.settings.content_max_width | default: 480 }}px; --content-width-tablet: {{ block.settings.content_max_width_tablet | default: 600 }}px; --content-width-desktop: {{ block.settings.content_max_width_desktop | default: 720 }}px;"{% endif %}>
            
