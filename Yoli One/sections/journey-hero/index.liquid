        {% elsif bg_color == 'secondary-light' %}
          {% assign bg_color_value = 'var(--clr-secondary-light)' %}
        {% elsif bg_color == 'secondary-lighter' %}
          {% assign bg_color_value = 'var(--clr-secondary-lighter)' %}
        {% elsif bg_color == 'success' %}
          {% assign bg_color_value = 'var(--clr-success)' %}
        {% elsif bg_color == 'warning' %}
          {% assign bg_color_value = 'var(--clr-warning)' %}
        {% elsif bg_color == 'error' %}
          {% assign bg_color_value = 'var(--clr-error)' %}
        {% elsif bg_color == 'info' %}
