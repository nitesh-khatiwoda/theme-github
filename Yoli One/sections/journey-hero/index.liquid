        {% elsif bg_color == 'neutral' %}
          {% assign bg_color_value = 'var(--clr-neutral)' %}
        {% elsif bg_color == 'neutral-light' %}
          {% assign bg_color_value = 'var(--clr-neutral-light)' %}
        {% elsif bg_color == 'neutral-medium' %}
          {% assign bg_color_value = 'var(--clr-neutral-medium)' %}
        {% elsif bg_color == 'neutral-lighter' %}
          {% assign bg_color_value = 'var(--clr-neutral-lighter)' %}
        {% elsif bg_color == 'neutral-dark' %}
          {% assign bg_color_value = 'var(--clr-neutral-dark)' %}
        {% elsif bg_color == 'accent-1' %}
          {% assign bg_color_value = 'var(--clr-accent-1)' %}
        {% elsif bg_color == 'accent-2' %}
          {% assign bg_color_value = 'var(--clr-accent-2)' %}
        {% elsif bg_color == 'accent-3' %}
          {% assign bg_color_value = 'var(--clr-accent-3)' %}
        {% elsif bg_color == 'accent-4' %}
          {% assign bg_color_value = 'var(--clr-accent-4)' %}
        {% elsif bg_color == 'accent-5' %}
          {% assign bg_color_value = 'var(--clr-accent-5)' %}
        {% elsif bg_color == 'accent-6' %}
          {% assign bg_color_value = 'var(--clr-accent-6)' %}
        {% elsif bg_color == 'accent-7' %}
          {% assign bg_color_value = 'var(--clr-accent-7)' %}
        {% elsif bg_color == 'brand-dark' %}
          {% assign bg_color_value = 'var(--clr-brand-dark)' %}
        {% elsif bg_color == 'brand-light' %}
          {% assign bg_color_value = 'var(--clr-brand-light)' %}
        {% elsif bg_color == 'brand-accent' %}
          {% assign bg_color_value = 'var(--clr-brand-accent)' %}
        {% elsif bg_color == 'brand-alt' %}
          {% assign bg_color_value = 'var(--clr-brand-alt)' %}
        {% elsif bg_color == 'accent-warm' %}
          {% assign bg_color_value = 'var(--clr-bg-accent-warm)' %}
        {% elsif bg_color == 'accent-dark' %}
