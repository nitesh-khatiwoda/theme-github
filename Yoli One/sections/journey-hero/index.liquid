                    src="{{ block.settings.content_image | image_url }}"
                    alt="{{ block.settings.content_image.alt | default: block.settings.heading | strip_html | truncate: 120 }}"
                    class="journey-hero__image"
                    style="object-fit: {{ image_fit }}; border-radius: {{ img_radius }};"
                    loading="lazy"
