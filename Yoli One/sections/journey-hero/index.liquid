        {% assign has_image = false %}
        {% assign has_color = false %}
        {% if block.settings.container_background_image %} {% assign has_image = true %} {% endif %}
        {% if bg_color_value != blank %} {% assign has_color = true %} {% endif %}
        
        {% assign background_priority = block.settings.background_priority | default: 'auto' %}
        
        {% assign show_image = false %}
        {% assign show_color = false %}
        
        {% if background_priority == 'image' and has_image %}
          {% assign show_image = true %}
        {% elsif background_priority == 'color' and has_color %}
          {% assign show_color = true %}
        {% elsif background_priority == 'auto' %}
          {% if has_image %}
            {% assign show_image = true %}
          {% elsif has_color %}
            {% assign show_color = true %}
          {% endif %}
        {% endif %}
        
