<link rel="stylesheet" href="{{ 'featured-testimonial-carousel/styles.css' | asset_url }}">

<!-- Featured Testimonial Carousel -->
<section class="featured-testimonial {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="featured-test-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="featured-testimonial-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="featured-test-wrapper {% if section.settings.flip_layout %}featured-test-wrapper--flipped{% endif %}">
      
        <!-- Heading (Left) -->
        <div class="featured-heading">
          {% if section.settings.heading != blank %}
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-white' }} leading-heading">
            {{ section.settings.heading }}
          </h2>
          {% endif %}
        </div>
        
        <!-- Carousel -->
        <div class="featured-carousel">
          <div class="carousel-track" data-featured-track>
            {% for block in section.blocks %}
              <div class="testimonial-slide" {{ block.fluid_attributes }}>
                
                <!-- Quote Text -->
                <div class="quote-text-wrapper">
                  {% if block.settings.quote != blank %}
                  <p class="quote-text {{ block.settings.quote_font_family | default: 'font-body' }} {{ block.settings.quote_font_size | default: 'text-xl' }} {{ block.settings.quote_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.quote_font_weight | default: 'font-normal' }} {{ block.settings.quote_color | default: 'text-white' }} leading-body">
                    "{{ block.settings.quote }}"
                  </p>
                  {% endif %}
                </div>
                
                <!-- Signature -->
                <div class="signature-wrapper">
                  {% if block.settings.signature_text != blank %}
                  <p class="signature-text font-handwritten {{ block.settings.signature_font_size | default: 'text-2xl' }} {{ block.settings.signature_font_size_desktop | default: 'lg:text-3xl' }} {{ block.settings.signature_color | default: 'text-white' }}">
                    {{ block.settings.signature_text }}
                  </p>
                  {% endif %}
                </div>
                
                <!-- Author Info -->
                <div class="author-info">
                  {% if block.settings.author != blank %}
                  <span class="author-name {{ block.settings.author_font_family | default: 'font-body' }} {{ block.settings.author_font_size | default: 'text-base' }} {{ block.settings.author_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.author_font_weight | default: 'font-semibold' }} {{ block.settings.author_color | default: 'text-white' }}">{{ block.settings.author }}</span>
                  {% endif %}
                </div>
                
                <!-- Member Photo (Right) -->
                <div class="featured-testimonial .member-photo {{ section.settings.photo_border_radius | default: 'rounded-tl-none' }}">
                  {% if block.settings.photo != blank %}
                  <img src="{{ block.settings.photo | image_url: width: 1200 }}" alt="{{ block.settings.author }}" loading="lazy">
                  {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy">
                  {% endif %}
                </div>
                
              </div>
            {% endfor %}
          </div>
          
          <!-- Navigation -->
          <div class="carousel-controls">
            <button class="nav-arrow nav-arrow--prev" data-prev aria-label="Previous testimonial">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="nav-arrow nav-arrow--next" data-next aria-label="Next testimonial">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
</section>

<script>
(function() {
  const track = document.querySelector('[data-featured-track]');
  const prevBtn = document.querySelector('[data-prev]');
  const nextBtn = document.querySelector('[data-next]');
  if (!track || !prevBtn || !nextBtn) return;
  
  let currentIndex = 0;
  const slides = Array.from(track.children);
  const totalSlides = slides.length;
  
  if (totalSlides === 0) return;
  
  function goToSlide(index) {
    currentIndex = index;
    const slideWidth = slides[0].offsetWidth;
    track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
  }
  
  prevBtn.addEventListener('click', () => {
    currentIndex = currentIndex > 0 ? currentIndex - 1 : totalSlides - 1;
    goToSlide(currentIndex);
  });
  
  nextBtn.addEventListener('click', () => {
    currentIndex = currentIndex < totalSlides - 1 ? currentIndex + 1 : 0;
    goToSlide(currentIndex);
  });
  
  // Responsive resize
  window.addEventListener('resize', () => {
    goToSlide(currentIndex);
  });
})();
</script>

