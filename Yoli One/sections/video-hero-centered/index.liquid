<link rel="stylesheet" href="{{ 'video-hero-centered/styles.css' | asset_url }}">

<section 
  class="video-hero-centered {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="video-hero-centered-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  {% if section.settings.overlay_enabled %}
  <div class="video-overlay" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.5 }});"></div>
  {% endif %}
  
  <div class="container">
    <div class="video-hero-centered-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="video-wrapper" style="max-width: {{ section.settings.video_max_width | default: 1088 }}px; margin: 0 auto;">
        
        <div class="video-container {{ section.settings.video_border_radius | default: 'rounded-lg' }}" style="border: {{ section.settings.video_border_width | default: 2 }}px solid {{ section.settings.video_border_color | default: '#e5ac40' }};">
          {% if section.settings.video_thumbnail != blank %}
          <img 
            src="{{ section.settings.video_thumbnail | image_url: width: 1200 }}" 
            alt="{{ section.settings.video_alt | default: 'Video thumbnail' }}"
            class="video-thumbnail"
            loading="lazy">
          {% else %}
          <img 
            src="{{ 'placeholder-image.png' | asset_url }}" 
            alt="Video thumbnail placeholder"
            class="video-thumbnail"
            loading="lazy">
          {% endif %}
          
          {% if section.settings.show_play_button %}
          <div class="play-button-wrapper">
            <button class="play-button" type="button" aria-label="Play video">
              <svg width="75" height="75" viewBox="0 0 75 75" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="37.5" cy="37.5" r="37.5" fill="white" fill-opacity="0.9"/>
                <path d="M30 25L50 37.5L30 50V25Z" fill="currentColor"/>
              </svg>
            </button>
          </div>
          {% endif %}
        </div>
        
        {% if section.settings.video_title != blank %}
        <div class="video-title-wrapper">
          <h3 class="video-title {{ section.settings.title_font_family | default: 'font-body' }} {{ section.settings.title_font_size | default: 'text-lg' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-white' }}">
            {{ section.settings.video_title }}
          </h3>
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</section>

