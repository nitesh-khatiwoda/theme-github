<link rel="stylesheet" href="{{ 'product-selector-cards/styles.css' | asset_url }}">

<script>
// Product Selector Cards - Hover Image Swap
document.addEventListener('DOMContentLoaded', function() {
  const cards = document.querySelectorAll('.product-selector-cards__card');
  
  cards.forEach(card => {
    const imageWrapper = card.querySelector('.product-selector-cards__image-wrapper');
    
    if (imageWrapper && imageWrapper.dataset.hoverImage) {
      const defaultImage = imageWrapper.style.backgroundImage;
      const hoverImage = `url('${imageWrapper.dataset.hoverImage}')`;
      
      card.addEventListener('mouseenter', () => {
        imageWrapper.style.backgroundImage = hoverImage;
      });
      
      card.addEventListener('mouseleave', () => {
        imageWrapper.style.backgroundImage = defaultImage;
      });
    }
  });
});
</script>

<!-- Product Selector Cards Section -->
<section class="product-selector-cards {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="product-selector-cards__inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Heading Section -->
      {% if section.settings.heading != blank %}
        <div class="product-selector-cards__heading-wrapper {{ section.settings.heading_background | default: '' }}">
          <h2 class="product-selector-cards__heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-primary' }}">
            {{ section.settings.heading }}
          </h2>
        </div>
      {% endif %}
      
      <!-- Product Cards Grid -->
      {% assign product_blocks = section.blocks | where: 'type', 'product' %}
      {% if product_blocks.size > 0 %}
        <div class="product-selector-cards__grid {{ section.settings.cards_background | default: '' }}">
          {% for block in product_blocks %}
            <a href="{{ block.settings.product_url | default: '#' }}" 
               class="product-selector-cards__card"
               {{ block.fluid_attributes }}>
              
              <!-- Card Content Wrapper -->
              <div class="product-selector-cards__card-inner">
                
                <!-- Top Text Section -->
                <div class="product-selector-cards__text-section">
                  {% if block.settings.product_title != blank %}
                    <h3 class="product-selector-cards__product-title {{ section.settings.product_title_font_family | default: 'font-primary' }} {{ section.settings.product_title_font_size | default: 'text-lg' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }} {{ section.settings.product_title_color | default: 'text-primary' }}">
                      {{ block.settings.product_title }}
                    </h3>
                  {% endif %}
                  
                  {% if block.settings.product_description != blank %}
                    <p class="product-selector-cards__product-description {{ section.settings.product_description_font_family | default: 'font-body' }} {{ section.settings.product_description_font_size | default: 'text-sm' }} {{ section.settings.product_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_description_font_weight | default: 'font-normal' }} {{ section.settings.product_description_color | default: 'text-primary' }}">
                      {{ block.settings.product_description }}
                    </p>
                  {% endif %}
                </div>
                
                <!-- Product Image Background -->
                <div class="product-selector-cards__image-wrapper"
                     {% if block.settings.product_image != blank %}
                       style="background-image: url('{{ block.settings.product_image | image_url: width: 600 }}');"
                       data-hover-image="{% if block.settings.product_image_hover != blank %}{{ block.settings.product_image_hover | image_url: width: 600 }}{% endif %}"
                     {% else %}
                       style="background-image: url('{{ 'placeholder-image.png' | asset_url }}');"
                     {% endif %}>
                </div>
                
                <!-- Shop Now Button -->
                <div class="product-selector-cards__button-wrapper">
                  <span class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'info' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded' }}">
                    {{ section.settings.button_text | default: 'Shop Now' }}
                  </span>
                </div>
                
              </div>
              
            </a>
          {% endfor %}
        </div>
      {% endif %}
      
    </div>
  </div>
</section>

