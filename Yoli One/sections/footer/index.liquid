<!-- Footer Section -->
<footer class="site-footer {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.text_color | default: 'text-white' }} {{ section.settings.padding_y_mobile | default: 'py-2xl' }} {{ section.settings.padding_y_desktop | default: 'lg:py-3xl' }}" id="footer-{{ section.id }}">
  <div class="container">
    
    <!-- Footer Logo -->
    {% if section.settings.show_logo %}
    <div class="footer-logo mb-2xl">
      {% if section.settings.footer_logo != blank %}
        <img 
          src="{{ section.settings.footer_logo | image_url: width: 300 }}" 
          alt="{{ shop.name }}"
          class="footer-logo-image"
          width="{{ section.settings.logo_width | default: 140 }}"
          height="auto"
          loading="lazy">
      {% else %}
        <span class="{{ section.settings.logo_font_size | default: 'text-2xl' }} {{ section.settings.logo_font_weight | default: 'font-bold' }}">
          {{ shop.name | default: 'Lorem' }}
        </span>
      {% endif %}
    </div>
    {% endif %}
    
    <!-- Footer Navigation -->
    <div class="footer-nav-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-xl lg:gap-2xl mb-2xl">
      
      <!-- Shop Slapp Column -->
      {% if section.settings.show_shop_menu %}
      <div class="footer-column">
        <h3 class="{{ section.settings.heading_font_size | default: 'text-lg' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} mb-md leading-heading">
          {{ section.settings.shop_menu_title | default: 'Shop Slapp' }}
        </h3>
        <ul class="footer-links space-y-sm">
          {% for link in linklists[section.settings.shop_menu].links %}
            <li>
              <a href="{{ link.url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      
      <!-- About Column -->
      {% if section.settings.show_about_menu %}
      <div class="footer-column">
        <h3 class="{{ section.settings.heading_font_size | default: 'text-lg' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} mb-md leading-heading">
          {{ section.settings.about_menu_title | default: 'About Slapp' }}
        </h3>
        <ul class="footer-links space-y-sm">
          {% for link in linklists[section.settings.about_menu].links %}
            <li>
              <a href="{{ link.url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      
      <!-- Policies Column -->
      {% if section.settings.show_policies %}
      <div class="footer-column">
        <h3 class="{{ section.settings.heading_font_size | default: 'text-lg' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} mb-md leading-heading">
          {{ section.settings.policies_title | default: 'Policies' }}
        </h3>
        <ul class="footer-links space-y-sm">
          <li>
            <a href="{{ routes.privacy_policy_url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="{{ routes.refund_policy_url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
              Refund Policy
            </a>
          </li>
          <li>
            <a href="{{ routes.shipping_policy_url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
              Shipping Policy
            </a>
          </li>
          <li>
            <a href="{{ routes.terms_of_service_url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
              Terms of Service
            </a>
          </li>
        </ul>
      </div>
      {% endif %}
      
      <!-- Support Column -->
      {% if section.settings.show_support_menu %}
      <div class="footer-column">
        <h3 class="{{ section.settings.heading_font_size | default: 'text-lg' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} mb-md leading-heading">
          {{ section.settings.support_title | default: 'Support & Info' }}
        </h3>
        <ul class="footer-links space-y-sm">
          {% for link in linklists[section.settings.support_menu].links %}
            <li>
              <a href="{{ link.url }}" class="{{ section.settings.link_font_size | default: 'text-base' }} hover:opacity-70 transition-opacity">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      
    </div>
    
    <!-- Social Media Icons -->
    {% if section.settings.show_social %}
    <div class="footer-social flex justify-center gap-md mb-xl">
      {% if section.settings.social_facebook != blank %}
        <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" class="social-link text-2xl hover:opacity-70 transition-opacity">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      {% endif %}
      {% if section.settings.social_instagram != blank %}
        <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" class="social-link text-2xl hover:opacity-70 transition-opacity">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      {% endif %}
      {% if section.settings.social_twitter != blank %}
        <a href="{{ section.settings.social_twitter }}" aria-label="Twitter" class="social-link text-2xl hover:opacity-70 transition-opacity">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>
      {% endif %}
    </div>
    {% endif %}
    
    <!-- Copyright -->
    <div class="footer-copyright text-center {{ section.settings.copyright_font_size | default: 'text-sm' }} opacity-70 pt-xl border-t border-white border-opacity-20">
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Lorem' }}. All Rights Reserved.</p>
    </div>
    
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Footer Logo"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show Logo",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 140
    },
    {
      "type": "select",
      "id": "logo_font_size",
      "label": "Text Logo Size",
      "options": [
        { "value": "text-xl", "label": "Extra Large" },
        { "value": "text-2xl", "label": "2X Large" },
        { "value": "text-3xl", "label": "3X Large" }
      ],
      "default": "text-2xl"
    },
    {
      "type": "select",
      "id": "logo_font_weight",
      "label": "Text Logo Weight",
      "options": [
        { "value": "font-semibold", "label": "Semibold" }
      ],
      "default": "font-semibold"
    },
    {
      "type": "header",
      "content": "Shop Menu"
    },
    {
      "type": "checkbox",
      "id": "show_shop_menu",
      "label": "Show Shop Menu",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_menu_title",
      "label": "Shop Menu Title",
      "default": "Shop Slapp"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop Menu",
      "default": "shop-menu"
    },
    {
      "type": "header",
      "content": "About Menu"
    },
    {
      "type": "checkbox",
      "id": "show_about_menu",
      "label": "Show About Menu",
      "default": true
    },
    {
      "type": "text",
      "id": "about_menu_title",
      "label": "About Menu Title",
      "default": "About Slapp"
    },
    {
      "type": "link_list",
      "id": "about_menu",
      "label": "About Menu"
    },
    {
      "type": "header",
      "content": "Policies"
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "Show Policies",
      "default": true
    },
    {
      "type": "text",
      "id": "policies_title",
      "label": "Policies Title",
      "default": "Policies"
    },
    {
      "type": "header",
      "content": "Support Menu"
    },
    {
      "type": "checkbox",
      "id": "show_support_menu",
      "label": "Show Support Menu",
      "default": true
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Support Menu Title",
      "default": "Support & Info"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Support Menu"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Media Links",
      "default": true
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "options": [
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "text-xl", "label": "Extra Large" }
      ],
      "default": "text-lg"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semibold" }
      ],
      "default": "font-semibold"
    },
    {
      "type": "select",
      "id": "link_font_size",
      "label": "Link Font Size",
      "options": [
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" }
      ],
      "default": "text-base"
    },
    {
      "type": "select",
      "id": "copyright_font_size",
      "label": "Copyright Font Size",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" }
      ],
      "default": "text-sm"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        { "value": "bg-black", "label": "Black" },
        { "value": "bg-primary", "label": "Primary Text" },
        { "value": "bg-neutral-dark", "label": "Neutral Dark" }
      ],
      "default": "bg-black"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "text-white", "label": "White" },
        { "value": "text-neutral-light", "label": "Neutral Light" }
      ],
      "default": "text-white"
    },
    {
      "type": "select",
      "id": "padding_y_mobile",
      "label": "Vertical Padding (Mobile)",
      "options": [
        { "value": "py-xl", "label": "Extra Large" },
        { "value": "py-2xl", "label": "2X Large" },
        { "value": "py-3xl", "label": "3X Large" }
      ],
      "default": "py-2xl"
    },
    {
      "type": "select",
      "id": "padding_y_desktop",
      "label": "Vertical Padding (Desktop)",
      "options": [
        { "value": "lg:py-2xl", "label": "2X Large" },
        { "value": "lg:py-3xl", "label": "3X Large" },
        { "value": "lg:py-4xl", "label": "4X Large" }
      ],
      "default": "lg:py-3xl"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}

