<link rel="stylesheet" href="{{ 'product-showcase-grid-hydrated/styles.css' | asset_url }}">

<!-- Product Showcase Grid Hydrated Section -->
<section class="product-showcase-grid {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-3xl' }}" id="product-showcase-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-showcase-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading (Optional) -->
      {% if section.settings.heading != blank %}
      <div class="section-heading mb-xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading text-center leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Product Grid -->
      {%- assign collection_name = section.settings.selected_collection | downcase | strip -%}
      {%- assign current_collection = null -%}
      {%- assign found_collection = false -%}
      
      {%- for c in collections -%}
        {%- if c.title | downcase | strip == collection_name -%}
          {%- assign current_collection = c -%}
          {%- assign found_collection = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      
      {%- if current_collection and current_collection.products.size > 0 -%}
        <div class="showcase-grid">
          {%- for product in current_collection.products limit: section.settings.products_limit -%}
            
            <a href="{{ product.url | default: '#' }}" class="product-card {{ section.settings.card_background | default: 'bg-secondary-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
              
              <!-- Product Image Container -->
              <div class="product-image-wrapper">
                <div class="product-image" data-hover-enabled="{% if product.images[1].src != blank %}true{% else %}false{% endif %}">
                  {% if product.images.first.src != blank %}
                    <img src="{{ product.images.first.src | image_url: width: 400 }}" 
                         alt="{{ product.title | default: 'Product' }}" 
                         loading="lazy"
                         class="product-image-default"
                         data-default-src="{{ product.images.first.src | image_url: width: 400 }}"
                         {% if product.images[1].src != blank %}
                         data-hover-src="{{ product.images[1].src | image_url: width: 400 }}"
                         {% endif %}>
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy" class="product-image-default">
                  {% endif %}
                </div>
                
                <!-- New Badge (Optional) -->
                {%- if section.settings.show_new_badge and forloop.first -%}
                <div class="new-badge {{ section.settings.badge_background_color | default: 'bg-neutral-dark' }}">
                  <span class="{{ section.settings.badge_text_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-white' }}">
                    {{ section.settings.badge_text | default: 'New' }}
                  </span>
                </div>
                {%- endif -%}
              </div>
              
              <!-- Product Content -->
              <div class="product-content">
                
                <!-- Product Info -->
                <div class="product-info">
                  
                  <!-- Product Name -->
                  <div class="product-name">
                    <h3 class="{{ section.settings.name_font_family | default: 'font-primary' }} {{ section.settings.name_font_size | default: 'text-xl' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.name_font_weight | default: 'font-semibold' }} {{ section.settings.name_color | default: 'text-primary' }} leading-heading">
                      {{ product.title | default: 'Product' }}
                    </h3>
                  </div>
                  
                  <!-- Product Description -->
                  {%- if section.settings.show_descriptions and product.short_description != blank -%}
                  <div class="product-description">
                    <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
                      {{ product.short_description }}
                    </p>
                  </div>
                  {%- endif -%}
                </div>
                
                <!-- Price Section -->
                <div class="product-pricing">
                  
                  <!-- Bundle Badge (Optional) - You can customize this based on product tags -->
                  {%- if product.tags contains 'bundle' and section.settings.show_bundle_badge -%}
                  <div class="bundle-badge {{ section.settings.bundle_badge_color | default: 'bg-success' }}">
                    <span class="{{ section.settings.bundle_badge_font_size | default: 'text-xs' }} {{ section.settings.bundle_badge_text_color | default: 'text-primary' }}">
                      {{ section.settings.bundle_badge_text | default: 'Bundle + Save 25%' }}
                    </span>
                  </div>
                  {%- endif -%}
                  
                  <!-- Price Display -->
                  <div class="price-wrapper">
                    <span class="current-price {{ section.settings.price_font_family | default: 'font-primary' }} {{ section.settings.price_font_size | default: 'text-lg' }} {{ section.settings.price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.price_font_weight | default: 'font-normal' }} {{ section.settings.price_color | default: 'text-primary' }}">
                      {{ product.price | default: '$0.00' }}
                    </span>
                    
                    <!-- Original Price (Optional) -->
                    {%- if section.settings.show_original_price and product.compare_at_price -%}
                    <span class="original-price {{ section.settings.original_price_font_size | default: 'text-base' }} {{ section.settings.original_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.original_price_color | default: 'text-neutral' }}">
                      {{ product.compare_at_price }}
                    </span>
                    {%- endif -%}
                  </div>
                </div>
                
                <!-- CTAs -->
                <div class="product-ctas">
                  <!-- Primary CTA (Learn More) -->
                  {%- if section.settings.show_primary_button -%}
                  <span class="btn btn-{{ section.settings.primary_button_style | default: 'filled' }}-{{ section.settings.primary_button_color | default: 'primary' }} {{ section.settings.primary_button_size | default: 'btn-md' }}">
                    {{ section.settings.primary_button_text | default: 'Learn More' }}
                  </span>
                  {%- endif -%}
                  
                  <!-- Secondary CTA (Add to Cart) -->
                  {%- if section.settings.show_secondary_link -%}
                  <span class="secondary-link {{ section.settings.secondary_link_font_size | default: 'text-base' }} {{ section.settings.secondary_link_color | default: 'text-primary' }}">
                    {{ section.settings.secondary_link_text | default: 'Add to Cart' }}
                  </span>
                  {%- endif -%}
                </div>
                
              </div>
              
            </a>
            
          {%- endfor -%}
        </div>
      {%- elsif current_collection and current_collection.products.size == 0 -%}
        <!-- No products in collection -->
        <div class="showcase-grid">
          <div class="product-card {{ section.settings.card_background | default: 'bg-secondary-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
            <div class="product-image-wrapper">
              <div class="product-image">
                <img src="{{ 'placeholder-image.png' | asset_url }}" alt="No products" loading="lazy" class="product-image-default">
              </div>
            </div>
            <div class="product-content">
              <div class="product-info">
                <div class="product-name">
                  <h3 class="{{ section.settings.name_font_family | default: 'font-primary' }} {{ section.settings.name_font_size | default: 'text-xl' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.name_font_weight | default: 'font-semibold' }} {{ section.settings.name_color | default: 'text-primary' }} leading-heading">
                    No products found in this collection
                  </h3>
                </div>
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <!-- Collection not found -->
        <div class="showcase-grid">
          <div class="product-card {{ section.settings.card_background | default: 'bg-secondary-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
            <div class="product-image-wrapper">
              <div class="product-image">
                <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Collection not found" loading="lazy" class="product-image-default">
              </div>
            </div>
            <div class="product-content">
              <div class="product-info">
                <div class="product-name">
                  <h3 class="{{ section.settings.name_font_family | default: 'font-primary' }} {{ section.settings.name_font_size | default: 'text-xl' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.name_font_weight | default: 'font-semibold' }} {{ section.settings.name_color | default: 'text-primary' }} leading-heading">
                    Collection "{{ section.settings.selected_collection }}" not found
                  </h3>
                </div>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
      
    </div>
  </div>
  
</section>

<script>
// Product Showcase Grid Hydrated - Hover Image Swap
document.addEventListener('DOMContentLoaded', function() {
  const productImages = document.querySelectorAll('.product-showcase-grid .product-image[data-hover-enabled="true"] img[data-hover-src]');

  productImages.forEach(img => {
    const defaultSrc = img.getAttribute('data-default-src');
    const hoverSrc = img.getAttribute('data-hover-src');

    if (hoverSrc) {
      const productCard = img.closest('.product-card');
      
      productCard.addEventListener('mouseenter', () => {
        img.src = hoverSrc;
      });

      productCard.addEventListener('mouseleave', () => {
        img.src = defaultSrc;
      });
    }
  });
});
</script>

