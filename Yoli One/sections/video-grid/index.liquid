<script>
  document.addEventListener('DOMContentLoaded', function () {

  
    // SETTINGS
    const pageSize = 8;          // items per page
    const maxPageButtons = 8;    // how many page number buttons to show

    const $items = $(".videos-grid .video-card");
    const totalItems = $items.length;
    const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
    let currentPage = 1;
    function buildPageButtons() {
      const $pages = $("#pagination .pages").empty();

      // windowed paging: show maxPageButtons around current page
      let start = Math.max(1, currentPage - Math.floor(maxPageButtons / 2));
      let end = start + maxPageButtons - 1;

      if (end > totalPages) {
        end = totalPages;
        start = Math.max(1, end - maxPageButtons + 1);
      }

      // optional: first + ellipsis
      if (start > 1) {
        $pages.append(`<button type="button" class="page-btn" data-page="1">1</button>`);
        if (start > 2) $pages.append(`<span class="dots">…</span>`);
      }

      for (let p = start; p <= end; p++) {
        $pages.append(`<button type="button" class="page-btn" data-page="${p}">${p}</button>`);
      }

      // optional: ellipsis + last
      if (end < totalPages) {
        if (end < totalPages - 1) $pages.append(`<span class="dots">…</span>`);
        $pages.append(`<button type="button" class="page-btn" data-page="${totalPages}">${totalPages}</button>`);
      }

      // highlight active
      $pages.find(`button[data-page="${currentPage}"]`).addClass("active");
    }

    function renderPage(page) {
      page = Math.max(1, Math.min(totalPages, page));
      currentPage = page;

      const startIndex = (currentPage - 1) * pageSize;
      const endIndex = Math.min(startIndex + pageSize, totalItems);

      $items.hide().slice(startIndex, endIndex).show();

      $("#pagination .prev").prop("disabled", currentPage === 1);
      $("#pagination .next").prop("disabled", currentPage === totalPages);

     
      buildPageButtons();
    }
    // EVENTS
    
    $(document).on("click", ".page-btn", function () {
      renderPage(Number($(this).data("page")));
      document.getElementById("video-target").scrollIntoView({ 
         behavior: "smooth" 
       });
    });

    $("#pagination .prev").on("click", function () {
      renderPage(currentPage - 1);
      document.getElementById("video-target").scrollIntoView({ 
         behavior: "smooth" 
       });
    });

    $("#pagination .next").on("click", function (e) {
       e.preventDefault(); 
        renderPage(currentPage + 1);
       document.getElementById("video-target").scrollIntoView({ 
         behavior: "smooth" 
       });
    });


    // INIT
    renderPage(1);
   });
</script>