<link rel="stylesheet" href="{{ 'video-grid/styles.css' | asset_url }}">


<!-- Video Grid Section -->
<div id="video-target"></div>
<section  class="video-grid {{ section.settings.background_color | default: 'bg-neutral-light' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="video-grid-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="video-grid-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading (Optional) -->
      {% if section.settings.heading != blank %}
      <div class="section-heading mb-xl lg:mb-2xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }}">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
    
      
      <!-- Video Grid -->
      {% if section.blocks.size > 0 %}
        <div class="videos-grid">
        {% for block in section.blocks %}
          {% if block.type == 'video_card' %}
          
          <div {% if block.settings.video_url != blank %}data-video-url="{{ block.settings.video_url }}"{% endif %} 
             class="video-card {{ section.settings.card_background | default: 'bg-white' }} {{ section.settings.card_border_radius | default: 'rounded' }} {% if block.settings.video_url != blank %}cursor-pointer{% endif %}" 
             {{ block.fluid_attributes }}
             role="button"
             tabindex="0"
             aria-label="Play video: {{ block.settings.video_title | default: block.settings.speaker_name | default: 'Video' }}">
            
            <!-- Video Thumbnail -->
            <div class="video-thumbnail-wrapper">
              <div class="video-thumbnail {{ section.settings.card_border_radius | default: 'rounded' }}" {% if section.settings.show_thumbnail_border %}style="border: 2px solid {{ section.settings.thumbnail_border_color | default: '#e5ac40' }};"{% endif %}>
                {% if block.settings.video_thumbnail != blank %}
                  <img src="{{ block.settings.video_thumbnail | image_url: width: 800 }}" 
                       alt="{{ block.settings.video_title | default: block.settings.speaker_name | default: 'Video thumbnail' }}" 
                       loading="lazy"
                       class="thumbnail-image">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Video thumbnail placeholder" loading="lazy" class="thumbnail-image">
                {% endif %}
                
                <!-- Play Button Overlay -->
                {% if block.settings.video_url != blank %}
                <div class="play-button-overlay">
                  <div class="play-button">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="48" height="48">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
                {% endif %}
              </div>
            </div>
            
            <!-- Video Content -->
            <div class="video-content">
              
              <!-- Speaker Name -->
              {% if block.settings.speaker_name != blank %}
              <div class="speaker-name mb-sm">
                <h3 class="{{ section.settings.name_font_family | default: 'font-serif' }} {{ section.settings.name_font_size | default: 'text-2xl' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.name_font_weight | default: 'font-normal' }} {{ section.settings.name_color | default: 'text-neutral-dark' }}">
                  {{ block.settings.speaker_name }}
                </h3>
              </div>
              {% endif %}
              
              <!-- Video Title -->
              {% if block.settings.video_title != blank %}
              <div class="video-title mb-sm">
                <p class="{{ section.settings.title_font_family | default: 'font-body' }} {{ section.settings.title_font_size | default: 'text-lg' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-neutral-dark' }}">
                  {{ block.settings.video_title }}
                </p>
              </div>
              {% endif %}
              
              <!-- Video Date -->
              {% if block.settings.video_date != blank %}
              <div class="video-date">
                <p class="{{ section.settings.date_font_family | default: 'font-body' }} {{ section.settings.date_font_size | default: 'text-base' }} {{ section.settings.date_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.date_font_weight | default: 'font-normal' }} {{ section.settings.date_color | default: 'text-neutral' }}">
                  {{ block.settings.video_date }}
                </p>
              </div>
              {% endif %}
              
            </div>
            
          </div>
          
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}

      <!-- Video Modal -->
      <div class="video-modal" id="video-modal-{{ section.id }}" aria-hidden="true">
        <div class="video-modal-overlay"></div>
        <div class="video-modal-container">
          <button class="video-modal-close" aria-label="Close video">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
          <div class="video-modal-content">
            <div class="video-modal-iframe-wrapper">
              <iframe 
                class="video-modal-iframe"
                src="" 
                frameborder="0" 
                allow="autoplay; fullscreen; picture-in-picture" 
                allowfullscreen>
              </iframe>
            </div>
          </div>
        </div>
      </div>

      <!-- Pagination -->
      {% if section.blocks.size > 8 %}
        <div id="pagination" class="video-pagination-section">
          <div class="video-pagination">
            <button class="prev page-nav-btn">Prev</button>
            <div class="pages"></div>
            <button class="next page-nav-btn">Next</button>
          </div>
        </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

<style>
  /* Video card styles */
  .video-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .video-card[data-video-url]:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
  }
  
  /* Play button overlay */
  .video-thumbnail-wrapper {
    position: relative;
  }
  
  .video-thumbnail {
    position: relative;
    overflow: hidden;
  }
  
  .play-button-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .video-card[data-video-url]:hover .play-button-overlay {
    opacity: 1;
  }
  
  .play-button {
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
    transition: transform 0.3s ease, background 0.3s ease;
  }
  
  .play-button svg {
    margin-left: 4px; /* Optical centering for play icon */
  }
  
  .video-card[data-video-url]:hover .play-button {
    transform: scale(1.1);
    background: #fff;
  }

  /* Video Modal Styles */
  .video-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  
  .video-modal.is-open {
    opacity: 1;
    visibility: visible;
  }
  
  .video-modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    cursor: pointer;
  }
  
  .video-modal-container {
    position: relative;
    width: 90%;
    max-width: 1000px;
    z-index: 1;
  }
  
  .video-modal-close {
    position: absolute;
    top: -50px;
    right: 0;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, transform 0.3s ease;
  }
  
  .video-modal-close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
  }
  
  .video-modal-content {
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }
  
  .video-modal-iframe-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
  }
  
  .video-modal-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  /* Prevent body scroll when modal is open */
  body.video-modal-open {
    overflow: hidden;
  }
</style>

<script>
// Video Grid functionality - animations and modal
(function() {
  const sectionId = 'video-grid-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const videosGrid = section.querySelector('.videos-grid');
  if (!videosGrid) return;
  
  const videoCards = Array.from(videosGrid.querySelectorAll('.video-card'));
  if (videoCards.length === 0) return;
  
  // Modal elements
  const modal = document.getElementById('video-modal-{{ section.id }}');
  const modalOverlay = modal.querySelector('.video-modal-overlay');
  const modalClose = modal.querySelector('.video-modal-close');
  const modalIframe = modal.querySelector('.video-modal-iframe');
  
  // Function to extract Vimeo video ID from URL
  function getVimeoId(url) {
    if (!url) return null;
    
    // Match various Vimeo URL formats
    const patterns = [
      /vimeo\.com\/(\d+)/,                    // vimeo.com/123456789
      /vimeo\.com\/video\/(\d+)/,             // vimeo.com/video/123456789
      /player\.vimeo\.com\/video\/(\d+)/,     // player.vimeo.com/video/123456789
      /vimeo\.com\/channels\/[^\/]+\/(\d+)/,  // vimeo.com/channels/channelname/123456789
      /vimeo\.com\/groups\/[^\/]+\/videos\/(\d+)/, // vimeo.com/groups/groupname/videos/123456789
      /vimeo\.com\/album\/[^\/]+\/video\/(\d+)/,   // vimeo.com/album/albumid/video/123456789
      /vimeo\.com\/(\d+)\/[a-zA-Z0-9]+/       // vimeo.com/123456789/hash (private videos)
    ];
    
    for (const pattern of patterns) {
      const match = url.match(pattern);
      if (match && match[1]) {
        return match[1];
      }
    }
    
    return null;
  }
  
  // Function to extract YouTube video ID from URL
  function getYouTubeId(url) {
    if (!url) return null;
    
    const patterns = [
      /youtube\.com\/watch\?v=([a-zA-Z0-9_-]+)/,
      /youtu\.be\/([a-zA-Z0-9_-]+)/,
      /youtube\.com\/embed\/([a-zA-Z0-9_-]+)/,
      /youtube\.com\/v\/([a-zA-Z0-9_-]+)/
    ];
    
    for (const pattern of patterns) {
      const match = url.match(pattern);
      if (match && match[1]) {
        return match[1];
      }
    }
    
    return null;
  }
  
  // Function to get embed URL
  function getEmbedUrl(url) {
    const vimeoId = getVimeoId(url);
    if (vimeoId) {
      return `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0`;
    }
    
    const youtubeId = getYouTubeId(url);
    if (youtubeId) {
      return `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`;
    }
    
    // If it's already an embed URL or direct video, return as-is
    if (url.includes('player.vimeo.com') || url.includes('youtube.com/embed')) {
      return url + (url.includes('?') ? '&' : '?') + 'autoplay=1';
    }
    
    return null;
  }
  
  // Open modal
  function openModal(videoUrl) {
    const embedUrl = getEmbedUrl(videoUrl);
    if (!embedUrl) {
      // Fallback: open in new tab if we can't embed
      window.open(videoUrl, '_blank');
      return;
    }
    
    modalIframe.src = embedUrl;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('video-modal-open');
    
    // Focus trap
    modalClose.focus();
  }
  
  // Close modal
  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('video-modal-open');
    
    // Clear iframe src to stop video
    setTimeout(() => {
      modalIframe.src = '';
    }, 300);
  }
  
  // Event listeners for video cards
  videoCards.forEach(card => {
    const videoUrl = card.dataset.videoUrl;
    if (!videoUrl) return;
    
    // Click handler
    card.addEventListener('click', (e) => {
      e.preventDefault();
      openModal(videoUrl);
    });
    
    // Keyboard handler for accessibility
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(videoUrl);
      }
    });
  });
  
  // Close modal events
  modalClose.addEventListener('click', closeModal);
  modalOverlay.addEventListener('click', closeModal);
  
  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) {
      closeModal();
    }
  });
  
  // Intersection Observer for staggered fade-in animation
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };
  
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        videoCards.forEach((card, index) => {
          setTimeout(() => {
            card.classList.add('animate-in');
          }, index * 100);
        });
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);
  
  observer.observe(section);
})();
</script>

