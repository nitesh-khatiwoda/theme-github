<link rel="stylesheet" href="{{ 'product-header-4/styles.css' | asset_url }}">

{% assign not_purchasable = product.out_of_stock || product.available_for_country != true || product.active != true %}

{% comment %} 
  Variant Selection Logic
  - Uses root-level selected_variant_id (from variables service) which resolves from option_value_ids params
  - Falls back to variant_id query param (for single-variant dropdown with no options)
  - Falls back to product.selected_or_first_available_variant.id if not available
{% endcomment %}
{% assign variants = product.variants %}
{% assign active_variants = product.variants | where: "active", true %}
{% comment %} variant_id from query params is a string; convert to int so variant.id == selected_variant_id works {% endcomment %}
{% if request.query_parameters.variant_id %}
  {% assign selected_variant_id = request.query_parameters.variant_id | plus: 0 %}
{% endif %}
{% assign selected_variant_id = selected_variant_id | default: product.selected_or_first_available_variant.id %}

{% comment %} Find the selected variant object {% endcomment %}
{% assign selected_variant = null %}
{% for variant in active_variants %}
  {% if variant.id == selected_variant_id %}
    {% assign selected_variant = variant %}
    {% break %}
  {% endif %}
{% endfor %}

{% comment %} Fallback to first active variant if not found {% endcomment %}
{% if selected_variant == null %}
  {% assign selected_variant = active_variants.first %}
  {% if selected_variant %}
    {% assign selected_variant_id = selected_variant.id %}
  {% endif %}
{% endif %}

{% comment %} Set active_variant for pricing - use variant country data if available {% endcomment %}
{% if selected_variant.variant_countries.first %}
  {% assign active_variant = selected_variant.variant_countries.first %}
{% else %}
  {% assign active_variant = product %}
{% endif %}

<!-- Product Header 4 Section -->
<section class="product-header-4 product-details-section {{ section.settings.background_color | default: 'bg-white' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="product-header-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{ section.settings.container_layout_width | default: 'container' }}">
    <div class="product-header-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-md' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      <div class="product-layout">
        
        <!-- Left Column: Media Gallery -->
        {% if section.settings.show_media_gallery %}
        <div class="media-column">
    
          <!-- Thumbnail Carousel -->
          <div class="thumbnail-carousel-wrapper {% if section.settings.gallery_layout == 'left' %}gallery-layout-left{% endif %} thumbnail-size-{{ section.settings.thumbnail_size | default: 'small' }}" id="carousel-{{ section.id }}">
            <!-- Thumbnails (shown first when layout is left) -->
            {% if section.settings.gallery_layout == 'left' %}
            <div class="carousel-thumbnails-wrapper carousel-thumbnails-wrapper-vertical">
              <div class="carousel-thumbnails-container carousel-thumbnails-left" id="carousel-thumbnails-{{ section.id }}">
                <div class="carousel-thumbnails-track carousel-thumbnails-vertical" style="gap: {{ section.settings.thumbnail_gap | default: '2' }}px;">
                {% for image in product.images %}
                  <button class="carousel-thumbnail {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" style="cursor: pointer; border-radius: {{ section.settings.gallery_border_radius | default: '8' }}px;" aria-label="View image {{ forloop.index }}">
                    <img src="{{ image.src | img_url: '200x' }}" alt="{{ image.alt | default: product.title }}" draggable="false" style="border-radius: {{ section.settings.gallery_border_radius | default: '8' }}px;">
                  </button>
                {% endfor %}
                </div>
              </div>
              <!-- Fade gradients for vertical scroller -->
              <div class="thumbnail-fade thumbnail-fade-top"></div>
              <div class="thumbnail-fade thumbnail-fade-bottom"></div>
            </div>
            {% endif %}
            
            <!-- Main Carousel -->
            <div class="carousel-main-container" id="carousel-main-{{ section.id }}" style="border-radius: {{ section.settings.gallery_border_radius | default: '16' }}px;">
              <div class="carousel-track" id="carousel-track-{{ section.id }}">
                {% for image in product.images %}
                  <div class="carousel-slide" data-index="{{ forloop.index0 }}">
                    <img src="{{ image.src | img_url: '1200x' }}" alt="{{ image.alt | default: product.title }}" {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %} draggable="false">
                  </div>
                {% endfor %}
              </div>
              
              <!-- Navigation Buttons Group -->
              <div class="results-carousel-nav-buttons {% if section.settings.arrow_position == 'sides' %}nav-position-sides{% endif %}">
                <button 
                  class="results-carousel-nav-btn results-carousel-prev bg-white text-black" 
                  id="carousel-prev-{{ section.id }}" 
                  aria-label="Previous image">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 19l-7-7 7-7"/>
                  </svg>
                </button>
                
                <button 
                  class="results-carousel-nav-btn results-carousel-next bg-white text-black" 
                  id="carousel-next-{{ section.id }}" 
                  aria-label="Next image">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </button>
              </div>
              
            </div>
            
            <!-- Thumbnails (shown below when layout is below) -->
            {% unless section.settings.gallery_layout == 'left' %}
            <div class="carousel-thumbnails-wrapper">
              <div class="carousel-thumbnails-container" id="carousel-thumbnails-{{ section.id }}">
                <div class="carousel-thumbnails-track" style="gap: {{ section.settings.thumbnail_gap | default: '2' }}px;">
                {% for image in product.images %}
                  <button class="carousel-thumbnail {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" style="cursor: pointer; border-radius: {{ section.settings.gallery_border_radius | default: '8' }}px;" aria-label="View image {{ forloop.index }}">
                    <img src="{{ image.src | img_url: '200x' }}" alt="{{ image.alt | default: product.title }}" draggable="false" style="border-radius: {{ section.settings.gallery_border_radius | default: '8' }}px;">
                  </button>
                {% endfor %}
                </div>
              </div>
              <!-- Fade gradients -->
              <div class="thumbnail-fade thumbnail-fade-left"></div>
              <div class="thumbnail-fade thumbnail-fade-right"></div>
            </div>
            {% endunless %}
          </div>
          
          <!-- Hover Zoom Panel (Amazon-style) - positioned outside carousel to avoid overflow:hidden -->
          {% if section.settings.zoom_lens_liquid_glass %}
          <!-- SVG Filter for Liquid Glass Effect -->
          <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position: absolute; overflow: hidden;">
            <defs>
              <filter id="liquid-glass-distortion-{{ section.id }}" x="0%" y="0%" width="100%" height="100%">
                <feTurbulence type="fractalNoise" baseFrequency="0.008 0.008" numOctaves="1" seed="42" result="noise"></feTurbulence>
                <feGaussianBlur in="noise" stdDeviation="4" result="blurred"></feGaussianBlur>
                <feDisplacementMap in="SourceGraphic" in2="blurred" scale="12" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap>
              </filter>
            </defs>
          </svg>
          {% endif %}
          <div class="carousel-zoom-lens {% if section.settings.zoom_lens_liquid_glass %}liquid-glass{% endif %}" id="zoom-lens-{{ section.id }}" {% if section.settings.zoom_lens_liquid_glass %}style="--liquid-filter: url(#liquid-glass-distortion-{{ section.id }});"{% endif %}></div>
          <div class="carousel-zoom-panel" id="zoom-panel-{{ section.id }}"></div>
          
        </div>
        {% endif %}
        
        <!-- Right Column: Product Info (Sticky) -->
        <div class="info-column">
          <div class="info-sticky">
              
            
            <!-- Product Image and Title Row -->
            <div class="product-image-title-row">
              <!-- Product Image (Left) -->
              {% if section.settings.show_right_column_image and product.images.first %}
              {% assign image_width = section.settings.right_column_image_width | default: 80 %}
              {% assign image_height = section.settings.right_column_image_height | default: 80 %}
              {% assign br_tl = section.settings.right_column_image_border_radius_top_left | default: 'rounded-lg' %}
              {% assign br_tr = section.settings.right_column_image_border_radius_top_right | default: 'rounded-lg' %}
              {% assign br_bl = section.settings.right_column_image_border_radius_bottom_left | default: 'rounded-lg' %}
              {% assign br_br = section.settings.right_column_image_border_radius_bottom_right | default: 'rounded-lg' %}
              {% assign border_width = section.settings.right_column_image_border_width | default: 0 %}
              {% assign border_color = section.settings.right_column_image_border_color | default: 'border-neutral' %}
              {% assign object_fit = section.settings.right_column_image_object_fit | default: 'cover' %}
              
              <div class="right-column-product-image {{ border_color }}" style="width: {{ image_width }}px; height: {{ image_height }}px; border-width: {{ border_width }}px;">
                <div class="right-column-product-image-inner" 
                     data-br-tl="{{ br_tl }}"
                     data-br-tr="{{ br_tr }}"
                     data-br-bl="{{ br_bl }}"
                     data-br-br="{{ br_br }}">
                  <img 
                    src="{{ product.images.first.src | img_url: '400x' }}" 
                    alt="{{ product.images.first.alt | default: product.title }}" 
                    loading="lazy"
                    class="right-column-product-img"
                    style="object-fit: {{ object_fit }}; box-shadow: none !important;"
                  >
                </div>
              </div>
              {% endif %}
              
              <!-- Title and Rating Group (Right) -->
              <div class="product-title-rating-group">
                
                <!-- Product Title with Code -->
                {% if section.settings.show_product_code or section.settings.show_product_title or section.settings.show_new_badge %}
                <div class="product-title-wrapper">
                  {% if section.settings.show_product_code and section.settings.product_code != blank %}
                  <div class="product-code-badge">
                    <span class="{{ section.settings.code_font_size | default: 'text-base' }} {{ section.settings.code_color | default: 'text-primary' }}">
                      {{ section.settings.product_code }}<sup>{{ section.settings.code_superscript | default: '™' }}</sup>
                    </span>
                  </div>
                  {% endif %}
                  
                  {% if section.settings.show_product_title %}
                  <h1 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-primary' }} leading-heading">
                    {{ product.title }}
                  </h1>
                  {% endif %}
                  
                  {% if section.settings.show_new_badge %}
                  <span class="new-badge {{ section.settings.badge_background_color | default: 'bg-accent-warm' }}">
                    <span class="{{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-primary' }}">
                      {{ section.settings.badge_text | default: 'New' }}
                    </span>
                  </span>
                  {% endif %}
                </div>
                {% endif %}
                <!-- Selling Points Headline -->
                {% if section.settings.show_selling_points_headline and section.settings.selling_points_headline != blank %}
                  <span class="{{ section.settings.selling_points_font_family | default: 'font-body' }} {{ section.settings.selling_points_font_size | default: 'text-base' }} {{ section.settings.selling_points_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.selling_points_font_weight | default: 'font-normal' }} {{ section.settings.selling_points_color | default: 'text-primary' }} leading-body">
                    {{ section.settings.selling_points_headline }}
                  </span>
                {% endif %}
                <!-- Rating & Reviews -->
                {% if section.settings.show_rating %}
                <div class="rating-wrapper">
                  <!-- Star Rating Display -->
                  <div class="star-rating-selector" id="starRating-{{ section.id }}" data-rating="{{ section.settings.rating_value | default: '4.8' }}">
                    {% for i in (1..5) %}
                      <div class="star-container" data-star="{{ i }}">
                        <i class="fas fa-star star-icon star-full" data-value="{{ i }}"></i>
                        <i class="fas fa-star-half-alt star-icon star-half" data-value="{{ i }}.5"></i>
                        <div class="star-overlay"></div>
                      </div>
                    {% endfor %}
                    <span class="rating-text {{ section.settings.rating_color | default: 'text-primary' }}">(<span id="ratingValue-{{ section.id }}">{{ section.settings.rating_value | default: '4.8' }}</span> stars)</span>
                  {% if section.settings.show_reviews_link %}
                  <span class="rating-separator {{ section.settings.rating_color | default: 'text-primary' }}">•</span>
                  <a href="{{ section.settings.reviews_link | default: '#reviews' }}" class="reviews-link {{ section.settings.rating_color | default: 'text-primary' }}">
                    {{ section.settings.reviews_text | default: '18 Reviews' }}
                  </a>
                  </div>
                  {% endif %}
                </div>
                {% endif %}
              </div>
            </div>
          
            
            <!-- Unavailable message: same UI for out of stock, not available in country, or inactive -->
            {% assign error_message_class = "hidden" %}
            {% if not_purchasable %}
              {% assign error_message_class = "" %}
            {% endif %}
            
            <div class="error-messages-container {{ error_message_class }} out-of-stock-section">
              <div class="error-message text-sm font-medium" style="background-color: #fee2e2; color: #dc2626; padding: 12px; border-radius: 6px; margin: 8px 0;">
                {% if product.available_for_country != true %}
                  {{ section.settings.not_available_country_message | default: 'This product is not available in your country' }}
                {% else %}
                  {{ section.settings.out_of_stock_message | default: 'This product is out of stock' }}
                {% endif %}
              </div>
            </div>
            
            <!-- Price Section (use root-level price like Fluid main_product - formatted with currency) -->
            {% if section.settings.show_price %}
            <div class="price-section">
              <span class="price {{ section.settings.price_font_family | default: 'font-primary' }} {{ section.settings.price_font_size | default: 'text-xl' }} {{ section.settings.price_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.price_font_weight | default: 'font-normal' }} {{ section.settings.price_color | default: 'text-primary' }}">
                {{ price }}
              </span>
            </div>
            {% endif %}
            
            <!-- Subscription Options -->
            
            
            
            
            {% if allow_subscription %}
              
            <div class="subscription-options-section {{ section.settings.subscription_spacing_top_mobile | default: 'mt-md' }} {{ section.settings.subscription_spacing_top_desktop | default: 'lg:mt-md' }} {{ section.settings.subscription_spacing_bottom_mobile | default: 'mb-md' }} {{ section.settings.subscription_spacing_bottom_desktop | default: 'lg:mb-md' }}">
              <div class="subscription-options-wrapper">
                
                <!-- Subscribe & Save Option -->
                {% comment %} Match Fluid main_product: use root-level subscription_price (formatted) like Fluid; only override when we have plans to show selected plan's display_subscription_price. Do NOT assign from product.subscription_price - it can be raw (13.0) in some contexts. {% endcomment %}
                {% assign subscription_plan_id = '' %}
                {% if product.subscription_plans.size > 1 %}
                  {% assign subscription_plan_id = product.subscription_plans.first.id %}
                  {% assign subscription_price = product.subscription_plans.first.display_subscription_price %}
                  {% for subscription_plan in product.subscription_plans %}
                    {% if subscription_plan.selected %}
                      {% assign subscription_plan_id = subscription_plan.id %}
                      {% assign subscription_price = subscription_plan.display_subscription_price %}
                      {% break %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
                <div class="subscription-option-card {{ section.settings.subscription_card_border_radius | default: 'rounded-lg' }} {% if request.query_parameters.subscribe or subscription_only %}selected{% endif %}" data-option="1" style="border-width: {{ section.settings.subscription_card_border_width | default: '2px' }};" data-subscription-plan-id="{{ subscription_plan_id }}">
                  {% assign saved_percentage = product.saved_percentage_on_subscription | plus: 0 %}
                  {% if saved_percentage > 1 %}
                  <div class="most-popular-badge {{ section.settings.banner_bottom_spacing | default: 'mb-xs' }}">
                    <span class="text-sm font-medium text-white">
                      Most Popular
                    </span>
                  </div>
                  {% endif %}
                  
                  <label class="subscription-option-label {{ section.settings.subscription_card_padding | default: 'p-md' }}">
                    <div class="subscription-option-content">
                      <div class="subscription-option-header">
                        <span class="subscription-option-title text-lg font-semibold text-primary">
                          {{ 'product.subscribe' | t | default: 'Subscribe & Save' }}
                        </span>
                        <div class="subscription-option-price-group">
                          <span class="subscription-option-price text-lg font-semibold text-primary subscription-price">
                            {{ subscription_price }}
                          </span>
                          <input 
                            type="radio" 
                            name="fluid-checkout-subscribe" 
                            value="subscription"
                            id="subscribe-and-save-{{ section.id }}"
                            class="subscription-radio"
                            {% if request.query_parameters.subscribe or subscription_only %}checked{% endif %}
                          >
                        </div>
                      </div>
                      {% assign subscription_benefit_blocks = section.blocks | where: "type", "subscription_benefit" %}
                      {% if subscription_benefit_blocks.size > 0 %}
                      <ul class="subscription-option-benefits">
                        {% for block in subscription_benefit_blocks %}
                          {% if block.settings.benefit_text != blank %}
                            {% assign benefit_text = block.settings.benefit_text %}
                            {% if block.settings.show_savings_percentage and saved_percentage > 1 %}
                              {% assign benefit_text = benefit_text | replace: '{savings}', product.saved_percentage_on_subscription %}
                            {% endif %}
                            <li class="{{ block.settings.benefit_font_size | default: 'text-sm' }} {{ block.settings.benefit_color | default: 'text-primary' }} flex align-center space-md" {{ block.fluid_attributes }}>
                              <span>•&nbsp;&nbsp;{{ benefit_text }}</span>
                            </li>
                          {% endif %}
                        {% endfor %}
                      </ul>
                      {% endif %}
                    </div>
                  </label>
                </div>
                
                <!-- One-Time Purchase Option -->
                {% unless subscription_only %}
                <div class="subscription-option-card {{ section.settings.subscription_card_border_radius | default: 'rounded-lg' }} {% unless request.query_parameters.subscribe %}selected{% endunless %}" data-option="2" style="border-width: {{ section.settings.subscription_card_border_width | default: '2px' }};">
                  <label class="subscription-option-label {{ section.settings.subscription_card_padding | default: 'p-md' }}">
                    <div class="subscription-option-content">
                      <div class="subscription-option-header">
                        <span class="subscription-option-title text-lg font-semibold text-primary">
                          {{ 'product.one_time_purchase' | t | default: 'One-Time Purchase' }}
                        </span>
                        <div class="subscription-option-price-group">
                          <span class="subscription-option-price text-lg font-semibold text-primary">
                            {{ price }}
                          </span>
                          <input 
                            type="radio" 
                            name="fluid-checkout-subscribe" 
                            value="regular" 
                            id="one-time-purchase-{{ section.id }}"
                            class="subscription-radio"
                            {% unless request.query_parameters.subscribe %}checked{% endunless %}
                          >
                        </div>
                      </div>
                    </div>
                  </label>
                </div>
                {% endunless %}
                
              </div>
              
              <!-- Subscription Plans: show when any plans exist (match Fluid main_product); hidden by default, shown when Subscribe is selected -->
              {% if product.subscription_plans.size > 1 %}
              <div class="subscription-plans mt-md" {% unless request.query_parameters.subscribe %}style="display: none;"{% endunless %}>
                <div class="flex flex-col space-sm">
                  <p class="text-base font-medium mb-sm">Subscription Plan</p>
                  <select class="subscription-plans-dropdown custom-select" style="width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 6px;">
                    {% for subscription_plan in product.subscription_plans %}
                      <option {% if subscription_plan.selected %}selected{% endif %} value="{{ subscription_plan.id }}" data-subscription-price="{{ subscription_plan.display_subscription_price }}">{{ subscription_plan.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              {% endif %}
            </div>
            {% endif %}
            
            <!-- Product Variant Options -->
            {% if variants.size > 1 %}
              <div class="product-variant-section flex flex-col space-sm mb-md {% if not_purchasable %}product-variant-section-out-of-stock{% endif %}">
                {% if product.available_values.size > 0 %}
                  <div class="variant-groups-wrapper flex flex-wrap gap-md">
                    {% for option in product.available_values %}
                      <div class="variant-option-group" style="flex: 1; min-width: 150px;">
                        <p class="text-sm font-medium mb-xs text-neutral-500">{{ option.presentation | default: option.name }}</p>
                        <div class="custom-select-wrapper">
                          <select 
                            class="variation-dropdown custom-select" 
                            style="width: 100%; padding: 10px; border: 1px solid #d1d5db; border-radius: 4px; background-color: white; font-size: 14px;"
                            data-option-index="{{ forloop.index0 }}"
                            onchange="handleVariantChange(this)"
                            {% if not_purchasable %}disabled{% endif %}
                          >

                            {% for value in option.values %}
                              {% comment %} Determine if this value is currently selected {% endcomment %}
                              {% assign is_selected = false %}
                              {% for variant_option in selected_variant.option_values %}
                                {% if variant_option.id == value.id %}
                                  {% assign is_selected = true %}
                                  {% break %}
                                {% endif %}
                              {% endfor %}
                              <option value="{{ value.id }}" {% if is_selected %}selected{% endif %}>
                                {{ value.presentation | default: value.name }}
                              </option>
                            {% endfor %}
                          </select>
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                {% else %}
                  {% comment %} Single dropdown listing all variants (no buttons) {% endcomment %}
                  <div class="variant-groups-wrapper flex flex-wrap gap-md">
                    <div class="variant-option-group" style="flex: 1; min-width: 150px;">
                      <p class="text-sm font-medium mb-xs text-neutral-500">Variant</p>
                      <div class="custom-select-wrapper">
                        <select
                          class="variation-dropdown variant-single-dropdown custom-select"
                          style="width: 100%; padding: 10px; border: 1px solid #d1d5db; border-radius: 4px; background-color: white; font-size: 14px;"
                          data-option-index="0"
                          onchange="if(this.value && !window._selectVariantInFlight) { var e = arguments[0] || window.event; if (e && e.stopImmediatePropagation) e.stopImmediatePropagation(); selectVariant(this.value); }"
                          {% if not_purchasable %}disabled{% endif %}
                        >
                          {% for variant in variants %}
                            <option
                              value="{{ variant.id }}"
                              data-option-value-ids="{{ variant.option_values | map: 'id' | join: ',' }}"
                              {% if variant.id == selected_variant_id %}selected{% endif %}
                            >
                              {{ variant.title }}
                            </option>
                          {% endfor %}
                        </select>
                      </div>
                    </div>
                  </div>
                {% endif %}
              </div>
            {% endif %}
            
            <!-- Add to Cart Section -->
            {% unless not_purchasable %}
            {% if section.settings.show_cta %}
            {% assign quantity_layout = section.settings.quantity_layout | default: 'above' %}
            {% assign quantity_type = section.settings.quantity_type | default: 'dropdown' %}
            <div class="add-to-cart-section {% if quantity_layout == 'side' %}quantity-side{% else %}quantity-above{% endif %}">
              <!-- Quantity Selector -->
              <div class="quantity-wrapper">
                {% if quantity_type == 'stepper' %}
                  <!-- Stepper -->
                  <div class="quantity-stepper-wrapper">
                    {% assign quantity_border_radius = section.settings.quantity_border_radius | default: 'use_theme' %}
                    {% if quantity_border_radius == 'use_theme' %}
                      {% assign quantity_radius_class = settings.button_border_radius | default: 'rounded-md' %}
                    {% else %}
                      {% assign quantity_radius_class = quantity_border_radius %}
                    {% endif %}
                    <div class="quantity-stepper {{ quantity_radius_class }}" data-quantity-stepper>
                      <button type="button" class="quantity-stepper-btn quantity-stepper-minus" aria-label="Decrease quantity" data-quantity-decrement>
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
