    quantityStepperInput.addEventListener('change', function() {
      setQuantity(this.value);
    });
    
    // Prevent invalid input
    quantityStepperInput.addEventListener('blur', function() {
      setQuantity(this.value);
    });
  }
  
  // ==========================================
  // Image Hover Zoom
  // ==========================================
  function initHoverZoom() {
    const zoomMode = '{{ section.settings.zoom_mode | default: "panel" }}';
    
    // Exit if zoom is disabled
    if (zoomMode === 'none') return;
    
    const container = document.querySelector('#carousel-main-' + sectionId);
    const track = document.querySelector('#carousel-track-' + sectionId);
    const lens = document.querySelector('#zoom-lens-' + sectionId);
    const panel = document.querySelector('#zoom-panel-' + sectionId);
    const mediaColumn = container?.closest('.media-column');
    
    if (!container || !track || !mediaColumn) return;
    
    // Only enable on desktop
    if (window.innerWidth < 1024) return;
    
    // Zoom configuration
    const zoomLevel = 3; // Magnification level
    const panelAspectRatio = 1 / 1; // Panel aspect ratio (1:1 square)
    
    // Calculate lens size based on container size and zoom level
    const containerRect = container.getBoundingClientRect();
    const lensWidth = containerRect.width / zoomLevel;
    const lensHeight = (containerRect.width / zoomLevel) / panelAspectRatio;
    
    function getCurrentSlideImage() {
      const activeThumbnail = document.querySelector('#carousel-' + sectionId + ' .carousel-thumbnail.active');
      if (activeThumbnail) {
        const slideIndex = parseInt(activeThumbnail.getAttribute('data-index')) || 0;
        const slides = track.querySelectorAll('.carousel-slide');
        return slides[slideIndex]?.querySelector('img');
      }
      const transform = track.style.transform;
      const match = transform.match(/translateX\(-?(\d+(?:\.\d+)?)(px|%)?\)/);
      let slideIndex = 0;
      if (match) {
        const value = parseFloat(match[1]);
        const unit = match[2];
        if (unit === '%') {
          slideIndex = Math.round(value / 100);
        } else {
          const containerWidth = container.getBoundingClientRect().width;
          slideIndex = containerWidth > 0 ? Math.round(value / containerWidth) : 0;
        }
      }
      const slides = track.querySelectorAll('.carousel-slide');
      return slides[slideIndex]?.querySelector('img');
    }
    
    // ==========================================
    // PANEL MODE (Amazon-style zoom panel on right)
    // ==========================================
    if (zoomMode === 'panel') {
      if (!lens || !panel) return;
      
      container.classList.add('zoom-enabled');
      lens.style.width = lensWidth + 'px';
      lens.style.height = lensHeight + 'px';
      
      function updatePanelZoom(e) {
        const containerRect = container.getBoundingClientRect();
        const mediaColumnRect = mediaColumn.getBoundingClientRect();
        const img = getCurrentSlideImage();
        
        if (!img) return;
        
        const x = e.clientX - containerRect.left;
        const y = e.clientY - containerRect.top;
        
        let lensX = x - lensWidth / 2;
        let lensY = y - lensHeight / 2;
        
        lensX = Math.max(0, Math.min(lensX, containerRect.width - lensWidth));
        lensY = Math.max(0, Math.min(lensY, containerRect.height - lensHeight));
        
        const lensOffsetX = containerRect.left - mediaColumnRect.left;
        const lensOffsetY = containerRect.top - mediaColumnRect.top;
        
        lens.style.left = (lensX + lensOffsetX) + 'px';
        lens.style.top = (lensY + lensOffsetY) + 'px';
        
        const maxLensX = containerRect.width - lensWidth;
        const maxLensY = containerRect.height - lensHeight;
        const percentX = maxLensX > 0 ? (lensX / maxLensX) * 100 : 0;
        const percentY = maxLensY > 0 ? (lensY / maxLensY) * 100 : 0;
        
        const highResUrl = img.src.replace(/width=\d+/, 'width=2400');
        panel.style.backgroundImage = 'url("' + highResUrl + '")';
        panel.style.backgroundSize = (zoomLevel * 100) + '%';
        panel.style.backgroundPosition = percentX + '% ' + percentY + '%';
      }
      
      container.addEventListener('mousemove', updatePanelZoom);
      
      container.addEventListener('mouseenter', function() {
        mediaColumn.classList.add('zoom-active');
        const img = getCurrentSlideImage();
        if (img) {
          const highResUrl = img.src.replace(/width=\d+/, 'width=2400');
          const preload = new Image();
          preload.src = highResUrl;
        }
      });
      
      container.addEventListener('mouseleave', function() {
        mediaColumn.classList.remove('zoom-active');
      });
      
      const observer = new MutationObserver(function() {
        const img = getCurrentSlideImage();
        if (img && panel.style.backgroundImage) {
          const highResUrl = img.src.replace(/width=\d+/, 'width=2400');
          panel.style.backgroundImage = 'url("' + highResUrl + '")';
        }
      });
      observer.observe(track, { attributes: true, attributeFilter: ['style'] });
    }
    
    // ==========================================
    // IN-PLACE MODE (zoom directly on image)
    // ==========================================
    if (zoomMode === 'inplace') {
      container.classList.add('zoom-inplace');
      
      function updateInplaceZoom(e) {
        const containerRect = container.getBoundingClientRect();
        const img = getCurrentSlideImage();
        
        if (!img) return;
        
        // Calculate cursor position as percentage
        const x = e.clientX - containerRect.left;
        const y = e.clientY - containerRect.top;
        const percentX = (x / containerRect.width) * 100;
        const percentY = (y / containerRect.height) * 100;
        
        // Set transform origin on the current slide image
        img.style.transformOrigin = percentX + '% ' + percentY + '%';
      }
      
      container.addEventListener('mousemove', updateInplaceZoom);
      
      container.addEventListener('mouseenter', function() {
        container.classList.add('zoom-inplace-active');
      });
      
      container.addEventListener('mouseleave', function() {
        container.classList.remove('zoom-inplace-active');
        // Reset transform origin
        const img = getCurrentSlideImage();
        if (img) {
          img.style.transformOrigin = 'center center';
        }
      });
    }
    
    // Handle window resize for both modes
    window.addEventListener('resize', function() {
      if (window.innerWidth < 1024) {
        container.classList.remove('zoom-enabled', 'zoom-inplace', 'zoom-inplace-active');
        mediaColumn.classList.remove('zoom-active');
      } else {
        if (zoomMode === 'panel') {
          container.classList.add('zoom-enabled');
        } else if (zoomMode === 'inplace') {
          container.classList.add('zoom-inplace');
        }
      }
    });
  }
   
  // Initialize hover zoom
  initHoverZoom();
})();
  
</script>
<script>
  function updateCart(quantity){
    $('.add-to-cart-btn').each(function(){
        $(this).attr('data-fluid-quantity', quantity);
    });
    $('.quantity-stepper-input').each(function(){
      $(this).val(quantity);
    });
  }
  
  function outOfStockHandler(showOutOfStockMessage){
     $('.out-of-stock-section').each(function(){
       if(showOutOfStockMessage){
         $(this).removeClass('hidden');
       } else {
         $(this).addClass('hidden');
       }
     });
  }
  
  function productIncrementHandler() {
    $(document).on('click', '.quantity-stepper-plus', function(){
      const oldVal = parseInt($(this).prev('.quantity-stepper-input').val(), 10);
      const maxQuanity = parseInt($(this).prev('.quantity-stepper-input').attr('max'), 10) || 10;
      const updatedQuantity = oldVal + 1;
      
      if (oldVal < maxQuanity) {
         updateCart(updatedQuantity);
      } 
      if( updatedQuantity == maxQuanity ){
        outOfStockHandler(true);
      }
    });
  }
  
  function productDecrementHandler() {
    $(document).on('click', '.quantity-stepper-minus', function(){
      const oldVal = parseInt($(this).next('.quantity-stepper-input').val(), 10);
      outOfStockHandler(false);
      if (oldVal > 1) {
         updateCart(oldVal - 1);
      }
    });
  }
  
  productIncrementHandler();
  productDecrementHandler();
 
</script>

