<script>
// Define handleVariantChange function - make it globally available for inline handlers and after section replacement
function handleVariantChange(el) {
  // If triggered from clone, sync clone dropdown values to main section first
  const cloneSection = el ? $(el).closest('.fluid-sidebar-clone') : null;
  if (cloneSection.length) {
    const mainSection = $('section.product-header-4:not(.fluid-sidebar-clone section)');
    if (mainSection.length) {
      // Sync clone dropdowns to main section dropdowns by data-option-index
      cloneSection.find('select.variation-dropdown:not(.variant-single-dropdown)').each(function() {
        const cloneIndex = $(this).attr('data-option-index');
        const cloneValue = $(this).val();
        const mainDropdown = mainSection.find(`select.variation-dropdown[data-option-index="${cloneIndex}"]:not(.variant-single-dropdown)`);
        if (mainDropdown.length && cloneValue) {
          mainDropdown.val(cloneValue);
        }
      });
    }
  }
  
  // Collect from main section only (exclude clone to avoid duplicates)
  const mainSection = $('section.product-header-4:not(.fluid-sidebar-clone section)');
  let option_value_ids = [];
  mainSection.find('select.variation-dropdown:not(.variant-single-dropdown)').each(function () {
    const val = $(this).val();
    if (val) {
      option_value_ids.push(val);
    }
  });
  
  const url = window.location.href.split('?')[0];
  const data = {
    option_value_ids: option_value_ids,
    subscription_plan: mainSection.find('select.subscription-plans-dropdown')?.val() || $('select.subscription-plans-dropdown')?.val()
  };
  
  const subscribeChecked = mainSection.find('input[name="fluid-checkout-subscribe"]:checked')[0] || $('input[name="fluid-checkout-subscribe"]:checked')[0];
  if (subscribeChecked && subscribeChecked.value == 'subscription') {
    data.subscribe = true;
  }
  
  $.ajax({
    url: url,
    data: data,
    success: function(response) {
      const newSection = $(response).find('section.product-header-4.product-details-section').first();
      const mainSectionEl = document.querySelector('section.product-header-4:not(.fluid-sidebar-clone section)');
      if (newSection.length && mainSectionEl) {
        $(mainSectionEl).replaceWith(newSection);
        
        // Helper function to re-clone sidebar for desktop view
        function reCloneSidebar() {
          if (window.innerWidth <= 1024) return;
          
          const sidebar = document.querySelector('.product-layout-grid-sidebar');
          if (!sidebar) return;
          
          // Remove old clone
          const oldClone = sidebar.querySelector('.fluid-sidebar-clone');
          if (oldClone) {
            oldClone.remove();
          }
          
          // Create new clone from updated main section
          const headerSection = document.querySelector('[data-fluid-section="lgp_product_header"]');
          const infoColumn = headerSection?.querySelector('.info-column');
          if (infoColumn) {
            const clonedInfoColumn = infoColumn.cloneNode(true);
            const wrapper = document.createElement('section');
            wrapper.className = 'fluid-sidebar-clone';
            wrapper.setAttribute('data-fluid-section', 'lgp_product_header');
            wrapper.setAttribute('data-fluid-section-type', 'product-header-4');
            wrapper.appendChild(clonedInfoColumn);
            sidebar.appendChild(wrapper);
          }
        }
        
        // Re-clone sidebar for desktop view (this will get updated prices and variant selections from the new section)
        reCloneSidebar();
        
        // Re-initialize any scripts that need to run after section replacement
        if (typeof updateSubcriptionValue === 'function') {
          updateSubcriptionValue();
        }
        if (typeof updateSubscriptionPrice === 'function') {
          updateSubscriptionPrice();
        }
        if (typeof updateSubscribeUI === 'function') {
          updateSubscribeUI();
        }
      }
    }
  });
}

// Make function globally available for inline handlers and after section replacement
window.handleVariantChange = handleVariantChange;

// For single-variant dropdown: send variant_id directly
// Works from both main section and sidebar clone
function selectVariant(variantId) {
  if (!variantId) return;
  if (window._selectVariantInFlight) return; // Prevent re-entry / reset loop
  window._selectVariantInFlight = true;
  
  // Find main section (not clone) - always use main section as source of truth
  const section = document.querySelector('section.product-header-4:not(.fluid-sidebar-clone section)');
  if (!section) { window._selectVariantInFlight = false; return; }
  
  const baseUrl = window.location.href.split('?')[0];
  const data = {
    variant_id: variantId,
    subscription_plan: section.querySelector('.subscription-plans-dropdown')?.value
  };
  
  if (section.querySelector('input[name="fluid-checkout-subscribe"]:checked')?.value === 'subscription') {
    data.subscribe = true;
  }
  
  $.ajax({
    url: baseUrl,
    data: data,
    success: function(response) {
      // Target only product-header-4 section (not other product-details-section blocks)
      const newSection = $(response).find('section.product-header-4.product-details-section').first();
      const mainSectionEl = document.querySelector('section.product-header-4:not(.fluid-sidebar-clone section)');
      if (newSection.length && mainSectionEl) {
        $(mainSectionEl).replaceWith(newSection);
        
        // Update URL so variant is preserved on refresh
        try {
          const url = new URL(baseUrl);
          url.searchParams.set('variant_id', String(variantId));
          if (data.subscribe) url.searchParams.set('subscribe', 'true');
          if (data.subscription_plan) url.searchParams.set('subscription_plan', data.subscription_plan);
          window.history.replaceState({}, '', url.toString());
        } catch (e) {}
        
        // Re-clone sidebar for desktop view
        function reCloneSidebar() {
          if (window.innerWidth <= 1024) return;
          
          const sidebar = document.querySelector('.product-layout-grid-sidebar');
          if (!sidebar) return;
          
          const oldClone = sidebar.querySelector('.fluid-sidebar-clone');
          if (oldClone) {
            oldClone.remove();
          }
          
          const headerSection = document.querySelector('[data-fluid-section="lgp_product_header"]');
          const infoColumn = headerSection?.querySelector('.info-column');
          if (infoColumn) {
            const clonedInfoColumn = infoColumn.cloneNode(true);
            const wrapper = document.createElement('section');
            wrapper.className = 'fluid-sidebar-clone';
            wrapper.setAttribute('data-fluid-section', 'lgp_product_header');
            wrapper.setAttribute('data-fluid-section-type', 'product-header-4');
            wrapper.appendChild(clonedInfoColumn);
            sidebar.appendChild(wrapper);
          }
        }
        
        reCloneSidebar();
        
        // Re-initialize scripts
        if (typeof updateSubcriptionValue === 'function') {
          updateSubcriptionValue();
        }
        if (typeof updateSubscriptionPrice === 'function') {
          updateSubscriptionPrice();
        }
        if (typeof updateSubscribeUI === 'function') {
          updateSubscribeUI();
        }
      }
      window._selectVariantInFlight = false;
    },
    error: function() {
      window._selectVariantInFlight = false;
    }
  });
}

// Make function globally available for inline handlers and after section replacement
window.selectVariant = selectVariant;

(function() {
  const sectionId = '{{ section.id }}';
  
  // Thumbnail Carousel functionality
  const carouselWrapper = document.getElementById('carousel-' + sectionId);
  if (carouselWrapper) {
    const carouselTrack = document.getElementById('carousel-track-' + sectionId);
    const carouselContainer = document.getElementById('carousel-main-' + sectionId);
    const prevBtn = document.getElementById('carousel-prev-' + sectionId);
    const nextBtn = document.getElementById('carousel-next-' + sectionId);
    const thumbnailsContainer = document.getElementById('carousel-thumbnails-' + sectionId);
    const thumbnails = carouselWrapper.querySelectorAll('.carousel-thumbnail');
    const slides = carouselWrapper.querySelectorAll('.carousel-slide');
    
    if (carouselTrack && slides.length > 0) {
      let currentIndex = 0;
      let isDragging = false;
      let startX = 0;
      let currentX = 0;
      let offsetX = 0;
      let startTime = 0;
      let lastX = 0;
      let lastTime = 0;
      let velocity = 0;
      
      // Update carousel position
      function updateCarouselPosition(animate = true) {
        if (!carouselContainer || !carouselTrack) return;
        
        const containerWidth = carouselContainer.offsetWidth || 1;
        
        // Set explicit track width to ensure proper alignment
        const totalWidth = containerWidth * slides.length;
        carouselTrack.style.width = totalWidth + 'px';
        
        // Ensure each slide is exactly container width with no gaps
        slides.forEach(slide => {
          slide.style.width = containerWidth + 'px';
          slide.style.minWidth = containerWidth + 'px';
          slide.style.maxWidth = containerWidth + 'px';
          slide.style.margin = '0';
          slide.style.padding = '0';
          slide.style.border = 'none';
          slide.style.outline = 'none';
          const img = slide.querySelector('img');
          if (img) {
            img.style.margin = '0';
            img.style.padding = '0';
            img.style.border = 'none';
            img.style.outline = 'none';
            img.style.width = '100%';
            img.style.height = '100%';
          }
        });
        
        const targetX = -currentIndex * containerWidth + offsetX;
        
        if (animate && !isDragging) {
          carouselTrack.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
        } else {
          carouselTrack.style.transition = 'none';
        }
        
        carouselTrack.style.transform = `translateX(${targetX}px)`;
        
        // Update navigation buttons
        if (prevBtn) {
          prevBtn.disabled = currentIndex === 0;
        }
        if (nextBtn) {
          nextBtn.disabled = currentIndex === slides.length - 1;
        }
      }
      
      // Initialize track width on load and resize
      function initializeTrackWidth() {
        if (!carouselContainer || !carouselTrack) return;
        const containerWidth = carouselContainer.offsetWidth || 1;
        const totalWidth = containerWidth * slides.length;
        carouselTrack.style.width = totalWidth + 'px';
        carouselTrack.style.margin = '0';
        carouselTrack.style.padding = '0';
        carouselTrack.style.gap = '0';
        
        slides.forEach(slide => {
          slide.style.width = containerWidth + 'px';
          slide.style.minWidth = containerWidth + 'px';
          slide.style.maxWidth = containerWidth + 'px';
          slide.style.margin = '0';
          slide.style.padding = '0';
          slide.style.border = 'none';
          slide.style.outline = 'none';
          const img = slide.querySelector('img');
          if (img) {
            img.style.margin = '0';
            img.style.padding = '0';
            img.style.border = 'none';
            img.style.outline = 'none';
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.display = 'block';
            img.style.verticalAlign = 'top';
          }
        });
      }
      
      // Match thumbnail wrapper height to carousel container (for left layout) and set thumbnail count (for stretch layout)
      function matchThumbnailHeight() {
        if (!carouselContainer || !carouselWrapper) return;
        
        const carouselHeight = carouselContainer.offsetHeight;
        
        // Handle left layout (vertical thumbnails)
        const isLeftLayout = carouselWrapper.classList.contains('gallery-layout-left');
        if (isLeftLayout && carouselHeight > 0) {
          const thumbnailWrapper = carouselWrapper.querySelector('.carousel-thumbnails-wrapper-vertical');
          if (thumbnailWrapper) {
            thumbnailWrapper.style.height = carouselHeight + 'px';
          }
        }
        
        // Handle stretch layout (set CSS variable for thumbnail count)
        const isStretchLayout = carouselWrapper.classList.contains('thumbnail-size-stretch');
        if (isStretchLayout) {
          const thumbnailTrack = carouselWrapper.querySelector('.carousel-thumbnails-track');
          if (thumbnailTrack) {
            // Set CSS variable for number of thumbnails so grid knows how many columns
            const thumbnailCount = thumbnailTrack.querySelectorAll('.carousel-thumbnail').length;
            thumbnailTrack.style.setProperty('--thumbnail-count', thumbnailCount);
          }
        }
      }
      
      // Handle window resize
      let resizeTimeout;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(function() {
          initializeTrackWidth();
          updateCarouselPosition(false);
          updateThumbnails(true);
          updateThumbnailFades();
          matchThumbnailHeight();
        }, 100);
      });
      
      // Smooth scroll function with custom duration
      function smoothScrollTo(element, target, isVertical, duration = 600) {
        const start = isVertical ? element.scrollTop : element.scrollLeft;
        const distance = target - start;
        const startTime = performance.now();
        
        function animate(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          // Easing function (ease-out)
          const ease = 1 - Math.pow(1 - progress, 3);
          const current = start + distance * ease;
          
          if (isVertical) {
            element.scrollTop = current;
          } else {
            element.scrollLeft = current;
          }
          
          if (progress < 1) {
            requestAnimationFrame(animate);
          }
        }
        
        requestAnimationFrame(animate);
      }
      
      // Update thumbnail active state and scroll position
      function updateThumbnails(shouldScroll = true, slowScroll = false) {
        thumbnails.forEach((thumb, index) => {
          if (index === currentIndex) {
            thumb.classList.add('active');
          } else {
            thumb.classList.remove('active');
          }
        });
        
        // Scroll thumbnails to center active thumbnail (only if shouldScroll is true)
        if (shouldScroll && thumbnailsContainer && thumbnails[currentIndex]) {
          const activeThumb = thumbnails[currentIndex];
          const isVertical = thumbnailsContainer.classList.contains('carousel-thumbnails-left');
          
          if (isVertical) {
            // Vertical scrolling (left layout)
            const containerHeight = thumbnailsContainer.offsetHeight;
