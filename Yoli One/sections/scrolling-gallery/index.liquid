<!-- Scrolling Gallery Section -->
{% assign custom_bg_color = section.settings.custom_background_color %}
{% assign custom_bg_opacity = section.settings.custom_background_opacity | default: 100 | divided_by: 100.0 %}
{% assign has_custom_bg = false %}
{% if custom_bg_color != blank and custom_bg_color != 'rgba(0,0,0,0)' %}
  {% assign has_custom_bg = true %}
{% endif %}
<section class="scrolling-gallery {% unless has_custom_bg %}{{ section.settings.background_color | default: 'bg-tertiary' }}{% endunless %} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  {% if has_custom_bg %}
  <div class="scrolling-gallery__custom-bg" style="position: absolute; inset: 0; background: {{ custom_bg_color }}; opacity: {{ custom_bg_opacity }}; pointer-events: none; z-index: 0; border-radius: inherit;"></div>
  {% endif %}
  
  <!-- Gradient Overlays -->
  {% if section.settings.show_top_gradient %}
  <div class="gradient-overlay gradient-overlay--top" style="--gradient-color: var(--clr-{{ section.settings.top_gradient_color | default: 'black' }}); --gradient-height: {{ section.settings.top_gradient_height | default: 150 }}px;"></div>
  {% endif %}
  {% if section.settings.show_bottom_gradient %}
  <div class="gradient-overlay gradient-overlay--bottom" style="--gradient-color: var(--clr-{{ section.settings.bottom_gradient_color | default: 'black' }}); --gradient-height: {{ section.settings.bottom_gradient_height | default: 150 }}px;"></div>
  {% endif %}
  
  <!-- Header Container -->
  <div class="{{section.settings.container_layout_width | default: 'default'}}">
    <div class="scrolling-gallery__header-container">
    <div class="scrolling-gallery__header-content" style="max-width: 770px; margin: 0 auto; text-align: center;">
      <h2 class="scrolling-gallery__heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}">
        {{ section.settings.heading | default: "You're in Good Company" }}
      </h2>
      <div class="scrolling-gallery__description {{ section.settings.description_font_family | default: 'font-body' }}">
        <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
          {{ section.settings.description | default: "We believe that getting healthy is better together. That's why our community is the heart of our culture, built on a simple idea we call BLP: Belonging, Love, and Purpose. Here's what it looks like in real life." }}
        </p>
      </div>
    </div>
  </div>
  </div>

  <!-- Gallery Full Width Container -->
  {% if section.blocks.size > 0 %}
    <div class="{{section.settings.container_layout_width | default: 'default'}}">
      <div class="scrolling-gallery__gallery-fullwidth">
        <div class="scrolling-gallery__track-container" style="margin-left: calc(-1 * {{ section.settings.scroll_start_offset | default: 24 }}px); width: calc(100% + {{ section.settings.scroll_start_offset | default: 24 }}px);">
          <div class="scrolling-gallery__track" data-gallery-track="{{ section.id }}">
            {% comment %} First set of images {% endcomment %}
            {% for block in section.blocks %}
              {% if block.type == 'gallery_image' %}
                <div class="scrolling-gallery__image-item" style="width: {{ block.settings.image_width | default: 480 }}px; border-radius: {{ section.settings.image_border_radius | default: 8 }}px;" {{ block.fluid_attributes }}>
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" 
                         alt="{{ block.settings.image_alt | default: 'Gallery image' }}"
                         class="scrolling-gallery__image"
                         style="object-fit: {{ block.settings.image_fit | default: 'cover' }};"
                         loading="lazy">
                  {% else %}
                    <svg class="scrolling-gallery__image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 312" fill="none" preserveAspectRatio="xMidYMid slice">
                      <rect width="480" height="312" fill="#f5f5f5"/>
                      <path d="M240 90c-33.1 0-60 26.9-60 60s26.9 60 60 60 60-26.9 60-60-26.9-60-60-60zm0 90c-16.5 0-30-13.5-30-30s13.5-30 30-30 30 13.5 30 30-13.5 30-30 30zm90 72H150l36-72 54 36 36-18 54 54z" fill="#d0d0d0"/>
                    </svg>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
            {% comment %} Duplicate set for seamless infinite scroll {% endcomment %}
            {% for block in section.blocks %}
              {% if block.type == 'gallery_image' %}
                <div class="scrolling-gallery__image-item" style="width: {{ block.settings.image_width | default: 480 }}px; border-radius: {{ section.settings.image_border_radius | default: 8 }}px;" {{ block.fluid_attributes }}>
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" 
                         alt="{{ block.settings.image_alt | default: 'Gallery image' }}"
                         class="scrolling-gallery__image"
                         style="object-fit: {{ block.settings.image_fit | default: 'cover' }};"
                         loading="lazy">
                  {% else %}
                    <svg class="scrolling-gallery__image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 312" fill="none" preserveAspectRatio="xMidYMid slice">
                      <rect width="480" height="312" fill="#f5f5f5"/>
                      <path d="M240 90c-33.1 0-60 26.9-60 60s26.9 60 60 60 60-26.9 60-60-26.9-60-60-60zm0 90c-16.5 0-30-13.5-30-30s13.5-30 30-30 30 13.5 30 30-13.5 30-30 30zm90 72H150l36-72 54 36 36-18 54 54z" fill="#d0d0d0"/>
                    </svg>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- Footer Container -->
  <div class="{{section.settings.container_layout_width | default: 'default'}}">
    <div class="scrolling-gallery__footer-container">
    <div class="scrolling-gallery__footer-content" style="max-width: 770px; margin: 0 auto; text-align: center;">
      <h3 class="scrolling-gallery__footer-heading {{ section.settings.footer_heading_font_family | default: 'font-handwritten' }} {{ section.settings.footer_heading_font_size | default: 'text-4xl' }} {{ section.settings.footer_heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.footer_heading_font_weight | default: 'font-normal' }} {{ section.settings.footer_heading_color | default: 'text-neutral-dark' }}">
        {{ section.settings.footer_heading | default: "Join the Conversation" }}
      </h3>
      <div class="scrolling-gallery__footer-description {{ section.settings.footer_description_font_family | default: 'font-body' }}">
        <p class="{{ section.settings.footer_description_font_size | default: 'text-base' }} {{ section.settings.footer_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.footer_description_font_weight | default: 'font-normal' }} {{ section.settings.footer_description_color | default: 'text-neutral-dark' }}">
          {{ section.settings.footer_description | default: "Our community is full of encouragement, celebrations, and everyday wins. Come be part of it." }}
        </p>
      </div>
      {% if section.settings.show_button %}
        <div class="scrolling-gallery__button-wrapper">
          <a href="{{ section.settings.button_url | default: '#' }}" 
             class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'info' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} font-body {{ settings.button_border_radius | default: 'rounded-full' }}">
            {{ section.settings.button_text | default: 'Join Our Community' }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
  </div>

</section>

<link rel="stylesheet" href="{{ 'scrolling-gallery/styles.css' | asset_url }}">

<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    const tracks = document.querySelectorAll('[data-gallery-track]');
    
    tracks.forEach(function(track) {
      const section = track.closest('.scrolling-gallery');
      if (!section) return;
      
      const trackContainer = track.closest('.scrolling-gallery__track-container');
      if (!trackContainer) return;
      
      // Wait for images to load before calculating width
      function initializeAnimation() {
        // Calculate the width of one set of images (half the total since we duplicated)
        const totalWidth = track.scrollWidth;
        const firstSetWidth = totalWidth / 2;
        
        // Only proceed if there's content to scroll
        if (firstSetWidth <= 0 || totalWidth <= 0) {
          // Retry after a short delay if images haven't loaded yet
          setTimeout(initializeAnimation, 100);
          return;
        }
        
        let isInView = false;
        let animationId = null;
        let currentPosition = 0;
        const scrollSpeed = 0.5; // pixels per frame (adjust for speed - lower = slower)
        
        function animate() {
          if (!isInView) {
            animationId = null;
            return;
          }
          
          // Move the track to the left
          currentPosition -= scrollSpeed;
          
          // Reset position when we've scrolled one full set (seamless loop)
          if (Math.abs(currentPosition) >= firstSetWidth) {
            currentPosition = 0;
          }
          
          track.style.transform = `translateX(${currentPosition}px)`;
          animationId = requestAnimationFrame(animate);
        }
        
        // Use Intersection Observer to detect when section is in view
        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            isInView = entry.isIntersecting;
            if (isInView && !animationId) {
              // Start animation when section enters viewport
              animationId = requestAnimationFrame(animate);
            } else if (!isInView && animationId) {
              // Stop animation when section leaves viewport to save resources
              cancelAnimationFrame(animationId);
              animationId = null;
            }
          });
        }, {
          threshold: 0,
          rootMargin: '50px' // Start animating slightly before section enters viewport
        });
        
        observer.observe(section);
        
        // Handle window resize - recalculate width if needed
        let resizeTimeout;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(function() {
            // Recalculate on resize, but keep current position
            const newTotalWidth = track.scrollWidth;
            const newFirstSetWidth = newTotalWidth / 2;
            if (newFirstSetWidth > 0) {
              // Adjust current position proportionally if needed
              if (Math.abs(currentPosition) >= newFirstSetWidth) {
                currentPosition = currentPosition % newFirstSetWidth;
              }
            }
          }, 250);
        }, { passive: true });
      }
      
      // Start initialization
      initializeAnimation();
    });
  });
})();
</script>

