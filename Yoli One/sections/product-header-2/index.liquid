<link rel="stylesheet" href="{{ 'product-header-2/styles.css' | asset_url }}">

<!-- Product Header 2 Section -->
<section class="product-header-2 {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="product-header-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-header-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-md' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="product-layout">
        
        <!-- Left Column: Media Gallery -->
        <div class="media-column">
          
          <!-- Hero Media (Video or Image) -->
          <div class="hero-media" data-media-index="0">
            {% if section.settings.hero_video != blank %}
              <video autoplay loop muted playsinline>
                <source src="{{ section.settings.hero_video }}" type="video/mp4">
              </video>
            {% elsif section.settings.hero_image != blank %}
              <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" alt="{{ section.settings.hero_image_alt | default: 'Product hero' }}" loading="eager" class="clickable-image" data-full-src="{{ section.settings.hero_image | image_url: width: 1600 }}">
            {% else %}
              <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
            {% endif %}
          </div>
          
          <!-- Gallery Grid (2x2) -->
          {% assign gallery_blocks = section.blocks | where: "type", "gallery_image" %}
          {% if gallery_blocks.size > 0 %}
          <div class="gallery-grid">
            {% for block in gallery_blocks limit: 4 %}
              {% assign index = forloop.index %}
              <div class="gallery-item" {{ block.fluid_attributes }} data-media-index="{{ index }}">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.image_alt | default: 'Product detail' }}" loading="lazy" class="clickable-image" data-full-src="{{ block.settings.image | image_url: width: 1600 }}">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
                {% endif %}
              </div>
            {% endfor %}
          </div>
          {% endif %}
          
        </div>
        
        <!-- Right Column: Product Info (Sticky) -->
        <div class="info-column">
          <div class="info-sticky">
            
            <!-- Product Title with Code -->
            <div class="product-title-wrapper">
              {% if section.settings.product_code != blank %}
              <div class="product-code-badge">
                <span class="{{ section.settings.code_font_size | default: 'text-base' }} {{ section.settings.code_color | default: 'text-primary' }}">
                  {{ section.settings.product_code }}<sup>{{ section.settings.code_superscript | default: '™' }}</sup>
                </span>
              </div>
              {% endif %}
              
              {% if section.settings.product_title != blank %}
              <h1 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-primary' }} leading-heading">
                {{ section.settings.product_title }}
              </h1>
              {% endif %}
            </div>
            
            <!-- Rating & Reviews -->
            {% if section.settings.show_rating %}
            <div class="rating-wrapper">
              <div class="stars">
                <img src="{{ section.settings.stars_image | image_url: width: 100 | default: 'placeholder-image.png' | asset_url }}" alt="Star rating" loading="lazy" style="width: 88px; height: 16px;">
              </div>
              <div class="rating-text">
                <span class="{{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                  {{ section.settings.rating_value | default: '4.8' }} •
                </span>
              </div>
              {% if section.settings.show_reviews_link %}
              <a href="{{ section.settings.reviews_link | default: '#reviews' }}" class="reviews-link {{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                {{ section.settings.reviews_text | default: '18 Reviews' }}
              </a>
              {% endif %}
            </div>
            {% endif %}
            
            <!-- Product Description -->
            {% if section.settings.description != blank %}
            <div class="product-description">
              <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
                {{ section.settings.description }}
              </p>
            </div>
            {% endif %}
            
            <!-- Price Section -->
            <div class="price-section">
              {% if section.settings.price != blank %}
              <span class="price {{ section.settings.price_font_family | default: 'font-primary' }} {{ section.settings.price_font_size | default: 'text-xl' }} {{ section.settings.price_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.price_font_weight | default: 'font-normal' }} {{ section.settings.price_color | default: 'text-primary' }}">
                {{ section.settings.price }}
              </span>
              {% endif %}
              
              {% if section.settings.show_new_badge %}
              <span class="new-badge" style="background-color: {{ section.settings.badge_background | default: '#d3fa99' }}">
                <span class="{{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-primary' }}">
                  {{ section.settings.badge_text | default: 'New' }}
                </span>
              </span>
              {% endif %}
            </div>
            
            <!-- Subscription Info -->
            {% if section.settings.subscription_info != blank %}
            <div class="subscription-info">
              <p class="{{ section.settings.subscription_font_size | default: 'text-sm' }} {{ section.settings.subscription_color | default: 'text-primary' }} leading-body">
                {{ section.settings.subscription_info }}
              </p>
            </div>
            {% endif %}
            
            <!-- CTA Button -->
            {% if section.settings.show_cta %}
            <div class="cta-wrapper">
              <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }} w-full">
                {{ section.settings.cta_text | default: 'Start Now' }}
              </a>
            </div>
            {% endif %}
            
            <!-- Guarantee Text -->
            {% if section.settings.guarantee_text != blank %}
            <div class="guarantee-text">
              <p class="{{ section.settings.guarantee_font_size | default: 'text-sm' }} {{ section.settings.guarantee_color | default: 'text-neutral' }} leading-body">
                {{ section.settings.guarantee_text }}
              </p>
            </div>
            {% endif %}
            
            <!-- Accordions -->
            <div class="accordions-wrapper">
              
              <!-- Benefits Accordion -->
              {% assign benefit_blocks = section.blocks | where: "type", "benefit_item" %}
              {% if benefit_blocks.size > 0 %}
              <div class="accordion-item">
                <button class="accordion-header" onclick="this.parentElement.classList.toggle('active')">
                  <span class="{{ section.settings.accordion_font_size | default: 'text-base' }} {{ section.settings.accordion_color | default: 'text-primary' }}">
                    {{ section.settings.benefits_title | default: 'Benefits*' }}
                  </span>
                  <svg class="accordion-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M19 9L12 16L5 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="accordion-content">
                  <ul class="benefits-list">
                    {% for block in benefit_blocks %}
                      {% if block.settings.benefit_text != blank %}
                      <li class="{{ section.settings.benefit_font_size | default: 'text-base' }} {{ section.settings.benefit_color | default: 'text-primary' }}" {{ block.fluid_attributes }}>
                        {{ block.settings.benefit_text }}
                      </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>
              </div>
              {% endif %}
              
              <!-- Ingredients Accordion -->
              {% if section.settings.show_ingredients %}
              <div class="accordion-item">
                <button class="accordion-header" onclick="this.parentElement.classList.toggle('active')">
                  <span class="{{ section.settings.accordion_font_size | default: 'text-base' }} {{ section.settings.accordion_color | default: 'text-primary' }}">
                    {{ section.settings.ingredients_title | default: 'Ingredients' }}
                  </span>
                  <svg class="accordion-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M19 9L12 16L5 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="accordion-content">
                  {% if section.settings.ingredients_content != blank %}
                  <div class="ingredients-content {{ section.settings.ingredients_font_size | default: 'text-sm' }} {{ section.settings.ingredients_color | default: 'text-primary' }}">
                    {{ section.settings.ingredients_content }}
                  </div>
                  {% endif %}
                </div>
              </div>
              {% endif %}
              
            </div>
            
            <!-- Bundle Upsell Card -->
            {% if section.settings.show_bundle_upsell %}
            <div class="bundle-card {{ section.settings.bundle_background | default: 'bg-secondary-light' }}">
              <div class="bundle-image">
                {% if section.settings.bundle_image != blank %}
                  <img src="{{ section.settings.bundle_image | image_url: width: 150 }}" alt="{{ section.settings.bundle_image_alt | default: 'Bundle products' }}" loading="lazy">
                {% endif %}
              </div>
              <div class="bundle-content">
                {% if section.settings.bundle_title != blank %}
                <h3 class="{{ section.settings.bundle_title_font_size | default: 'text-base' }} {{ section.settings.bundle_title_color | default: 'text-primary' }} leading-heading">
                  {{ section.settings.bundle_title }}
                </h3>
                {% endif %}
                
                {% if section.settings.bundle_description != blank %}
                <p class="{{ section.settings.bundle_description_font_size | default: 'text-sm' }} {{ section.settings.bundle_description_color | default: 'text-primary' }} leading-body">
                  {{ section.settings.bundle_description }}
                </p>
                {% endif %}
                
                <div class="bundle-footer">
                  {% if section.settings.bundle_price != blank %}
                  <div class="bundle-pricing">
                    <span class="bundle-price {{ section.settings.bundle_price_font_size | default: 'text-base' }} {{ section.settings.bundle_price_color | default: 'text-primary' }}">
                      {{ section.settings.bundle_price }}
                    </span>
                    {% if section.settings.show_bundle_original_price and section.settings.bundle_original_price != blank %}
                    <span class="bundle-original-price {{ section.settings.bundle_price_font_size | default: 'text-base' }}">
                      {{ section.settings.bundle_original_price }}
                    </span>
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  {% if section.settings.show_bundle_button %}
                  <a href="{{ section.settings.bundle_button_url | default: '#' }}" class="btn btn-{{ section.settings.bundle_button_style | default: 'filled' }}-{{ section.settings.bundle_button_color | default: 'primary' }} {{ section.settings.bundle_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                    {{ section.settings.bundle_button_text | default: 'Add' }}
                  </a>
                  {% endif %}
                </div>
              </div>
            </div>
            {% endif %}
            
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
  
  <!-- Sticky Footer (appears on scroll) -->
  {% if section.settings.show_sticky_footer %}
  <div class="sticky-footer" id="stickyFooter-{{ section.id }}">
    <div class="sticky-footer-content">
      <div class="sticky-product-info">
        {% if section.settings.hero_image != blank %}
        <div class="sticky-thumb">
          <img src="{{ section.settings.hero_image | image_url: width: 100 }}" alt="{{ section.settings.product_title }}">
        </div>
        {% endif %}
        <div class="sticky-text">
          {% if section.settings.product_code != blank %}
          <span class="sticky-code {{ section.settings.sticky_code_font_size | default: 'text-sm' }} {{ section.settings.sticky_code_color | default: 'text-primary' }}">
            {{ section.settings.product_code }}<sup>{{ section.settings.code_superscript | default: '™' }}</sup>
          </span>
          {% endif %}
          {% if section.settings.product_title != blank %}
          <h3 class="{{ section.settings.sticky_title_font_size | default: 'text-lg' }} {{ section.settings.sticky_title_color | default: 'text-primary' }} leading-heading">
            {{ section.settings.product_title }}
          </h3>
          {% endif %}
        </div>
      </div>
      <div class="sticky-cta">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.sticky_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
          {{ section.settings.cta_text | default: 'Start Now' }}
        </a>
      </div>
    </div>
  </div>
  {% endif %}
  
  <!-- Image Modal/Lightbox -->
  <div class="image-modal" id="imageModal-{{ section.id }}">
    <button class="modal-close" aria-label="Close modal">&times;</button>
    <div class="modal-content">
      <div class="modal-main-image">
        <img src="" alt="" id="modalMainImage-{{ section.id }}">
      </div>
      <div class="modal-thumbnails">
        <!-- Hero thumbnail -->
        {% if section.settings.hero_image != blank %}
        <div class="modal-thumb" data-index="0">
          <img src="{{ section.settings.hero_image | image_url: width: 150 }}" alt="Thumbnail" data-full-src="{{ section.settings.hero_image | image_url: width: 1600 }}">
        </div>
        {% endif %}
        
        <!-- Gallery thumbnails -->
        {% assign gallery_blocks = section.blocks | where: "type", "gallery_image" %}
        {% for block in gallery_blocks limit: 4 %}
          {% if block.settings.image != blank %}
          <div class="modal-thumb" data-index="{{ forloop.index }}">
            <img src="{{ block.settings.image | image_url: width: 150 }}" alt="Thumbnail" data-full-src="{{ block.settings.image | image_url: width: 1600 }}">
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
  
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const modal = document.getElementById('imageModal-' + sectionId);
  const modalMainImage = document.getElementById('modalMainImage-' + sectionId);
  const clickableImages = document.querySelectorAll('#product-header-' + sectionId + ' .clickable-image');
  const modalClose = modal.querySelector('.modal-close');
  const modalThumbs = modal.querySelectorAll('.modal-thumb');
  
  let currentIndex = 0;
  
  // Open modal when clicking an image
  clickableImages.forEach((img, index) => {
    img.addEventListener('click', function() {
      const fullSrc = this.getAttribute('data-full-src');
      const mediaIndex = this.closest('[data-media-index]').getAttribute('data-media-index');
      
      modalMainImage.src = fullSrc;
      modalMainImage.alt = this.alt;
      currentIndex = parseInt(mediaIndex);
      
      // Update active thumbnail
      updateActiveThumbnail(currentIndex);
      
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    });
  });
  
  // Close modal
  function closeModal() {
    modal.classList.remove('active');
    document.body.style.overflow = '';
  }
  
  modalClose.addEventListener('click', closeModal);
  
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });
  
  // ESC key to close
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('active')) {
      closeModal();
    }
  });
  
  // Thumbnail navigation
  modalThumbs.forEach((thumb, index) => {
    thumb.addEventListener('click', function() {
      const img = this.querySelector('img');
      const fullSrc = img.getAttribute('data-full-src');
      const thumbIndex = parseInt(this.getAttribute('data-index'));
      
      modalMainImage.src = fullSrc;
      modalMainImage.alt = img.alt;
      currentIndex = thumbIndex;
      
      updateActiveThumbnail(currentIndex);
    });
  });
  
  function updateActiveThumbnail(index) {
    modalThumbs.forEach((thumb, i) => {
      if (parseInt(thumb.getAttribute('data-index')) === index) {
        thumb.classList.add('active');
      } else {
        thumb.classList.remove('active');
      }
    });
  }
  
  // Accordion functionality
  const accordions = document.querySelectorAll('#product-header-' + sectionId + ' .accordion-header');
  
  accordions.forEach(header => {
    header.addEventListener('click', function() {
      const item = this.parentElement;
      const wasActive = item.classList.contains('active');
      
      if (wasActive) {
        item.classList.remove('active');
      } else {
        item.classList.add('active');
      }
    });
  });
  
  // Sticky Footer functionality
  const stickyFooter = document.getElementById('stickyFooter-' + sectionId);
  const productSection = document.getElementById('product-header-' + sectionId);
  
  if (stickyFooter && productSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Section is in view, hide sticky footer
            stickyFooter.classList.remove('visible');
          } else {
            // Section is out of view, show sticky footer
            stickyFooter.classList.add('visible');
          }
        });
      },
      {
        threshold: 0,
        rootMargin: '-100px 0px 0px 0px'
      }
    );
    
    observer.observe(productSection);
  }
})();
</script>

{% schema %}
{
  "name": "Product Header 2",
  "tag": "section",
  "class": "product-header-2-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Width (Container)"
    },
    {
      "type": "select",
      "id": "container_layout_width",
      "label": "Layout Width (Container)",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-full", "label": "Full Width (Container Full)" }
