<!-- CTA Hero with Image Section -->
<section class="cta-hero-image {% if section.settings.background_type == 'color' or section.settings.background_type == 'both' %}{{ section.settings.background_color | default: 'bg-secondary' }}{% endif %} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="cta-hero-{{ section.id }}" {% if section.settings.background_image and (section.settings.background_type == 'image' or section.settings.background_type == 'both') %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  {% if section.settings.background_image and (section.settings.background_type == 'image' or section.settings.background_type == 'both') and section.settings.overlay_enabled %}
  <div class="cta-hero-overlay" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.5 }});"></div>
  {% endif %}
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="cta-hero-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="cta-hero-grid">
        
        <!-- Content Column -->
        <div class="cta-hero-content">
          
          <!-- Heading -->
          {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
          <div class="cta-hero-heading mb-sm">
            <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="line-height: 1.1; letter-spacing: -0.03em;">
              {% if section.settings.heading_line_1 != blank %}
                {{ section.settings.heading_line_1 }}<br>
              {% endif %}
              {% if section.settings.heading_line_2 != blank %}
                {{ section.settings.heading_line_2 }}
              {% endif %}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.description != blank %}
          <div class="cta-hero-description mb-lg">
            <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }} leading-body">
              {{ section.settings.description }}
            </p>
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button %}
          <div class="cta-hero-button mb-sm">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text | default: 'Shop Now' }}
            </a>
          </div>
          {% endif %}
          
          <!-- Subtext/Notice -->
          {% if section.settings.show_subtext and section.settings.subtext != blank %}
          <div class="cta-hero-subtext">
            <p class="{{ section.settings.subtext_font_size | default: 'text-sm' }} {{ section.settings.subtext_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.subtext_font_weight | default: 'font-normal' }} {{ section.settings.subtext_color | default: 'text-black' }} leading-body">
              {{ section.settings.subtext }}
            </p>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Image Column -->
        <div class="cta-hero-image">
          {% if section.settings.product_image != blank %}
            <img src="{{ section.settings.product_image | image_url: width: 800 }}" alt="{{ section.settings.image_alt | default: 'Product' }}" loading="lazy">
          {% else %}
            <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy">
          {% endif %}
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

