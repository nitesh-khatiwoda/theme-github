<link rel="stylesheet" href="{{ 'testimonials-videos-grid/styles.css' | asset_url }}">

{% comment %} Count visible blocks {% endcomment %}
{% assign visible_block_count = 0 %}
{% for block in section.blocks %}
  {% if block.type == 'testimonial' %}
    {% assign visible_block_count = visible_block_count | plus: 1 %}
  {% elsif block.type == 'video_card' and section.settings.hide_video_blocks != true %}
    {% assign visible_block_count = visible_block_count | plus: 1 %}
  {% endif %}
{% endfor %}

{% comment %} Calculate actual column counts (capped by visible items) {% endcomment %}
{% assign cols_mobile = section.settings.columns_mobile | default: 1 %}
{% assign cols_tablet = section.settings.columns_tablet | default: 2 %}
{% assign cols_desktop = section.settings.columns_desktop | default: 4 %}

{% if visible_block_count < cols_mobile %}{% assign cols_mobile = visible_block_count %}{% endif %}
{% if visible_block_count < cols_tablet %}{% assign cols_tablet = visible_block_count %}{% endif %}
{% if visible_block_count < cols_desktop %}{% assign cols_desktop = visible_block_count %}{% endif %}

<!-- Testimonials & Videos Grid Section -->
<section class="testimonials-videos-grid {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}}  {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="testimonials-videos-grid-{{ section.id }}" {% if section.settings.background_image %}style="background-image: url('{{ section.settings.background_image | image_url }}');"{% endif %}>
  
  <!-- Gradient Overlays -->
  {% if section.settings.show_top_gradient %}
  <div class="gradient-overlay gradient-overlay--top" style="--gradient-color: var(--clr-{{ section.settings.top_gradient_color | default: 'black' }}); --gradient-height: {{ section.settings.top_gradient_height | default: 150 }}px;"></div>
  {% endif %}
  {% if section.settings.show_bottom_gradient %}
  <div class="gradient-overlay gradient-overlay--bottom" style="--gradient-color: var(--clr-{{ section.settings.bottom_gradient_color | default: 'black' }}); --gradient-height: {{ section.settings.bottom_gradient_height | default: 150 }}px;"></div>
  {% endif %}
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="testimonials-videos-grid-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}style="background-image: url('{{ section.settings.container_background_image | image_url }}');"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.show_heading and section.settings.heading != blank %}
      <div class="section-heading text-{{ section.settings.heading_alignment | default: 'center' }} mb-xl lg:mb-2xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }}">
          {{ section.settings.heading }}
        </h2>
        {% if section.settings.description != blank %}
        <div class="section-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
      </div>
      {% endif %}
      
      <!-- Grid -->
      {% if section.blocks.size > 0 %}
      <div class="cards-grid layout-masonry mobile-scroll {% if section.settings.content_based_height %}content-based-height{% endif %}" data-cols-mobile="{{ cols_mobile }}" data-cols-tablet="{{ cols_tablet }}" data-cols-desktop="{{ cols_desktop }}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'testimonial' %}
              <!-- Testimonial Card -->
              {% assign card_padding = section.settings.testimonial_card_padding | default: 'medium' %}
              {% case card_padding %}
                {% when 'small' %}
                  {% assign padding_classes = 'pt-md lg:pt-lg pb-md lg:pb-lg px-md lg:px-lg' %}
                {% when 'medium' %}
                  {% assign padding_classes = 'pt-lg lg:pt-xl pb-lg lg:pb-xl px-lg lg:px-xl' %}
                {% when 'large' %}
                  {% assign padding_classes = 'pt-xl lg:pt-2xl pb-xl lg:pb-2xl px-xl lg:px-2xl' %}
                {% else %}
                  {% assign padding_classes = 'pt-lg lg:pt-xl pb-lg lg:pb-xl px-lg lg:px-xl' %}
              {% endcase %}
              <div class="testimonial-card {{ section.settings.testimonial_card_background | default: 'bg-neutral-light' }} {{ section.settings.testimonial_card_border_radius | default: 'rounded-md' }} {{ padding_classes }} {% if section.settings.show_card_shadows %}card-with-shadow{% endif %}" {{ block.fluid_attributes }}>
                
                <!-- Stars Rating -->
                {% if section.settings.show_stars %}
                <div class="stars-rating stars-size-{{ section.settings.star_size | default: 'medium' }}">
                  {% assign star_rating = block.settings.star_rating | default: 5 %}
                  {% assign full_stars = star_rating | floor %}
                  {% assign empty_stars = 5 | minus: full_stars %}
                  
                  {% comment %} Full stars {% endcomment %}
                  {% if full_stars > 0 %}
                    {% for i in (1..full_stars) %}
                      <span class="star star-full {{ section.settings.star_color_filled | default: 'text-warning' }}">{{ section.settings.star_character | default: '★' }}</span>
                    {% endfor %}
                  {% endif %}
                  
                  {% comment %} Empty stars {% endcomment %}
                  {% if empty_stars > 0 %}
                    {% for i in (1..empty_stars) %}
                      <span class="star star-empty {{ section.settings.star_color_empty | default: 'text-neutral-light' }}">{{ section.settings.star_character | default: '★' }}</span>
                    {% endfor %}
                  {% endif %}
                </div>
                {% endif %}
                
                <!-- Review Text -->
                {% if block.settings.review_text != blank %}
                <p class="review-text {{ section.settings.review_font_family | default: 'font-body' }} {{ section.settings.review_font_size | default: 'text-lg' }} {{ section.settings.review_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.review_font_weight | default: 'font-normal' }} {{ section.settings.review_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.review_text }}
                  </p>
                {% endif %}
                
                <!-- Author Info -->
                {% if block.settings.author_name != blank or block.settings.author_avatar != blank %}
                <div class="testimonial-author">
                  {% if block.settings.author_avatar != blank %}
                  <div class="testimonial-author-avatar">
                    <img src="{{ block.settings.author_avatar | image_url: width: 80 }}" alt="{{ block.settings.author_name | default: 'Author' }}" class="author-avatar-image">
                  </div>
                  {% endif %}
                  {% if block.settings.author_name != blank %}
                  <span class="testimonial-author-name {{ section.settings.name_font_family | default: 'font-body' }} {{ section.settings.name_font_size | default: 'text-base' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.name_font_weight | default: 'font-semibold' }} {{ section.settings.name_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.author_name }}
                  </span>
                  {% endif %}
                </div>
                {% endif %}
                
              </div>
            
            {% when 'video_card' %}
              {% unless section.settings.hide_video_blocks %}
              <!-- Video Card -->
              <div class="video-card {{ section.settings.video_card_background | default: 'bg-black' }} {{ section.settings.video_card_border_radius | default: 'rounded-md' }} {% if section.settings.show_card_shadows %}card-with-shadow{% endif %}" {{ block.fluid_attributes }}>
                
                <!-- Video Content -->
                <div class="video-thumbnail-wrapper">
                  {% if block.settings.video_url != blank %}
                    <video
                      class="video-element"
                      autoplay
                      muted
                      loop
                      playsinline
                      {% if block.settings.poster_image %}poster="{{ block.settings.poster_image | image_url: width: 600 }}"{% endif %}
                    >
                      <source src="{{ block.settings.video_url }}" type="video/mp4">
                    </video>
                  {% elsif block.settings.poster_image != blank %}
                    <img src="{{ block.settings.poster_image | image_url: width: 600 }}" 
                         alt="{{ block.settings.title | default: 'Video thumbnail' }}" 
                         class="video-thumbnail"
                         loading="lazy">
                    
                    <!-- Play Button Overlay -->
                    {% if section.settings.show_play_button %}
                    <div class="play-button-overlay">
                      <svg class="play-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6.66667 4.16667L15.8333 10L6.66667 15.8333V4.16667Z" fill="currentColor"/>
                      </svg>
                    </div>
                    {% endif %}
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" 
                         alt="Add video URL to display video" 
                         class="video-thumbnail"
                         loading="lazy">
                    
                    <!-- Play Button Overlay (placeholder only) -->
                    {% if section.settings.show_play_button %}
                    <div class="play-button-overlay">
                      <svg class="play-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6.66667 4.16667L15.8333 10L6.66667 15.8333V4.16667Z" fill="currentColor"/>
                      </svg>
                    </div>
                    {% endif %}
                  {% endif %}
                </div>
                
              </div>
              {% endunless %}
          {% endcase %}
        {% endfor %}
      </div>
      
      <!-- Mobile Scroll Navigation -->
      <div class="mobile-scroll-nav {% if section.settings.mobile_scroll_controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
        <div class="scroll-arrows">
          <button class="scroll-arrow scroll-arrow-prev {{ section.settings.mobile_nav_button_background | default: 'bg-white' }} {{ section.settings.mobile_nav_button_color | default: 'text-black' }}" aria-label="Previous slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <button class="scroll-arrow scroll-arrow-next {{ section.settings.mobile_nav_button_background | default: 'bg-white' }} {{ section.settings.mobile_nav_button_color | default: 'text-black' }}" aria-label="Next slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
        
        {% if section.settings.show_mobile_scroll_dots %}
        <div class="scroll-dots">
          {% assign dot_index = 0 %}
          {% for block in section.blocks %}
            {% assign show_dot = false %}
            {% if block.type == 'testimonial' %}
              {% assign show_dot = true %}
            {% elsif block.type == 'video_card' and section.settings.hide_video_blocks != true %}
              {% assign show_dot = true %}
            {% endif %}
            {% if show_dot %}
              <button class="scroll-dot{% if dot_index == 0 %} active{% endif %}" data-index="{{ dot_index }}" aria-label="Go to slide {{ dot_index | plus: 1 }}"></button>
              {% assign dot_index = dot_index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const section = document.getElementById(`testimonials-videos-grid-${sectionId}`);
  if (!section) return;
  
  // ========================================
  // MASONRY LAYOUT - Even distribution logic
  // ========================================
  const grid = section.querySelector('.cards-grid.layout-masonry');
  if (grid) {
    const colsMobile = parseInt(grid.dataset.colsMobile) || 1;
    const colsTablet = parseInt(grid.dataset.colsTablet) || 2;
    const colsDesktop = parseInt(grid.dataset.colsDesktop) || 4;
    
    // Check if we're in mobile scroll mode
    function isMobileScrollMode() {
      return window.innerWidth < 768 && grid.classList.contains('mobile-scroll');
    }
    
    // Get current column count based on viewport
    function getColumnCount() {
      const width = window.innerWidth;
      if (width >= 1024) return colsDesktop;
      if (width >= 768) return colsTablet;
      return colsMobile;
    }
    
    // Distribute items into columns using "shortest column first" algorithm
    function distributeMasonry() {
      // Skip masonry distribution in mobile scroll mode
      if (isMobileScrollMode()) {
        // In mobile scroll mode, ensure cards are direct children (not in columns)
        const existingColumns = grid.querySelectorAll('.masonry-column');
        if (existingColumns.length > 0) {
          existingColumns.forEach(col => {
            while (col.firstChild) {
              grid.insertBefore(col.firstChild, col);
            }
            col.remove();
          });
        }
        return;
      }
      
      // Get all cards (not column wrappers)
      const existingColumns = grid.querySelectorAll('.masonry-column');
      let cards = [];
      
      if (existingColumns.length > 0) {
        // Cards are already in columns, extract them
        existingColumns.forEach(col => {
          cards.push(...Array.from(col.children));
        });
        // Remove old columns
        existingColumns.forEach(col => col.remove());
      } else {
        // First run - cards are direct children
        cards = Array.from(grid.querySelectorAll('.testimonial-card, .video-card'));
      }
      
      if (cards.length === 0) return;
      
      const columnCount = Math.min(getColumnCount(), cards.length); // Never more columns than cards
      
      // Create column containers
      const columns = [];
      const columnHeights = [];
      for (let i = 0; i < columnCount; i++) {
        const col = document.createElement('div');
        col.className = 'masonry-column';
        columns.push(col);
        columnHeights.push(0);
      }
      
      // Distribute cards to shortest column (for balanced heights)
      cards.forEach(card => {
        // Find the shortest column
        let shortestIndex = 0;
        let shortestHeight = columnHeights[0];
        for (let i = 1; i < columnCount; i++) {
          if (columnHeights[i] < shortestHeight) {
            shortestHeight = columnHeights[i];
            shortestIndex = i;
          }
        }
        
        // Add card to shortest column
        columns[shortestIndex].appendChild(card);
        // Estimate height (use actual height if rendered, otherwise estimate)
        columnHeights[shortestIndex] += card.offsetHeight || 400;
      });
      
      // Add columns to grid
      columns.forEach(col => {
        if (col.children.length > 0) {
          grid.appendChild(col);
        }
      });
    }
    
    // Run on load
    distributeMasonry();
    
    // Re-run on resize (debounced)
    let resizeTimeout;
    let lastColumnCount = getColumnCount();
    let wasMobileScroll = isMobileScrollMode();
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const newColumnCount = getColumnCount();
        const nowMobileScroll = isMobileScrollMode();
        if (newColumnCount !== lastColumnCount || nowMobileScroll !== wasMobileScroll) {
          lastColumnCount = newColumnCount;
          wasMobileScroll = nowMobileScroll;
          distributeMasonry();
        }
      }, 150);
    });
    
    // ========================================
    // MOBILE SCROLL NAVIGATION
    // ========================================
    const scrollNav = section.querySelector('.mobile-scroll-nav');
    const dots = section.querySelectorAll('.scroll-dot');
    const prevBtn = section.querySelector('.scroll-arrow-prev');
    const nextBtn = section.querySelector('.scroll-arrow-next');
    
    if (scrollNav) {
      let currentIndex = 0;
      
      // Get all cards in the grid (direct children or from columns)
      function getCards() {
        const columns = grid.querySelectorAll('.masonry-column');
        if (columns.length > 0) {
          let cards = [];
          columns.forEach(col => {
            cards.push(...Array.from(col.querySelectorAll('.testimonial-card, .video-card')));
          });
          return cards;
        }
        return Array.from(grid.querySelectorAll(':scope > .testimonial-card, :scope > .video-card'));
      }
      
      // Scroll to a specific card index
      function scrollToCard(index) {
        const cards = getCards();
        if (index < 0 || index >= cards.length) return;
        
        currentIndex = index;
        const card = cards[index];
        const cardWidth = card.offsetWidth;
        const gap = parseFloat(getComputedStyle(grid).gap) || 16;
        const scrollPosition = index * (cardWidth + gap);
        
        grid.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });
        
        updateDots();
        updateButtons();
      }
      
      // Update active dot
      function updateDots() {
        if (dots.length === 0) return;
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }
      
      // Update button states
      function updateButtons() {
        const cards = getCards();
        const maxIndex = cards.length - 1;
        
        if (prevBtn) {
          if (currentIndex === 0) {
            prevBtn.disabled = true;
            prevBtn.style.opacity = '0.4';
            prevBtn.style.cursor = 'not-allowed';
          } else {
            prevBtn.disabled = false;
            prevBtn.style.opacity = '0.7';
            prevBtn.style.cursor = 'pointer';
          }
        }
        
        if (nextBtn) {
          if (currentIndex >= maxIndex) {
            nextBtn.disabled = true;
            nextBtn.style.opacity = '0.4';
            nextBtn.style.cursor = 'not-allowed';
          } else {
            nextBtn.disabled = false;
            nextBtn.style.opacity = '0.7';
            nextBtn.style.cursor = 'pointer';
          }
        }
      }
      
      // Dot click handlers
      if (dots.length > 0) {
        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => scrollToCard(index));
        });
      }
      
      // Arrow click handlers
      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          scrollToCard(currentIndex - 1);
        });
      }
      
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          scrollToCard(currentIndex + 1);
        });
      }
      
      // Update current index on scroll
      let scrollTimeout;
      grid.addEventListener('scroll', () => {
        if (!isMobileScrollMode()) return;
        
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          const cards = getCards();
          const scrollLeft = grid.scrollLeft;
          const cardWidth = cards[0]?.offsetWidth || 280;
          const gap = parseFloat(getComputedStyle(grid).gap) || 16;
          
          const newIndex = Math.round(scrollLeft / (cardWidth + gap));
          if (newIndex !== currentIndex && newIndex >= 0 && newIndex < cards.length) {
            currentIndex = newIndex;
            updateDots();
            updateButtons();
          }
        }, 50);
      });
      
      // Initialize button states
      updateButtons();
    }
  }
  
  // Fade-up animation for all cards
  const allCards = section.querySelectorAll('.testimonial-card, .video-card');
  
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, index) => {
      if (entry.isIntersecting) {
        // Stagger the animation based on visible order
        const delay = index * 100;
        setTimeout(() => {
          entry.target.classList.add('fade-in');
        }, delay);
        fadeObserver.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  });
  
  allCards.forEach(card => {
    fadeObserver.observe(card);
  });
  
  const testimonialCards = section.querySelectorAll('.testimonial-card');
  if (testimonialCards.length === 0) return;
  
  // Function to animate typing effect with variable speed and cursor
  // Only types the last sentence, everything before appears instantly
  // Locks the element height before typing to prevent layout shifts
  function typeText(element, text, baseSpeed = 15) {
    return new Promise((resolve) => {
      // STEP 1: Measure and lock the final height BEFORE clearing the text
      // The element still has the full text at this point, so this is the final height
      const finalHeight = element.offsetHeight;
      element.style.minHeight = finalHeight + 'px';
      
      // Find the last sentence - look for the last sentence-ending punctuation
      // that's followed by a space and more text
      const sentenceEnders = /[.!?]\s+(?=[A-Z])/g;
      let lastSentenceStart = 0;
      let match;
      
      while ((match = sentenceEnders.exec(text)) !== null) {
        lastSentenceStart = match.index + match[0].length;
      }
      
      // If no sentence break found, type the last 30% as fallback
      if (lastSentenceStart === 0) {
        lastSentenceStart = Math.floor(text.length * 0.7);
      }
      
      const instantText = text.substring(0, lastSentenceStart);
      const typedText = text.substring(lastSentenceStart);
      
      let index = 0;
      
      // Create cursor element
      const cursor = document.createElement('span');
      cursor.className = 'typing-cursor';
      cursor.textContent = '|';
      
      // Create text container
      const textSpan = document.createElement('span');
      textSpan.className = 'typed-text';
      textSpan.textContent = instantText; // Start with instant portion
      
      // STEP 2: Now clear and rebuild - height is locked so no layout shift
      element.textContent = '';
      element.appendChild(textSpan);
      element.appendChild(cursor);
      
      // Create speed pattern - simulate natural typing variations
      const speedPattern = [];
      let currentSpeed = baseSpeed;
      let patternLength = 0;
      
      // Generate variable speed pattern for typed portion only
      for (let i = 0; i < typedText.length; i++) {
        // Change speed every 3-8 characters to simulate typing rhythm
        if (patternLength === 0 || patternLength >= 3 + Math.random() * 5) {
          // Random speed variation: 0.3x to 2.2x base speed for more variety
          const variation = 0.3 + Math.random() * 1.9;
          currentSpeed = baseSpeed * variation;
          patternLength = 0;
        }
        patternLength++;
        
        // Faster for spaces and punctuation
        if (typedText.charAt(i) === ' ') {
          speedPattern.push(currentSpeed * 0.15);
        } else if (/[.,!?;:]/.test(typedText.charAt(i))) {
          speedPattern.push(currentSpeed * 0.5);
        } else {
          speedPattern.push(currentSpeed);
        }
      }
      
      function type() {
        if (index < typedText.length) {
          textSpan.textContent += typedText.charAt(index);
          const delay = speedPattern[index] || baseSpeed;
          index++;
          setTimeout(type, delay);
        } else {
          // Remove cursor after typing is complete
          setTimeout(() => {
            cursor.style.opacity = '0';
            setTimeout(() => cursor.remove(), 300);
          }, 500);
          resolve();
        }
      }
      
      type();
    });
  }
  
  // Intersection Observer to trigger animation when cards come into view
  const observerOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, index) => {
      if (entry.isIntersecting && !entry.target.classList.contains('typing-animated')) {
        entry.target.classList.add('typing-animated');
        
        const reviewTextElement = entry.target.querySelector('.review-text');
        if (reviewTextElement) {
          const originalText = reviewTextElement.textContent.trim();
          const card = entry.target;
          
          // Lock the card height BEFORE typing starts to prevent layout shifts
          // This is especially important for content-based-height mode
          const cardHeight = card.offsetHeight;
          card.style.minHeight = cardHeight + 'px';
          
          // Wait for fade-in animation (600ms) + stagger delay between cards
          const fadeInDuration = 600;
          const staggerDelay = index * 150; // 150ms delay between each card
          const totalDelay = fadeInDuration + staggerDelay;
          
          // Variable base speed per card (8-18ms) to simulate different typing speeds
          const baseSpeed = 8 + Math.random() * 10;
          
          setTimeout(() => {
            typeText(reviewTextElement, originalText, baseSpeed).then(() => {
              // Fade in author info after typing completes
              const authorElement = entry.target.querySelector('.testimonial-author');
              if (authorElement) {
                setTimeout(() => {
                  authorElement.classList.add('fade-in');
                }, 200); // Small delay after typing finishes
              }
            });
          }, totalDelay);
        }
      }
    });
  }, observerOptions);
  
  // Observe all testimonial cards
  // testimonialCards.forEach((card) => {
  //   observer.observe(card);
  // });
  
})();
</script>

{% schema %}
{
  "name": "Testimonials & Videos Grid",
  "tag": "section",
  "class": "testimonials-videos-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Width (Container)"
    },
