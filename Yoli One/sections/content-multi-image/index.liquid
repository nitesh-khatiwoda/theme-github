<link rel="stylesheet" href="{{ 'content-multi-image/styles.css' | asset_url }}">

<!-- Content Multi-Image Section -->
<section class="content-multi-image {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-t-3xl' }}" id="content-multi-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="content-multi-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="content-image-wrapper {% if section.settings.flip_layout %}content-image-wrapper--flipped{% endif %}">
        
        <!-- Content Column -->
        <div class="content-column">
          
          <!-- Badge (Optional) -->
          {% if section.settings.show_badge and section.settings.badge_text != blank %}
          <div class="badge-wrapper">
            <div class="content-badge {{ section.settings.badge_background_color | default: 'bg-success' }}">
              <span class="{{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-primary' }}">
                {{ section.settings.badge_text }}
              </span>
            </div>
          </div>
          {% endif %}
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
          <div class="heading-wrapper">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Description -->
          {% if section.settings.description != blank %}
          <div class="description-wrapper">
            <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
              {{ section.settings.description }}
            </p>
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button and section.settings.button_text != blank %}
          <div class="button-wrapper">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text }}
            </a>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Image Column -->
        <div class="image-column">
          
          <!-- Hero Image -->
          {% if section.settings.hero_image != blank %}
          <div class="hero-image-wrapper">
            <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="{{ section.settings.hero_image_alt | default: 'Featured products' }}" loading="lazy">
          </div>
          {% else %}
          <div class="hero-image-wrapper">
            <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
          </div>
          {% endif %}
          
          <!-- Small Images Grid -->
          {% if section.blocks.size > 0 %}
          <div class="small-images-grid">
            {% for block in section.blocks %}
              {% if block.type == 'small_image' %}
              <div class="small-image-item" {{ block.fluid_attributes }}>
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.image_alt | default: 'Product detail' }}" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

