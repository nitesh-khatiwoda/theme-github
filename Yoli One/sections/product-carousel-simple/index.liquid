<!-- Product Carousel Simple - Minimal Version -->
<link rel="stylesheet" href="{{ 'product-carousel-simple/styles.css' | asset_url }}">

<section 
  class="product-carousel-simple {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }}"
  id="carousel-{{ section.id }}">
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-carousel-simple-inner {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }}">
      
      <!-- Title -->
      {% if section.settings.title != blank %}
      <div class="product-carousel-simple-header">
        <h2 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-black' }}">
          {{ section.settings.title }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Carousel -->
      {% if section.blocks.size > 0 %}
      <div class="product-carousel-simple-wrapper">
        <div class="product-carousel-simple-container">
          
          <!-- Track -->
          <div class="product-carousel-simple-track {{ section.settings.card_gap | default: 'gap-md' }}" id="track-{{ section.id }}">
            {% for block in section.blocks %}
              {% if block.type == 'product' %}
              <div class="product-carousel-simple-card" {{ block.fluid_attributes }}>
                <a href="{{ block.settings.product_url | default: '#' }}" class="product-card-link">
                  
                  <!-- Image -->
                  <div class="product-card-image-wrapper">
                    {% if block.settings.product_image %}
                      <img
                        src="{{ block.settings.product_image | image_url: width: 600 }}"
                        alt="{{ block.settings.product_title | default: 'Product image' }}"
                        class="product-card-image"
                        loading="lazy">
                    {% else %}
                      <svg class="product-card-image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" fill="none">
                        <rect width="400" height="400" fill="#f5f5f5"/>
                        <path d="M200 120c-22.1 0-40 17.9-40 40s17.9 40 40 40 40-17.9 40-40-17.9-40-40-40zm0 60c-11 0-20-9-20-20s9-20 20-20 20 9 20 20-9 20-20 20zm100 120H100l40-80 60 40 40-20 60 60z" fill="#d0d0d0"/>
                      </svg>
                    {% endif %}
                  </div>
                  
                  <!-- Info -->
                  <div class="product-card-info">
                    {% if block.settings.product_title != blank %}
                    <h3 class="{{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-lg' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }} {{ section.settings.product_title_color | default: 'text-black' }}">
                      {{ block.settings.product_title }}
                    </h3>
                    {% endif %}
                    
                    {% if block.settings.product_price != blank %}
                    <p class="{{ section.settings.product_price_font_family | default: 'font-body' }} {{ section.settings.product_price_font_size | default: 'text-base' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} {{ section.settings.product_price_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.product_price }}
                    </p>
                    {% endif %}
                  </div>
                  
                </a>
              </div>
              {% endif %}
            {% endfor %}
          </div>
          
        </div>
        
        <!-- Navigation -->
        <div class="product-carousel-simple-nav">
          <button class="carousel-nav-btn carousel-prev" id="prev-{{ section.id }}" aria-label="Previous">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <button class="carousel-nav-btn carousel-next" id="next-{{ section.id }}" aria-label="Next">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
        
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

<script>
(function() {
  try {
    // Wait for DOM to be fully loaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCarousel);
    } else {
      initCarousel();
    }
    
    function initCarousel() {
      try {
        const sectionId = '{{ section.id }}';
        const track = document.getElementById('track-' + sectionId);
        const prevBtn = document.getElementById('prev-' + sectionId);
        const nextBtn = document.getElementById('next-' + sectionId);
        
        if (!track || !prevBtn || !nextBtn) {
          console.warn('Product carousel: Elements not found');
          return;
        }
        
        const cards = track.querySelectorAll('.product-carousel-simple-card');
        if (cards.length === 0) {
          console.warn('Product carousel: No cards found');
          return;
        }
        
        let currentIndex = 0;
        
        function updateCarousel() {
          try {
            if (!cards[0]) return;
            
            // Get dimensions
            const cardWidth = cards[0].offsetWidth || 280;
            const trackStyles = window.getComputedStyle(track);
            const gap = parseInt(trackStyles.gap) || 16;
            
            // Calculate position
            const scrollDistance = currentIndex * (cardWidth + gap);
            
            // Apply animation
            track.style.transition = 'transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
            track.style.transform = 'translateX(-' + scrollDistance + 'px)';
            
            // Update buttons
            prevBtn.disabled = currentIndex === 0;
            nextBtn.disabled = currentIndex >= cards.length - 1;
            
            prevBtn.style.opacity = currentIndex === 0 ? '0.4' : '1';
            prevBtn.style.cursor = currentIndex === 0 ? 'not-allowed' : 'pointer';
            
            nextBtn.style.opacity = currentIndex >= cards.length - 1 ? '0.4' : '1';
            nextBtn.style.cursor = currentIndex >= cards.length - 1 ? 'not-allowed' : 'pointer';
          } catch (e) {
            console.error('Product carousel update error:', e);
          }
        }
        
        prevBtn.addEventListener('click', function() {
          if (currentIndex > 0) {
            currentIndex--;
            updateCarousel();
          }
        });
        
        nextBtn.addEventListener('click', function() {
          if (currentIndex < cards.length - 1) {
            currentIndex++;
            updateCarousel();
          }
        });
        
        // Initialize
        updateCarousel();
        
        // Handle resize
        let resizeTimeout;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(updateCarousel, 250);
        });
        
      } catch (e) {
        console.error('Product carousel initialization error:', e);
      }
    }
  } catch (e) {
    console.error('Product carousel script error:', e);
  }
})();
</script>

