<link rel="stylesheet" href="{{ 'image-content-split-list/styles.css' | asset_url }}">

<section 
  class="image-content-split-list {{ section.settings.background_color | default: 'bg-tertiary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="image-content-split-list-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout-width | default: 'container'}}">
    <div class="image-content-split-list-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="split-layout {% if section.settings.flip_layout %}split-layout--flipped{% endif %}">
        
        <!-- Image Column -->
        <div class="image-column">
          {% if section.settings.image != blank %}
          <img 
            src="{{ section.settings.image | image_url: width: 1200 }}" 
            alt="{{ section.settings.image_alt | default: section.settings.heading }}"
            class="section-image {{ section.settings.image_border_radius | default: 'rounded-lg' }}"
            loading="lazy">
          {% else %}
          <img 
            src="{{ 'placeholder-image.png' | asset_url }}" 
            alt="Placeholder"
            class="section-image {{ section.settings.image_border_radius | default: 'rounded-lg' }}"
            loading="lazy">
          {% endif %}
        </div>
        
        <!-- Content Column -->
        <div class="content-column">
          {% if section.settings.heading != blank %}
          <div class="heading-wrapper">
            <h2 class="heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-secondary' }}">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- List Items -->
          {% if section.blocks.size > 0 %}
          <div class="list-items">
            {% for block in section.blocks %}
              {% if block.type == 'list_item' %}
              <div class="list-item" {{ block.fluid_attributes }}>
                {% if block.settings.item_heading != blank %}
                <h3 class="item-heading {{ block.settings.heading_font_family | default: 'font-body' }} {{ block.settings.heading_font_size | default: 'text-lg' }} {{ block.settings.heading_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.heading_font_weight | default: 'font-bold' }} {{ block.settings.heading_color | default: 'text-secondary' }}">
                  {{ block.settings.item_heading }}
                </h3>
                {% endif %}
                
                {% if block.settings.item_description != blank %}
                <p class="item-description {{ block.settings.description_font_family | default: 'font-body' }} {{ block.settings.description_font_size | default: 'text-sm' }} {{ block.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.description_font_weight | default: 'font-normal' }} {{ block.settings.description_color | default: 'text-secondary' }}">
                  {{ block.settings.item_description }}
                </p>
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          
          {% if section.settings.show_button %}
          <div class="button-wrapper">
            <a href="{{ section.settings.button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'secondary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} font-body">
              {{ section.settings.button_text | default: 'Get Started' }}
            </a>
          </div>
          {% endif %}
        </div>
        
      </div>
    </div>
  </div>
</section>

