<link rel="stylesheet" href="{{ 'hero-main-with-cards/styles.css' | asset_url }}">

<!-- Hero Main with Cards Section -->
<section class="hero-main-cards {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }}" id="hero-main-{{ section.id }}">
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="hero-main-inner font-body">
      
      <!-- Top Header Row -->
      <div class="hero-header">
        <div class="header-left">
          <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-white' }} leading-heading">
            {{ section.settings.heading | default: "The peptide wellness company." }}
          </h1>
        </div>
        
        <div class="header-right">
          {% if section.blocks.size > 0 %}
          <div class="benefit-list">
            {% for block in section.blocks %}
              {% if block.type == 'benefit' %}
              <div class="benefit-item" {{ block.fluid_attributes }}>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="check-icon {{ section.settings.check_icon_color | default: 'text-white' }}">
                  <circle cx="8" cy="8" r="7.5" stroke="currentColor"/>
                  <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" fill="none"/>
                </svg>
                <span class="{{ section.settings.benefit_font_size | default: 'text-sm' }} {{ section.settings.benefit_color | default: 'text-white' }}">{{ block.settings.text }}</span>
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
      
      <!-- Hero Image + Cards Wrapper -->
      <div class="hero-cards-wrapper {{ section.settings.hero_border_radius | default: 'rounded' }}">
        
        <!-- Main Hero Image Section -->
        <a href="{{ section.settings.hero_button_url | default: '#' }}" class="hero-main-image" style="background-color: {{ section.settings.hero_bg_color | default: '#f3f5f6' }};">
          {% if section.settings.hero_image %}
          <img src="{{ section.settings.hero_image | image_url: width: 1400 }}" alt="{{ section.settings.hero_image_alt | default: 'Hero' }}" loading="eager" class="hero-image-zoom">
          {% endif %}
          
          <!-- Hero Overlay Content -->
          <div class="hero-overlay-content">
            <h2 class="{{ section.settings.overlay_heading_font_family | default: 'font-primary' }} {{ section.settings.overlay_heading_font_size | default: 'text-3xl' }} {{ section.settings.overlay_heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.overlay_heading_color | default: 'text-inverse' }} leading-heading">
              {{ section.settings.overlay_heading | default: "Remember when you felt like you? Let's get you back there." }}
            </h2>
            
            {% if section.settings.overlay_subline %}
            <p class="{{ section.settings.overlay_subline_font_size | default: 'text-base' }} {{ section.settings.overlay_subline_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.overlay_subline_color | default: 'text-inverse' }} {{ section.settings.overlay_subline_opacity | default: 'opacity-90' }}">
              {{ section.settings.overlay_subline | default: "The complete peptide system: energy, hydration, focus, weight loss, calm, and muscle recovery." }}
            </p>
            {% endif %}
            
            {% if section.settings.show_hero_button %}
            <span class="hero-quiz-btn" style="background-color: {{ section.settings.hero_button_bg | default: '#1a1a1a' }};">
              <span class="{{ section.settings.hero_button_color | default: 'text-inverse' }}">{{ section.settings.hero_button_text | default: 'Shop the collection' }}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="{{ section.settings.hero_button_color | default: 'text-inverse' }}">
                <path d="M3 8h10m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </span>
            {% endif %}
          </div>
        </a>
        
        <!-- Bottom Cards Row -->
        <div class="bottom-cards">
        
        <!-- Card 1 -->
        {% if section.settings.show_card_1 %}
        <a href="{{ section.settings.card_1_url | default: '#' }}" class="bottom-card {{ section.settings.card_1_bg | default: 'bg-card-primary' }}">
          <div class="card-icon">
            {% if section.settings.card_1_icon %}
            <img src="{{ section.settings.card_1_icon | image_url: width: 128 }}" alt="">
            {% endif %}
          </div>
          <div class="card-text">
            <h3 class="{{ section.settings.card_heading_font_size | default: 'text-lg' }} {{ section.settings.card_text_color | default: 'text-primary' }}">{{ section.settings.card_1_text | default: 'Sleep deeper tonight.' }}</h3>
          </div>
          <div class="card-arrow {{ section.settings.card_arrow_bg | default: 'bg-black' }}">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10m0 0l-4-4m4 4l-4 4" stroke="{{ section.settings.card_arrow_color | default: '#ffffff' }}" stroke-width="1.5"/>
            </svg>
          </div>
        </a>
        {% endif %}
        
        <!-- Card 2 -->
        {% if section.settings.show_card_2 %}
        <a href="{{ section.settings.card_2_url | default: '#' }}" class="bottom-card {{ section.settings.card_2_bg | default: 'bg-card-secondary' }}">
          <div class="card-icon">
            {% if section.settings.card_2_icon %}
            <img src="{{ section.settings.card_2_icon | image_url: width: 128 }}" alt="">
            {% endif %}
          </div>
          <div class="card-text">
            <h3 class="{{ section.settings.card_heading_font_size | default: 'text-lg' }} {{ section.settings.card_text_color | default: 'text-primary' }}">{{ section.settings.card_2_text | default: 'Build muscle. Burn fat. Stay hydrated.' }}</h3>
          </div>
          <div class="card-arrow {{ section.settings.card_arrow_bg | default: 'bg-black' }}">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10m0 0l-4-4m4 4l-4 4" stroke="{{ section.settings.card_arrow_color | default: '#ffffff' }}" stroke-width="1.5"/>
            </svg>
          </div>
        </a>
        {% endif %}
        
        <!-- Card 3 -->
        {% if section.settings.show_card_3 %}
        <a href="{{ section.settings.card_3_url | default: '#' }}" class="bottom-card {{ section.settings.card_3_bg | default: 'bg-accent-soft' }}">
          <div class="card-icon">
            {% if section.settings.card_3_icon %}
            <img src="{{ section.settings.card_3_icon | image_url: width: 128 }}" alt="">
            {% endif %}
          </div>
          <div class="card-text">
            <h3 class="{{ section.settings.card_heading_font_size | default: 'text-lg' }} {{ section.settings.card_text_color | default: 'text-primary' }}">{{ section.settings.card_3_text | default: 'Join the movement.' }}</h3>
          </div>
          <div class="card-arrow {{ section.settings.card_arrow_bg | default: 'bg-black' }}">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10m0 0l-4-4m4 4l-4 4" stroke="{{ section.settings.card_arrow_color | default: '#ffffff' }}" stroke-width="1.5"/>
            </svg>
          </div>
        </a>
        {% endif %}
        
        </div>
        
      </div><!-- End hero-cards-wrapper -->
      
    </div>
  </div>
  
</section>

