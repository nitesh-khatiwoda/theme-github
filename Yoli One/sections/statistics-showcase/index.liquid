{% comment %}
  Statistics Showcase Section
  Features heading, body text, and a grid of stat cards and lifestyle images
{% endcomment %}

<section class="statistics-showcase {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header Content -->
      <div class="statistics-header" style="max-width: 100%; margin: 0 auto;">
        <div class="header-content flex flex-col lg:flex-row gap-xl lg:gap-3xl">
          
          <!-- Heading Column -->
          <div class="heading-column {{ section.settings.heading_font_family | default: 'font-serif' }}" style="flex: 1;">
            <h2 class="{{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }} {{ section.settings.heading_font_weight | default: 'font-normal' }}" style="line-height: 1;">
              {{ section.settings.heading | default: "Big Change, Small Shift: Omega Effect in Numbers" }}
            </h2>
          </div>
          
          <!-- Body Text Column -->
          <div class="body-column {{ section.settings.body_font_family | default: 'font-body' }}" style="flex: 1;">
            <p class="{{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.body_color | default: 'text-neutral-dark' }} {{ section.settings.body_font_weight | default: 'font-normal' }}">
              {{ section.settings.body_text | default: "With every drop, every dose, and every decision, Yoli customers are seeing real results. From measurable shifts in Omega-3 levels to thousands of stories of better focus, energy, and wellbeing—these aren't just numbers. They're proof that better starts with balance." }}
            </p>
          </div>
          
        </div>
      </div>
      
      <!-- Statistics Grid -->
      {% if section.blocks.size > 0 %}
      <div class="statistics-grid {% if section.settings.flip_layout %}statistics-grid-flipped{% endif %}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'stat_card' %}
              <div class="stat-card {% if block.settings.display_as_image_only %}stat-card-image-only{% endif %} {{ section.settings.card_background_color | default: 'bg-neutral' }} {{ section.settings.card_border_radius | default: 'rounded-md' }}" {{ block.fluid_attributes }}>
                {% if block.settings.background_image %}
                  <div class="stat-card-bg-image {% if block.settings.display_as_image_only %}stat-card-bg-image-no-overlay{% endif %}" style="background-image: url('{{ block.settings.background_image | image_url }}');"></div>
                {% endif %}
                
                {% unless block.settings.display_as_image_only %}
                <div class="stat-card-content">
                  {% if block.settings.title != blank %}
                    <div class="stat-card-title {{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.title }}
                    </div>
                  {% endif %}
                  
                  <div class="stat-card-metric">
                    {% if block.settings.person_name != blank %}
                      <div class="stat-person-name {{ section.settings.metric_font_family | default: 'font-body' }} {{ section.settings.metric_font_size | default: 'text-6xl' }} {{ section.settings.metric_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.metric_font_weight | default: 'font-bold' }} {{ section.settings.metric_color | default: 'text-neutral-dark' }}">
                        {{ block.settings.person_name }}
                      </div>
                    {% endif %}
                    {% if block.settings.number != blank %}
                      <div class="stat-number {{ section.settings.metric_font_family | default: 'font-body' }} {{ section.settings.metric_font_size | default: 'text-6xl' }} {{ section.settings.metric_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.metric_font_weight | default: 'font-bold' }} {{ section.settings.metric_color | default: 'text-neutral-dark' }}">
                        {{ block.settings.number }}
                      </div>
                    {% endif %}
                    {% if block.settings.number != blank or block.settings.person_name != blank %}
                      <div class="stat-divider"></div>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <div class="stat-description {{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_description_color | default: 'text-neutral-dark' }}">
                        {{ block.settings.description }}
                      </div>
                    {% endif %}
                  </div>
                </div>
                {% endunless %}
              </div>
            
            {% when 'lifestyle_image' %}
              <div class="lifestyle-image-wrapper {{ section.settings.image_border_radius | default: 'rounded-md' }}" {{ block.fluid_attributes }}>
                {% if block.settings.image %}
                  <img src="{{ block.settings.image | image_url }}" 
                       alt="{{ block.settings.image_alt | default: 'Lifestyle image' }}" 
                       class="lifestyle-image w-full h-full object-cover">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" 
                       alt="Lifestyle image"
                       class="lifestyle-image w-full h-full object-cover">
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

<style>
  .statistics-showcase {
    position: relative;
    z-index: var(--z-10);
  }
  
  .statistics-showcase::after {
    display: none !important;
  }
  
  .statistics-showcase[data-bg]::after {
    content: "";
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    z-index: var(--z-0);
    background-color: rgba(0, 0, 0, 0.6);
    pointer-events: none;
    display: block !important;
  }
  
  .statistics-showcase .inner-container {
    position: relative;
    z-index: var(--z-10);
  }
  
  .statistics-showcase .inner-container[data-bg]:after {
    content: "";
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    z-index: var(--z-0);
    background-color: rgba(0, 0, 0, 0.6);
    pointer-events: none;
  }
  
  .statistics-showcase .inner-container > * {
    position: relative;
    z-index: var(--z-10);
  }
  
  .statistics-header {
    margin-bottom: var(--space-3xl);
  }
  
  .body-column {
    margin-bottom: var(--space-2xl);
  }
  
  .header-content {
    width: 100%;
  }
  
  .heading-column h2 {
    line-height: 1;
  }
  
  @media (min-width: 1024px) {
    .heading-column h2 {
      line-height: 67.2px;
    }
  }
  
  .statistics-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(300px, auto);
    gap: 16px;
    width: 100%;
  }
  
  @media (min-width: 768px) {
    .statistics-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(300px, auto);
      gap: 16px;
    }
  }
  
  @media (min-width: 1024px) {
    .statistics-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(250px, 275px);
      grid-auto-flow: row dense;
      align-items: start;
      gap: 16px;
      max-height: 600px;
      overflow: hidden;
    }
    
    .statistics-grid-flipped {
      direction: rtl;
    }
    
    .statistics-grid-flipped > * {
      direction: ltr;
    }
    
    .stat-card,
    .lifestyle-image-wrapper {
      grid-column: span 1;
    }
  }
  
  .stat-card {
    position: relative;
    min-height: 400px;
    padding: var(--space-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  
  @media (min-width: 1024px) {
    .stat-card {
      min-height: 250px;
      height: 100%;
    }
    
    .lifestyle-image-wrapper {
      height: 100%;
      min-height: 250px;
    }
  }
  
  .stat-card-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0.3;
    mix-blend-mode: darken;
    z-index: 0;
  }
  
  .stat-card-bg-image-no-overlay {
    opacity: 1;
    mix-blend-mode: normal;
  }
  
  .stat-card-image-only {
    padding: 0;
  }
  
  .stat-card-image-only .stat-card-bg-image {
    opacity: 1;
    mix-blend-mode: normal;
  }
  
  .stat-card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    height: 100%;
    justify-content: space-between;
  }
  
  .stat-card-title {
    margin-bottom: 0;
  }
  
  .stat-card-metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: flex-start;
  }
  
  .stat-number,
  .stat-person-name {
    line-height: 1;
    white-space: pre-line;
    margin-bottom: 0;
  }
  
  .stat-divider {
    width: 100%;
    height: 2px;
    background-color: var(--clr-neutral-dark);
    margin: var(--space-sm) 0;
  }
  
  .stat-description {
    text-align: right;
    width: 100%;
    margin-top: 0;
  }
  
  @media (min-width: 1024px) {
    .stat-description {
      text-align: right;
    }
  }
  
  .lifestyle-image-wrapper {
    width: 100%;
    height: 100%;
    min-height: 400px;
    overflow: hidden;
    border: 1px solid var(--clr-neutral);
  }
  
  @media (min-width: 1024px) {
    .lifestyle-image-wrapper {
      aspect-ratio: 1 / 1;
      min-height: auto;
    }
  }
  
  .lifestyle-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  @media (max-width: 767px) {
    .statistics-grid {
      gap: var(--space-lg);
    }
    
    .stat-card {
      min-height: 300px;
      padding: var(--space-lg);
    }
  }
</style>

