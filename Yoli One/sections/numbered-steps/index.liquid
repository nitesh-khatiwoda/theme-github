<link rel="stylesheet" href="{{ 'numbered-steps/styles.css' | asset_url }}">

<style>
  /* Number styles - color applies to all sizes */
  #section-{{ section.id }} .numbered-step-number-text {
    {% case section.settings.number_color | default: 'text-tertiary' %}
      {% when 'text-white' %}color: var(--clr-white);
      {% when 'text-black' %}color: var(--clr-black);
      {% when 'text-primary' %}color: var(--clr-primary);
      {% when 'text-secondary' %}color: var(--clr-secondary);
      {% when 'text-tertiary' %}color: var(--clr-tertiary);
      {% when 'text-quaternary' %}color: var(--clr-quaternary);
      {% when 'text-success' %}color: var(--clr-success);
      {% when 'text-warning' %}color: var(--clr-warning);
      {% when 'text-error' %}color: var(--clr-error);
      {% when 'text-info' %}color: var(--clr-info);
      {% when 'text-neutral' %}color: var(--clr-neutral);
      {% when 'text-neutral-light' %}color: var(--clr-neutral-light);
      {% when 'text-neutral-dark' %}color: var(--clr-neutral-dark);
    {% endcase %}
    {% case section.settings.number_font_family_mobile | default: section.settings.number_font_family | default: 'font-primary' %}
      {% when 'font-primary' %}font-family: var(--font-primary);
      {% when 'font-body' %}font-family: var(--font-body);
      {% when 'font-handwritten' %}font-family: var(--font-handwritten);
      {% when 'font-serif' %}font-family: var(--font-serif);
    {% endcase %}
    {% case section.settings.number_font_weight_mobile | default: section.settings.number_font_weight | default: 'font-bold' %}
      {% when 'font-light' %}font-weight: 300;
      {% when 'font-normal' %}font-weight: 400;
      {% when 'font-medium' %}font-weight: 500;
      {% when 'font-semibold' %}font-weight: 600;
      {% when 'font-bold' %}font-weight: 700;
    {% endcase %}
    font-style: italic;
    line-height: 1;
  }
  
  /* Desktop number styles - font family and weight only */
  @media (min-width: 769px) {
    #section-{{ section.id }} .numbered-step-number-text {
      {% case section.settings.number_font_family | default: 'font-primary' %}
        {% when 'font-primary' %}font-family: var(--font-primary);
        {% when 'font-body' %}font-family: var(--font-body);
        {% when 'font-handwritten' %}font-family: var(--font-handwritten);
        {% when 'font-serif' %}font-family: var(--font-serif);
      {% endcase %}
      {% case section.settings.number_font_weight | default: 'font-bold' %}
        {% when 'font-light' %}font-weight: 300;
        {% when 'font-normal' %}font-weight: 400;
        {% when 'font-medium' %}font-weight: 500;
        {% when 'font-semibold' %}font-weight: 600;
        {% when 'font-bold' %}font-weight: 700;
      {% endcase %}
    }
  }
</style>

<!-- Numbered Steps Section -->
<section class="numbered-steps {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %} id="section-{{ section.id }}">
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="numbered-steps-container">
    <div class="numbered-steps-inner {{ section.settings.container_background_color | default: 'bg-neutral-light' }} {{ section.settings.container_border_radius | default: 'rounded-md' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Steps List -->
      {% if section.blocks.size > 0 %}
      {% assign mobile_inline_class = '' %}
      {% if section.settings.mobile_inline_layout %}
        {% assign mobile_inline_class = ' numbered-steps-list--mobile-inline' %}
      {% endif %}
      <div class="numbered-steps-list{{ mobile_inline_class }}" data-section-id="{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
          <div class="numbered-step-item" {{ block.fluid_attributes }}>
            
            <!-- Step Number -->
            <div class="numbered-step-number">
              <span class="numbered-step-number-text {{ section.settings.number_font_size | default: 'text-6xl' }} {{ section.settings.number_font_size_desktop | default: 'lg:text-6xl' }}">
                {{ block.settings.step_number | default: forloop.index }}
              </span>
            </div>
            
            <!-- Step Content -->
            <div class="numbered-step-content">
              <!-- Step Title -->
              {% if block.settings.title != blank %}
              <div class="numbered-step-title mb-sm">
                <h3 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
                  {{ block.settings.title }}
                </h3>
              </div>
              {% endif %}
              
              <!-- Step Description -->
              {% if block.settings.description != blank %}
              <div class="numbered-step-description">
                <div class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
                  {{ block.settings.description }}
                </div>
              </div>
              {% endif %}
            </div>
            
          </div>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
  </div>
</section>

<script>
// Fade-in animation on scroll for numbered steps
(function() {
  const sectionId = 'section-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const stepsList = section.querySelector('.numbered-steps-list');
  if (!stepsList) return;
  
  const steps = Array.from(stepsList.querySelectorAll('.numbered-step-item'));
  if (steps.length === 0) return;
  
  let hasAnimated = false;
  
  function animateSteps() {
    if (hasAnimated) return;
    
    // Stagger animation: each step fades in 100ms after the previous one
    steps.forEach((step, index) => {
      setTimeout(() => {
        step.classList.add('animate-in');
      }, index * 100);
    });
    
    hasAnimated = true;
  }
  
  // Use Intersection Observer to detect when section is near viewport
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !hasAnimated) {
        // Trigger animation when section is 60% visible
        if (entry.intersectionRatio >= 0.6) {
          animateSteps();
        }
      }
    });
  }, {
    threshold: [0, 0.6],
    rootMargin: '0px 0px -10% 0px'
  });
  
  observer.observe(section);
  
  // Also check on load in case section is already in view
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      const rect = section.getBoundingClientRect();
      // Require section to be more scrolled into view (60% of viewport)
      if (rect.top < window.innerHeight * 0.4) {
        animateSteps();
      }
    });
  } else {
    const rect = section.getBoundingClientRect();
    // Require section to be more scrolled into view (60% of viewport)
    if (rect.top < window.innerHeight * 0.4) {
      animateSteps();
    }
  }
})();
</script>

