<link rel="stylesheet" href="{{ 'category-card-grid/styles.css' | asset_url }}">

<!-- Category Card Grid Section -->
<section class="category-card-grid {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="category-card-grid-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="category-card-grid-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.heading != blank %}
      <div class="section-heading text-center mb-2xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Category Cards Grid -->
      {% if section.blocks.size > 0 %}
      <div class="category-grid category-card-grid__grid {{ section.settings.grid_gap | default: 'gap-lg' }}">
        {% for block in section.blocks %}
          {% if block.type == 'category' %}
          <a href="{{ block.settings.category_url | default: '#' }}" 
             class="category-card relative overflow-hidden"
             style="border-radius: {{ section.settings.card_border_radius | default: 8 }}px; height: {{ section.settings.card_height | default: 200 }}px;"
             {{ block.fluid_attributes }}>
            
            <!-- Background Image -->
            <div class="category-bg absolute inset-0 z-0">
              {% if block.settings.background_image %}
                <img src="{{ block.settings.background_image | image_url: width: 600 }}" 
                     alt="{{ block.settings.category_title | default: 'Category' }}"
                     class="w-full h-full object-cover"
                     loading="lazy">
              {% else %}
                <img src="{{ 'placeholder-image.png' | asset_url }}" 
                     alt="Placeholder"
                     class="w-full h-full object-cover">
              {% endif %}
            </div>
            
            <!-- Overlay (optional) - 75% white when enabled -->
            {% if section.settings.show_overlay %}
            <div class="category-overlay absolute inset-0 z-10" style="background-color: rgba(255, 255, 255, 0.75);"></div>
            {% endif %}
            
            <!-- Content - Vertically and Horizontally Centered -->
            <div class="category-content absolute inset-0 z-20 flex items-center justify-center px-md">
              <div class="content-wrapper flex flex-col items-center">
                
                <!-- Icon -->
                {% if block.settings.icon %}
                <div class="category-icon" style="margin-bottom: {{ section.settings.icon_spacing | default: 16 }}px;">
                  <img src="{{ block.settings.icon | image_url: width: 100 }}" 
                       alt="{{ block.settings.category_title }} icon"
                       style="width: {{ section.settings.icon_size | default: 50 }}px; height: {{ section.settings.icon_size | default: 50 }}px; display: block;"
                       loading="lazy">
                </div>
                {% endif %}
                
                <!-- Title -->
                {% if block.settings.category_title != blank %}
                <div class="category-title">
                  <h3 class="{{ block.settings.title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: 'text-xl' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.title_font_weight | default: 'font-semibold' }} {{ block.settings.title_color | default: 'text-primary' }} text-center leading-heading" style="white-space: nowrap;">
                    {{ block.settings.category_title }}
                  </h3>
                </div>
                {% endif %}
                
              </div>
            </div>
            
          </a>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}

      <!-- Shop all button -->
      {% if section.settings.show_shop_all_button %}
      <div class="category-card-grid__cta">
        <a href="{{ section.settings.shop_all_button_url | default: '#' }}" 
           class="btn btn-{{ section.settings.shop_all_button_style | default: 'filled' }}-{{ section.settings.shop_all_button_color | default: 'primary' }} {{ section.settings.shop_all_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
          {{ section.settings.shop_all_button_text | default: 'Shop all' }}
        </a>
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

