<link rel="stylesheet" href="{{ 'cta-with-logos/styles.css' | asset_url }}">

<!-- CTA with Logos Section -->
<section class="cta-with-logos {{ section.settings.background_color | default: 'bg-card-primary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="cta-logos-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="cta-logos-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="cta-content-wrapper">
        
        <!-- Heading -->
        {% if section.settings.heading != blank or section.settings.heading_highlight != blank %}
        <div class="cta-heading">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
            {% if section.settings.heading != blank %}
              {{ section.settings.heading }}
            {% endif %}
            {% if section.settings.heading_highlight != blank %}
              <span class="{{ section.settings.highlight_color | default: 'text-accent' }}">{{ section.settings.heading_highlight }}</span>
            {% endif %}
          </h2>
        </div>
        {% endif %}
        
        <!-- Description -->
        {% if section.settings.description != blank %}
        <div class="cta-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
        
        <!-- CTA Button -->
        {% if section.settings.show_button and section.settings.button_text != blank %}
        <div class="cta-button-wrapper">
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
            {{ section.settings.button_text }}
          </a>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Logos Section -->
      {% if section.blocks.size > 0 %}
      <div class="logos-section">
        <div class="logos-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'logo' %}
            <div class="logo-item" {{ block.fluid_attributes }}>
              {% if block.settings.logo != blank %}
                <img src="{{ block.settings.logo | image_url: width: 400 }}" alt="{{ block.settings.logo_alt | default: 'Partner logo' }}" loading="lazy">
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

