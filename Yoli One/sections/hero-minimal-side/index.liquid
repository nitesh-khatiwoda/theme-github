<link rel="stylesheet" href="{{ 'hero-minimal-side/styles.css' | asset_url }}">

<!-- Hero Minimal Side Section -->
<section class="hero-minimal-side {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}">
  <div class="hero-minimal-side__outer-container">
    <div class="hero-minimal-side__wrapper {{ section.settings.hero_border_radius | default: 'rounded-lg' }}">
      
      <!-- Background Image/Video -->
      <div class="hero-minimal-side__background">
        {% if section.settings.background_image != blank %}
          <img src="{{ section.settings.background_image | image_url: width: 2000 }}" 
               alt="{{ section.settings.background_image_alt | default: 'Hero background' }}"
               class="hero-minimal-side__background-image">
        {% else %}
          <img src="{{ 'placeholder-image.png' | asset_url }}" 
               alt="Hero background placeholder"
               class="hero-minimal-side__background-image">
        {% endif %}
        
        <!-- Play Button Overlay (optional) -->
        {% if section.settings.show_play_button %}
          <button class="hero-minimal-side__play-button" aria-label="Play video">
            <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="15" fill="rgba(255, 255, 255, 0.9)"/>
              <path d="M12 9L21 15L12 21V9Z" fill="currentColor"/>
            </svg>
          </button>
        {% endif %}
      </div>
      
      <!-- Content Overlay -->
      <div class="hero-minimal-side__content-wrapper">
        <div class="hero-minimal-side__content">
          
          <!-- Eyebrow -->
          {% if section.settings.eyebrow != blank %}
            <p class="hero-minimal-side__eyebrow {{ section.settings.eyebrow_font_family | default: 'font-body' }} {{ section.settings.eyebrow_font_size | default: 'text-xs' }} {{ section.settings.eyebrow_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.eyebrow_font_weight | default: 'font-normal' }} {{ section.settings.eyebrow_color | default: 'text-white' }}">
              {{ section.settings.eyebrow }}
            </p>
          {% endif %}
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
            <h1 class="hero-minimal-side__heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }}">
              {{ section.settings.heading }}
            </h1>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button %}
            <div class="hero-minimal-side__button-wrapper">
              <a href="{{ section.settings.button_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-bold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                {{ section.settings.button_text | default: 'Get started' }}
              </a>
            </div>
          {% endif %}
          
        </div>
      </div>
      
    </div>
  </div>
</section>

