<link rel="stylesheet" href="{{ 'background-sub-page-header/styles.css' | asset_url }}">

<!-- Background Sub Page Header Section -->
<section class="bg-sub-page-header {{ section.settings.background_color | default: 'bg-black' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}">
  
  <!-- Desktop: Video with Overlay Content -->
  <div class="bg-sub-page-header__desktop">
    <!-- Background Video -->
    {% if section.settings.video_url != blank %}
      <video
        class="bg-sub-page-header__video"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.poster_image %}poster="{{ section.settings.poster_image | image_url }}"{% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4" />
      </video>
    {% else %}
      <!-- Fallback to poster image if no video -->
      {% if section.settings.poster_image %}
        <img src="{{ section.settings.poster_image | image_url }}" alt="Hero background" class="bg-sub-page-header__video" style="object-fit: cover;">
      {% else %}
        <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Hero background placeholder" class="bg-sub-page-header__video" style="object-fit: cover;">
      {% endif %}
    {% endif %}

    <!-- Overlay with Content -->
    <div class="bg-sub-page-header__overlay">
      <div class="container">
        <div class="bg-sub-page-header__content">
          
          <!-- Headline -->
          {% if section.settings.heading != blank %}
            <h1 class="bg-sub-page-header__headline {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }}">
              {{ section.settings.heading }}
            </h1>
          {% endif %}

          <!-- Subtext -->
          {% if section.settings.subtext != blank %}
            <div class="bg-sub-page-header__subtext {{ section.settings.subtext_font_family | default: 'font-body' }} {{ section.settings.subtext_font_size | default: 'text-base' }} {{ section.settings.subtext_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subtext_font_weight | default: 'font-normal' }} {{ section.settings.subtext_color | default: 'text-white' }}">
              {{ section.settings.subtext }}
            </div>
          {% endif %}

          <!-- Action Buttons -->
          {% if section.settings.show_button_one or section.settings.show_button_two %}
            <div class="bg-sub-page-header__actions">
              {% if section.settings.show_button_one %}
                <a href="{{ section.settings.button_one_url | default: '#' }}" 
                   class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'primary' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ section.settings.button_one_font_weight | default: 'font-semibold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                  {{ section.settings.button_one_text | default: 'Lorem Ipsum' }}
                </a>
              {% endif %}

              {% if section.settings.show_button_two %}
                <a href="{{ section.settings.button_two_url | default: '#' }}" 
                   class="btn btn-{{ section.settings.button_two_style | default: 'outline' }}-{{ section.settings.button_two_color | default: 'white' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ section.settings.button_two_font_weight | default: 'font-semibold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                  {{ section.settings.button_two_text | default: 'Lorem Ipsum' }}
                </a>
              {% endif %}
            </div>
          {% endif %}

        </div>
      </div>
    </div>
  </div>

  <!-- Mobile: Content in White Section Below Video -->
  <div class="bg-sub-page-header__mobile">
    <div class="bg-sub-page-header__mobile-content {{ section.settings.mobile_background_color | default: 'bg-white' }} {{ section.settings.container_padding_y_mobile | default: 'py-2xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}">
      <div class="bg-sub-page-header__mobile-inner">
        
        <!-- Headline -->
        {% if section.settings.heading != blank %}
          <h1 class="bg-sub-page-header__headline {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.mobile_heading_color | default: 'text-black' }}">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        <!-- Subtext -->
        {% if section.settings.subtext != blank %}
          <div class="bg-sub-page-header__subtext {{ section.settings.subtext_font_family | default: 'font-body' }} {{ section.settings.subtext_font_size | default: 'text-base' }} {{ section.settings.subtext_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subtext_font_weight | default: 'font-normal' }} {{ section.settings.mobile_subtext_color | default: 'text-white' }}">
            {{ section.settings.subtext }}
          </div>
        {% endif %}

        <!-- Action Buttons -->
        {% if section.settings.show_button_one or section.settings.show_button_two %}
          <div class="bg-sub-page-header__actions bg-sub-page-header__actions--mobile">
            {% if section.settings.show_button_one %}
              <a href="{{ section.settings.button_one_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'primary' }} {{ section.settings.button_one_size | default: 'btn-md' }} {{ section.settings.button_one_font_weight | default: 'font-semibold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                {{ section.settings.button_one_text | default: 'Lorem Ipsum' }}
              </a>
            {% endif %}

            {% if section.settings.show_button_two %}
              <a href="{{ section.settings.button_two_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_two_style | default: 'outline' }}-{{ section.settings.mobile_button_two_color | default: 'black' }} {{ section.settings.button_two_size | default: 'btn-md' }} {{ section.settings.button_two_font_weight | default: 'font-semibold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                {{ section.settings.button_two_text | default: 'Lorem Ipsum' }}
              </a>
            {% endif %}
          </div>
        {% endif %}

      </div>
    </div>
  </div>

</section>

