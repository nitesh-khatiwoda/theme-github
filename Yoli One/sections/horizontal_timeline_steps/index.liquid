<link rel="stylesheet" href="{{ 'horizontal_timeline_steps/styles.css' | asset_url }}">

<!-- Horizontal Timeline Steps Section -->
<section 
  class="horizontal-timeline-steps {{ section.settings.background_color | default: 'bg-neutral-light' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="section-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout-width | default:'container'}}">
    <div class="inner-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}"
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="timeline-wrapper">
        
        <!-- Left Column: Sticky Text -->
        <div class="left-column-sticky">
          
          <!-- Main Heading -->
          {% if section.settings.main_heading != blank %}
          <h1 class="{{ section.settings.main_heading_font_family | default: 'font-handwritten' }} {{ section.settings.main_heading_font_size | default: 'text-4xl' }} {{ section.settings.main_heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.main_heading_font_weight | default: 'font-normal' }} {{ section.settings.main_heading_color | default: 'text-primary' }}">
            {{ section.settings.main_heading }}
          </h1>
          {% endif %}
          
          <!-- Supporting Text -->
          {% if section.settings.supporting_text != blank %}
          <div class="supporting-text {{ section.settings.supporting_text_font_family | default: 'font-body' }} {{ section.settings.supporting_text_font_size | default: 'text-base' }} {{ section.settings.supporting_text_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.supporting_text_font_weight | default: 'font-normal' }} {{ section.settings.supporting_text_color | default: 'text-neutral-dark' }}">
            {{ section.settings.supporting_text }}
          </div>
          {% endif %}
          
        </div>
        
        <!-- Right Column: Scrollable Timeline -->
        <div class="right-column-timeline">
          
          <!-- Timeline Heading -->
          {% if section.settings.timeline_heading != blank %}
          <h2 class="{{ section.settings.timeline_heading_font_family | default: 'font-handwritten' }} {{ section.settings.timeline_heading_font_size | default: 'text-2xl' }} {{ section.settings.timeline_heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.timeline_heading_font_weight | default: 'font-normal' }} {{ section.settings.timeline_heading_color | default: 'text-primary' }} timeline-main-heading">
            {{ section.settings.timeline_heading }}
          </h2>
          {% endif %}
          
          <!-- Timeline Line Container -->
          <div class="timeline-line-container">
            <div class="timeline-line-bg {{ section.settings.timeline_line_color | default: 'bg-neutral' }}"></div>
            <div class="timeline-line-fill {{ section.settings.timeline_fill_color | default: 'bg-primary' }}"></div>
          </div>
          
          <!-- Steps Blocks -->
          {% if section.blocks.size > 0 %}
          <div class="steps-container">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'step' %}
                  <div class="step-item" {{ block.fluid_attributes }} data-step-index="{{ forloop.index0 }}">
                    
                    <!-- Circle Marker -->
                    <div class="step-marker">
                      <div class="marker-circle {{ section.settings.marker_background_color | default: 'bg-white' }} {{ section.settings.marker_border_color | default: 'border-black' }}"></div>
                    </div>
                    
                    <!-- Step Content -->
                    <div class="step-content">
                      
                      <!-- Step Title -->
                      {% if block.settings.step_title != blank %}
                      <h3 class="{{ section.settings.step_title_font_family | default: 'font-handwritten' }} {{ section.settings.step_title_font_size | default: 'text-xl' }} {{ section.settings.step_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.step_title_font_weight | default: 'font-normal' }} {{ section.settings.step_title_color | default: 'text-primary' }}">
                        {{ block.settings.step_title }}
                      </h3>
                      {% endif %}
                      
                      <!-- Step Description -->
                      {% if block.settings.step_description != blank %}
                      <div class="{{ section.settings.step_description_font_family | default: 'font-body' }} {{ section.settings.step_description_font_size | default: 'text-base' }} {{ section.settings.step_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.step_description_font_weight | default: 'font-normal' }} {{ section.settings.step_description_color | default: 'text-neutral-dark' }}">
                        {{ block.settings.step_description }}
                      </div>
                      {% endif %}
                      
                    </div>
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

