<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<!-- Shop by Category Section -->
<section class="shop-by-category {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="shop-by-category-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{ section.settings.container_layout_width | default: 'container' }}">
    <div class="shop-by-category-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Header -->
      <div class="shop-by-category-header text-center mb-2xl">
        {% if section.settings.heading != blank %}
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }} leading-heading mb-md">
          {{ section.settings.heading }}
        </h2>
        {% endif %}
        
        {% if section.settings.subtitle != blank %}
        <p class="{{ section.settings.subtitle_font_family | default: 'font-body' }} {{ section.settings.subtitle_font_size | default: 'text-base' }} {{ section.settings.subtitle_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subtitle_font_weight | default: 'font-normal' }} {{ section.settings.subtitle_color | default: 'text-black' }} leading-relaxed max-w-3xl mx-auto">
          {{ section.settings.subtitle }}
        </p>
        {% endif %}
      </div>
      
      <!-- Category Carousel -->
      {%- if section.blocks.size > 0 -%}
      <div class="shop-by-category-carousel-wrapper swiper" data-swiper-wrapper="{{ section.id }}">
        <div class="swiper-wrapper shop-by-category-carousel-track {{ section.settings.carousel_card_gap | default: 'gap-md' }}" data-carousel-track="{{ section.id }}">
            
            {%- comment -%} Block-based categories (primary method) {%- endcomment -%}
            {% for block in section.blocks %}
                {% if block.type == 'category_item' %}
                  {%- assign current_category = blank -%}
                  {%- assign category_url = block.settings.category_url | default: '#' -%}
                  {%- assign category_title = 'Category' -%}
                  {%- assign background_image = block.settings.background_image -%}
                  
                  {%- comment -%} If category is selected, use its data {%- endcomment -%}
                  {%- if block.settings.category != blank -%}
                    {%- assign category_setting = block.settings.category -%}
                    {%- assign category_id = blank -%}
                    
                    {%- comment -%} Handle both object and ID formats {%- endcomment -%}
                    {%- if category_setting.id != blank -%}
                      {%- assign category_id = category_setting.id -%}
                    {%- elsif category_setting != blank -%}
                      {%- assign category_id = category_setting -%}
                    {%- endif -%}
                    
                    {%- comment -%} Find category from global categories object {%- endcomment -%}
                    {%- if category_id != blank -%}
                      {%- assign category_id_num = category_id | plus: 0 -%}
                      {%- for cat in categories -%}
                        {%- assign cat_id = cat.id | plus: 0 -%}
                        {%- if cat_id == category_id_num -%}
                          {%- assign current_category = cat -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                    
                    {%- if current_category != blank -%}
                      {%- comment -%} Build shop URL with category filter - matching main_shop_list format {%- endcomment -%}
                      {%- assign shop_url = section.settings.shop_page_url | default: '/shop' -%}
                      {%- assign category_url = shop_url | append: '?filterrific[with_category_id][]=' | append: current_category.id -%}
                      {%- comment -%} Always use category title when category is selected {%- endcomment -%}
                      {%- assign category_title = current_category.title | default: 'Category' -%}
                      {%- comment -%} Use category image only if manual image is not provided {%- endcomment -%}
                      {%- if background_image == blank or background_image == null -%}
                        {%- if current_category.image != blank -%}
                          {%- assign background_image = current_category.image -%}
                        {%- elsif current_category.products.first != blank and current_category.products.first.images.first != blank -%}
                          {%- assign background_image = current_category.products.first.images.first -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                  
                  {%- comment -%} Use manual title if no category found or no category selected {%- endcomment -%}
                  {%- if current_category == blank and block.settings.category_title != blank and block.settings.category_title != '' -%}
                    {%- assign category_title = block.settings.category_title -%}
                  {%- endif -%}
                  
                  <div class="swiper-slide">
                    <a href="{{ category_url }}" 
                       class="shop-by-category-card"
                       style="border-radius: {{ section.settings.card_border_radius | default: 8 }}px; height: {{ section.settings.card_height | default: 400 }}px; min-width: {{ section.settings.card_width_mobile | default: 280 }}px; width: {{ section.settings.card_width_mobile | default: 280 }}px;"
                       {{ block.fluid_attributes }}
                       {% if current_category != blank %}data-category-id="{{ current_category.id }}"{% endif %}>
                    
                    <!-- Background Image -->
                    <div class="shop-by-category-bg">
                      {% if background_image %}
                        <img src="{{ background_image | image_url: width: 800 }}" 
                             alt="{{ category_title }}"
                             class="w-full h-full object-cover"
                             loading="lazy">
                      {% else %}
                        <img src="{{ 'placeholder-image.png' | asset_url }}" 
                             alt="Placeholder"
                             class="w-full h-full object-cover">
                      {% endif %}
                    </div>
                    
                    <!-- Overlay (optional) -->
                    {% if section.settings.show_overlay %}
                    <div class="shop-by-category-overlay" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.3 }});"></div>
                    {% endif %}
                    
                    <!-- Content - Bottom Left Aligned -->
                    <div class="shop-by-category-content">
                      <div class="shop-by-category-title-wrapper">
                        {% if category_title != blank %}
                        <h3 class="{{ block.settings.title_font_family | default: section.settings.title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: section.settings.title_font_size | default: 'text-xl' }} {{ block.settings.title_font_size_desktop | default: section.settings.title_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.title_font_weight | default: section.settings.title_font_weight | default: 'font-semibold' }} {{ block.settings.title_color | default: section.settings.title_color | default: 'text-white' }}">
                          {{ category_title }}
                        </h3>
                        {% endif %}
                      </div>
                    </div>
                    
                    </a>
                  </div>
                {% endif %}
              {% endfor %}
            
        </div>
      </div>
      {%- endif -%}
      
    </div>
  </div>
</section>

<style>
  #shop-by-category-{{ section.id }} .shop-by-category-card {
    min-width: {{ section.settings.card_width_mobile | default: 280 }}px;
    width: {{ section.settings.card_width_mobile | default: 280 }}px;
  }
  @media (min-width: 640px) {
    #shop-by-category-{{ section.id }} .shop-by-category-card {
      min-width: {{ section.settings.card_width_tablet | default: 320 }}px;
      width: {{ section.settings.card_width_tablet | default: 320 }}px;
    }
  }
  @media (min-width: 1024px) {
    #shop-by-category-{{ section.id }} .shop-by-category-card {
      min-width: {{ section.settings.card_width_desktop | default: 400 }}px;
      width: {{ section.settings.card_width_desktop | default: 400 }}px;
    }
  }
</style>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
(function() {
  try {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSwiper);
    } else {
      initSwiper();
    }
    
    function initSwiper() {
      const sectionId = '{{ section.id }}';
      const swiperWrapper = document.querySelector(`[data-swiper-wrapper="${sectionId}"]`);
      
      if (!swiperWrapper) {
        return;
      }
      
      // Get only original slides (exclude clones)
      const slides = swiperWrapper.querySelectorAll('.swiper-slide:not([data-clone])');
      
      if (slides.length === 0) {
        return;
      }
      
      // For single slide, don't initialize Swiper or clone
      if (slides.length === 1) {
        return;
      }
      
      // Prevent multiple initializations
      if (swiperWrapper.swiper) {
        swiperWrapper.swiper.destroy(true, true);
      }
      
      // Remove any existing clones first
      const wrapper = swiperWrapper.querySelector('.swiper-wrapper');
      wrapper.querySelectorAll('[data-clone]').forEach(clone => clone.remove());
      
      const scrollSpeed = parseFloat('{{ section.settings.scroll_speed | default: 1 }}') || 1;
      
      // Get gap from CSS
      const gap = parseInt(getComputedStyle(wrapper).gap) || parseInt(getComputedStyle(wrapper).columnGap) || 16;
      
      // Initialize Swiper without loop (we'll handle looping manually)
      const swiper = new Swiper(swiperWrapper, {
        slidesPerView: 'auto',
        spaceBetween: gap,
        loop: false, // Disable Swiper's loop, we'll handle it manually
        speed: 1000,
        allowTouchMove: true,
        grabCursor: true,
        freeMode: false,
        watchSlidesProgress: true,
        watchSlidesVisibility: true,
      });
      
      // Get original slides array
      const originalSlides = Array.from(slides);
      
      // Check if we should enable auto-scroll
      // Below 1024px: Always scroll if more than 1 item
      // Above 1024px: Only scroll if more than 3 items
      function shouldAutoScroll() {
        const viewportWidth = window.innerWidth;
        if (viewportWidth <= 1024) {
          return originalSlides.length > 1; // Always scroll below 1024px if more than 1 item
        } else {
          return originalSlides.length > 3; // Above 1024px, only scroll if more than 3 items
        }
      }
      
      // Only clone slides if we actually need auto-scroll
      // This prevents showing duplicate blocks when scrolling isn't active
      if (shouldAutoScroll()) {
        const cloneCount = 2; // Clone twice for seamless looping
        
        for (let i = 0; i < cloneCount; i++) {
          originalSlides.forEach(slide => {
            const clone = slide.cloneNode(true);
            clone.setAttribute('data-clone', 'true');
            clone.setAttribute('aria-hidden', 'true');
            wrapper.appendChild(clone);
          });
        }
        
        // Reinitialize Swiper to recognize new slides
        swiper.update();
      }
      
      // Custom continuous autoplay with seamless loop
      let scrollPosition = 0;
      let isPaused = false;
      let lastTime = performance.now();
      let animationFrameId = null;
      const pixelsPerMs = scrollSpeed * 0.1; // Pixels per millisecond
      
      // Calculate original content width (for seamless reset)
      function getOriginalWidth() {
        let width = 0;
        originalSlides.forEach((slide, index) => {
          const slideWidth = slide.offsetWidth;
          width += slideWidth;
          if (index < originalSlides.length - 1) {
            width += gap;
          }
        });
        return width;
      }
      
      let originalWidth = getOriginalWidth();
      
      function continuousScroll(currentTime) {
        // Check if we should continue scrolling
        if (!shouldAutoScroll()) {
          // Reset position to 0 if we shouldn't scroll
          scrollPosition = 0;
          wrapper.style.transform = 'translate3d(0, 0, 0)';
          animationFrameId = null;
          return;
        }
        
        if (!swiper || !swiper.slides || swiper.slides.length === 0) {
          return;
        }
        
        if (isPaused) {
          lastTime = currentTime;
          animationFrameId = requestAnimationFrame(continuousScroll);
          return;
        }
        
        const deltaTime = currentTime - lastTime;
        lastTime = currentTime;
        
        scrollPosition += pixelsPerMs * deltaTime;
        
        // Recalculate width on resize
        const currentOriginalWidth = getOriginalWidth();
        if (currentOriginalWidth > 0 && currentOriginalWidth !== originalWidth) {
          originalWidth = currentOriginalWidth;
        }
        
        // Reset position seamlessly when scrolled past original content
        if (originalWidth > 0 && scrollPosition >= originalWidth) {
          scrollPosition = scrollPosition % originalWidth;
        }
        
        // Apply transform directly to wrapper for smoother performance
        wrapper.style.transform = `translate3d(-${scrollPosition}px, 0, 0)`;
        wrapper.style.willChange = 'transform';
        
        animationFrameId = requestAnimationFrame(continuousScroll);
      }
      
      // Handle resize to recalculate width and start/stop scrolling
      let resizeTimeout;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(function() {
          originalWidth = getOriginalWidth();
          // Adjust scroll position if needed
          if (scrollPosition >= originalWidth) {
            scrollPosition = scrollPosition % originalWidth;
          }
          
          // Check if we need clones
          const hasClones = wrapper.querySelectorAll('[data-clone]').length > 0;
          const needsClones = shouldAutoScroll();
          
          // Add or remove clones based on conditions
          if (needsClones && !hasClones) {
            // Need clones but don't have them - add them
            const cloneCount = 2;
            for (let i = 0; i < cloneCount; i++) {
              originalSlides.forEach(slide => {
                const clone = slide.cloneNode(true);
                clone.setAttribute('data-clone', 'true');
                clone.setAttribute('aria-hidden', 'true');
                wrapper.appendChild(clone);
              });
            }
            swiper.update();
          } else if (!needsClones && hasClones) {
            // Don't need clones but have them - remove them
            wrapper.querySelectorAll('[data-clone]').forEach(clone => clone.remove());
            swiper.update();
            scrollPosition = 0;
            wrapper.style.transform = 'translate3d(0, 0, 0)';
          }
          
          // Start or stop scrolling based on conditions
          if (shouldAutoScroll() && !animationFrameId) {
            lastTime = performance.now();
            animationFrameId = requestAnimationFrame(continuousScroll);
          } else if (!shouldAutoScroll() && animationFrameId) {
            cancelAnimationFrame(animationFrameId);
            animationFrameId = null;
            scrollPosition = 0;
            wrapper.style.transform = 'translate3d(0, 0, 0)';
          }
        }, 250);
      });
      
      // Pause on hover
      swiperWrapper.addEventListener('mouseenter', function() {
        isPaused = true;
      });
      
      swiperWrapper.addEventListener('mouseleave', function() {
        isPaused = false;
        lastTime = performance.now();
      });
      
      // Start continuous scroll only if conditions are met
      if (shouldAutoScroll()) {
        lastTime = performance.now();
        animationFrameId = requestAnimationFrame(continuousScroll);
      } else {
        // Reset to start position if not scrolling
        wrapper.style.transform = 'translate3d(0, 0, 0)';
      }
      
      // Store swiper instance for cleanup
      swiperWrapper.swiper = swiper;
    }
  } catch (e) {
    console.error('Shop by Category Swiper initialization error:', e);
  }
})();
</script>

