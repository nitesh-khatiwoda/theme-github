      "id": "card_height",
      "label": "Card Height (px)",
      "min": 300,
      "max": 600,
      "step": 20,
      "default": 400,
      "info": "Height of each category card"
    },
    {
      "type": "text",
      "id": "card_width_mobile",
      "label": "Card Width - Mobile (px)",
      "default": "280",
      "info": "Width of category cards on mobile devices"
    },
    {
      "type": "text",
      "id": "card_width_tablet",
      "label": "Card Width - Tablet (px)",
      "default": "320",
      "info": "Width of category cards on tablet devices"
    },
    {
      "type": "text",
      "id": "card_width_desktop",
      "label": "Card Width - Desktop (px)",
      "default": "400",
      "info": "Width of category cards on desktop devices"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card Border Radius (px)",
