  }
  
  .text-block-effects-2-inner.text-right {
    align-items: flex-end;
  }
  
  .text-block-effects-2-heading {
    width: 100%;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  
  .text-block-effects-2-heading.fade-in {
    opacity: 1;
