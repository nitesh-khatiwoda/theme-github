<script>
(function() {
  const sectionId = 'section-{{ section.id }}';
  
  function initFadeUp() {
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const headingBlock = section.querySelector('.text-block-effects-2-heading');
    if (!headingBlock) return;
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('fade-in');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });
    
    observer.observe(headingBlock);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFadeUp);
  } else {
    initFadeUp();
  }
  
  // Re-init on Shopify theme editor updates
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', initFadeUp);
  }
})();
</script>

