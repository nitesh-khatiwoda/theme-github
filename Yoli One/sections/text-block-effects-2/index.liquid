<!-- Text Block Effects 2 Section -->
<section 
  class="text-block-effects-2 {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.padding_top_mobile | default: 'pt-xl' }} {{ section.settings.padding_bottom_mobile | default: 'pb-3xl' }} {{ section.settings.padding_x_mobile | default: 'px-md' }} {% if section.settings.padding_top_desktop != blank %}{{ section.settings.padding_top_desktop }}{% else %}lg:pt-2xl{% endif %} {% if section.settings.padding_bottom_desktop != blank %}{{ section.settings.padding_bottom_desktop }}{% else %}lg:pb-4xl{% endif %} {% if section.settings.padding_x_desktop != blank %}{{ section.settings.padding_x_desktop }}{% else %}lg:px-xl{% endif %}"
  id="section-{{ section.id }}">
  
  <div class="{{ section.settings.container_layout_width | default: 'container' }}">
    <div class="text-block-effects-2-inner text-{{ section.settings.alignment | default: 'center' }}">
      
      <!-- Heading Text -->
      {% if section.settings.heading != blank %}
      <div class="text-block-effects-2-heading">
        <h2 class="text-block-effects-2__heading {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-black' }}">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Optional Button -->
      {% if section.settings.button_text != blank and section.settings.button_url != blank %}
      <div class="text-block-effects-2-footer">
        <a href="{{ section.settings.button_url }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}" style="cursor: pointer;">
          {{ section.settings.button_text }}
        </a>
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

<style>
