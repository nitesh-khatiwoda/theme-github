<link rel="stylesheet" href="{{ 'milestone-timeline.css' | asset_url }}">

<!-- Milestone Timeline Section -->
<section 
  class="milestone-timeline {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.padding_top_mobile | default: 'pt-xl' }} {{ section.settings.padding_bottom_mobile | default: 'pb-3xl' }} {{ section.settings.padding_x_mobile | default: 'px-md' }} {% if section.settings.padding_top_desktop != blank %}{{ section.settings.padding_top_desktop }}{% else %}lg:pt-2xl{% endif %} {% if section.settings.padding_bottom_desktop != blank %}{{ section.settings.padding_bottom_desktop }}{% else %}lg:pb-4xl{% endif %} {% if section.settings.padding_x_desktop != blank %}{{ section.settings.padding_x_desktop }}{% else %}lg:px-xl{% endif %}"
  id="section-{{ section.id }}">
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="milestone-timeline-inner">
      
      <!-- Heading Area -->
      <div class="milestone-timeline-header">
        {% if section.settings.title != blank %}
        <h2 class="milestone-timeline-title {{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-3xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.title_font_weight | default: 'font-semibold' }} {{ section.settings.title_color | default: 'text-black' }}">
          {{ section.settings.title }}
        </h2>
        {% endif %}
        
        {% if section.settings.subtext != blank %}
        <p class="milestone-timeline-subtext {{ section.settings.subtext_font_family | default: 'font-body' }} {{ section.settings.subtext_font_size | default: 'text-base' }} {{ section.settings.subtext_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subtext_font_weight | default: 'font-normal' }} {{ section.settings.subtext_color | default: 'text-neutral-dark' }}">
          {{ section.settings.subtext }}
        </p>
        {% endif %}
        
        <!-- Optional Button - Above Timeline -->
        {% assign button_pos = section.settings.button_position | default: 'below_timeline' %}
        {% if section.settings.button_text != blank and section.settings.button_url != blank and button_pos == 'above_timeline' %}
        <div class="milestone-timeline-button-above">
          <a href="{{ section.settings.button_url }}" target="_blank" class="milestone-button btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
            {{ section.settings.button_text }}
          </a>
        </div>
        {% endif %}
      </div>
      
      <!-- Timeline Steps -->
      {% if section.blocks.size > 0 %}
      <div class="milestone-timeline-steps" data-section-id="{{ section.id }}">
        {% for block in section.blocks %}
          {% assign block_column = block.settings.column | default: '1' %}
          {% assign block_order = block.settings.order | default: forloop.index0 %}
          <div class="milestone-step" 
               data-column="{{ block_column }}" 
               data-order="{{ block_order }}"
               {{ block.fluid_attributes }}>
            
            <!-- Mirrored Content (Above Marker Row) -->
            <div class="milestone-step-content milestone-step-content-mirrored">
              {% if block.settings.title != blank %}
              <h3 class="milestone-step-title {{ block.settings.title_font_family | default: section.settings.step_title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: section.settings.step_title_font_size | default: 'text-lg' }} {{ block.settings.title_font_size_desktop | default: section.settings.step_title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.title_font_weight | default: section.settings.step_title_font_weight | default: 'font-semibold' }} {{ block.settings.title_color | default: section.settings.step_title_color | default: 'text-black' }}">
                {{ block.settings.title }}
              </h3>
              {% endif %}
              
              {% if block.settings.text != blank and section.settings.show_step_text %}
              <p class="milestone-step-text {{ block.settings.text_font_family | default: section.settings.step_text_font_family | default: 'font-body' }} {{ block.settings.text_font_size | default: section.settings.step_text_font_size | default: 'text-sm' }} {{ block.settings.text_font_size_desktop | default: section.settings.step_text_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.text_font_weight | default: section.settings.step_text_font_weight | default: 'font-normal' }} {{ block.settings.text_color | default: section.settings.step_text_color | default: 'text-neutral-dark' }}">
                {{ block.settings.text }}
              </p>
              {% endif %}
            </div>
            
            <!-- Dot and Connector Row -->
            <div class="milestone-step-marker-row">
              <!-- Dot -->
              <div class="milestone-dot"></div>
              
              <!-- Connector Line (hidden on last item) -->
              {% unless forloop.last %}
              <div class="milestone-connector {{ section.settings.connector_color | default: 'bg-neutral' }}"></div>
              {% endunless %}
            </div>
            
            <!-- Content -->
            <div class="milestone-step-content">
              {% if block.settings.title != blank %}
              <h3 class="milestone-step-title {{ block.settings.title_font_family | default: section.settings.step_title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: section.settings.step_title_font_size | default: 'text-lg' }} {{ block.settings.title_font_size_desktop | default: section.settings.step_title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.title_font_weight | default: section.settings.step_title_font_weight | default: 'font-semibold' }} {{ block.settings.title_color | default: section.settings.step_title_color | default: 'text-black' }}">
                {{ block.settings.title }}
              </h3>
              {% endif %}
              
              {% if block.settings.text != blank and section.settings.show_step_text %}
              <p class="milestone-step-text {{ block.settings.text_font_family | default: section.settings.step_text_font_family | default: 'font-body' }} {{ block.settings.text_font_size | default: section.settings.step_text_font_size | default: 'text-sm' }} {{ block.settings.text_font_size_desktop | default: section.settings.step_text_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.text_font_weight | default: section.settings.step_text_font_weight | default: 'font-normal' }} {{ block.settings.text_color | default: section.settings.step_text_color | default: 'text-neutral-dark' }}">
                {{ block.settings.text }}
              </p>
              {% endif %}
            </div>
            
          </div>
        {% endfor %}
      </div>
      {% endif %}
      
      <script>
      (function() {
        function sortMilestoneBlocks() {
          const sectionId = 'section-{{ section.id }}';
          const section = document.getElementById(sectionId);
          if (!section) return;
          
          const stepsContainer = section.querySelector('.milestone-timeline-steps');
          if (!stepsContainer) return;
          
          const blocks = Array.from(stepsContainer.querySelectorAll('.milestone-step'));
          if (blocks.length === 0) return;
          
          // Sort blocks by column, then by order
          blocks.sort((a, b) => {
            const aColumn = parseInt(a.dataset.column || '1');
            const bColumn = parseInt(b.dataset.column || '1');
            const aOrder = parseInt(a.dataset.order || '0');
            const bOrder = parseInt(b.dataset.order || '0');
            
            if (aColumn !== bColumn) {
              return aColumn - bColumn;
            }
            return aOrder - bOrder;
          });
          
          // Re-append blocks in sorted order
          blocks.forEach(block => stepsContainer.appendChild(block));
        }
        
        // Run on load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', sortMilestoneBlocks);
        } else {
          sortMilestoneBlocks();
        }
        
        // Also run when theme editor updates
        if (typeof Shopify !== 'undefined' && Shopify.designMode) {
          document.addEventListener('shopify:section:load', sortMilestoneBlocks);
          document.addEventListener('shopify:section:reorder', sortMilestoneBlocks);
        }
      })();
      
      // Fade-in animation on scroll
      (function() {
        const sectionId = 'section-{{ section.id }}';
        const section = document.getElementById(sectionId);
        if (!section) return;
        
        const stepsContainer = section.querySelector('.milestone-timeline-steps');
        if (!stepsContainer) return;
        
        const steps = Array.from(stepsContainer.querySelectorAll('.milestone-step'));
        if (steps.length === 0) return;
        
        let hasAnimated = false;
        
        function animateSteps() {
          if (hasAnimated) return;
          
          // Stagger animation: each step fades in 100ms after the previous one
          steps.forEach((step, index) => {
            setTimeout(() => {
              step.classList.add('animate-in');
            }, index * 100);
          });
          
          hasAnimated = true;
        }
        
        // Use Intersection Observer to detect when section is near viewport
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !hasAnimated) {
              // Trigger animation when section is 60% visible (later trigger)
              if (entry.intersectionRatio >= 0.6) {
                animateSteps();
              }
            }
          });
        }, {
          threshold: [0, 0.6],
          rootMargin: '0px 0px -10% 0px'
        });
        
        observer.observe(section);
        
        // Also check on load in case section is already in view
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => {
            const rect = section.getBoundingClientRect();
            // Require section to be more scrolled into view (60% of viewport)
            if (rect.top < window.innerHeight * 0.4) {
              animateSteps();
            }
          });
        } else {
          const rect = section.getBoundingClientRect();
          // Require section to be more scrolled into view (60% of viewport)
          if (rect.top < window.innerHeight * 0.4) {
            animateSteps();
          }
        }
      })();
      </script>
      
      <!-- Optional Button - Below Timeline -->
      {% assign button_pos = section.settings.button_position | default: 'below_timeline' %}
      {% if section.settings.button_text != blank and section.settings.button_url != blank and button_pos != 'above_timeline' %}
      <div class="milestone-timeline-footer">
        <a href="{{ section.settings.button_url }}" target="_blank" class="milestone-button btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
          {{ section.settings.button_text }}
        </a>
      </div>
      {% endif %}
      
    </div>
    <!-- Button -->
    {% if block.settings.show_button %}
      {% assign button_border_setting = block.settings.button_border | default: 'auto' %}
      {% assign button_color_setting = block.settings.button_color | default: 'white' %}
      {% assign border_color = 'currentColor' %}
      {% if button_color_setting == 'primary' %}
        {% assign border_color = 'var(--clr-primary)' %}
      {% elsif button_color_setting == 'secondary' %}
        {% assign border_color = 'var(--clr-secondary)' %}
      {% elsif button_color_setting == 'tertiary' %}
        {% assign border_color = 'var(--clr-tertiary)' %}
      {% elsif button_color_setting == 'quaternary' %}
        {% assign border_color = 'var(--clr-quaternary)' %}
      {% elsif button_color_setting == 'success' %}
        {% assign border_color = 'var(--clr-success)' %}
      {% elsif button_color_setting == 'warning' %}
        {% assign border_color = 'var(--clr-warning)' %}
      {% elsif button_color_setting == 'error' %}
        {% assign border_color = 'var(--clr-error)' %}
      {% elsif button_color_setting == 'info' %}
        {% assign border_color = 'var(--clr-info)' %}
      {% elsif button_color_setting == 'black' %}
        {% assign border_color = 'var(--clr-black)' %}
      {% elsif button_color_setting == 'white' %}
        {% assign border_color = 'var(--clr-white)' %}
      {% endif %}
      <div class="journey-hero__button-wrapper">
        <a href="{{ block.settings.button_url | default: '#' }}" target="_blank"
           class="btn btn-{{ block.settings.button_style | default: 'filled' }}-{{ button_color_setting }} {{ block.settings.button_size | default: 'btn-md' }} {{ block.settings.button_font_weight | default: 'font-normal' }} font-body {{ settings.button_border_radius | default: 'rounded-full' }}"
           {% if button_border_setting == 'hide' %}style="border: none !important;"{% elsif button_border_setting == 'show' %}style="border: 2px solid {{ border_color }} !important;"{% endif %}>
          {{ block.settings.button_text | default: 'Find your Transformation kit' }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

