<link rel="stylesheet" href="{{ 'ingredients-formula/styles.css' | asset_url }}">

<!-- Ingredients Formula Section -->
<section class="ingredients-formula {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %} id="section-{{ section.id }}">
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="ingredients-formula-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header Content -->
      <div class="ingredients-formula-header mb-2xl lg:mb-3xl">
        
        <!-- Main Heading -->
        {% if section.settings.heading != blank %}
        <div class="ingredients-formula-heading mb-lg">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
            {{ section.settings.heading }}
          </h2>
        </div>
        {% endif %}
        
        <!-- Description -->
        {% if section.settings.description != blank %}
        <div class="ingredients-formula-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Ingredients Blocks -->
      {% if section.blocks.size > 0 %}
      <div class="ingredients-formula-items mb-2xl lg:mb-3xl">
        <div class="ingredients-items-list flex flex-col gap-lg lg:gap-xl">
          {% for block in section.blocks %}
            {% if block.type == 'ingredient' %}
            <div class="ingredient-item flex gap-md lg:gap-lg items-center" {{ block.fluid_attributes }}>
              
              <!-- Ingredient Image -->
              <div class="ingredient-image-wrapper shrink-0">
                {% if block.settings.ingredient_image %}
                <div class="ingredient-image {{ section.settings.image_border_radius | default: 'rounded-full' }}" style="width: {{ section.settings.image_size | default: '101' }}px; height: {{ section.settings.image_size | default: '101' }}px; border: {{ section.settings.image_border_width | default: '3' }}px solid {{ section.settings.image_border_color | default: '#FFFFFF' }};">
                  <img src="{{ block.settings.ingredient_image | image_url: width: 200 }}"
                       alt="{{ block.settings.ingredient_image_alt | default: block.settings.ingredient_title }}"
                       class="w-full h-full object-cover rounded-full"
                       loading="lazy"
                       style="box-shadow: none !important;">
                </div>
                {% else %}
                <div class="ingredient-image {{ section.settings.image_border_radius | default: 'rounded-full' }}" style="width: {{ section.settings.image_size | default: '101' }}px; height: {{ section.settings.image_size | default: '101' }}px; border: {{ section.settings.image_border_width | default: '3' }}px solid {{ section.settings.image_border_color | default: '#FFFFFF' }};">
                  <img src="{{ 'placeholder-image.png' | asset_url }}"
                       alt="Placeholder"
                       class="w-full h-full object-cover rounded-full"
                       loading="lazy"
                       style="box-shadow: none !important;">
                </div>
                {% endif %}
              </div>
              
              <!-- Ingredient Content -->
              <div class="ingredient-content flex flex-col gap-xs">
                
                <!-- Ingredient Title -->
                {% if block.settings.ingredient_title != blank %}
                <div class="ingredient-title">
                  <h3 class="{{ section.settings.ingredient_title_font_family | default: 'font-body' }} {{ section.settings.ingredient_title_font_size | default: 'text-xl' }} {{ section.settings.ingredient_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.ingredient_title_font_weight | default: 'font-bold' }} {{ section.settings.ingredient_title_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.ingredient_title }}
                  </h3>
                </div>
                {% endif %}
                
                <!-- Ingredient Description -->
                {% if block.settings.ingredient_description != blank %}
                <div class="ingredient-description">
                  <p class="{{ section.settings.ingredient_description_font_family | default: 'font-body' }} {{ section.settings.ingredient_description_font_size | default: 'text-base' }} {{ section.settings.ingredient_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.ingredient_description_font_weight | default: 'font-normal' }} {{ section.settings.ingredient_description_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.ingredient_description }}
                  </p>
                </div>
                {% endif %}
                
              </div>
              
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
      
      <!-- Fine Print -->
      {% if section.settings.fine_print != blank %}
      <div class="ingredients-formula-fineprint">
        <p class="{{ section.settings.fine_print_font_family | default: 'font-body' }} {{ section.settings.fine_print_font_size | default: 'text-sm' }} {{ section.settings.fine_print_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.fine_print_font_weight | default: 'font-normal' }} {{ section.settings.fine_print_color | default: 'text-neutral-dark' }}" style="font-style: italic;">
          {{ section.settings.fine_print }}
        </p>
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

