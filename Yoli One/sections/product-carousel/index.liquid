<link rel="stylesheet" href="{{ 'product-carousel/styles.css' | asset_url }}">

<section 
  class="product-carousel {{ section.settings.background_color | default: 'bg-secondary' }}"
  style="
    padding-top: var(--space-{{ section.settings.section_padding_y_mobile | default: '2xl' }});
    padding-bottom: var(--space-{{ section.settings.section_padding_y_mobile | default: '2xl' }});
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    {% if section.settings.section_border_radius != blank and section.settings.section_border_radius != 'rounded-none' %}
      border-radius: var(--radius-{{ section.settings.section_border_radius | remove: 'rounded-' }});
    {% endif %}
  "
>
  <div class="product-carousel-container">
    
    <!-- Left Content Area -->
    <div class="product-carousel-left font-primary">
      
      <!-- Heading -->
      {% if section.settings.heading != blank %}
      <div class="product-carousel-heading mb-lg">
        <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-black' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading" style="line-height: 1.24;">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Subheading -->
      {% if section.settings.subheading != blank %}
      <div class="product-carousel-subheading mb-lg">
        <p class="{{ section.settings.subheading_font_size | default: 'text-base' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-black' }} leading-body" style="line-height: 1.5;">
          {{ section.settings.subheading }}
        </p>
      </div>
      {% endif %}
      
      <!-- CTA Button -->
      {% if section.settings.show_button and section.settings.button_text != blank %}
      <div class="product-carousel-cta">
        <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
          {{ section.settings.button_text }}
        </a>
      </div>
      {% endif %}
      
    </div>
    
    <!-- Right Carousel Area -->
    <div class="product-carousel-right">
      
      <!-- Carousel Container -->
      {% if section.blocks.size > 0 %}
      <div class="product-carousel-wrapper">
        
        <!-- Navigation Arrows -->
        <div class="product-carousel-nav">
          <button class="product-carousel-nav-btn product-carousel-prev {{ section.settings.nav_button_background | default: 'bg-primary' }}" aria-label="Previous product">
            <svg width="10" height="17" viewBox="0 0 10 17" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-white' }}">
              <path d="M9.5 1L1.5 8.5L9.5 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="product-carousel-nav-btn product-carousel-next {{ section.settings.nav_button_background | default: 'bg-primary' }}" aria-label="Next product">
            <svg width="10" height="17" viewBox="0 0 10 17" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.nav_arrow_color | default: 'text-white' }}">
              <path d="M0.5 1L8.5 8.5L0.5 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        
        <div class="product-carousel-container-inner">
          <div class="product-carousel-track">
          
          {% for block in section.blocks %}
            
            <!-- Product Card -->
            {% if block.type == 'product' %}
            <div class="product-card {{ section.settings.card_background | default: 'bg-white' }}" {{ block.fluid_attributes }}>
              
              <!-- Product Image -->
              <div class="product-image-wrapper">
                {% if block.settings.product_image != blank %}
                  <img src="{{ block.settings.product_image | image_url: width: 400 }}" alt="{{ block.settings.product_name }}" class="product-image" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.svg' | asset_url }}" alt="Product" class="product-image" loading="lazy">
                {% endif %}
              </div>
              
              <!-- Product Info -->
              <div class="product-info">
                
                <!-- Product Name -->
                {% if block.settings.product_name != blank %}
                <div class="product-name mb-xs">
                  <h3 class="{{ block.settings.name_font_size | default: 'text-lg' }} {{ block.settings.name_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.name_font_weight | default: 'font-bold' }} {{ block.settings.name_color | default: 'text-black' }} leading-heading" style="line-height: 1.3;">
                    {{ block.settings.product_name }}
                  </h3>
                </div>
                {% endif %}
                
                <!-- Product Description -->
                {% if block.settings.product_description != blank %}
                <div class="product-description mb-sm">
                  <p class="{{ block.settings.description_font_size | default: 'text-sm' }} {{ block.settings.description_font_size_desktop | default: 'lg:text-sm' }} {{ block.settings.description_font_weight | default: 'font-normal' }} {{ block.settings.description_color | default: 'text-neutral-dark' }} leading-body" style="line-height: 1.5;">
                    {{ block.settings.product_description }}
                  </p>
                </div>
                {% endif %}
                
                <!-- Price -->
                <div class="product-price mb-sm">
                  {% if block.settings.compare_price != blank %}
                  <span class="compare-price {{ block.settings.price_font_size | default: 'text-base' }} {{ block.settings.price_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.price_font_weight | default: 'font-normal' }} text-neutral-dark" style="text-decoration: line-through;">
                    ${{ block.settings.compare_price }}
                  </span>
                  {% endif %}
                  {% if block.settings.price != blank %}
                  <span class="price {{ block.settings.price_font_size | default: 'text-base' }} {{ block.settings.price_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.price_font_weight | default: 'font-bold' }} {{ block.settings.price_color | default: 'text-primary' }}">
                    ${{ block.settings.price }}
                  </span>
                  {% endif %}
                </div>
                
                <!-- Add to Cart Button -->
                {% if block.settings.show_button and block.settings.button_text != blank %}
                <div class="product-button">
                  <a href="{{ block.settings.button_url | default: '#' }}" class="btn btn-{{ block.settings.product_button_style | default: 'filled' }}-{{ block.settings.product_button_color | default: 'primary' }} btn-{{ block.settings.product_button_size | default: 'sm' }}">
                    {{ block.settings.button_text }}
                  </a>
                </div>
                {% endif %}
                
              </div>
            </div>
            {% endif %}
            
          {% endfor %}
          
        </div>
      </div>
      
      </div>
      {% endif %}
      
    </div>
    
  </div>
</section>

<script>
(function() {
  const carousel = document.querySelector('.product-carousel-track');
  const prevBtn = document.querySelector('.product-carousel-prev');
  const nextBtn = document.querySelector('.product-carousel-next');
  
  if (!carousel || !prevBtn || !nextBtn) return;
  
  let scrollAmount = 0;
  const cardWidth = 270 + 24; // Card width + gap
  
  function updateButtons() {
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    prevBtn.style.opacity = scrollAmount <= 0 ? '0.4' : '1';
    prevBtn.disabled = scrollAmount <= 0;
    nextBtn.style.opacity = scrollAmount >= maxScroll ? '0.4' : '1';
    nextBtn.disabled = scrollAmount >= maxScroll;
  }
  
  nextBtn.addEventListener('click', () => {
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    scrollAmount = Math.min(scrollAmount + cardWidth, maxScroll);
    carousel.style.transform = `translateX(-${scrollAmount}px)`;
    updateButtons();
  });
  
  prevBtn.addEventListener('click', () => {
    scrollAmount = Math.max(scrollAmount - cardWidth, 0);
    carousel.style.transform = `translateX(-${scrollAmount}px)`;
    updateButtons();
  });
  
  updateButtons();
})();
</script>

