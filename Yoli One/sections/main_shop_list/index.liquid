<link rel="stylesheet" href="{{ 'main_shop_list/styles.css' | asset_url }}">

<section class="main-shop-list-section {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }} shop-list-{{ section.id }}">
    <form id='filterrific_filter' url='{{ url }}' method='get'>
        {%- comment -%} Preserve count parameter - default to 10 items per page (matches controller MINIMUM_PRODUCT_COUNT) {%- endcomment -%}
        {%- assign current_count = request.query_parameters.count -%}
        {%- if current_count == blank or current_count == '' or current_count == null -%}
            {%- assign current_count = 10 -%}
        {%- endif -%}
        {%- assign current_count_num = current_count | plus: 0 -%}
        <input type="hidden" name="count" id="products-per-page-count" value="{{ current_count_num }}">
        <div class="{{section.settings.container_layout_width | default: 'container'}} filter-style-{{ section.settings.filter_style | default: 'sidebar' }}">
        
            {%- assign filter_style = section.settings.filter_style | default: 'sidebar' -%}
            
            <div class="shop-layout filter-style-{{ filter_style }}">
                
                {%- comment -%} Sidebar Filter Layout {%- endcomment -%}
                <!-- Left Sidebar: Filters -->
                <aside class="shop-sidebar filter-layout-sidebar" id="shop-sidebar">
                    <div class="sidebar-content">
                    
                        <!-- Filters Header -->
                        <div class="filters-header">
                            <div class="filters-header-left">
                                <h3 class="filters-title {{ section.settings.filters_title_font_family | default: 'font-primary' }} {{ section.settings.filters_title_font_size | default: 'text-sm' }} {{ section.settings.filters_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.filters_title_font_weight | default: 'bold' }} {{ section.settings.filters_title_color | default: 'text-primary' }}">Filters</h3>
                            </div>
                            <div class="filters-header-right">
                                <a href='#' id='clear-form' class='clear-all-btn {{ section.settings.clear_all_font_size | default: 'text-sm' }} {{ section.settings.clear_all_color | default: 'text-info' }} font-{{ section.settings.clear_all_font_weight | default: 'medium' }}'>
                                    Clear All
                                </a>
                                <button type="button" class="sidebar-close-btn" id="sidebar-close-btn" aria-label="Close filters">
                                    <svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M11.7773 2.06641L7.55859 6.28516L11.7422 10.4688C12.0938 10.7852 12.0938 11.3125 11.7422 11.6289C11.4258 11.9805 10.8984 11.9805 10.582 11.6289L6.36328 7.44531L2.17969 11.6289C1.86328 11.9805 1.33594 11.9805 1.01953 11.6289C0.667969 11.3125 0.667969 10.7852 1.01953 10.4336L5.20312 6.25L1.01953 2.06641C0.667969 1.75 0.667969 1.22266 1.01953 0.871094C1.33594 0.554688 1.86328 0.554688 2.21484 0.871094L6.39844 5.08984L10.582 0.90625C10.8984 0.554688 11.4258 0.554688 11.7773 0.90625C12.0938 1.22266 12.0938 1.75 11.7773 2.06641Z" fill="black" fill-opacity="0.5"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        
                        <!-- Filter Accordions -->
                        <div class="filters-list">
                        
                            <!-- Categories Filter -->
                            {% if categories.size > 0 %}
                                {% if section.settings.category_filter_order != blank %}
                                    {% assign category_order = section.settings.category_filter_order %}
                                {% else %}
                                    {% assign category_order = 'order-1' %}
                                {% endif %}
                                <div class="filter-accordion-item active {{ category_order }}" data-filter-type="categories" data-order="{{ category_order }}">
                                    <button class="filter-accordion-header" type="button">
                                        <div class="filter-accordion-header-left">
                                            <span class="filter-accordion-title {{ section.settings.sidebar_filter_title_font_family | default: 'font-primary' }} {{ section.settings.sidebar_filter_title_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.sidebar_filter_title_font_weight | default: 'bold' }} {{ section.settings.sidebar_filter_title_color | default: 'text-primary' }}">Categories</span>
                                        </div>
                                        <svg class="filter-accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="filter-accordion-content">
                                        <ul class="filter-options">
                                            {% for category in categories %}
                                            {% assign id = 'filterrific_with_category_id_' | append: category.id %}
                                            {% assign category_product_count = 0 %}
                                            {% if category.products %}
                                                {% assign category_product_count = category.products.size %}
                                            {% elsif collection.products %}
                                                {% for product in collection.products %}
                                                {% if product.category_id == category.id %}
                                                    {% assign category_product_count = category_product_count | plus: 1 %}
                                                {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                            {% if category_product_count == 0 %}
                                                {% assign category_product_count = category.count %}
                                            {% endif %}
                                            <li data-title="{{ category.title }}" data-value="{{ category.id }}" class="filter-option-item">
                                                <div class="filter-checkbox-wrapper">
                                                <label class="filter-checkbox-label" for="{{ id }}">
                                                    <input 
                                                    type="checkbox" 
                                                    class="filter-checkbox" 
                                                    id="{{ id }}"
                                                    name="filterrific[with_category_id][]" 
                                                    value="{{ category.id }}"
                                                    {% if category.selected %}checked{% endif %}
                                                    />
                                                    <span class="filter-checkbox-text {{ section.settings.sidebar_filter_item_font_family | default: 'font-body' }} {{ section.settings.sidebar_filter_item_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_item_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.sidebar_filter_item_font_weight | default: 'normal' }} {{ section.settings.sidebar_filter_item_color | default: 'text-primary' }}">
                                                    {{ category.title }} ({{ category_product_count }})
                                                    </span>
                                                </label>
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                </div>
                            {% endif %}
                            
                            <!-- Collections Filter -->
                            {% if collections.size > 0 %}
                                {% if section.settings.collection_filter_order != blank %}
                                    {% assign collection_order = section.settings.collection_filter_order %}
                                {% else %}
                                    {% assign collection_order = 'order-2' %}
                                {% endif %}
                                <div class="filter-accordion-item active {{ collection_order }}" data-filter-type="collections">
                                    <button class="filter-accordion-header" type="button">
                                        <div class="filter-accordion-header-left">
                                            <span class="filter-accordion-title {{ section.settings.sidebar_filter_title_font_family | default: 'font-primary' }} {{ section.settings.sidebar_filter_title_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.sidebar_filter_title_font_weight | default: 'bold' }} {{ section.settings.sidebar_filter_title_color | default: 'text-primary' }}">Collections</span>
                                        </div>
                                        <svg class="filter-accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="filter-accordion-content">
                                        <ul class="filter-options">
                                            {% for collection_item in collections %}
                                            {% assign id = 'filterrific_by_collection_' | append: collection_item.id %}
                                            {% assign collection_product_count = 0 %}
                                            {% if collection_item.products %}
                                                {% assign collection_product_count = collection_item.products.size %}
                                            {% elsif collection_item.count %}
                                                {% assign collection_product_count = collection_item.count %}
                                            {% endif %}
                                            <li data-title="{{ collection_item.title }}" data-value="{{ collection_item.id }}" class="filter-option-item">
                                                <div class="filter-checkbox-wrapper">
                                                <label class="filter-checkbox-label" for="{{ id }}">
                                                    <input 
                                                    type="checkbox" 
                                                    class="filter-checkbox" 
                                                    id="{{ id }}"
                                                    name="filterrific[by_collection][]" 
                                                    value="{{ collection_item.id }}"
                                                    {% if collection_item.selected %}checked{% endif %}
                                                    />
                                                    <span class="filter-checkbox-text {{ section.settings.sidebar_filter_item_font_family | default: 'font-body' }} {{ section.settings.sidebar_filter_item_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_item_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.sidebar_filter_item_font_weight | default: 'normal' }} {{ section.settings.sidebar_filter_item_color | default: 'text-primary' }}">
                                                    {{ collection_item.title }} ({{ collection_product_count }})
                                                    </span>
                                                </label>
                                                </div>
                                            </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                </div>
                            {% endif %}
                            
                            
                            <!-- Price Filter -->
                            {% if price_ranges.size > 0 %}
                            {% if section.settings.price_filter_order != blank %}
                                {% assign price_order = section.settings.price_filter_order %}
                            {% else %}
                                {% assign price_order = 'order-4' %}
                            {% endif %}
                            <div class="filter-accordion-item active {{ price_order }}" data-filter-type="price">
                                <button class="filter-accordion-header" type="button">
                                    <div class="filter-accordion-header-left">
                                        <span class="filter-accordion-title {{ section.settings.sidebar_filter_title_font_family | default: 'font-primary' }} {{ section.settings.sidebar_filter_title_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.sidebar_filter_title_font_weight | default: 'bold' }} {{ section.settings.sidebar_filter_title_color | default: 'text-primary' }}">Price Range</span>
                                    </div>
                                    <svg class="filter-accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                                <div class="filter-accordion-content">
                                    <ul class="filter-options">
                                        {% for range in price_ranges %}
                                        {% assign id = 'filterrific_with_prices_' | append: range.lower_range | append: '_' | append: range.upper_range %}
                                        <li data-title="{{ range.lower_range }}-{{ range.upper_range }}" class="filter-option-item">
                                            <div class="filter-checkbox-wrapper">
                                            <label class="filter-checkbox-label" for="{{ id }}">
                                                <input 
                                                type="checkbox" 
                                                class="filter-checkbox" 
                                                id="{{ id }}"
                                                name="filterrific[with_prices][]" 
                                                value="{{ range.lower_range }} {{ range.upper_range }}"
                                                {% if range.selected %}checked{% endif %}
                                                />
                                                <span class="filter-checkbox-text {{ section.settings.sidebar_filter_item_font_family | default: 'font-body' }} {{ section.settings.sidebar_filter_item_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_item_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.sidebar_filter_item_font_weight | default: 'normal' }} {{ section.settings.sidebar_filter_item_color | default: 'text-primary' }} {% if range.selected %}{{ section.settings.sidebar_filter_item_selected_color | default: 'text-info' }}{% endif %}">
                                                <span>{{ range.lower_range_display }}</span>
                                                <span class="price-separator">-</span>
                                                <span>{{ range.upper_range_display }}</span>
                                                </span>
                                            </label>
                                            </div>
                                        </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                            {% endif %}
                            
                            <!-- Options Filter (Size, etc.) -->
                            {% for option in options %}
                                {% if option.values.size > 0 %}
                                {% if section.settings.option_filter_order != blank %}
                                    {% assign option_order = section.settings.option_filter_order %}
                                {% else %}
                                    {% assign option_order = 'order-5' %}
                                {% endif %}
                                <div class="filter-accordion-item active {{ option_order }}" data-filter-type="option-{{ option.id }}">
                                    <button class="filter-accordion-header" type="button">
                                        <div class="filter-accordion-header-left">
                                            <span class="filter-accordion-title {{ section.settings.sidebar_filter_title_font_family | default: 'font-primary' }} {{ section.settings.sidebar_filter_title_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.sidebar_filter_title_font_weight | default: 'bold' }} {{ section.settings.sidebar_filter_title_color | default: 'text-primary' }}">{{ option.title }}</span>
                                        </div>
                                        <svg class="filter-accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="filter-accordion-content">
                                        <ul class="filter-options">
                                            {% for value in option.values %}
                                                {% assign id = 'filterrific_with_option_value_ids_' | append: value.id %}
                                                <li data-title="{{ value.presentation }}" data-value="{{ value.id }}" class="filter-option-item">
                                                    <div class="filter-checkbox-wrapper">
                                                        <label class="filter-checkbox-label" for="{{ id }}">
                                                        <input 
                                                            type="checkbox" 
                                                            class="filter-checkbox" 
                                                            id="{{ id }}"
                                                            name="filterrific[with_option_value_ids][]" 
                                                            value="{{ value.id }}"
                                                            {% if value.selected %}checked{% endif %}
                                                        />
                                                        <span class="filter-checkbox-text {{ section.settings.sidebar_filter_item_font_family | default: 'font-body' }} {{ section.settings.sidebar_filter_item_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_item_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.sidebar_filter_item_font_weight | default: 'normal' }} {{ section.settings.sidebar_filter_item_color | default: 'text-primary' }}">{{ value.presentation }}</span>
                                                        </label>
                                                    </div>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                            
                            {%- comment -%} Collect all unique tags from products {%- endcomment -%}
                            {%- assign all_tags_string = '' -%}
                            
                            {%- comment -%} Parse collection.products if it's a JSON string (like products_array below) {%- endcomment -%}
                            {%- assign products_for_tags = collection.products | parse_json -%}
                            {%- if products_for_tags and products_for_tags.size > 0 -%}
                                {%- for product in products_for_tags -%}
                                    {%- if product.tags -%}
                                        {%- for tag in product.tags -%}
                                            {%- assign tag_separator = '|||' | append: tag | append: '|||' -%}
                                            {%- unless all_tags_string contains tag_separator -%}
                                                {%- if all_tags_string == blank or all_tags_string == '' -%}
                                                    {%- assign all_tags_string = tag -%}
                                                {%- else -%}
                                                    {%- assign all_tags_string = all_tags_string | append: '|||' | append: tag -%}
                                                {%- endif -%}
                                            {%- endunless -%}
                                        {%- endfor -%}
                                    {%- endif -%}
                                {%- endfor -%}
                            {%- endif -%}
                            
                            {%- comment -%} Split tags string into array {%- endcomment -%}
                            {%- if all_tags_string != blank and all_tags_string != '' -%}
                                {%- assign tags_array = all_tags_string | split: '|||' -%}
                            {%- else -%}
                                {%- assign tags_array = '' | split: ',' -%}
                            {%- endif -%}
                            
                            {%- comment -%} Tags Filter - Show if setting is enabled {%- endcomment -%}
                            {%- assign show_tags = true -%}
                            {%- if section.settings.show_tags_filter == false -%}
                                {%- assign show_tags = false -%}
                            {%- endif -%}
                            {%- if show_tags -%}
                                {%- comment -%} Only show filter content if we have tags {%- endcomment -%}
                                {%- if all_tags_string != blank and all_tags_string != '' and tags_array.size > 0 -%}
                                {%- assign selected_tags = request.query_parameters['filterrific[with_tags]'] | split: ',' -%}
                                {% if section.settings.tags_filter_order != blank %}
                                    {% assign tags_order = section.settings.tags_filter_order %}
                                {% else %}
                                    {% assign tags_order = 'order-6' %}
                                {% endif %}
                                <div class="filter-accordion-item active {{ tags_order }}" data-filter-type="tags">
                                    <button class="filter-accordion-header" type="button">
                                        <div class="filter-accordion-header-left">
                                            <span class="filter-accordion-title {{ section.settings.sidebar_filter_title_font_family | default: 'font-primary' }} {{ section.settings.sidebar_filter_title_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.sidebar_filter_title_font_weight | default: 'bold' }} {{ section.settings.sidebar_filter_title_color | default: 'text-primary' }}">Tags</span>
                                        </div>
                                        <svg class="filter-accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="filter-accordion-content">
                                        <ul class="filter-options">
                                            {%- for tag in tags_array -%}
                                                {%- if tag != '' -%}
                                                {%- assign tag_id = 'filterrific_tag_' | append: tag | handleize -%}
                                                {%- assign tag_selected = false -%}
                                                {%- if selected_tags -%}
                                                    {%- for selected_tag in selected_tags -%}
                                                        {%- if selected_tag == tag -%}
                                                            {%- assign tag_selected = true -%}
                                                            {%- break -%}
                                                        {%- endif -%}
                                                    {%- endfor -%}
                                                {%- endif -%}
                                                {%- assign tag_count = 0 -%}
                                                {%- if collection.products -%}
                                                    {%- for product in collection.products -%}
                                                        {%- if product.tags contains tag -%}
                                                            {%- assign tag_count = tag_count | plus: 1 -%}
                                                        {%- endif -%}
                                                    {%- endfor -%}
                                                {%- elsif products_array -%}
                                                    {%- for product in products_array -%}
                                                        {%- if product.tags contains tag -%}
                                                            {%- assign tag_count = tag_count | plus: 1 -%}
                                                        {%- endif -%}
                                                    {%- endfor -%}
                                                {%- endif -%}
                                                <li data-title="{{ tag }}" data-value="{{ tag }}" class="filter-option-item">
                                                    <div class="filter-checkbox-wrapper">
                                                    <label class="filter-checkbox-label" for="{{ tag_id }}">
                                                            <input 
                                                                type="checkbox" 
                                                                class="filter-checkbox" 
                                                                id="{{ tag_id }}"
                                                                name="filterrific[with_tags][]" 
                                                                value="{{ tag }}"
                                                                {% if tag_selected %}checked{% endif %}
                                                            />
                                                            <span class="filter-checkbox-text {{ section.settings.sidebar_filter_item_font_family | default: 'font-body' }} {{ section.settings.sidebar_filter_item_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_item_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.sidebar_filter_item_font_weight | default: 'normal' }} {{ section.settings.sidebar_filter_item_color | default: 'text-primary' }} {% if tag_selected %}{{ section.settings.sidebar_filter_item_selected_color | default: 'text-info' }}{% endif %}">
                                                                {{ tag }} {% if tag_count > 0 %}({{ tag_count }}){% endif %}
                                                            </span>
                                                        </label>
                                                    </div>
                                                </li>
                                                {%- endif -%}
                                            {%- endfor -%}
                                        </ul>
                                    </div>
                                </div>
                                {%- else -%}
                                    {%- comment -%} No tags found - show empty state or hide {%- endcomment -%}
                                {%- endif -%}
                            {%- endif -%}
                            
                            {%- comment -%} Bundles Filter {%- endcomment -%}
                            {%- assign bundle_count = 0 -%}
                            {%- if collection.products -%}
                                {%- for product in collection.products -%}
                                    {%- if product.tags contains 'bundle' -%}
                                        {%- assign bundle_count = bundle_count | plus: 1 -%}
                                    {%- endif -%}
                                {%- endfor -%}
                            {%- elsif products_array -%}
                                {%- for product in products_array -%}
                                    {%- if product.tags contains 'bundle' -%}
                                        {%- assign bundle_count = bundle_count | plus: 1 -%}
                                    {%- endif -%}
                                {%- endfor -%}
                            {%- endif -%}
                            {%- if section.settings.show_bundles_filter != false -%}
                                {% if section.settings.bundle_filter_order != blank %}
                                    {% assign bundle_order = section.settings.bundle_filter_order %}
                                {% else %}
                                    {% assign bundle_order = 'order-7' %}
                                {% endif %}
                                <div class="filter-accordion-item active {{ bundle_order }}" data-filter-type="bundles">
                                    <button class="filter-accordion-header" type="button">
                                        <div class="filter-accordion-header-left">
                                            <span class="filter-accordion-title {{ section.settings.sidebar_filter_title_font_family | default: 'font-primary' }} {{ section.settings.sidebar_filter_title_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.sidebar_filter_title_font_weight | default: 'bold' }} {{ section.settings.sidebar_filter_title_color | default: 'text-primary' }}">Bundles</span>
                                        </div>
                                        <svg class="filter-accordion-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <div class="filter-accordion-content">
                                        <ul class="filter-options">
                                            <li data-title="Show Bundles Only" class="filter-option-item">
                                                <div class="filter-checkbox-wrapper">
                                                    <label class="filter-checkbox-label" for="filterrific_show_bundles_only">
                                                        <!-- Hidden field to ensure unchecked value is sent -->
                                                        <input type="hidden" name="filterrific[show_bundles_only]" value="0" />
                                                        <input 
                                                            type="checkbox" 
                                                            class="filter-checkbox" 
                                                            id="filterrific_show_bundles_only"
                                                            name="filterrific[show_bundles_only]" 
                                                            value="1"
                                                            data-filter-type="bundles"
                                                        />
                                                        <span class="filter-checkbox-text {{ section.settings.sidebar_filter_item_font_family | default: 'font-body' }} {{ section.settings.sidebar_filter_item_font_size | default: 'text-sm' }} {{ section.settings.sidebar_filter_item_font_size_desktop | default: 'lg:text-sm' }} font-{{ section.settings.sidebar_filter_item_font_weight | default: 'normal' }} {{ section.settings.sidebar_filter_item_color | default: 'text-primary' }}">
                                                            Show Bundles Only {% if bundle_count > 0 %}({{ bundle_count }}){% endif %}
                                                        </span>
                                                    </label>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            {%- endif -%}
                        
                        </div>
                    </div>
                </aside>
                
                {%- comment -%} Drawer Filter Layout {%- endcomment -%}
                <!-- Drawer: Filters -->
                <aside class="shop-filters-drawer filter-layout-drawer" id="shop-filters-drawer">
                    <div class="drawer-overlay" id="drawer-overlay"></div>
                    <div class="drawer-content">
                        <!-- Filters Header -->
                        <div class="filters-header">
                            <div class="filters-header-left">
                                <h3 class="filters-title {{ section.settings.filters_title_font_family | default: 'font-primary' }} {{ section.settings.filters_title_font_size | default: 'text-sm' }} {{ section.settings.filters_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.filters_title_font_weight | default: 'bold' }} {{ section.settings.filters_title_color | default: 'text-primary' }}">Filters</h3>
                            </div>
                            <div class="filters-header-right">
                                <a href='#' id='clear-form-drawer' class='clear-all-btn {{ section.settings.clear_all_font_size | default: 'text-sm' }} {{ section.settings.clear_all_color | default: 'text-info' }} font-{{ section.settings.clear_all_font_weight | default: 'medium' }}'>
                                    Clear All
                                </a>
                                <button type="button" class="drawer-close-btn" id="drawer-close-btn" aria-label="Close filters">
                                    <svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M11.7773 2.06641L7.55859 6.28516L11.7422 10.4688C12.0938 10.7852 12.0938 11.3125 11.7422 11.6289C11.4258 11.9805 10.8984 11.9805 10.582 11.6289L6.36328 7.44531L2.17969 11.6289C1.86328 11.9805 1.33594 11.9805 1.01953 11.6289C0.667969 11.3125 0.667969 10.7852 1.01953 10.4336L5.20312 6.25L1.01953 2.06641C0.667969 1.75 0.667969 1.22266 1.01953 0.871094C1.33594 0.554688 1.86328 0.554688 2.21484 0.871094L6.39844 5.08984L10.582 0.90625C10.8984 0.554688 11.4258 0.554688 11.7773 0.90625C12.0938 1.22266 12.0938 1.75 11.7773 2.06641Z" fill="black" fill-opacity="0.5"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        
                        <!-- Filter Accordions (content cloned from sidebar filters-list) -->
                        <div class="filters-list" id="filters-list-drawer">
                            <!-- Content will be cloned from sidebar filters-list -->
                        </div>
                    </div>
                </aside>
                
                <!-- Right Content: Products -->
                <main class="shop-main-content">
                
                    <!-- Search and Sort Bar -->
                    <div class="shop-header-bar">
                        <div class="shop-header-top">
                            <div class="shop-title-wrapper">
                                <h2 class="shop-title {{ section.settings.shop_title_font_family | default: 'font-primary' }} {{ section.settings.shop_title_font_size | default: 'text-2xl' }} {{ section.settings.shop_title_font_size_desktop | default: 'lg:text-3xl' }} font-{{ section.settings.shop_title_font_weight | default: 'bold' }} {{ section.settings.shop_title_color | default: 'text-primary' }}">{{ section.settings.shop_title  | default: 'All Products' }}</h2>
                            </div>
                            <p class="shop-product-count {{ section.settings.product_count_font_family | default: 'font-body' }} {{ section.settings.product_count_font_size | default: 'text-sm' }} {{ section.settings.product_count_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_count_color | default: 'text-neutral' }}">
                                <span class="product-count-label">Showing:</span> {{ collection.products_count }}
                                {% if collection.products_count > 1 %}
                                products
                                {% else %}
                                product
                                {% endif %}
                            </p>
                        </div>
                        
                        <div class="shop-header-bottom">
                          <div class="shop-header-bottom-wrapper">
                              <!-- Filter Toggle Button -->
                              <div class="filter-toggle-wrapper">
                                  {% if filter_style == 'drawer' %}
                                  <button type="button" class="filter-drawer-toggle-btn filter-layout-drawer" id="filter-drawer-toggle-btn" aria-label="Open filters">
                                    <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path fill-rule="evenodd" clip-rule="evenodd" d="M5 1C5.26522 1 5.51957 1.10536 5.70711 1.29289C5.89464 1.48043 6 1.73478 6 2V4C6 4.26522 5.89464 4.51957 5.70711 4.70711C5.51957 4.89464 5.26522 5 5 5C4.73478 5 4.48043 4.89464 4.29289 4.70711C4.10536 4.51957 4 4.26522 4 4V2C4 1.73478 4.10536 1.48043 4.29289 1.29289C4.48043 1.10536 4.73478 1 5 1V1Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path d="M17 3H6" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path d="M4 3H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path fill-rule="evenodd" clip-rule="evenodd" d="M5 11C5.26522 11 5.51957 11.1054 5.70711 11.2929C5.89464 11.4804 6 11.7348 6 12V14C6 14.2652 5.89464 14.5196 5.70711 14.7071C5.51957 14.8946 5.26522 15 5 15C4.73478 15 4.48043 14.8946 4.29289 14.7071C4.10536 14.5196 4 14.2652 4 14V12C4 11.7348 4.10536 11.4804 4.29289 11.2929C4.48043 11.1054 4.73478 11 5 11Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path d="M17 13H6" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path d="M4 13H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path fill-rule="evenodd" clip-rule="evenodd" d="M13 6C13.2652 6 13.5196 6.10536 13.7071 6.29289C13.8946 6.48043 14 6.73478 14 7V9C14 9.26522 13.8946 9.51957 13.7071 9.70711C13.5196 9.89464 13.2652 10 13 10C12.7348 10 12.4804 9.89464 12.2929 9.70711C12.1054 9.51957 12 9.26522 12 9V7C12 6.73478 12.1054 6.48043 12.2929 6.29289C12.4804 6.10536 12.7348 6 13 6V6Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path d="M12 8H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      <path d="M17 8H14" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                    <span>Filters</span>
                                  </button>
                                  {% elsif filter_style == 'horizontal_bar' %}
                                  <button type="button" class="mobile-filter-toggle-btn" id="mobile-filter-toggle-btn" aria-label="Toggle filters">
                                      <span class="filter-btn-text">Filter</span>
                                      <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                          <path fill-rule="evenodd" clip-rule="evenodd" d="M5 1C5.26522 1 5.51957 1.10536 5.70711 1.29289C5.89464 1.48043 6 1.73478 6 2V4C6 4.26522 5.89464 4.51957 5.70711 4.70711C5.51957 4.89464 5.26522 5 5 5C4.73478 5 4.48043 4.89464 4.29289 4.70711C4.10536 4.51957 4 4.26522 4 4V2C4 1.73478 4.10536 1.48043 4.29289 1.29289C4.48043 1.10536 4.73478 1 5 1V1Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M17 3H6" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M4 3H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path fill-rule="evenodd" clip-rule="evenodd" d="M5 11C5.26522 11 5.51957 11.1054 5.70711 11.2929C5.89464 11.4804 6 11.7348 6 12V14C6 14.2652 5.89464 14.5196 5.70711 14.7071C5.51957 14.8946 5.26522 15 5 15C4.73478 15 4.48043 14.8946 4.29289 14.7071C4.10536 14.5196 4 14.2652 4 14V12C4 11.7348 4.10536 11.4804 4.29289 11.2929C4.48043 11.1054 4.73478 11 5 11Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M17 13H6" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M4 13H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path fill-rule="evenodd" clip-rule="evenodd" d="M13 6C13.2652 6 13.5196 6.10536 13.7071 6.29289C13.8946 6.48043 14 6.73478 14 7V9C14 9.26522 13.8946 9.51957 13.7071 9.70711C13.5196 9.89464 13.2652 10 13 10C12.7348 10 12.4804 9.89464 12.2929 9.70711C12.1054 9.51957 12 9.26522 12 9V7C12 6.73478 12.1054 6.48043 12.2929 6.29289C12.4804 6.10536 12.7348 6 13 6V6Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M12 8H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M17 8H14" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                  </button>
                                  {% else %}
                                  <button type="button" class="mobile-filter-toggle-btn" id="mobile-filter-toggle-btn" aria-label="Toggle filters">
                                      <span class="filter-btn-text">Filter</span>
                                      <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                          <path fill-rule="evenodd" clip-rule="evenodd" d="M5 1C5.26522 1 5.51957 1.10536 5.70711 1.29289C5.89464 1.48043 6 1.73478 6 2V4C6 4.26522 5.89464 4.51957 5.70711 4.70711C5.51957 4.89464 5.26522 5 5 5C4.73478 5 4.48043 4.89464 4.29289 4.70711C4.10536 4.51957 4 4.26522 4 4V2C4 1.73478 4.10536 1.48043 4.29289 1.29289C4.48043 1.10536 4.73478 1 5 1V1Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M17 3H6" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M4 3H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path fill-rule="evenodd" clip-rule="evenodd" d="M5 11C5.26522 11 5.51957 11.1054 5.70711 11.2929C5.89464 11.4804 6 11.7348 6 12V14C6 14.2652 5.89464 14.5196 5.70711 14.7071C5.51957 14.8946 5.26522 15 5 15C4.73478 15 4.48043 14.8946 4.29289 14.7071C4.10536 14.5196 4 14.2652 4 14V12C4 11.7348 4.10536 11.4804 4.29289 11.2929C4.48043 11.1054 4.73478 11 5 11Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M17 13H6" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M4 13H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path fill-rule="evenodd" clip-rule="evenodd" d="M13 6C13.2652 6 13.5196 6.10536 13.7071 6.29289C13.8946 6.48043 14 6.73478 14 7V9C14 9.26522 13.8946 9.51957 13.7071 9.70711C13.5196 9.89464 13.2652 10 13 10C12.7348 10 12.4804 9.89464 12.2929 9.70711C12.1054 9.51957 12 9.26522 12 9V7C12 6.73478 12.1054 6.48043 12.2929 6.29289C12.4804 6.10536 12.7348 6 13 6V6Z" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M12 8H1" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M17 8H14" stroke="#818596" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                  </button>
                                  {% endif %}
                              </div>
                              {% if section.settings.show_search != false %}
                                  <div class="search-wrapper">
                                      <div class="shop-search-input-wrapper">
                                      <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                          <path d="M7 12C9.76142 12 12 9.76142 12 7C12 4.23858 9.76142 2 7 2C4.23858 2 2 4.23858 2 7C2 9.76142 4.23858 12 7 12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                          <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                      </svg>
                                      <input 
                                          type="search" 
                                          class="shop-search-input {{ section.settings.search_input_font_size | default: 'text-sm' }} {{ section.settings.search_input_color | default: 'text-primary' }}" 
                                          name="filterrific[search_query]"
                                          value="{{ search_query }}"
                                          placeholder="Search product"
                                      />
                                      </div>
                                  </div>
                              {% endif %}
                            </div>
                            <div class="shop-header-sortby-wrapper">
                                
                                {% if section.settings.show_sorting_dropdown != false %}
                                    <div class="sort-wrapper">
                                        <label class="sort-label {{ section.settings.toolbar_label_font_family | default: 'font-body' }} {{ section.settings.toolbar_label_font_size | default: 'text-sm' }} {{ section.settings.toolbar_label_color | default: 'text-primary' }} font-{{ section.settings.toolbar_label_font_weight | default: 'medium' }}">Sort by:</label>
                                        <select class="sort-select {{ section.settings.toolbar_select_font_size | default: 'text-sm' }} {{ section.settings.toolbar_select_color | default: 'text-primary' }}" name="filterrific[sorted_by]">
                                        <option value="">Sort by</option>
                                        <option value="price_desc" {% if sorted_by == 'price_desc' %}selected{% endif %}>
                                            Price: High to Low
                                        </option>
                                        <option value="price_asc" {% if sorted_by == 'price_asc' %}selected{% endif %}>
                                            Price: Low to High
                                        </option>
                                        <option value="title_asc" {% if sorted_by == 'title_asc' %}selected{% endif %}>
                                            Alphabetical: A-Z
                                        </option>
                                        <option value="title_desc" {% if sorted_by == 'title_desc' %}selected{% endif %}>
                                            Alphabetical: Z-A
                                        </option>
                                        </select>
                                    </div>
                                {% endif %}
                                {% if section.settings.show_products_per_page != false %}
                                    <div class="products-per-page-wrapper">
                                        <label class="products-per-page-label {{ section.settings.toolbar_label_font_family | default: 'font-body' }} {{ section.settings.toolbar_label_font_size | default: 'text-sm' }} {{ section.settings.toolbar_label_color | default: 'text-primary' }} font-{{ section.settings.toolbar_label_font_weight | default: 'medium' }}">Show:</label>
                                        <select class="products-per-page-select {{ section.settings.toolbar_select_font_size | default: 'text-sm' }} {{ section.settings.toolbar_select_color | default: 'text-primary' }}" id="products-per-page-select">
                                            <option value="10" {% if current_count_num == 10 %}selected{% endif %}>10</option>
                                            <option value="15" {% if current_count_num == 15 %}selected{% endif %}>15</option>
                                            <option value="20" {% if current_count_num == 20 %}selected{% endif %}>20</option>
                                            <option value="25" {% if current_count_num == 25 %}selected{% endif %}>25</option>
                                            <option value="30" {% if current_count_num == 30 %}selected{% endif %}>30</option>
                                            <option value="35" {% if current_count_num == 35 %}selected{% endif %}>35</option>
                                            <option value="40" {% if current_count_num == 40 %}selected{% endif %}>40</option>
                                            <option value="45" {% if current_count_num == 45 %}selected{% endif %}>45</option>
                                            <option value="50" {% if current_count_num == 50 %}selected{% endif %}>50</option>
                                        </select>
                                    </div>
                                {% endif %}
                                {% if section.settings.show_view_toggle != false %}
                                    <div class="view-toggle-wrapper">
                                        <button type="button" class="view-toggle-btn {% if section.settings.default_view == 'grid' or section.settings.default_view == blank %}active{% endif %}" data-view="grid" aria-label="Grid view" title="Grid view">
                                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <rect x="1" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                                <rect x="9" y="1" width="6" height="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                                <rect x="1" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                                <rect x="9" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                            </svg>
                                        </button>
                                        <button type="button" class="view-toggle-btn {% if section.settings.default_view == 'list' %}active{% endif %}" data-view="list" aria-label="List view" title="List view">
                                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <rect x="1" y="2" width="14" height="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                                <rect x="1" y="7" width="14" height="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                                <rect x="1" y="12" width="14" height="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                            </svg>
                                        </button>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    
                    {%- comment -%} Horizontal Bar Filter Layout {%- endcomment -%}
                    <!-- Horizontal Bar: Filters - Below Shop Header Bar -->
                    <div class="shop-filters-horizontal-bar filter-layout-horizontal-bar" id="shop-filters-horizontal-bar">
                        <div class="filters-horizontal-content">
                            <!-- Filters Header -->
                            <div class="filters-header-horizontal">
                                <div class="filters-header-left">
                                    <h3 class="filters-title {{ section.settings.filters_title_font_family | default: 'font-primary' }} {{ section.settings.filters_title_font_size | default: 'text-sm' }} {{ section.settings.filters_title_font_size_desktop | default: 'lg:text-base' }} font-{{ section.settings.filters_title_font_weight | default: 'bold' }} {{ section.settings.filters_title_color | default: 'text-primary' }}">Filters</h3>
                                </div>
                                <div class="filters-header-right">
                                    <a href='#' id='clear-form-horizontal' class='clear-all-btn {{ section.settings.clear_all_font_size | default: 'text-sm' }} {{ section.settings.clear_all_color | default: 'text-info' }} font-{{ section.settings.clear_all_font_weight | default: 'medium' }}'>
                                        Clear All
                                    </a>
                                    <button type="button" class="horizontal-bar-close-btn" id="horizontal-bar-close-btn" aria-label="Close filters">
                                        <svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M11.7773 2.06641L7.55859 6.28516L11.7422 10.4688C12.0938 10.7852 12.0938 11.3125 11.7422 11.6289C11.4258 11.9805 10.8984 11.9805 10.582 11.6289L6.36328 7.44531L2.17969 11.6289C1.86328 11.9805 1.33594 11.9805 1.01953 11.6289C0.667969 11.3125 0.667969 10.7852 1.01953 10.4336L5.20312 6.25L1.01953 2.06641C0.667969 1.75 0.667969 1.22266 1.01953 0.871094C1.33594 0.554688 1.86328 0.554688 2.21484 0.871094L6.39844 5.08984L10.582 0.90625C10.8984 0.554688 11.4258 0.554688 11.7773 0.90625C12.0938 1.22266 12.0938 1.75 11.7773 2.06641Z" fill="black" fill-opacity="0.5"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Filter Accordions - Horizontal Layout (content cloned from sidebar via JS) -->
                            <div class="filters-list-horizontal" id="filters-list-horizontal">
                                <!-- Content will be cloned from sidebar filters-list -->
                            </div>
                        </div>
                    </div>
                
                    <!-- Product Grid -->
                    <div class="product-grid-section" {% if section.settings.aspect_ratio_source == 'custom' and section.settings.custom_aspect_ratio != blank %}style="--custom-aspect-ratio: {{ section.settings.custom_aspect_ratio }};"{% endif %}>
                        {% assign products_array = collection.products | parse_json %}
                        {% if products_array.size > 0 %}
                        {% assign default_view = section.settings.default_view | default: 'grid' %}
                        {% assign grid_columns_mobile = section.settings.grid_columns_mobile | default: 2 %}
                        {% assign grid_columns_tablet = section.settings.grid_columns_tablet | default: 3 %}
                        {% assign grid_columns_desktop = section.settings.grid_columns_desktop | default: 4 %}
                        {% assign out_of_stock_handling = section.settings.out_of_stock_handling | default: 'show_with_overlay' %}
                        
                        <div class="product-grid product-view-{{ default_view }} {% if default_view == 'grid' %}grid-cols-mobile-{{ grid_columns_mobile }} grid-cols-tablet-{{ grid_columns_tablet }} grid-cols-desktop-{{ grid_columns_desktop }}{% endif %}" data-view="{{ default_view }}" data-grid-cols-mobile="{{ grid_columns_mobile }}" data-grid-cols-tablet="{{ grid_columns_tablet }}" data-grid-cols-desktop="{{ grid_columns_desktop }}">
                            {%- comment -%} Product loop {%- endcomment -%}
                            {%- for product in products_array -%}
                                {%- assign is_out_of_stock = false -%}
                                {%- if product.out_of_stock == true or product.available_for_country == false -%}
                                    {%- assign is_out_of_stock = true -%}
                                {%- endif -%}
                                
                                {%- comment -%} Skip out-of-stock products if handling is 'hide' {%- endcomment -%}
                                {%- if out_of_stock_handling == 'hide' and is_out_of_stock -%}
                                    {%- continue -%}
                                {%- endif -%}
                            {% assign content_position = section.settings.content_position | default: 'bottom' %}
                            {% assign text_alignment = section.settings.text_alignment | default: 'left' %}
                            
                            {%- comment -%} Price Type Selection {%- endcomment -%}
                            {%- comment -%} Check if product is out of stock {%- endcomment -%}
                            {%- assign is_out_of_stock = false -%}
                            {%- if product.out_of_stock == true or product.available_for_country == false -%}
                                {%- assign is_out_of_stock = true -%}
                            {%- endif -%}
                            
                            {% assign content_position = section.settings.content_position | default: 'bottom' %}
                            {% assign text_alignment = section.settings.text_alignment | default: 'left' %}
                            
                            {%- comment -%} Price Type Selection {%- endcomment -%}
                            {%- assign price_type = section.settings.price_type | default: 'retail' -%}
                            {%- assign selected_price = product.price -%}
                            {%- assign selected_display_price = product.display_price | default: product.price | money -%}
                            
                            {%- if price_type == 'wholesale' -%}
                                {%- assign selected_price = product.wholesale_price | default: product.price -%}
                                {%- assign selected_display_price = product.display_wholesale_price | default: product.wholesale_price | money | default: product.price | money -%}
                            {%- elsif price_type == 'subscription' -%}
                                {%- assign selected_price = product.subscription_price | default: product.price -%}
                                {%- assign selected_display_price = product.display_subscription_price | default: product.subscription_price | money | default: product.price | money -%}
                            {%- elsif price_type == 'wholesale_subscription' -%}
                                {%- assign selected_price = product.wholesale_subscription_price | default: product.price -%}
                                {%- assign selected_display_price = product.display_wholesale_subscription_price | default: product.wholesale_subscription_price | money | default: product.price | money -%}
                            {%- endif -%}
                            
                            {%- assign quick_view_images = '' -%}
                              {%- if product.images and product.images.size > 0 -%}
                                {%- for img in product.images -%}
                                  {%- if img.src -%}
                                    {%- if quick_view_images != '' -%}{%- assign quick_view_images = quick_view_images | append: '|||' -%}{%- endif -%}
                                    {%- assign quick_view_images = quick_view_images | append: img.src | image_url: width: 600 -%}
                                  {%- endif -%}
                                {%- endfor -%}
                              {%- endif -%}
