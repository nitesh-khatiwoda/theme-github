        const horizontalBar = document.getElementById('shop-filters-horizontal-bar');
        if (sidebar && sidebar.classList.contains('sidebar-open')) {
          LayoutManager.closeMobileSidebar();
        }
        if (horizontalBar && horizontalBar.classList.contains('horizontal-bar-open')) {
          LayoutManager.closeHorizontalBar();
        }
      }
    });
    
    // Filter accordion toggle functionality
    const accordionHeaders = document.querySelectorAll('.filter-accordion-header');
    accordionHeaders.forEach(header => {
