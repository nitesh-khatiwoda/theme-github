        const accordion = this.parentElement;
        accordion.classList.toggle('active');
      });
    });
    

    
    // Handle out-of-stock product ordering (show at end)
    function reorderOutOfStockProducts() {
      const productGrid = document.querySelector('.product-grid');
      if (!productGrid) return;
      
      const outOfStockHandling = '{{ section.settings.out_of_stock_handling | default: "show_with_overlay" }}';
      
      if (outOfStockHandling === 'show_at_end') {
        const productCards = Array.from(productGrid.querySelectorAll('.product-card'));
        const inStockCards = [];
        const outOfStockCards = [];
        
        productCards.forEach(function(card) {
          const isOutOfStock = card.getAttribute('data-out-of-stock') === 'true';
          if (isOutOfStock) {
            outOfStockCards.push(card);
          } else {
            inStockCards.push(card);
          }
        });
        
        // Clear grid
        productCards.forEach(function(card) {
          card.remove();
        });
        
        // Re-append: in-stock first, then out-of-stock
        inStockCards.forEach(function(card) {
          productGrid.appendChild(card);
        });
        outOfStockCards.forEach(function(card) {
          productGrid.appendChild(card);
        });
      }
    }
    
    // Reorder products on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', reorderOutOfStockProducts);
    } else {
      reorderOutOfStockProducts();
    }
    
    // Make filter options scrollable if more than 5 items
    const filterOptions = document.querySelectorAll('.filter-options');
    filterOptions.forEach(function(optionsList) {
      const items = optionsList.querySelectorAll('li');
      if (items.length > 5) {
        optionsList.classList.add('scrollable');
      }
    });
    
    // Product card click handler - navigate to product URL when card is clicked
    const productCards = document.querySelectorAll('.product-card[data-product-url]');
    productCards.forEach(function(card) {
      card.addEventListener('click', function(e) {
        // Don't navigate if clicking on buttons, links, or interactive elements
        const isClickOnButton = e.target.closest('button');
        const isClickOnLink = e.target.closest('a');
        const isClickOnCTA = e.target.closest('.product-ctas');
        
        if (!isClickOnButton && !isClickOnLink && !isClickOnCTA) {
          const productUrl = card.getAttribute('data-product-url');
          if (productUrl) {
            window.location.href = productUrl;
          }
        }
      });
      
      // Make card cursor pointer to indicate it's clickable
      card.style.cursor = 'pointer';
    });
    
    // Quick View modal
    (function() {
      const modal = document.getElementById('quick-view-modal');
      if (!modal) return;
      const overlay = modal.querySelector('.quick-view-modal-overlay');
      const closeBtn = modal.querySelector('.quick-view-modal-close');
      const titleEl = document.getElementById('quick-view-modal-title');
      const priceEl = document.getElementById('quick-view-modal-price');
      const descEl = document.getElementById('quick-view-modal-description');
      const mainImgEl = document.getElementById('quick-view-modal-image');
      const thumbnailsEl = document.getElementById('quick-view-modal-thumbnails');
      const viewProductLink = document.getElementById('quick-view-modal-view-product');
      const addToCartBtn = document.getElementById('quick-view-modal-add-to-cart');
      
      function openQuickView(card) {
        if (!card || !titleEl) return;
        const title = card.getAttribute('data-quick-view-title') || 'Product';
        const price = card.getAttribute('data-quick-view-price') || '';

        const description = card.getAttribute('data-quick-view-description') || '';
        const variantId = card.getAttribute('data-quick-view-variant-id') || '';
        const productUrl = card.getAttribute('data-product-url') || '#';
        const imagesStr = card.getAttribute('data-quick-view-images') || '';
        const images = imagesStr ? imagesStr.split('|||').filter(Boolean) : [];
        
        titleEl.textContent = title;
        if (priceEl) {
          priceEl.innerHTML = '';
          if (price) {
            const priceSpan = document.createElement('span');
            priceSpan.className = 'current-price';
            priceSpan.textContent = price;
            priceEl.appendChild(priceSpan);
          }

        }
        if (descEl) {
          descEl.textContent = description;
          descEl.style.display = description ? 'block' : 'none';
        }
        if (mainImgEl) {
          mainImgEl.src = images[0] || '';
          mainImgEl.alt = title;
          mainImgEl.style.display = images[0] ? 'block' : 'none';
        }
        if (thumbnailsEl) {
          thumbnailsEl.innerHTML = '';
          images.forEach(function(src, i) {
            if (!src) return;
            var img = document.createElement('img');
            img.src = src;
            img.alt = title + ' - ' + (i + 1);
            img.loading = 'lazy';
            img.className = 'quick-view-thumb' + (i === 0 ? ' active' : '');
            img.addEventListener('click', function() {
              if (mainImgEl) { mainImgEl.src = src; mainImgEl.alt = img.alt; }
              thumbnailsEl.querySelectorAll('.quick-view-thumb').forEach(function(t) { t.classList.remove('active'); });
              img.classList.add('active');
            });
            thumbnailsEl.appendChild(img);
          });
          thumbnailsEl.style.display = images.length > 1 ? 'flex' : 'none';
        }
        if (viewProductLink) {
          viewProductLink.href = productUrl;
        }
        if (addToCartBtn) {
          addToCartBtn.setAttribute('data-fluid-add-to-cart', variantId);
          addToCartBtn.setAttribute('data-fluid-quantity', '1');
        }
        modal.classList.add('quick-view-modal-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      
      function closeQuickView() {
        modal.classList.remove('quick-view-modal-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      
      document.querySelectorAll('[data-quick-view-trigger]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var card = this.closest('.product-card');
          if (card) openQuickView(card);
        });
      });
      
      [overlay, closeBtn].forEach(function(el) {
        if (el) el.addEventListener('click', closeQuickView);
      });
      modal.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeQuickView();
      });
    })();
    
    // View toggle functionality (Grid/List)
    const viewToggleButtons = document.querySelectorAll('.view-toggle-btn');
    const productGrid = document.querySelector('.product-grid');
    
    // Load saved view preference from localStorage
    const savedView = localStorage.getItem('shop-view-preference');
    if (savedView && productGrid) {
      updateView(savedView);
    }
    
    viewToggleButtons.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const view = this.getAttribute('data-view');
        updateView(view);
        // Save preference to localStorage
        localStorage.setItem('shop-view-preference', view);
      });
    });
    
    function updateView(view) {
      if (!productGrid) return;
      
      // Update grid classes
      productGrid.setAttribute('data-view', view);
      productGrid.className = productGrid.className.replace(/product-view-\w+/g, '');
      productGrid.classList.add('product-view-' + view);
      
      // When switching to grid, ensure column classes are applied (mobile/tablet/desktop)
      if (view === 'grid') {
        productGrid.className = productGrid.className.replace(/\bgrid-cols-mobile-\d+\b/g, '');
        productGrid.className = productGrid.className.replace(/\bgrid-cols-tablet-\d+\b/g, '');
        productGrid.className = productGrid.className.replace(/\bgrid-cols-desktop-\d+\b/g, '');
        var mobile = productGrid.getAttribute('data-grid-cols-mobile') || '2';
        var tablet = productGrid.getAttribute('data-grid-cols-tablet') || '3';
        var desktop = productGrid.getAttribute('data-grid-cols-desktop') || '4';
        productGrid.classList.add('grid-cols-mobile-' + mobile, 'grid-cols-tablet-' + tablet, 'grid-cols-desktop-' + desktop);
      }
      
      // Update product cards
      const productCards = productGrid.querySelectorAll('.product-card');
      productCards.forEach(function(card) {
        card.className = card.className.replace(/product-card-\w+/g, '');
        card.classList.add('product-card-' + view);
      });
      
      // Update button states
      viewToggleButtons.forEach(function(btn) {
        if (btn.getAttribute('data-view') === view) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
    }
    
    // Handle form submission and filter changes - matching fluid theme approach exactly
    const filterForm = document.getElementById('filterrific_filter');
    if (filterForm) {
      // Set action from url attribute if it exists (matching fluid theme)
      // The url variable should contain the shop page URL
      const urlAttr = filterForm.getAttribute('url');
      if (urlAttr && urlAttr.trim() !== '') {
        // Remove query string from URL to get base URL (form will add filterrific params on submit)
        // But preserve non-filterrific query params if they exist in the current URL
        const baseUrl = urlAttr.split('?')[0];
        const currentUrl = new URL(window.location.href);
        const currentParams = new URLSearchParams(currentUrl.search);
        
        // Remove filterrific params from current URL (they'll be added by form)
        currentParams.delete('filterrific');
        Array.from(currentParams.keys()).forEach(key => {
          if (key.startsWith('filterrific[')) {
            currentParams.delete(key);
          }
        });
        
        // Build final URL with preserved non-filterrific params
        const preservedParams = currentParams.toString();
        filterForm.action = preservedParams ? baseUrl + '?' + preservedParams : baseUrl;
      } else {
        // Fallback: use current URL pathname
        filterForm.action = window.location.pathname;
      }
      
      // Ensure form method is GET
      filterForm.method = 'get';
      
      // Sync checkboxes from URL parameters (fallback if backend doesn't set selected)
      FilterSync.syncCheckboxesFromURL();
      
      // Also sync after a short delay to ensure DOM is fully ready
      setTimeout(function() {
        FilterSync.syncCheckboxesFromURL();
      }, 100);
      
      // Listen for change events directly on the form (matching fluid theme: $(document).on('change', '#filterrific_filter', function () { $(this).submit() }))
      filterForm.addEventListener('change', function(e) {
        const target = e.target;
        
        console.log('[Form Change] Target:', target.id, target.name, target.type, target.checked);
        
        // Skip products per page selector (handled separately)
        if (target.id === 'products-per-page-select') {
          return;
        }
        // Only process checkboxes, selects, and search inputs
        if (target.type === 'checkbox' || target.tagName === 'SELECT' || target.type === 'search') {
          // Update visual state if it's a checkbox
          if (target.type === 'checkbox') {
            Utils.updateCheckboxVisualState(
              target,
              target.checked,
              '{{ section.settings.sidebar_filter_item_selected_color | default: "text-info" }}',
              '{{ section.settings.sidebar_filter_item_color | default: "text-primary" }}'
            );
          }
          // Ensure form action is set correctly before submitting
          const urlAttr = filterForm.getAttribute('url');
          if (urlAttr && urlAttr.trim() !== '') {
            const baseUrl = urlAttr.split('?')[0];
            const currentUrl = new URL(window.location.href);
            const currentParams = new URLSearchParams(currentUrl.search);
            
            // Remove filterrific params (form will add new ones)
            currentParams.delete('filterrific');
            Array.from(currentParams.keys()).forEach(key => {
              if (key.startsWith('filterrific[')) {
                currentParams.delete(key);
              }
            });
            
            // Preserve count parameter from hidden input (matches controller MINIMUM_PRODUCT_COUNT)
            const countInput = filterForm.querySelector('input[name="count"]');
            if (countInput && countInput.value) {
              currentParams.set('count', countInput.value);
            } else if (!currentParams.has('count')) {
              currentParams.set('count', '10');
            }
            
            const preservedParams = currentParams.toString();
            filterForm.action = preservedParams ? baseUrl + '?' + preservedParams : baseUrl;
          } else if (!filterForm.action || filterForm.action === '') {
            filterForm.action = window.location.pathname;
          }
          
          // Submit the form immediately (matching fluid theme: $(this).submit())
          // Chips will be populated after page reload from checked checkboxes
          // Use setTimeout to ensure disabled state is applied before submission
          setTimeout(function() {
            filterForm.submit();
          }, 10);
        }
      });
      
      // Re-enable select after form submission attempt (in case submission was prevented)
      filterForm.addEventListener('submit', function() {
        const sortSelect = filterForm.querySelector('select[name="filterrific[sorted_by]"]');
        if (sortSelect && sortSelect.disabled) {
          setTimeout(function() {
            sortSelect.disabled = false;
          }, 1000);
        }
      });
      
    }
    
    // Function to clear all filters
    function clearAllFilters() {
      const form = document.getElementById('filterrific_filter');
      if (form) {
        // Uncheck all checkboxes (matching fluid theme: $('#filterrific_filter input[type="checkbox"]').prop('checked', false))
        document.querySelectorAll('#filterrific_filter input[type="checkbox"]').forEach(function(checkbox) {
          checkbox.checked = false;
          // Remove checked attribute for proper CSS :checked pseudo-class support
          checkbox.removeAttribute('checked');
          checkbox.classList.remove('is-checked');
        });
        
        
        // Clear search input
        const searchInput = form.querySelector('input[name="filterrific[search_query]"]');
        if (searchInput) {
          searchInput.value = '';
        }
        
        // Ensure count parameter is preserved (default to 10 to match controller MINIMUM_PRODUCT_COUNT)
        const countInput = form.querySelector('input[name="count"]');
        if (!countInput) {
          const hiddenCount = document.createElement('input');
          hiddenCount.type = 'hidden';
          hiddenCount.name = 'count';
          hiddenCount.value = '10';
          form.appendChild(hiddenCount);
        }
        
        // Submit form directly (matching fluid theme: document.getElementById('filterrific_filter').submit())
        form.submit();
      }
    }
    
    // Clear all filters - matching fluid theme approach
    document.addEventListener('click', function(e) {
      if (e.target.closest('#clear-form') || 
          e.target.closest('#clear-form-horizontal') || 
          e.target.closest('#clear-form-drawer')) {
        e.preventDefault();
        clearAllFilters();
      }
      
      // Handle empty state clear filters button
      if (e.target.closest('#empty-state-clear-filters')) {
        e.preventDefault();
        clearAllFilters();
      }
      
      // Handle drawer toggle button
      if (e.target.closest('#filter-drawer-toggle-btn')) {
        e.preventDefault();
        LayoutManager.openDrawer();
      }
      
      // Handle drawer close button
      if (e.target.closest('#drawer-close-btn')) {
        console.log('[Debug] Drawer close button clicked');
        e.preventDefault();
        LayoutManager.closeDrawer();
      }
      
      // Handle drawer overlay click
      if (e.target.closest('#drawer-overlay')) {
        e.preventDefault();
        LayoutManager.closeDrawer();
      }
    });
    
    // Close drawer on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const drawer = document.getElementById('shop-filters-drawer');
        if (drawer && drawer.classList.contains('drawer-open')) {
          LayoutManager.closeDrawer();
        }
      }
    });
  });
  
  // Shop Add to Cart button handler - prevent link navigation when clicking add to cart
  // We need to stop the <a> tag from navigating while still allowing Fluid's SDK to work
  document.addEventListener('click', function(e) {
    const addToCartBtn = e.target.closest('.shop-add-to-cart-btn');
    if (addToCartBtn) {
      // Prevent the parent <a> from navigating
      e.preventDefault();
      e.stopPropagation();
      
      // Get the variant details
      const variantId = addToCartBtn.getAttribute('data-fluid-add-to-cart');
      const quantity = parseInt(addToCartBtn.getAttribute('data-fluid-quantity') || '1');
      const openCart = addToCartBtn.getAttribute('data-fluid-open-cart-after-add') === 'true';
      
      if (!variantId) {
        console.error('No variant ID found');
        return;
      }
      
      // Use Fluid's cart API to add the item
      // The SDK exposes methods on window after loading
      function tryAddToCart() {
        // Method 1: Try FairShareSDK (seen in other sections)
        if (typeof FairShareSDK !== 'undefined') {
          // Check for different method signatures
          if (FairShareSDK.addToCart) {
            FairShareSDK.addToCart(variantId, quantity, openCart);
            return true;
          }
          if (FairShareSDK.cart && FairShareSDK.cart.add) {
            FairShareSDK.cart.add({ variant_id: variantId, quantity: quantity });
            if (openCart && FairShareSDK.cart.open) FairShareSDK.cart.open();
            return true;
          }
        }
        
        // Method 2: Try FluidCommerceSDK
        if (typeof FluidCommerceSDK !== 'undefined') {
          if (FluidCommerceSDK.addToCart) {
            FluidCommerceSDK.addToCart(variantId, quantity, openCart);
            return true;
          }
          if (FluidCommerceSDK.cart && FluidCommerceSDK.cart.add) {
            FluidCommerceSDK.cart.add({ variant_id: variantId, quantity: quantity });
            if (openCart && FluidCommerceSDK.cart.open) FluidCommerceSDK.cart.open();
            return true;
          }
        }
        
        // Method 3: Try window.Fluid
        if (typeof window.Fluid !== 'undefined' && window.Fluid.cart) {
          window.Fluid.cart.add({ variant_id: variantId, quantity: quantity });
          if (openCart && window.Fluid.cart.open) window.Fluid.cart.open();
          return true;
        }
        
        return false;
      }
      
      if (!tryAddToCart()) {
        // Fallback: Create a standalone element and trigger its click
        // The SDK should auto-bind to elements with data-fluid-add-to-cart
        const form = document.createElement('form');
        form.style.cssText = 'position:fixed;top:-9999px;left:-9999px;';
        form.innerHTML = '<button type="button" data-fluid-add-to-cart="' + variantId + '" data-fluid-quantity="' + quantity + '" ' + (openCart ? 'data-fluid-open-cart-after-add="true"' : '') + '>Add</button>';
        document.body.appendChild(form);
        
        // Wait a frame for SDK to potentially bind, then click
        setTimeout(function() {
          const btn = form.querySelector('button');
          if (btn) btn.click();
          setTimeout(function() { form.remove(); }, 2000);
        }, 100);
      }
    }
  }, true); // Use capture phase to intercept before bubbling
  
  // Pagination: Load More & Infinite Scroll
  (function() {
    function loadNextPage(options) {
      const { currentPage, totalPages, perPage, baseUrl, hasPaginate, productGrid, style } = options;
      
      if (currentPage >= totalPages) {
        return Promise.resolve(false);
      }
      
      const nextPage = currentPage + 1;
      const loadingElement = style === 'infinite_scroll' 
        ? document.querySelector('.pagination-infinite-scroll-trigger .infinite-scroll-loading')
        : null;
      
      const loadMoreBtn = document.querySelector('.pagination-load-more-btn');
      
      // Show loading state
      if (loadingElement) loadingElement.style.display = 'flex';
      if (loadMoreBtn) {
        loadMoreBtn.disabled = true;
        loadMoreBtn.querySelector('.load-more-text').style.display = 'none';
        loadMoreBtn.querySelector('.load-more-loading').style.display = 'inline-flex';
        loadMoreBtn.querySelector('.load-more-loading').style.alignItems = 'center';
        loadMoreBtn.querySelector('.load-more-loading').style.gap = '0.5rem';
      }
      
      // Build URL with page parameter
      const url = new URL(baseUrl || window.location.pathname, window.location.origin);
      const params = new URLSearchParams(window.location.search);
      params.set('page', nextPage.toString());
      
      // Preserve count parameter
      if (perPage && !params.has('count')) {
        params.set('count', perPage.toString());
      }
      
      // Fetch next page
      return fetch(url.pathname + '?' + params.toString(), {
        method: 'GET',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'text/html'
        }
      })
      .then(response => {
        if (!response.ok) throw new Error('Failed to load page');
        return response.text();
      })
      .then(html => {
        // Parse the HTML response
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        
        // Find product grid in response
        const responseGrid = doc.querySelector('.product-grid');
        if (!responseGrid) {
          throw new Error('Product grid not found in response');
        }
        
        // Append new products to existing grid
        if (productGrid) {
          const newProducts = Array.from(responseGrid.children);
          newProducts.forEach(product => {
            productGrid.appendChild(product);
          });
        }
        
        // Update pagination info
        const paginationInfo = document.querySelector('.pagination-info');
        if (paginationInfo && doc.querySelector('.pagination-info')) {
          const newInfo = doc.querySelector('.pagination-info').textContent;
          paginationInfo.textContent = newInfo;
        }
        
        // Update current page in data attributes
        const trigger = document.querySelector('.pagination-infinite-scroll-trigger, .pagination-load-more-wrapper');
        let currentTotalPages = totalPages;

        if (trigger) {
          trigger.setAttribute('data-current-page', nextPage);
          if (loadMoreBtn) {
            loadMoreBtn.setAttribute('data-current-page', nextPage);
            
            // Sync total pages and per page from response to handle filter/count changes
            const newBtn = doc.querySelector('.pagination-load-more-btn');
            const newTrigger = doc.querySelector('.pagination-infinite-scroll-trigger, .pagination-load-more-wrapper');
            
            if (newBtn) {
              const newTotal = newBtn.getAttribute('data-total-pages');
              loadMoreBtn.setAttribute('data-total-pages', newTotal);
              currentTotalPages = parseInt(newTotal) || currentTotalPages;
            } else if (newTrigger) {
              const newTotal = newTrigger.getAttribute('data-total-pages');
              trigger.setAttribute('data-total-pages', newTotal);
              currentTotalPages = parseInt(newTotal) || currentTotalPages;
            }
          }
        }
        
        // Check if there are more pages
        const hasMore = nextPage < currentTotalPages;

        if (!hasMore) {
          // Hide pagination elements when no more pages
          if (trigger) trigger.style.display = 'none';
        }
        
        return hasMore;
      })
      .catch(error => {
        console.error('Error loading next page:', error);
        alert('Failed to load more products. Please try again.');
        return false;
      })
      .finally(() => {
        // Hide loading state
        if (loadingElement) loadingElement.style.display = 'none';
        if (loadMoreBtn) {
          loadMoreBtn.disabled = false;
          loadMoreBtn.querySelector('.load-more-text').style.display = 'inline';
          loadMoreBtn.querySelector('.load-more-loading').style.display = 'none';
        }
      });
    }
    
    // Initialize Load More button
    function initLoadMore() {
      const loadMoreBtn = document.querySelector('.pagination-load-more-btn');
      if (!loadMoreBtn) return;
      
      loadMoreBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (this.disabled) return;
        
        const currentPage = parseInt(this.getAttribute('data-current-page')) || 1;
        const totalPages = parseInt(this.getAttribute('data-total-pages')) || 1;
        const perPage = parseInt(this.getAttribute('data-per-page')) || 10;
        const baseUrl = this.getAttribute('data-base-url') || window.location.pathname;
        const hasPaginate = this.getAttribute('data-has-paginate') === 'true';
        const productGrid = document.querySelector('.product-grid');
        
        loadNextPage({
          currentPage,
          totalPages,
          perPage,
          baseUrl,
          hasPaginate,
          productGrid,
          style: 'load_more'
        }).then(hasMore => {
          if (hasMore) {
            // Update button data attributes for next load
            this.setAttribute('data-current-page', currentPage + 1);
          }
        });
      });
    }
    
    // Initialize Infinite Scroll
    function initInfiniteScroll() {
      const trigger = document.querySelector('.pagination-infinite-scroll-trigger');
      if (!trigger) return;
      
      const productGrid = document.querySelector('.product-grid');
      if (!productGrid) return;
      
      let isLoading = false;
      let hasMore = true;
      
      function checkScroll() {
        if (isLoading || !hasMore) return;
        
        const rect = trigger.getBoundingClientRect();
        const windowHeight = window.innerHeight || document.documentElement.clientHeight;
        
        // Trigger when trigger element is visible (within 200px of viewport)
        if (rect.top <= windowHeight + 200) {
          isLoading = true;
          
          const currentPage = parseInt(trigger.getAttribute('data-current-page')) || 1;
          const totalPages = parseInt(trigger.getAttribute('data-total-pages')) || 1;
          const perPage = parseInt(trigger.getAttribute('data-per-page')) || 10;
          const baseUrl = trigger.getAttribute('data-base-url') || window.location.pathname;
          const hasPaginate = trigger.getAttribute('data-has-paginate') === 'true';
          
          const loadingElement = trigger.querySelector('.infinite-scroll-loading');
          if (loadingElement) loadingElement.style.display = 'flex';
          
          loadNextPage({
            currentPage,
            totalPages,
            perPage,
            baseUrl,
            hasPaginate,
            productGrid,
            style: 'infinite_scroll'
          }).then(result => {
            hasMore = result;
            isLoading = false;
            if (loadingElement) loadingElement.style.display = 'none';
            
            if (hasMore) {
              // Update trigger data attributes
              trigger.setAttribute('data-current-page', currentPage + 1);
            } else {
              trigger.style.display = 'none';
            }
          });
        }
      }
      
      // Throttle scroll events
      let scrollTimeout;
      window.addEventListener('scroll', function() {
        if (scrollTimeout) {
          window.cancelAnimationFrame(scrollTimeout);
        }
        scrollTimeout = window.requestAnimationFrame(checkScroll);
      }, { passive: true });
      
      // Initial check
      checkScroll();
    }
    
    // Initialize based on pagination style
    document.addEventListener('DOMContentLoaded', function() {
      const loadMoreWrapper = document.querySelector('.pagination-load-more-wrapper');
      const infiniteScrollTrigger = document.querySelector('.pagination-infinite-scroll-trigger');
      
      if (loadMoreWrapper) {
        initLoadMore();
      }
      
      if (infiniteScrollTrigger) {
        initInfiniteScroll();
      }
    });
  })();
  
})();

</script>

