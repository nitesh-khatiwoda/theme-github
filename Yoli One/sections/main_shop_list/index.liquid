                                <!-- End Product Content Below -->
                                {% endif %}
                                
                                {% if content_position == 'right' %}
                                <!-- Product Content Right of Media (Desktop only, shows as bottom on mobile) -->
                                <div class="product-content">
                                
                                <!-- Product Info -->
                                <div class="product-info">
                                    
                                    <!-- Product Name -->
                                    <div class="product-name">
                                    <h3 class="{{ section.settings.product_title_font_family | default: 'font-primary' }} {{ section.settings.product_title_font_size | default: 'text-xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-2xl' }} font-{{ section.settings.product_title_font_weight | default: 'semibold' }} {{ section.settings.product_title_color | default: 'text-primary' }}">
                                        {{ product.title | default: 'Product' }}
                                    </h3>
                                    </div>
                                    
                                    <!-- Product Ratings -->
                                    {% assign product_rating = product.metafields.custom.custom_ratings | default: product.ratings %}
                                    {% if section.settings.show_ratings and product_rating %}
                                    <div class="product-rating">
                                        <div class="product-stars-rating">
                                            {% assign star_rating = product_rating | default: 5 | round %}
                                            {% assign full_stars = star_rating | floor %}
                                            {% assign empty_stars = 5 | minus: full_stars %}
                                            
                                            {% if full_stars > 0 %}
                                                {% for i in (1..full_stars) %}
                                                    <span class="product-star star-full text-warning">★</span>
                                                {% endfor %}
                                            {% endif %}
                                            
                                            {% if empty_stars > 0 %}
                                                {% for i in (1..empty_stars) %}
                                                    <span class="product-star star-empty text-neutral-light">★</span>
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                        {% if product.reviews.size > 0 %}
                                        <span class="product-rating-text text-sm text-neutral-dark">
                                            {{ star_rating }} • ({{ product.reviews.size }} Reviews)
                                        </span>
                                        {% endif %}
                                    </div>
                                    {% endif %}
                                    
                                    <!-- Product Description -->
                                    {% if section.settings.show_descriptions and product.short_description != blank %}
                                    <div class="product-description">
                                    <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }}">
                                        {{ product.short_description }}
                                    </p>
                                    </div>
                                    {% endif %}
                                    
                                    <!-- Price Section -->
                                    {% unless selected_price == 0 or selected_price == blank or section.settings.hide_price %}
                                    <div class="product-pricing">
                                        
                                        <!-- Bundle Badge (Optional) -->
                                        {% if product.tags contains 'bundle' and section.settings.show_bundle_badge %}
                                        <div class="bundle-badge {{ section.settings.bundle_badge_color | default: 'bg-success' }}">
                                        <span class="{{ section.settings.bundle_badge_font_size | default: 'text-xs' }} {{ section.settings.bundle_badge_text_color | default: 'text-primary' }}">
                                            {{ section.settings.bundle_badge_text | default: 'Bundle + Save 25%' }}
                                        </span>
                                        </div>
                                        {% endif %}
                                        
                                        <!-- Price Display -->
                                        <div class="price-wrapper">
                                        <span class="current-price {{ section.settings.product_price_font_family | default: 'font-primary' }} {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} font-{{ section.settings.product_price_font_weight | default: 'normal' }} {{ section.settings.product_price_color | default: 'text-primary' }}">
                                            {% if selected_display_price != blank %}
                                                {{ selected_display_price }}
                                            {% else %}
                                                {{ selected_price | money }}
                                            {% endif %}
                                        </span>
                                        </div>
                                    </div>
                                    {% endunless %}
                                </div>
                                
                                <!-- CTAs -->
                                <div class="product-ctas" onclick="event.stopPropagation()">
                                    <!-- Primary Button (Add to Cart) -->
                                    {% unless section.settings.show_primary_button == false %}
                                    <button 
                                        type="button"
                                        class="btn btn-{{ section.settings.primary_button_style | default: 'filled' }}-{{ section.settings.primary_button_color | default: 'primary' }} {{ section.settings.primary_button_size | default: 'btn-md' }} {{ section.settings.primary_button_border_radius | default: 'rounded-md' }} shop-add-to-cart-btn"
                                        data-fluid-add-to-cart="{{ product.selected_variant_id }}"
                                        data-fluid-quantity="1"
                                        data-fluid-open-cart-after-add="true"
                                        onclick="event.stopPropagation()">
                                        {{ section.settings.primary_button_text | default: 'Add to Cart' }}
                                    </button>
                                    {% endunless %}
                                    
                                    <!-- Secondary Link (Learn More) -->
                                    {% unless section.settings.show_secondary_link == false %}
                                    <button 
                                        type="button"
                                        class="secondary-link {{ section.settings.secondary_link_font_size | default: 'text-base' }} {{ section.settings.secondary_link_color | default: 'text-primary' }} {{ section.settings.secondary_link_border_radius | default: 'rounded-none' }}"
                                        onclick="event.stopPropagation(); window.location.href='{{ product.url }}';"
                                        style="background: none; border: none; cursor: pointer; text-decoration: underline;">
                                        {{ section.settings.secondary_link_text | default: 'Learn More' }}
                                    </button>
                                    {% endunless %}
                                </div>
                                
                                </div>
                                <!-- End Product Content Right of Media -->
                                {% endif %}
                                
                                {%- comment -%} Out of Stock Overlay {%- endcomment -%}
                                {%- if is_out_of_stock and (out_of_stock_handling == 'show_with_overlay' or out_of_stock_handling == 'show_at_end') -%}
                                    {%- assign out_of_stock_overlay_bg_color_option = section.settings.out_of_stock_overlay_background_color | default: 'black' -%}
                                    {%- assign out_of_stock_overlay_bg_color = '#000000' -%}
                                    {%- if out_of_stock_overlay_bg_color_option == 'white' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#ffffff' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'primary' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#49473e' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'secondary' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#6b7280' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'neutral' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#9ca3af' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'neutral-dark' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#374151' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'error' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#ef4444' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'warning' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#f59e0b' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'success' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#10b981' -%}
                                    {%- elsif out_of_stock_overlay_bg_color_option == 'info' -%}
                                        {%- assign out_of_stock_overlay_bg_color = '#3b82f6' -%}
                                    {%- endif -%}
                                    {%- assign out_of_stock_overlay_opacity = section.settings.out_of_stock_overlay_opacity | default: 75 -%}
                                    {%- assign out_of_stock_overlay_opacity_decimal = out_of_stock_overlay_opacity | divided_by: 100.0 -%}
                                    <div class="product-out-of-stock-overlay" style="--out-of-stock-overlay-bg-color: {{ out_of_stock_overlay_bg_color }}; --out-of-stock-overlay-opacity: {{ out_of_stock_overlay_opacity_decimal }};">
                                        <div class="out-of-stock-content">
                                            <span class="out-of-stock-text {{ section.settings.out_of_stock_text_color | default: 'text-white' }} {{ section.settings.out_of_stock_text_font_size | default: 'text-lg' }} font-{{ section.settings.out_of_stock_text_font_weight | default: 'bold' }}">
                                                {{ section.settings.out_of_stock_text | default: 'Out of Stock' }}
                                            </span>
                                        </div>
                                    </div>
                                {%- endif -%}
                                
                            </div>
                            {% endfor %}
                        </div>
                        {% else %}
                        <div class="empty-state">
                            <div class="empty-state-content">
                                {%- assign empty_state_title = section.settings.empty_state_title | default: 'No products found' -%}
                                {%- assign empty_state_description = section.settings.empty_state_description | default: 'Try adjusting your filters or search terms to find what you re looking for.' -%}
                                {%- assign empty_state_behavior = section.settings.empty_state_behavior | default: 'show_message_and_clear' -%}
                                
                                <h3 class="empty-state-title {{ section.settings.empty_state_title_font_size | default: 'text-2xl' }} {{ section.settings.empty_state_title_color | default: 'text-neutral-dark' }} font-semibold">
                                    {{ empty_state_title }}
                                </h3>
                                
                                {% if empty_state_description != blank %}
                                <p class="empty-state-description {{ section.settings.empty_state_description_font_size | default: 'text-base' }} {{ section.settings.empty_state_description_color | default: 'text-neutral-medium' }}">
                                    {{ empty_state_description }}
                                </p>
                                {% endif %}
                                
                                {% if empty_state_behavior == 'show_message_and_clear' or empty_state_behavior == 'show_all_options' %}
                                <div class="empty-state-actions">
                                    <button type="button" class="empty-state-btn btn btn-{{ section.settings.empty_state_button_style | default: 'filled' }}-{{ section.settings.empty_state_button_color | default: 'primary' }} btn-md rounded-md" id="empty-state-clear-filters">
                                        {{ section.settings.empty_state_clear_button_text | default: 'Clear All Filters' }}
                                    </button>
                                </div>
                                {% endif %}
                                
                                {% if empty_state_behavior == 'show_message_and_show_all' or empty_state_behavior == 'show_all_options' %}
                                <div class="empty-state-actions">
                                    {% if empty_state_behavior == 'show_message_and_show_all' %}
                                    <a href="{{ collection.url | default: '/' }}" class="empty-state-btn btn btn-{{ section.settings.empty_state_button_style | default: 'filled' }}-{{ section.settings.empty_state_button_color | default: 'primary' }} btn-md rounded-md">
                                        {{ section.settings.empty_state_show_all_button_text | default: 'Show All Products' }}
                                    </a>
                                    {% else %}
                                    <button type="button" class="empty-state-btn btn btn-{{ section.settings.empty_state_button_style | default: 'filled' }}-{{ section.settings.empty_state_button_color | default: 'primary' }} btn-md rounded-md" id="empty-state-clear-filters">
                                        {{ section.settings.empty_state_clear_button_text | default: 'Clear All Filters' }}
                                    </button>
                                    <a href="{{ collection.url | default: '/' }}" class="empty-state-btn btn btn-outlined-{{ section.settings.empty_state_button_color | default: 'primary' }} btn-md rounded-md">
                                        {{ section.settings.empty_state_show_all_button_text | default: 'Show All Products' }}
                                    </a>
                                    {% endif %}
                                </div>
                                {% endif %}
                            </div>
                        </div>
                        {% endif %}
                        
                        {%- comment -%} Pagination {%- endcomment -%}
                        {%- assign pagination_style = section.settings.pagination_style | default: 'traditional' -%}
                        
                        {%- comment -%} Calculate pagination info {%- endcomment -%}
                        {%- assign current_page_num = 1 -%}
                        {%- assign total_pages_num = 1 -%}
                        {%- assign has_next_page = false -%}
                        {%- assign per_page = 10 -%}
                        
                        {%- if paginate -%}
                            {%- assign current_page_num = paginate.current_page -%}
                            {%- assign total_pages_num = paginate.pages -%}
                            {%- assign has_next_page = paginate.next != null -%}
                            {%- assign per_page = paginate.page_size -%}
                        {%- else -%}
                            {%- if pagination and pagination.current_page -%}
                                {%- assign current_page_num = pagination.current_page | plus: 0 -%}
                            {%- elsif request.query_parameters.page -%}
                                {%- assign current_page_num = request.query_parameters.page | plus: 0 -%}
                            {%- endif -%}
                            
                            {%- if pagination and pagination.per_page -%}
                                {%- assign per_page = pagination.per_page | plus: 0 -%}
                            {%- elsif request.query_parameters.count -%}
                                {%- assign per_page = request.query_parameters.count | plus: 0 -%}
                            {%- endif -%}
                            
                            {%- assign total_count = 0 -%}
                            {%- if pagination and pagination.total_count -%}
                                {%- assign total_count = pagination.total_count | plus: 0 -%}
                            {%- endif -%}
                            
                            {%- if total_count > 0 -%}
                                {%- assign total_pages_num = total_count | divided_by: per_page | plus: 0 -%}
                                {%- if total_count | modulo: per_page > 0 -%}
                                    {%- assign total_pages_num = total_pages_num | plus: 1 -%}
                                {%- endif -%}
                            {%- endif -%}
                            
                            {%- assign has_next_page = current_page_num < total_pages_num -%}
                        {%- endif -%}
                        
                        {%- comment -%} Render pagination based on style {%- endcomment -%}
                        {%- if pagination_style == 'traditional' -%}
                            {%- if paginate -%}
                                {% render 'pagination', 
                                    paginate: paginate,
                                    anchor: '',
                                    button_font_family: section.settings.pagination_button_font_family,
                                    button_font_size: section.settings.pagination_button_font_size,
                                    button_font_weight: section.settings.pagination_button_font_weight,
                                    button_color: section.settings.pagination_button_color,
                                    info_font_family: section.settings.pagination_info_font_family,
                                    info_font_size: section.settings.pagination_info_font_size,
                                    info_color: section.settings.pagination_info_color
                                %}
                            {%- else -%}
                                {% render 'pagination',
                                    total_count: total_count,
                                    base_url: url,
                                    button_font_family: section.settings.pagination_button_font_family,
                                    button_font_size: section.settings.pagination_button_font_size,
                                    button_font_weight: section.settings.pagination_button_font_weight,
                                    button_color: section.settings.pagination_button_color,
                                    info_font_family: section.settings.pagination_info_font_family,
                                    info_font_size: section.settings.pagination_info_font_size,
                                    info_color: section.settings.pagination_info_color
                                %}
                        {%- endif -%}
                        {%- elsif pagination_style == 'load_more' -%}
                            {%- comment -%} Load More Button {%- endcomment -%}
                            {%- if has_next_page -%}
                                <div class="pagination-load-more-wrapper" data-section-id="{{ section.id }}">
                                    <button 
                                        type="button" 
                                        class="pagination-load-more-btn btn btn-{{ section.settings.load_more_button_style | default: 'filled' }}-{{ section.settings.load_more_button_color | default: 'primary' }} {{ section.settings.load_more_button_size | default: 'btn-md' }} {{ section.settings.load_more_button_border_radius | default: 'rounded-md' }} {{ section.settings.load_more_button_font_family | default: 'font-body' }} {{ section.settings.load_more_button_font_size | default: 'text-base' }} font-{{ section.settings.load_more_button_font_weight | default: 'medium' }}"
                                        data-current-page="{{ current_page_num }}"
                                        data-total-pages="{{ total_pages_num }}"
                                        data-per-page="{{ per_page }}"
                                        data-base-url="{{ url }}"
                                        data-has-paginate="{% if paginate %}true{% else %}false{% endif %}">
                                        <span class="load-more-text">{{ section.settings.load_more_button_text | default: 'Load More' }}</span>
                                        <span class="load-more-loading" style="display: none;">
                                            <svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                            </svg>
                                            Loading...
                                        </span>
                                    </button>
                                    {%- if total_pages_num > 1 -%}
                                        <div class="pagination-info {{ section.settings.pagination_info_font_family | default: 'font-body' }} {{ section.settings.pagination_info_font_size | default: 'text-sm' }} {{ section.settings.pagination_info_color | default: 'text-primary' }}" style="margin-top: 0.5rem; text-align: center;">
                                            <span>Page {{ current_page_num }} of {{ total_pages_num }}</span>
                                        </div>
                                    {%- endif -%}
                                </div>
                            {%- endif -%}
                        {%- elsif pagination_style == 'infinite_scroll' -%}
                            {%- comment -%} Infinite Scroll - No visible pagination, but add trigger element {%- endcomment -%}
                            {%- if has_next_page -%}
                                <div class="pagination-infinite-scroll-trigger" 
                                     data-section-id="{{ section.id }}"
                                     data-current-page="{{ current_page_num }}"
                                     data-total-pages="{{ total_pages_num }}"
                                     data-per-page="{{ per_page }}"
                                     data-base-url="{{ url }}"
                                     data-has-paginate="{% if paginate %}true{% else %}false{% endif %}"
                                     style="height: 100px; display: flex; align-items: center; justify-content: center;">
                                    <div class="infinite-scroll-loading" style="display: none;">
                                        <svg class="animate-spin" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                        </svg>
                                    </div>
                                </div>
                            {%- endif -%}
                        {%- endif -%}
                    </div>
                </main> 
                
            </div>
        </div>
    </form>
    
    <!-- Quick View Modal -->
    <div id="quick-view-modal" class="quick-view-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="quick-view-modal-title">
        <div class="quick-view-modal-overlay" data-quick-view-close></div>
        <div class="quick-view-modal-dialog">
            <button type="button" class="quick-view-modal-close" data-quick-view-close aria-label="Close quick view">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <div class="quick-view-modal-content">
                <div class="quick-view-modal-gallery">
                    <div class="quick-view-modal-main-image">
                        <img id="quick-view-modal-image" src="" alt="" loading="lazy">
                    </div>
                    <div id="quick-view-modal-thumbnails" class="quick-view-modal-thumbnails"></div>
                </div>
                <div class="quick-view-modal-details">
                    <h2 id="quick-view-modal-title" class="quick-view-modal-title"></h2>
                    <div id="quick-view-modal-price" class="quick-view-modal-price"></div>
                    <div id="quick-view-modal-description" class="quick-view-modal-description"></div>
                    <div class="quick-view-modal-actions">
                        <a id="quick-view-modal-view-product" href="#" class="btn btn-outlined-primary btn-md rounded-md">View full details</a>
                        <button type="button" id="quick-view-modal-add-to-cart" class="btn btn-filled-primary btn-md rounded-md shop-add-to-cart-btn" data-fluid-open-cart-after-add="true">Add to Cart</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
(function() {
  'use strict';
  
  // ============================================================================
  // CONSTANTS & CONFIGURATION
  // ============================================================================
  const CONFIG = {
    DEFAULT_COUNT: 10,
    MAX_FILTER_ITEMS_BEFORE_SCROLL: 5,
    INFINITE_SCROLL_THRESHOLD: 200,
    SYNC_DELAY: 100
  };
  
  const SELECTORS = {
    filterForm: '#filterrific_filter',
    productGrid: '.product-grid',
    sidebar: '#shop-sidebar',
    drawer: '#shop-filters-drawer',
    drawerOverlay: '#drawer-overlay',
    horizontalBar: '#shop-filters-horizontal-bar',
    bundlesCheckbox: '#filterrific_show_bundles_only',
    productsPerPageSelect: '#products-per-page-select',
    quickViewModal: '#quick-view-modal'
  };
  
  // ============================================================================
  // UTILITY FUNCTIONS
  // ============================================================================
  const Utils = {
    parseURLParams() {
      const urlParams = new URLSearchParams(window.location.search);
      const allParams = {};
      
      urlParams.forEach((value, key) => {
        if (key.startsWith('filterrific[') && key.endsWith(']')) {
          const paramName = key.replace('filterrific[', '').replace(']', '');
          if (!allParams[paramName]) allParams[paramName] = [];
          allParams[paramName].push(value);
        } else if (key.includes('filterrific')) {
          const match = key.match(/filterrific\[([^\]]+)\]/);
          if (match) {
            const paramName = match[1];
            if (!allParams[paramName]) allParams[paramName] = [];
            allParams[paramName].push(value);
          }
        }
      });
      
      return allParams;
    },
    
    getSortedByFromURL() {
      const urlParams = new URLSearchParams(window.location.search);
      let sortedBy = urlParams.get('filterrific[sorted_by]') || urlParams.get('sorted_by');
      
      if (!sortedBy) {
        const allParams = this.parseURLParams();
        if (allParams['sorted_by']) {
          sortedBy = Array.isArray(allParams['sorted_by']) ? allParams['sorted_by'][0] : allParams['sorted_by'];
        }
      }
      
      if (!sortedBy) {
        const urlString = window.location.search;
        const match = urlString.match(/[?&]filterrific%5Bsorted_by%5D=([^&]+)/) || 
                      urlString.match(/[?&]filterrific\[sorted_by\]=([^&]+)/);
        if (match) sortedBy = decodeURIComponent(match[1]);
      }
      
      return sortedBy;
    },
    
    syncInputState(input, isChecked) {
      input.checked = isChecked;
      if (isChecked) {
        input.setAttribute('checked', 'checked');
        input.classList.add('is-checked');
      } else {
        input.removeAttribute('checked');
        input.classList.remove('is-checked');
      }
    },
    
    updateCheckboxVisualState(checkbox, isChecked, selectedClass, defaultClass) {
      const label = checkbox.closest('label');
      if (!label) return;
      
      const textSpan = label.querySelector('.filter-checkbox-text');
      if (!textSpan) return;
      
      if (isChecked) {
        textSpan.classList.add(selectedClass);
        textSpan.classList.remove(defaultClass);
      } else {
        textSpan.classList.remove(selectedClass);
        textSpan.classList.add(defaultClass);
      }
    }
  };
  
  // ============================================================================
  // JQUERY DROPDOWN FALLBACK
  // ============================================================================
  const jQueryFallback = (() => {
    function setupDropdownFallback() {
      if (typeof window.jQuery !== 'undefined' || typeof window.$ !== 'undefined') {
        const $ = window.jQuery || window.$;
        if ($.fn && !$.fn.dropdown) {
          $.fn.dropdown = function() { return this; };
        }
      }
    }
    
    function init() {
      setupDropdownFallback();
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupDropdownFallback);
      }
      window.addEventListener('load', setupDropdownFallback);
      
      let checkCount = 0;
      const checkInterval = setInterval(() => {
        setupDropdownFallback();
        checkCount++;
        if (checkCount > 10) clearInterval(checkInterval);
      }, 500);
    }
    
    return { init };
  })();
  
  // ============================================================================
  // URL & FILTER SYNC MANAGER
  // ============================================================================
  const FilterSync = (() => {
    function syncCheckboxesFromURL() {
      const allParams = Utils.parseURLParams();
      const sortedByFromUrl = Utils.getSortedByFromURL();
      
      // Sync brand checkboxes
      if (allParams['with_brand_id[]']) {
        allParams['with_brand_id[]'].forEach(brandId => {
          const checkbox = document.getElementById('filterrific_with_brand_id_' + brandId);
          if (checkbox && !checkbox.checked) checkbox.checked = true;
        });
      }
      
      // Sync category checkboxes
      if (allParams['with_category_id[]']) {
        allParams['with_category_id[]'].forEach(categoryId => {
          const checkbox = document.getElementById('filterrific_with_category_id_' + categoryId);
          if (checkbox && !checkbox.checked) checkbox.checked = true;
        });
      }
      
      // Sync collection checkboxes
      if (allParams['by_collection[]']) {
        allParams['by_collection[]'].forEach(collectionId => {
          const checkbox = document.getElementById('filterrific_by_collection_' + collectionId);
          if (checkbox && !checkbox.checked) checkbox.checked = true;
        });
      }
      
      // Sync price checkboxes
      if (allParams['with_prices[]']) {
        allParams['with_prices[]'].forEach(priceRange => {
          const parts = priceRange.split(' ');
          if (parts.length === 2) {
            const checkboxId = 'filterrific_with_prices_' + parts[0] + '_' + parts[1];
            const checkbox = document.getElementById(checkboxId);
            if (checkbox && !checkbox.checked) checkbox.checked = true;
          }
        });
      }
      
      // Sync sorted_by dropdown
      const sortSelect = document.querySelector('select[name="filterrific[sorted_by]"]');
      if (sortedByFromUrl && sortSelect) {
        sortSelect.value = sortedByFromUrl;
      }
      
      // Sync option checkboxes
      if (allParams['with_option_value_ids[]']) {
        allParams['with_option_value_ids[]'].forEach(optionValueId => {
          const checkbox = document.getElementById('filterrific_with_option_value_ids_' + optionValueId);
          if (checkbox && !checkbox.checked) checkbox.checked = true;
        });
      }
      
      // Sync bundles checkbox
      if (allParams['show_bundles_only']) {
        const bundlesVals = allParams['show_bundles_only'];
        const isChecked = bundlesVals.includes('1') || bundlesVals.includes('true');
        const bundlesCheckbox = document.getElementById('filterrific_show_bundles_only');
        if (bundlesCheckbox) {
          bundlesCheckbox.checked = isChecked;
          Utils.updateCheckboxVisualState(
            bundlesCheckbox,
            isChecked,
            '{{ section.settings.sidebar_filter_item_selected_color | default: "text-info" }}',
            '{{ section.settings.sidebar_filter_item_color | default: "text-primary" }}'
          );
        }
      }
      
      // Sync tags checkboxes
      if (allParams['with_tags[]']) {
        allParams['with_tags[]'].forEach(tag => {
          const tagId = 'filterrific_tag_' + tag.toLowerCase().replace(/\s+/g, '-');
          const checkbox = document.getElementById(tagId);
          if (checkbox && !checkbox.checked) checkbox.checked = true;
        });
      }
    }
    
    return { syncCheckboxesFromURL };
  })();
  
  // ============================================================================
  // LAYOUT MANAGER (Sidebar, Drawer, Horizontal Bar)
  // ============================================================================
  const LayoutManager = (() => {
    function toggleMobileSidebar() {
      const sidebar = document.getElementById('shop-sidebar');
      const body = document.body;
      
      if (sidebar) {
        sidebar.classList.toggle('sidebar-open');
        body.classList.toggle('sidebar-overlay-active');
        
        if (sidebar.classList.contains('sidebar-open')) {
          cloneFiltersContent();
        }
      }
    }
    
    function closeMobileSidebar() {
      const sidebar = document.getElementById('shop-sidebar');
      const body = document.body;
      
      if (sidebar) {
        sidebar.classList.remove('sidebar-open');
        body.classList.remove('sidebar-overlay-active');
      }
    }
    
    function toggleHorizontalBar() {
      const horizontalBar = document.getElementById('shop-filters-horizontal-bar');
      
      if (horizontalBar) {
        horizontalBar.classList.toggle('horizontal-bar-open');
        
        if (horizontalBar.classList.contains('horizontal-bar-open')) {
          cloneFiltersContent();
        }
      }
    }
    
    function closeHorizontalBar() {
      const horizontalBar = document.getElementById('shop-filters-horizontal-bar');
      if (horizontalBar) {
        horizontalBar.classList.remove('horizontal-bar-open');
      }
    }
    
    function openDrawer() {
      const drawer = document.getElementById('shop-filters-drawer');
      const overlay = document.getElementById('drawer-overlay');
      const body = document.body;
      
      if (drawer && overlay) {
        drawer.classList.add('drawer-open');
        overlay.classList.add('active');
        body.classList.add('drawer-overlay-active');
        cloneFiltersContent();
      }
    }
    
    function closeDrawer() {
      const drawer = document.getElementById('shop-filters-drawer');
      const overlay = document.getElementById('drawer-overlay');
      const body = document.body;
      
      if (drawer && overlay) {
        drawer.classList.remove('drawer-open');
        overlay.classList.remove('active');
        body.classList.remove('drawer-overlay-active');
      }
    }
    
    function cloneFiltersContent() {
      const sidebarFiltersList = document.querySelector('.shop-sidebar .filters-list');
      const horizontalFiltersList = document.getElementById('filters-list-horizontal');
      const drawerFiltersList = document.getElementById('filters-list-drawer');
      
      if (sidebarFiltersList) {
        if (horizontalFiltersList) setupClonedFilters(sidebarFiltersList, horizontalFiltersList, 'horizontal');
        if (drawerFiltersList) setupClonedFilters(sidebarFiltersList, drawerFiltersList, 'drawer');
      }
    }
    
    function setupClonedFilters(source, target, suffix) {
      target.innerHTML = '';
      const cloned = source.cloneNode(true);
      
      // Fix duplicate IDs and update label for-attributes
      cloned.querySelectorAll('[id]').forEach(el => {
        const origId = el.id;
        el.id = origId + '_' + suffix;
        cloned.querySelectorAll('label[for="' + origId + '"]').forEach(lbl => {
          lbl.setAttribute('for', el.id);
        });
      });
      
      // Move cloned children to target
      while (cloned.firstChild) {
        target.appendChild(cloned.firstChild);
      }
      
      // Sync checked state from source to cloned inputs
      source.querySelectorAll('input[type="checkbox"], input[type="radio"]').forEach(srcInput => {
        if (srcInput.id) {
          const expectedId = srcInput.id + '_' + suffix;
          const clonedInput = document.getElementById(expectedId);
          if (clonedInput) {
            Utils.syncInputState(clonedInput, srcInput.checked);
          }
        }
      });
      
      // Re-attach accordion toggle listeners
      target.querySelectorAll('.filter-accordion-header').forEach(header => {
        header.addEventListener('click', function(e) {
          e.stopPropagation();
          this.parentElement.classList.toggle('active');
        });
      });
      
      // Sync cloned input changes back to sidebar
      target.querySelectorAll('input[type="checkbox"], input[type="radio"]').forEach(clonedInput => {
        clonedInput.addEventListener('change', function(e) {
          e.stopPropagation();
          
          const isChecked = this.checked;
          const inputName = this.name;
          
          // Sync to ALL inputs with same name and value
          if (inputName) {
            const form = document.getElementById('filterrific_filter');
            if (form) {
              const safeInputName = inputName.replace(/"/g, '\\"');
              form.querySelectorAll('input[name="' + safeInputName + '"]').forEach(input => {
                if (input !== clonedInput && input.value === clonedInput.value) {
                  Utils.syncInputState(input, isChecked);
                }
              });
            }
          }
          
          // Trigger change on original sidebar input
          const origId = this.id.replace(new RegExp('_' + suffix + '$'), '');
          const sidebarInput = document.getElementById(origId);
          if (sidebarInput) {
            Utils.syncInputState(sidebarInput, isChecked);
            
            // Handle radio button groups
            if (this.type === 'radio' && this.checked && this.name) {
              const form = document.getElementById('filterrific_filter');
              if (form) {
                form.querySelectorAll('input[type="radio"][name="' + this.name + '"]').forEach(r => {
                  if (r !== sidebarInput && r !== clonedInput) {
                    Utils.syncInputState(r, false);
                  }
                });
              }
            }
            
            sidebarInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });
      });
    }
    
    return {
      toggleMobileSidebar,
      closeMobileSidebar,
      toggleHorizontalBar,
      closeHorizontalBar,
      openDrawer,
      closeDrawer
    };
  })();
  
    // Initialize on DOM ready
    document.addEventListener('DOMContentLoaded', function() {
      // Initialize jQuery fallback
      jQueryFallback.init();
      
      // Sync filters from URL
      FilterSync.syncCheckboxesFromURL();
      setTimeout(() => FilterSync.syncCheckboxesFromURL(), CONFIG.SYNC_DELAY);
      
      // Products per page selector handler
      const productsPerPageSelect = document.getElementById('products-per-page-select');
      
      if (productsPerPageSelect) {
        productsPerPageSelect.addEventListener('change', function(e) {
          e.stopPropagation();
          e.preventDefault();
          
          const selectedValue = this.value;
          
          // Update the hidden count input
          const productsPerPageCountInput = document.getElementById('products-per-page-count');
          if (productsPerPageCountInput) {
            productsPerPageCountInput.value = selectedValue;
          }
          
          // Build new URL
          const currentParams = new URLSearchParams(window.location.search);
          currentParams.set('count', selectedValue);
          currentParams.set('page', '1');
          currentParams.delete('filterrific[page]');
          
          const baseUrl = window.location.pathname;
          const newUrl = baseUrl + '?' + currentParams.toString();
          window.location.href = newUrl;
        });
      }
      
    // Mobile filter toggle button
    const mobileFilterToggle = document.getElementById('mobile-filter-toggle-btn');
    if (mobileFilterToggle) {
      mobileFilterToggle.addEventListener('click', function(e) {
