<link rel="stylesheet" href="{{ 'framer-carousel/styles.css' | asset_url }}">

<section 
  class="framer-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="framer-carousel-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="framer-carousel-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      {% if section.blocks.size > 0 %}
      <div class="framer-carousel-wrapper" style="max-width: {{ section.settings.carousel_max_width | default: 896 }}px; margin: 0 auto;">
        
        <!-- Carousel Container -->
        <div class="framer-carousel-container" data-carousel-container="{{ section.id }}" style="--carousel-height: {{ section.settings.carousel_height | default: 500 }}px;">
          
          <!-- Carousel Track -->
          <div class="framer-carousel-track" data-carousel-track="{{ section.id }}">
            {% for block in section.blocks %}
              {% if block.type == 'carousel_item' %}
              <div class="framer-carousel-item" {{ block.fluid_attributes }}>
                {% if block.settings.image != blank %}
                  <img 
                    src="{{ block.settings.image | image_url: width: 1200 }}" 
                    alt="{{ block.settings.title | default: 'Carousel image' }}"
                    class="framer-carousel-image"
                    loading="lazy"
                    draggable="false">
                {% else %}
                  <img 
                    src="{{ 'placeholder-image.png' | asset_url }}" 
                    alt="Placeholder"
                    class="framer-carousel-image"
                    loading="lazy"
                    draggable="false">
                {% endif %}
                
                {% if block.settings.title != blank %}
                <div class="framer-carousel-item-title {{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-lg' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.title_font_weight | default: 'font-semibold' }} {{ section.settings.title_color | default: 'text-black' }}">
                  {{ block.settings.title }}
                </div>
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          
          <!-- Navigation Buttons -->
          <button 
            class="framer-carousel-nav-btn framer-carousel-prev {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
            data-carousel-prev="{{ section.id }}"
            aria-label="Previous slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          
          <button 
            class="framer-carousel-nav-btn framer-carousel-next {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
            data-carousel-next="{{ section.id }}"
            aria-label="Next slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </button>
          
          <!-- Progress Indicator -->
          <div class="framer-carousel-progress">
            {% for block in section.blocks %}
              {% if block.type == 'carousel_item' %}
              <button 
                class="framer-carousel-progress-dot"
                data-carousel-dot="{{ section.id }}"
                data-index="{{ forloop.index0 }}"
                aria-label="Go to slide {{ forloop.index }}">
              </button>
              {% endif %}
            {% endfor %}
          </div>
          
        </div>
        
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const container = document.querySelector(`[data-carousel-container="${sectionId}"]`);
  const track = document.querySelector(`[data-carousel-track="${sectionId}"]`);
  const prevBtn = document.querySelector(`[data-carousel-prev="${sectionId}"]`);
  const nextBtn = document.querySelector(`[data-carousel-next="${sectionId}"]`);
  const dots = document.querySelectorAll(`[data-carousel-dot="${sectionId}"]`);
  
  if (!container || !track || !prevBtn || !nextBtn) return;
  
  const items = track.querySelectorAll('.framer-carousel-item');
  if (items.length === 0) return;
  
  let currentIndex = 0;
  const totalItems = items.length;
  
  // Spring-like animation function
  function animateToIndex(newIndex) {
    if (newIndex < 0 || newIndex >= totalItems) return;
    
    currentIndex = newIndex;
    const containerWidth = container.offsetWidth || 1;
    const targetX = -currentIndex * containerWidth;
    
    // Apply smooth spring-like transition
    track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
    track.style.transform = `translateX(${targetX}px)`;
    
    // Update button states
    updateButtons();
    updateDots();
  }
  
  function updateButtons() {
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex === totalItems - 1;
    
    if (currentIndex === 0) {
      prevBtn.style.opacity = '0.4';
      prevBtn.style.cursor = 'not-allowed';
    } else {
      prevBtn.style.opacity = '0.7';
      prevBtn.style.cursor = 'pointer';
    }
    
    if (currentIndex === totalItems - 1) {
      nextBtn.style.opacity = '0.4';
      nextBtn.style.cursor = 'not-allowed';
    } else {
      nextBtn.style.opacity = '0.7';
      nextBtn.style.cursor = 'pointer';
    }
  }
  
  function updateDots() {
    dots.forEach((dot, index) => {
      if (index === currentIndex) {
        dot.classList.add('is-active');
      } else {
        dot.classList.remove('is-active');
      }
    });
  }
  
  // Event listeners
  prevBtn.addEventListener('click', function() {
    if (currentIndex > 0) {
      animateToIndex(currentIndex - 1);
    }
  });
  
  nextBtn.addEventListener('click', function() {
    if (currentIndex < totalItems - 1) {
      animateToIndex(currentIndex + 1);
    }
  });
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', function() {
      animateToIndex(index);
    });
  });
  
  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  track.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  
  track.addEventListener('touchend', function(e) {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  }, { passive: true });
  
  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0 && currentIndex < totalItems - 1) {
        // Swipe left - next
        animateToIndex(currentIndex + 1);
      } else if (diff < 0 && currentIndex > 0) {
        // Swipe right - previous
        animateToIndex(currentIndex - 1);
      }
    }
  }
  
  // Handle resize
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function() {
      animateToIndex(currentIndex);
    }, 250);
  });
  
  // Initialize
  updateButtons();
  updateDots();
  animateToIndex(0);
})();
</script>

