<!-- Scrolling Gallery 2 - Continuous Auto-Scroll -->
<section class="scrolling-gallery-2 {{ section.settings.background_color | default: 'bg-tertiary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <!-- Header Container -->
  <div class="scrolling-gallery-2__header-container">
    <div class="scrolling-gallery-2__header-content" style="max-width: 770px; margin: 0 auto; text-align: center;">
      <h2 class="scrolling-gallery-2__heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}">
        {{ section.settings.heading | default: "You're in Good Company" }}
      </h2>
      <div class="scrolling-gallery-2__description {{ section.settings.description_font_family | default: 'font-body' }}">
        <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
          {{ section.settings.description | default: "We believe that getting healthy is better together. That's why our community is the heart of our culture, built on a simple idea we call BLP: Belonging, Love, and Purpose. Here's what it looks like in real life." }}
        </p>
      </div>
    </div>
  </div>

  <!-- Gallery Full Width Container with Auto-Scroll -->
  {% if section.blocks.size > 0 %}
    <div class="scrolling-gallery-2__gallery-fullwidth">
      <div class="scrolling-gallery-2__track-wrapper">
        <div class="scrolling-gallery-2__track" data-scroll-speed="{{ section.settings.scroll_speed | default: 30 }}">
          <!-- First set of images -->
          <div class="scrolling-gallery-2__track-set">
            {% for block in section.blocks %}
              {% if block.type == 'gallery_image' %}
                <div class="scrolling-gallery-2__image-item" style="height: {{ block.settings.image_height | default: 312 }}px; border-radius: {{ section.settings.image_border_radius | default: 8 }}px;" {{ block.fluid_attributes }}>
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" 
                         alt="{{ block.settings.image_alt | default: 'Gallery image' }}"
                         class="scrolling-gallery-2__image"
                         loading="lazy">
                  {% else %}
                    <svg class="scrolling-gallery-2__image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 312" fill="none" preserveAspectRatio="xMidYMid slice">
                      <rect width="800" height="312" fill="#f5f5f5"/>
                      <path d="M400 90c-33.1 0-60 26.9-60 60s26.9 60 60 60 60-26.9 60-60-26.9-60-60-60zm0 90c-16.5 0-30-13.5-30-30s13.5-30 30-30 30 13.5 30 30-13.5 30-30 30zm150 120H250l60-120 90 60 60-30 90 90z" fill="#d0d0d0"/>
                    </svg>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <!-- Duplicate set for seamless loop -->
          <div class="scrolling-gallery-2__track-set" aria-hidden="true">
            {% for block in section.blocks %}
              {% if block.type == 'gallery_image' %}
                <div class="scrolling-gallery-2__image-item" style="height: {{ block.settings.image_height | default: 312 }}px; border-radius: {{ section.settings.image_border_radius | default: 8 }}px;">
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" 
                         alt="{{ block.settings.image_alt | default: 'Gallery image' }}"
                         class="scrolling-gallery-2__image"
                         loading="lazy">
                  {% else %}
                    <svg class="scrolling-gallery-2__image" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 312" fill="none" preserveAspectRatio="xMidYMid slice">
                      <rect width="800" height="312" fill="#f5f5f5"/>
                      <path d="M400 90c-33.1 0-60 26.9-60 60s26.9 60 60 60 60-26.9 60-60-26.9-60-60-60zm0 90c-16.5 0-30-13.5-30-30s13.5-30 30-30 30 13.5 30 30-13.5 30-30 30zm150 120H250l60-120 90 60 60-30 90 90z" fill="#d0d0d0"/>
                    </svg>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <!-- Footer Container -->
  <div class="scrolling-gallery-2__footer-container">
    <div class="scrolling-gallery-2__footer-content" style="max-width: 770px; margin: 0 auto; text-align: center;">
      <h3 class="scrolling-gallery-2__footer-heading {{ section.settings.footer_heading_font_family | default: 'font-handwritten' }} {{ section.settings.footer_heading_font_size | default: 'text-4xl' }} {{ section.settings.footer_heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.footer_heading_font_weight | default: 'font-normal' }} {{ section.settings.footer_heading_color | default: 'text-neutral-dark' }}">
        {{ section.settings.footer_heading | default: "Join the Conversation" }}
      </h3>
      <div class="scrolling-gallery-2__footer-description {{ section.settings.footer_description_font_family | default: 'font-body' }}">
        <p class="{{ section.settings.footer_description_font_size | default: 'text-base' }} {{ section.settings.footer_description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.footer_description_font_weight | default: 'font-normal' }} {{ section.settings.footer_description_color | default: 'text-neutral-dark' }}">
          {{ section.settings.footer_description | default: "Our community is full of encouragement, celebrations, and everyday wins. Come be part of it." }}
        </p>
      </div>
      {% if section.settings.show_button %}
        <div class="scrolling-gallery-2__button-wrapper">
          <a href="{{ section.settings.button_url | default: '#' }}" 
             class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'info' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} font-body {{ settings.button_border_radius | default: 'rounded-full' }}">
            {{ section.settings.button_text | default: 'Join Our Community' }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>

</section>

<link rel="stylesheet" href="{{ 'scrolling-gallery-2/styles.css' | asset_url }}">

<script>
(function() {
  // Initialize continuous scrolling animation
  document.addEventListener('DOMContentLoaded', function() {
    const tracks = document.querySelectorAll('.scrolling-gallery-2__track');
    
    tracks.forEach(function(track) {
      const scrollSpeed = parseInt(track.getAttribute('data-scroll-speed')) || 30;
      const trackSet = track.querySelector('.scrolling-gallery-2__track-set');
      
      if (trackSet) {
        // Calculate the width of one set
        const setWidth = trackSet.offsetWidth;
        
        // Set CSS custom property for animation
        track.style.setProperty('--track-width', setWidth + 'px');
        track.style.setProperty('--scroll-speed', scrollSpeed + 's');
        
        // Pause on hover
        track.addEventListener('mouseenter', function() {
          track.style.animationPlayState = 'paused';
        });
        
        track.addEventListener('mouseleave', function() {
          track.style.animationPlayState = 'running';
        });
      }
    });
  });
})();
</script>

