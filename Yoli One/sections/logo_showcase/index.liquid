<!-- Logo Showcase Section -->
<section class="logo-showcase section {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-sm' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-sm' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_padding_y_mobile | default: 'py-xl' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {{ section.settings.container_border_radius | default: 'rounded-none' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Logo Component Layout -->
      <div class="logo2_component">
        <div class="logo2_content">
          
          <!-- Left Content -->
          {% if section.settings.show_heading %}
          <div class="logo2_content-left">
            {% if section.settings.heading != blank %}
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-base' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-black' }} {{ section.settings.heading_line_height | default: 'leading-tight' }}">
              {{ section.settings.heading }}
            </h2>
            {% endif %}
            
            {% if section.settings.description != blank %}
            <p class="{{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_line_height | default: 'leading-relaxed' }} {{ section.settings.description_color | default: 'text-neutral-dark' }} {{ section.settings.description_margin_top | default: 'mt-md' }}">
              {{ section.settings.description }}
            </p>
            {% endif %}
          </div>
          {% endif %}
          
          <!-- Right Logos List -->
          <div class="logo2_logo-list">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'logo_item' %}
                  <div class="logo2_wrapper" {{ block.fluid_attributes }}>
                    {% if block.settings.logo_image != blank %}
                      {% if block.settings.logo_link != blank %}
                        <a href="{{ block.settings.logo_link }}" class="logo2_link" target="_blank" rel="noopener">
                      {% endif %}
                      
                      <img src="{{ block.settings.logo_image | image_url: width: 200 }}" 
                           alt="{{ block.settings.logo_alt | default: 'Company logo' }}"
                           class="logo2_logo"
                           loading="lazy">
                      
                      {% if block.settings.logo_link != blank %}
                        </a>
                      {% endif %}
                    {% else %}
                      <!-- Placeholder Image -->
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Logo placeholder"
                           class="logo2_logo placeholder"
                           loading="lazy">
                    {% endif %}
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
          
        </div>
      </div>
      
    </div>
  </div>
</section>

