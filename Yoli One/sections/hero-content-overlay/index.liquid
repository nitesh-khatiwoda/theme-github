<link rel="stylesheet" href="{{ 'hero-content-overlay/styles.css' | asset_url }}">

{% assign height_mode = section.settings.height_mode | default: 'normal' %}
{% assign base_height = section.settings.section_height | default: 400 %}
{% if height_mode == 'double' %}
  {% assign final_height = base_height | times: 1.5 %}
{% else %}
  {% assign final_height = base_height %}
{% endif %}

<section 
  class="hero-content-overlay {% if height_mode == 'double' %}hero-content-overlay--double{% endif %} {% unless section.settings.background_image %}{{ section.settings.background_color | default: 'bg-neutral' }}{% endunless %} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="hero-content-overlay-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}" style="background-image: url('{{ section.settings.background_image | image_url }}'); --base-height: {{ base_height }}px;"{% else %}style="--base-height: {{ base_height }}px;"{% endif %}>
  
  <div class="hero-content-overlay-overlay" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.4 }});"></div>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="hero-content-overlay-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="hero-content-overlay-content" style="max-width: {{ section.settings.content_max_width | default: 560 }}px;">
        
        <!-- Main Heading -->
        {% if section.settings.heading != blank %}
        <div class="heading-wrapper">
          <h1 class="heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-5xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }}">
            {{ section.settings.heading }}
          </h1>
        </div>
        {% endif %}
        
        <!-- Paragraph 1 -->
        {% if section.settings.paragraph_one != blank %}
        <div class="paragraph-wrapper paragraph-one-wrapper">
          <div class="paragraph paragraph-one {{ section.settings.paragraph_one_font_family | default: 'font-body' }} {{ section.settings.paragraph_one_font_size | default: 'text-lg' }} {{ section.settings.paragraph_one_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.paragraph_one_font_weight | default: 'font-normal' }} {{ section.settings.paragraph_one_color | default: 'text-white' }}">
            {{ section.settings.paragraph_one }}
          </div>
        </div>
        {% endif %}
        
        <!-- Paragraph 2 -->
        {% if section.settings.paragraph_two != blank %}
        <div class="paragraph-wrapper paragraph-two-wrapper">
          <div class="paragraph paragraph-two {{ section.settings.paragraph_two_font_family | default: 'font-body' }} {{ section.settings.paragraph_two_font_size | default: 'text-lg' }} {{ section.settings.paragraph_two_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.paragraph_two_font_weight | default: 'font-normal' }} {{ section.settings.paragraph_two_color | default: 'text-white' }}">
            {{ section.settings.paragraph_two }}
          </div>
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</section>

