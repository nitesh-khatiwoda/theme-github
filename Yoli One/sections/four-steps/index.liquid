<link rel="stylesheet" href="{{ 'four-steps/styles.css' | asset_url }}">

<!-- Four Steps Section -->
<section class="four-steps {{ section.settings.background_color | default: 'bg-card-primary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="steps-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="four-steps-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Heading -->
      {% if section.settings.heading != blank %}
      <div class="steps-heading">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Steps Grid -->
      <div class="steps-grid-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
          <div class="step-row {% cycle 'left-image', 'right-image', 'left-image', 'right-image' %}" {{ block.fluid_attributes }}>
            
            <!-- Image -->
            <div class="step-image">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="Step {{ forloop.index }}" loading="lazy">
              {% else %}
                <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Step {{ forloop.index }}">
              {% endif %}
            </div>
            
            <!-- Number Circle -->
            <div class="step-number" style="background-color: {{ section.settings.circle_bg | default: '#e0f262' }}; border-color: {{ section.settings.circle_border | default: '#e0f262' }};">
              <span class="{{ section.settings.number_font_family | default: 'font-primary' }} {{ section.settings.number_color | default: 'text-primary' }}">{{ forloop.index }}</span>
            </div>
            
            <!-- Description -->
            <div class="step-description">
              <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
                {{ block.settings.description }}
              </p>
            </div>
            
          </div>
          {% endif %}
        {% endfor %}
      </div>
      
      <!-- CTA Button -->
      {% if section.settings.show_button %}
      <div class="steps-cta">
        <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
          {{ section.settings.button_text | default: 'Take our quiz' }}
        </a>
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

