<link rel="stylesheet" href="{{ 'customer-reviews-2/styles.css' | asset_url }}">

<!-- Customer Reviews 2 Section -->
<section class="customer-reviews-2 {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="customer-reviews-2__inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Two-Column Layout -->
      <div class="customer-reviews-2__split">
        
        <!-- Left Sticky Column -->
        <div class="customer-reviews-2__sidebar">
          <div class="customer-reviews-2__sidebar-content">
            
            <!-- Eyebrow -->
            {% if section.settings.eyebrow != blank %}
              <p class="customer-reviews-2__eyebrow {{ section.settings.eyebrow_font_family | default: 'font-body' }} {{ section.settings.eyebrow_font_size | default: 'text-xs' }} {{ section.settings.eyebrow_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.eyebrow_font_weight | default: 'font-semibold' }} {{ section.settings.eyebrow_color | default: 'text-neutral-dark' }}">
                {{ section.settings.eyebrow }}
              </p>
            {% endif %}
            
            <!-- Heading -->
            {% if section.settings.heading != blank %}
              <h2 class="customer-reviews-2__heading {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }}">
                {{ section.settings.heading }}
              </h2>
            {% endif %}
            
            <!-- Rating Display -->
            {% if section.settings.show_rating %}
              <div class="customer-reviews-2__rating-display {{ section.settings.rating_font_family | default: 'font-primary' }} {{ section.settings.rating_font_size | default: 'text-6xl' }} {{ section.settings.rating_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.rating_font_weight | default: 'font-normal' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                {{ section.settings.rating_value | default: '4.85/5' }}
              </div>
            {% endif %}
            
          </div>
        </div>
        
        <!-- Right Scrollable Column -->
        <div class="customer-reviews-2__content">
          
          <!-- Top Meta Row -->
          <div class="customer-reviews-2__meta">
            <p class="customer-reviews-2__meta-text {{ section.settings.meta_font_family | default: 'font-body' }} {{ section.settings.meta_font_size | default: 'text-sm' }} {{ section.settings.meta_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.meta_font_weight | default: 'font-normal' }} {{ section.settings.meta_color | default: 'text-primary' }}">
              {% if section.settings.review_count_text != blank %}
                {{ section.settings.review_count_text }}
              {% else %}
                Based on 2616 reviews
              {% endif %}
            </p>
            
            {% if section.settings.show_sort %}
              <div class="customer-reviews-2__sort {{ section.settings.meta_font_family | default: 'font-body' }} {{ section.settings.meta_font_size | default: 'text-sm' }} {{ section.settings.meta_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.meta_color | default: 'text-primary' }}">
                <span class="{{ section.settings.meta_font_weight | default: 'font-normal' }}">Sort by</span>
                <span class="font-semibold">{{ section.settings.sort_text | default: 'Newest to oldest' }}</span>
                <svg class="customer-reviews-2__sort-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {% endif %}
          </div>
          
          <!-- Reviews List -->
          {% assign review_blocks = section.blocks | where: 'type', 'review' %}
          {% if review_blocks.size > 0 %}
            <div class="customer-reviews-2__reviews">
              {% for block in review_blocks %}
                <div class="customer-reviews-2__review" {{ block.fluid_attributes }}>
                  
                  <!-- Top Row: Stars + Date -->
                  <div class="customer-reviews-2__review-header">
                    <!-- Stars -->
                    <div class="customer-reviews-2__stars">
                      {% for i in (1..5) %}
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="#FFD700" stroke="#FFD700" stroke-width="1"/>
                        </svg>
                      {% endfor %}
                    </div>
                    
                    <!-- Date -->
                    <span class="customer-reviews-2__date {{ section.settings.date_font_family | default: 'font-body' }} {{ section.settings.date_font_size | default: 'text-sm' }} {{ section.settings.date_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.date_font_weight | default: 'font-normal' }} {{ section.settings.date_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.date | default: '1 day ago' }}
                    </span>
                  </div>
                  
                  <!-- Review Text -->
                  {% if block.settings.review_text != blank %}
                    <p class="customer-reviews-2__review-text {{ section.settings.review_font_family | default: 'font-body' }} {{ section.settings.review_font_size | default: 'text-sm' }} {{ section.settings.review_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.review_font_weight | default: 'font-normal' }} {{ section.settings.review_color | default: 'text-primary' }}">
                      {{ block.settings.review_text }}
                    </p>
                  {% endif %}
                  
                  <!-- Author Info -->
                  <div class="customer-reviews-2__author">
                    <!-- Avatar with Verified Badge -->
                    <div class="customer-reviews-2__avatar-wrapper">
                      <div class="customer-reviews-2__avatar {{ section.settings.avatar_background | default: 'bg-primary' }}">
                        {% if block.settings.author_avatar != blank %}
                          <img src="{{ block.settings.author_avatar | image_url: width: 100 }}" 
                               alt="{{ block.settings.author_name | default: 'Reviewer' }}"
                               class="customer-reviews-2__avatar-image">
                        {% else %}
                          <span class="{{ section.settings.avatar_font_family | default: 'font-body' }} {{ section.settings.avatar_font_size | default: 'text-base' }} {{ section.settings.avatar_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.avatar_font_weight | default: 'font-normal' }} {{ section.settings.avatar_color | default: 'text-white' }}">
                            {{ block.settings.author_initial | default: 'A' }}
                          </span>
                        {% endif %}
                      </div>
                      
                      {% if section.settings.show_verified %}
                        <div class="customer-reviews-2__verified-badge {{ section.settings.verified_badge_color | default: 'bg-success' }}">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M11.6667 3.5L5.25 9.91667L2.33333 7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </div>
                      {% endif %}
                    </div>
                    
                    <!-- Name and Verified Text -->
                    <div class="customer-reviews-2__author-info">
                      {% if block.settings.author_name != blank %}
                        <p class="customer-reviews-2__author-name {{ section.settings.author_name_font_family | default: 'font-body' }} {{ section.settings.author_name_font_size | default: 'text-xs' }} {{ section.settings.author_name_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.author_name_font_weight | default: 'font-normal' }} {{ section.settings.author_name_color | default: 'text-primary' }}">
                          {{ block.settings.author_name }}
                        </p>
                      {% endif %}
                      
                      {% if section.settings.show_verified and section.settings.verified_text != blank %}
                        <p class="customer-reviews-2__verified-text {{ section.settings.verified_text_font_family | default: 'font-body' }} {{ section.settings.verified_text_font_size | default: 'text-xs' }} {{ section.settings.verified_text_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.verified_text_font_weight | default: 'font-normal' }} {{ section.settings.verified_text_color | default: 'text-neutral-dark' }}">
                          {{ section.settings.verified_text }}
                        </p>
                      {% endif %}
                    </div>
                  </div>
                  
                </div>
              {% endfor %}
            </div>
          {% endif %}
          
          <!-- Show More Button -->
          {% if section.settings.show_button %}
            <div class="customer-reviews-2__button-wrapper">
              <a href="{{ section.settings.button_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                {{ section.settings.button_text | default: 'Show more' }}
              </a>
            </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
</section>

