<link rel="stylesheet" href="{{ 'medication-carousel/styles.css' | asset_url }}">

<!-- Medication Carousel Section -->
<section class="medication-carousel {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-lg' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
    
    <!-- Carousel Wrapper -->
    <div class="medication-carousel__wrapper">
      
      <!-- Horizontal Scrolling Track -->
      <div class="medication-carousel__track-container">
        <div class="medication-carousel__track" id="medication-track-{{ section.id }}">
        
        {% for block in section.blocks %}
          
          {% if block.type == 'featured_card' %}
            <!-- Featured Card (with background image) -->
            <div class="medication-carousel__card medication-carousel__card--featured {{ section.settings.featured_card_border_radius | default: 'rounded-xl' }}" {{ block.fluid_attributes }}>
              
              <!-- Background Image -->
              {% if block.settings.background_image != blank %}
                <div class="medication-carousel__featured-bg" style="background-image: url('{{ block.settings.background_image | image_url: width: 800 }}');"></div>
              {% else %}
                <div class="medication-carousel__featured-bg" style="background-image: url('{{ 'placeholder-image.png' | asset_url }}');"></div>
              {% endif %}
              
              <!-- Content Overlay -->
              <div class="medication-carousel__featured-content">
                
                <!-- Badge -->
                {% if block.settings.show_badge and block.settings.badge_text != blank %}
                  <div class="medication-carousel__badge {{ section.settings.badge_background | default: 'bg-success' }}">
                    <span class="{{ section.settings.badge_font_family | default: 'font-body' }} {{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.badge_font_weight | default: 'font-normal' }} {{ section.settings.badge_color | default: 'text-black' }}">
                      {{ block.settings.badge_text }}
                    </span>
                  </div>
                {% endif %}
                
                <!-- Title -->
                {% if block.settings.title != blank %}
                  <h2 class="medication-carousel__featured-title {{ section.settings.featured_title_font_family | default: 'font-body' }} {{ section.settings.featured_title_font_size | default: 'text-2xl' }} {{ section.settings.featured_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.featured_title_font_weight | default: 'font-normal' }} {{ section.settings.featured_title_color | default: 'text-white' }}">
                    {{ block.settings.title }}
                  </h2>
                {% endif %}
                
                <!-- Description -->
                {% if block.settings.description != blank %}
                  <p class="medication-carousel__featured-description {{ section.settings.featured_description_font_family | default: 'font-body' }} {{ section.settings.featured_description_font_size | default: 'text-sm' }} {{ section.settings.featured_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.featured_description_font_weight | default: 'font-normal' }} {{ section.settings.featured_description_color | default: 'text-white' }}">
                    {{ block.settings.description }}
                  </p>
                {% endif %}
                
                <!-- CTA Button -->
                {% if block.settings.show_button and block.settings.button_text != blank %}
                  <div class="medication-carousel__featured-button-wrapper">
                    <a href="{{ block.settings.button_url | default: '#' }}" 
                       class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'white' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                      {{ block.settings.button_text }}
                    </a>
                  </div>
                {% endif %}
                
              </div>
            </div>
            
          {% elsif block.type == 'product_card' %}
            <!-- Standard Product Card -->
            <div class="medication-carousel__card medication-carousel__card--product {{ section.settings.card_background | default: 'bg-success' }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}" {{ block.fluid_attributes }}>
              
              <div class="medication-carousel__product-content">
                
                <!-- Product Title -->
                {% if block.settings.product_title != blank %}
                  <h3 class="medication-carousel__product-title {{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-2xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.product_title_font_weight | default: 'font-normal' }} {{ section.settings.product_title_color | default: 'text-black' }}">
                    {{ block.settings.product_title }}
                  </h3>
                {% endif %}
                
                <!-- Subtitle (optional) -->
                {% if block.settings.product_subtitle != blank %}
                  <p class="medication-carousel__product-subtitle {{ section.settings.product_subtitle_font_family | default: 'font-body' }} {{ section.settings.product_subtitle_font_size | default: 'text-base' }} {{ section.settings.product_subtitle_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_subtitle_font_weight | default: 'font-normal' }} {{ section.settings.product_subtitle_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.product_subtitle }}
                  </p>
                {% endif %}
                
                <!-- Product Image -->
                <div class="medication-carousel__product-image-wrapper">
                  {% if block.settings.product_image != blank %}
                    <img src="{{ block.settings.product_image | image_url: width: 800 }}" 
                         alt="{{ block.settings.image_alt | default: block.settings.product_title }}"
                         class="medication-carousel__product-image"
                         loading="lazy">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" 
                         alt="Product placeholder"
                         class="medication-carousel__product-image">
                  {% endif %}
                </div>
                
                <!-- Action Buttons -->
                <div class="medication-carousel__product-actions">
                  <!-- Learn More Button -->
                  {% if block.settings.show_learn_button and block.settings.learn_button_text != blank %}
                    <a href="{{ block.settings.learn_button_url | default: '#' }}" 
                       class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'white' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                      {{ block.settings.learn_button_text }}
                    </a>
                  {% endif %}
                </div>
                
              </div>
            </div>
            
          {% endif %}
          
        {% endfor %}
        
        </div>
      </div>
      
    </div>
    
    </div>
  </div>
</section>

<script>
(function() {
  // Smooth horizontal scrolling for medication carousel
  function initMedicationCarousel() {
    const tracks = document.querySelectorAll('[id^="medication-track-"]');
    
    tracks.forEach(function(track) {
      let isDown = false;
      let startX;
      let scrollLeft;
      
      track.addEventListener('mousedown', function(e) {
        isDown = true;
        track.style.cursor = 'grabbing';
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      });
      
      track.addEventListener('mouseleave', function() {
        isDown = false;
        track.style.cursor = 'grab';
      });
      
      track.addEventListener('mouseup', function() {
        isDown = false;
        track.style.cursor = 'grab';
      });
      
      track.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 2;
        track.scrollLeft = scrollLeft - walk;
      });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMedicationCarousel);
  } else {
    initMedicationCarousel();
  }
})();
</script>

