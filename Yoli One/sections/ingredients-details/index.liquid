<link rel="stylesheet" href="{{ 'ingredients-details/styles.css' | asset_url }}">

<!-- Ingredients Details Section -->
<section class="ingredients-details {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="container">
    <div class="ingredients-details__inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="ingredients-details__layout">
        
        <!-- Left Content Side -->
        <div class="ingredients-details__content-side">
          
          <!-- Heading -->
          {% if section.settings.heading != blank or section.settings.heading_emphasis != blank %}
            <div class="ingredients-details__heading-group">
              {% if section.settings.heading != blank %}
                <h2 class="{{ section.settings.heading_font_family | default: 'font-body' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-black' }}">
                  {{ section.settings.heading }}
                </h2>
              {% endif %}
              {% if section.settings.heading_emphasis != blank %}
                <p class="{{ section.settings.emphasis_font_family | default: 'font-body' }} {{ section.settings.emphasis_font_size | default: 'text-xl' }} {{ section.settings.emphasis_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.emphasis_font_weight | default: 'font-light' }} {{ section.settings.emphasis_color | default: 'text-black' }} ingredients-details__emphasis">
                  {{ section.settings.heading_emphasis }}
                </p>
              {% endif %}
            </div>
          {% endif %}

          <!-- Description -->
          {% if section.settings.description != blank %}
            <div class="ingredients-details__description">
              <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }}">
                {{ section.settings.description }}
              </p>
            </div>
          {% endif %}

          <!-- Badge Links -->
          {% assign badge_blocks = section.blocks | where: 'type', 'badge_link' %}
          {% if badge_blocks.size > 0 %}
            <div class="ingredients-details__badges">
              {% for block in badge_blocks %}
                {% if block.settings.text != blank %}
                  <div class="ingredients-details__badge" {{ block.fluid_attributes }}>
                    {% if block.settings.icon != blank %}
                      <img src="{{ block.settings.icon | image_url: width: 32 }}" alt="" class="ingredients-details__badge-icon">
                    {% endif %}
                    <span class="{{ section.settings.badge_font_family | default: 'font-body' }} {{ section.settings.badge_font_size | default: 'text-sm' }} {{ section.settings.badge_font_weight | default: 'font-normal' }} {{ section.settings.badge_text_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.text }}
                    </span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

        </div>

        <!-- Product Cards Side -->
        <div class="ingredients-details__cards-side">
          {% assign product_cards = section.blocks | where: 'type', 'product_card' %}
          {% if product_cards.size > 0 %}
            <div class="ingredients-details__cards-grid">
              {% for block in product_cards %}
                <a href="{{ block.settings.url | default: '#' }}" class="ingredients-details__card" {{ block.fluid_attributes }}>
                  
                  <!-- Card Image -->
                  <div class="ingredients-details__card-image">
                    {% if block.settings.image != blank %}
                      <img src="{{ block.settings.image | image_url: width: 800 }}" 
                           alt="{{ block.settings.image_alt | default: block.settings.title }}"
                           loading="lazy">
                    {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}" 
                           alt="Placeholder">
                    {% endif %}
                    
                    <!-- Optional Top Badge -->
                    {% if block.settings.show_badge and block.settings.badge_text != blank %}
                      <div class="ingredients-details__card-badge {{ section.settings.card_badge_background | default: 'bg-white' }}">
                        <span class="{{ section.settings.card_badge_font_family | default: 'font-body' }} {{ section.settings.card_badge_font_size | default: 'text-sm' }} {{ section.settings.card_badge_font_weight | default: 'font-normal' }} {{ section.settings.card_badge_text_color | default: 'text-black' }}">
                          {{ block.settings.badge_text }}
                        </span>
                      </div>
                    {% endif %}

                    <!-- Card Overlay Content -->
                    <div class="ingredients-details__card-overlay">
                      
                      <!-- Product Title -->
                      {% if block.settings.title != blank %}
                        <h3 class="{{ section.settings.card_title_font_family | default: 'font-body' }} {{ section.settings.card_title_font_size | default: 'text-lg' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.card_title_font_weight | default: 'font-medium' }} {{ section.settings.card_title_color | default: 'text-white' }} ingredients-details__card-title">
                          {{ block.settings.title }}
                        </h3>
                      {% endif %}

                      <!-- Features List -->
                      <div class="ingredients-details__features-list">
                        {% if block.settings.feature_one != blank %}
                          <div class="ingredients-details__feature-item">
                            <span class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-sm' }} {{ section.settings.feature_font_weight | default: 'font-medium' }} {{ section.settings.feature_text_color | default: 'text-white' }}">
                              {{ block.settings.feature_one }}
                            </span>
                            {% if block.settings.feature_one_icon != blank %}
                              <img src="{{ block.settings.feature_one_icon | image_url: width: 40 }}" alt="" class="ingredients-details__feature-icon">
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.feature_two != blank %}
                          <div class="ingredients-details__feature-item">
                            <span class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-sm' }} {{ section.settings.feature_font_weight | default: 'font-medium' }} {{ section.settings.feature_text_color | default: 'text-white' }}">
                              {{ block.settings.feature_two }}
                            </span>
                            {% if block.settings.feature_two_icon != blank %}
                              <img src="{{ block.settings.feature_two_icon | image_url: width: 40 }}" alt="" class="ingredients-details__feature-icon">
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.feature_three != blank %}
                          <div class="ingredients-details__feature-item">
                            <span class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-sm' }} {{ section.settings.feature_font_weight | default: 'font-medium' }} {{ section.settings.feature_text_color | default: 'text-white' }}">
                              {{ block.settings.feature_three }}
                            </span>
                            {% if block.settings.feature_three_icon != blank %}
                              <img src="{{ block.settings.feature_three_icon | image_url: width: 40 }}" alt="" class="ingredients-details__feature-icon">
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.feature_four != blank %}
                          <div class="ingredients-details__feature-item">
                            <span class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-sm' }} {{ section.settings.feature_font_weight | default: 'font-medium' }} {{ section.settings.feature_text_color | default: 'text-white' }}">
                              {{ block.settings.feature_four }}
                            </span>
                            {% if block.settings.feature_four_icon != blank %}
                              <img src="{{ block.settings.feature_four_icon | image_url: width: 40 }}" alt="" class="ingredients-details__feature-icon">
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.feature_five != blank %}
                          <div class="ingredients-details__feature-item">
                            <span class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-sm' }} {{ section.settings.feature_font_weight | default: 'font-medium' }} {{ section.settings.feature_text_color | default: 'text-white' }}">
                              {{ block.settings.feature_five }}
                            </span>
                            {% if block.settings.feature_five_icon != blank %}
                              <img src="{{ block.settings.feature_five_icon | image_url: width: 40 }}" alt="" class="ingredients-details__feature-icon">
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.feature_six != blank %}
                          <div class="ingredients-details__feature-item">
                            <span class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-sm' }} {{ section.settings.feature_font_weight | default: 'font-medium' }} {{ section.settings.feature_text_color | default: 'text-white' }}">
                              {{ block.settings.feature_six }}
                            </span>
                            {% if block.settings.feature_six_icon != blank %}
                              <img src="{{ block.settings.feature_six_icon | image_url: width: 40 }}" alt="" class="ingredients-details__feature-icon">
                            {% endif %}
                          </div>
                        {% endif %}
                      </div>

                    </div>
                  </div>

                </a>
              {% endfor %}
            </div>
          {% endif %}
        </div>

      </div>

    </div>
  </div>

</section>

