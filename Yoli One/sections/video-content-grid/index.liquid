<link rel="stylesheet" href="{{ 'video-content-grid/styles.css' | asset_url }}">

<!-- Video Content Grid Section -->
<section 
  class="video-content-grid {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="video-content-grid-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="video-content-grid-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="video-content-grid-layout {% if section.settings.flip_layout %}video-content-grid-layout--flipped{% endif %}">
        
        <!-- Left Column: Text Content -->
        <div class="video-content-text-column">
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
          <div class="video-content-heading {{ section.settings.heading_paragraph_spacing_mobile | default: 'mb-lg' }} {{ section.settings.heading_paragraph_spacing_desktop | default: 'lg:mb-xl' }}">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }}">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Paragraph -->
          {% if section.settings.paragraph != blank %}
          <div class="video-content-paragraph">
            <p class="{{ section.settings.paragraph_font_family | default: 'font-body' }} {{ section.settings.paragraph_font_size | default: 'text-base' }} {{ section.settings.paragraph_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.paragraph_font_weight | default: 'font-normal' }} {{ section.settings.paragraph_color | default: 'text-black' }}">
              {{ section.settings.paragraph }}
            </p>
          </div>
          {% endif %}
          
        </div>
        
        <!-- Right Column: Video Grid (2x2) -->
        {% if section.blocks.size > 0 %}
        <div class="video-content-grid-column">
          <div class="video-thumbnails-grid">
            {% for block in section.blocks %}
              {% if block.type == 'video_thumbnail' %}
              <div class="video-thumbnail-item" data-video-item="{{ section.id }}-{{ forloop.index0 }}" {{ block.fluid_attributes }}>
                <div class="video-carousel-video-wrapper {{ section.settings.video_card_border_radius | default: 'rounded-lg' }}">
                  <video
                    class="video-carousel-video"
                    data-video="{{ section.id }}-{{ forloop.index0 }}"
                    {% if block.settings.poster_image != blank %}poster="{{ block.settings.poster_image | image_url: width: 600 }}"{% elsif block.settings.thumbnail_image != blank %}poster="{{ block.settings.thumbnail_image | image_url: width: 600 }}"{% else %}poster="{{ 'placeholder-image.png' | asset_url }}"{% endif %}
                    loop
                    playsinline
                    preload="metadata">
                    {% if block.settings.video_url != blank %}
                      {% if block.settings.video_url contains '.mp4' or block.settings.video_url contains '.mov' or block.settings.video_url contains '.webm' %}
                        <source src="{{ block.settings.video_url }}" type="video/mp4">
                      {% endif %}
                    {% elsif block.settings.video_media != blank %}
                      {% assign media_url = block.settings.video_media %}
                      {% if media_url contains '.mp4' or media_url contains '.mov' or media_url contains '.webm' %}
                        <source src="{{ media_url }}" type="video/mp4">
                      {% endif %}
                    {% endif %}
                  </video>
                  
                  <!-- Play/Pause Overlay Button -->
                  <button 
                    class="video-carousel-play-btn"
                    data-play-btn="{{ section.id }}-{{ forloop.index0 }}"
                    aria-label="Play video"
                    type="button">
                    <svg class="video-carousel-play-icon" width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="32" cy="32" r="32" fill="rgba(0, 0, 0, 0.5)"/>
                      <path d="M26 20L42 32L26 44V20Z" fill="white"/>
                    </svg>
                    <svg class="video-carousel-pause-icon" width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: none;">
                      <circle cx="32" cy="32" r="32" fill="rgba(0, 0, 0, 0.5)"/>
                      <rect x="22" y="20" width="8" height="24" fill="white"/>
                      <rect x="34" y="20" width="8" height="24" fill="white"/>
                    </svg>
                  </button>
                  
                  {% if block.settings.title != blank %}
                  <div class="video-carousel-item-title {{ section.settings.video_title_font_family | default: 'font-primary' }} {{ section.settings.video_title_font_size | default: 'text-base' }} {{ section.settings.video_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.video_title_font_weight | default: 'font-semibold' }} {{ section.settings.video_title_color | default: 'text-white' }}">
                    {{ block.settings.title }}
                  </div>
                  {% endif %}
                </div>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
  
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const videoItems = document.querySelectorAll(`#video-content-grid-${sectionId} .video-thumbnail-item`);
  if (videoItems.length === 0) return;
  
  let currentlyPlayingVideo = null;
  
  // Pause all videos
  function pauseAllVideos() {
    videoItems.forEach((item) => {
      const video = item.querySelector('.video-carousel-video');
      const playBtn = item.querySelector('.video-carousel-play-btn');
      if (video && playBtn) {
        video.pause();
        playBtn.classList.remove('is-playing');
        playBtn.querySelector('.video-carousel-play-icon').style.display = 'block';
        playBtn.querySelector('.video-carousel-pause-icon').style.display = 'none';
      }
    });
    currentlyPlayingVideo = null;
  }
  
  // Video play/pause handlers
  videoItems.forEach((item) => {
    const video = item.querySelector('.video-carousel-video');
    const playBtn = item.querySelector('.video-carousel-play-btn');
    
    if (!video || !playBtn) return;
    
    playBtn.addEventListener('click', async function(e) {
      e.stopPropagation();
      
      // If this video is already playing, pause it
      if (currentlyPlayingVideo === video) {
        video.pause();
        playBtn.classList.remove('is-playing');
        playBtn.querySelector('.video-carousel-play-icon').style.display = 'block';
        playBtn.querySelector('.video-carousel-pause-icon').style.display = 'none';
        currentlyPlayingVideo = null;
        return;
      }
      
      // Pause any other playing video
      pauseAllVideos();
      
      // Play this video
      try {
        await video.play();
        currentlyPlayingVideo = video;
        playBtn.classList.add('is-playing');
        playBtn.querySelector('.video-carousel-play-icon').style.display = 'none';
        playBtn.querySelector('.video-carousel-pause-icon').style.display = 'block';
      } catch (err) {
        console.error('Play failed:', err);
      }
    });
    
    // Update button state when video plays/pauses
    video.addEventListener('play', function() {
      playBtn.classList.add('is-playing');
      playBtn.querySelector('.video-carousel-play-icon').style.display = 'none';
      playBtn.querySelector('.video-carousel-pause-icon').style.display = 'block';
    });
    
    video.addEventListener('pause', function() {
      playBtn.classList.remove('is-playing');
      playBtn.querySelector('.video-carousel-play-icon').style.display = 'block';
      playBtn.querySelector('.video-carousel-pause-icon').style.display = 'none';
    });
    
    video.addEventListener('ended', function() {
      playBtn.classList.remove('is-playing');
      playBtn.querySelector('.video-carousel-play-icon').style.display = 'block';
      playBtn.querySelector('.video-carousel-pause-icon').style.display = 'none';
      currentlyPlayingVideo = null;
    });
  });
})();
</script>

