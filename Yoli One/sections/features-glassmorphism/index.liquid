<link rel="stylesheet" href="{{ 'features-glassmorphism/styles.css' | asset_url }}">

<!-- Features Glassmorphism Section -->
<section class="features-glassmorphism {{ section.settings.background_color | default: 'bg-secondary-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-lg' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="features-glass-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="features-glass-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-md' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Background Image Container -->
      <div class="background-wrapper {{ section.settings.inner_border_radius | default: 'rounded-3xl' }}">
        {% if section.settings.hero_background_image != blank %}
          <div class="background-image" style="background-image: url('{{ section.settings.hero_background_image | image_url: width: 1600 }}');"></div>
        {% endif %}
        
        <!-- Overlay (optional) -->
        {% if section.settings.show_overlay %}
        <div class="background-overlay" style="background-color: {{ section.settings.overlay_color | default: 'rgba(0,0,0,0.3)' }};"></div>
        {% endif %}
        
        <!-- Content Wrapper -->
        <div class="content-wrapper">
          
          <!-- Top Content -->
          <div class="top-content">
            
            <!-- Intro Text -->
            {% if section.settings.intro_text != blank %}
            <div class="intro-text-wrapper">
              <p class="{{ section.settings.intro_font_family | default: 'font-body' }} {{ section.settings.intro_font_size | default: 'text-lg' }} {{ section.settings.intro_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.intro_font_weight | default: 'font-normal' }} {{ section.settings.intro_color | default: 'text-white' }} leading-body">
                {{ section.settings.intro_text }}
              </p>
            </div>
            {% endif %}
            
            <!-- Heading -->
            {% if section.settings.heading != blank %}
            <div class="heading-wrapper">
              <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }} leading-heading">
                {{ section.settings.heading }}
              </h2>
            </div>
            {% endif %}
            
          </div>
          
          <!-- Glass Container with Features -->
          {% if section.blocks.size > 0 %}
          <div class="glass-container">
            <div class="features-grid">
              {% for block in section.blocks %}
                {% if block.type == 'feature' %}
                <div class="feature-item" {{ block.fluid_attributes }}>
                  
                  <!-- Icon -->
                  {% if block.settings.icon != blank %}
                  <div class="feature-icon">
                    <img src="{{ block.settings.icon | image_url: width: 128 }}" alt="{{ block.settings.icon_alt | default: 'Feature icon' }}" loading="lazy">
                  </div>
                  {% endif %}
                  
                  <!-- Title -->
                  {% if block.settings.title != blank %}
                  <div class="feature-title">
                    <h3 class="{{ block.settings.title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: 'text-lg' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.title_font_weight | default: 'font-normal' }} {{ block.settings.title_color | default: 'text-white' }} leading-heading">
                      {{ block.settings.title }}
                    </h3>
                  </div>
                  {% endif %}
                  
                  <!-- Description -->
                  {% if block.settings.description != blank %}
                  <div class="feature-description">
                    <p class="{{ block.settings.description_font_family | default: 'font-body' }} {{ block.settings.description_font_size | default: 'text-sm' }} {{ block.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ block.settings.description_font_weight | default: 'font-normal' }} {{ block.settings.description_color | default: 'text-white' }} leading-body">
                      {{ block.settings.description }}
                    </p>
                  </div>
                  {% endif %}
                  
                </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

