<script>
  // ================| Packs enrollment ids |================
  const packs = [
    {
      "name": "Transformation pack",
      "enrollment_pack_id": 461,
      "subscription_pack_id": 446,
      "pack_id": "1nVHTpRorDvGN1eXJtXEfN6a"

    },
    {
      "name": "Transformation Launch Pack",
      "enrollment_pack_id": 447,
      "subscription_pack_id": 460, 
      "pack_id": "4V7kFTCGAdc5nFSKVfDLjhuo"
    },  
    {
      "name": "Transformation Share Pack",
      "enrollment_pack_id": 448,
      "subscription_pack_id": 459,
      "pack_id": "aENA7VyztXbPdvXHaEsp4DbB"
    },
    {
      "name": "Launch Pack",
      "enrollment_pack_id": 450,
      "subscription_pack_id": 458,
      "pack_id": "3BJtX1Dn6UeiPWddbzPFqreS"
    },
    {
      "name": "Builder Pack",
      "enrollment_pack_id": 451,
      "subscription_pack_id": 457,
      "pack_id": "dga2t3w9PKQ38zcrCDXpX7gb"
    },
    {
      "name": "ProBuilder Pack",
      "enrollment_pack_id": 463,
      "subscription_pack_id": 456,
      "pack_id": "mJMmCQspobm6z9jQYQNvpG6o"
    }
  ]

  function getCurrentPackToken() {
    const currentPack = window.location.pathname.split('/').pop();
    return currentPack;
  }

  function setAddToCartButtonData() {
    const currentPackId = getCurrentPackToken();
    const currentPack = packs.find(pack => pack.pack_id === currentPackId);
    const isSubscriptionChecked = $('input[name="purchase-type"]:checked').val() === 'subscription';
    const addToCartButton = document.getElementById('add-to-cart-button');

    if (isSubscriptionChecked) {
      addToCartButton.setAttribute('data-fluid-add-enrollment-pack', currentPack.subscription_pack_id);
    } else {
      addToCartButton.setAttribute('data-fluid-add-enrollment-pack', currentPack.enrollment_pack_id);
    }
  }

  // ================| Subscription price |================
  async function updateSubscriptionPrice() {
    const currentPack = getCurrentPackToken();
    console.log('currentPack token:', currentPack);

    const packMapping = {
      '1nVHTpRorDvGN1eXJtXEfN6a': 53586,
      'aENA7VyztXbPdvXHaEsp4DbB': 53588,
      '4V7kFTCGAdc5nFSKVfDLjhuo': 53589,
      '3BJtX1Dn6UeiPWddbzPFqreS': 55625,
      'dga2t3w9PKQ38zcrCDXpX7gb': 55626,
      'mJMmCQspobm6z9jQYQNvpG6o': 55627
    };

    const subscription_pack_id = packMapping[currentPack];
    console.log('subscription_pack_id:', subscription_pack_id);

    const subscriptionPrice = await getSubscriptionPrice(subscription_pack_id);

    if (subscriptionPrice) {
      const subscriptionPriceElement = document.getElementById('subscription-price');
      if (subscriptionPriceElement) {
        subscriptionPriceElement.textContent = `${subscriptionPrice}`;
      }
    }
  }

  async function getSubscriptionPrice(subscription_pack_id) {
    try {
      const url = `https://yoli.fluid.app/api/company/v1/products/${subscription_pack_id}?lang=en`;
      const token = 'PT-tKicE8bWxwyVhURbc6yhYufB';

      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${token}`,
          'x-fluid-client': 'fair-share',
        },
      });

      console.log('Response status:', response.status, response.ok);

      if (!response.ok) {
        console.error('API error:', response.status);
        return null;
      }

      const data = await response.json();
      const subscriptionPrice = data.product.product_subscription_plans[0].subscription_plan.wholesale_subscription_price;

      return subscriptionPrice.replace(/\s*\(USD\)/, '');
    } catch (error) {
      console.error('Error getting subscription price:', error);
      return null;
    }
  }

  // ================| Bundle variants |================
  
  function bundleVariants() {
    const bundles = JSON.parse(localStorage.getItem('selectedProductsCart') || '{}');
    console.log("bundles", bundles);
    const items = [];
  
    for (const key in bundles) {
      const bundle = bundles[key];
      const item = {
        "variant_id": parseInt(bundle.variant_id),
        "quantity": parseInt(bundle.quantity),
        "display_to_customer": (parseInt(bundle.quantity) > 0)
      };
      items.push(item);
    }
    console.log("items", items);
    return items;
  }
  
  let cartToken = '';

  async function getCartToken() {
    const cart = await window.FairShareSDK.getCart();
    return cart.cart_token;
  }

  async function getItemId() {
    const cart = await window.FairShareSDK.getCart();
    return cart.items?.[0]?.id ?? null;
  }

  async function updateBundleProducts(item_id) {
    const url = `https://yoli.fluid.app/api/carts/${cartToken}/items/${item_id}/bundled_items`;
    try {
      const response = await fetch(url, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({
           "bundled_items": bundleVariants()
          }),
      });
      
      const data = await response.json();

      if (!response.ok) {
        console.error('API error:', response.status, data);
        return null;
      }

      return data;
    } catch (error) {
      console.error('Error updating cart:', error);
    }
  }

  async function updateCart() {
    if (!cartToken) cartToken = await getCartToken();
    const item_id = await getItemId();
    if (!item_id) return;

    await updateBundleProducts(item_id);
  }

  let updateCartTimeoutId = null;
  function scheduleUpdateCart() {
    if (updateCartTimeoutId) clearTimeout(updateCartTimeoutId);
    updateCartTimeoutId = setTimeout(() => { updateCart(); }, 1000);
  }

  // ================| update colors |================

  function updateRadioColors() {
    const subscriptionRadio = document.querySelector('input[value="subscription"]');
    const tryOnceRadio = document.querySelector('input[value="once"]');
    const chosenLabel = document.querySelector('.form12_radio-2.chosen');
    const tryOnceLabel = document.querySelector('.form12_radio-2.buy-once');
    const mostPopularDiv = document.querySelector('.div-block-2');

    const isSubscription = !!(subscriptionRadio && subscriptionRadio.checked);
    const colors = isSubscription
      ? { chosen: '#49473D', chosenBorder: '#0f100fde', tryOnce: '#49473D99', tryOnceBorder: '#49473D99', most: '#49473D' }
      : { chosen: '#49473D99', chosenBorder: '#49473D99', tryOnce: '#49473D', tryOnceBorder: '#0f100fde', most: '#49473D99' };

    if (chosenLabel) {
      chosenLabel.style.color = colors.chosen;
      chosenLabel.style.borderColor = colors.chosenBorder;
    }
    if (tryOnceLabel) {
      tryOnceLabel.style.color = colors.tryOnce;
      tryOnceLabel.style.borderColor = colors.tryOnceBorder;
    }
    if (mostPopularDiv) {
      mostPopularDiv.style.color = colors.most;
    }
  }

  // ================| initializer |================

  function updateAddToCartEnabled() {
    const addToCartButton = document.getElementById('add-to-cart-button');
    if (!addToCartButton) return;
    const complete = JSON.parse(localStorage.getItem('packSelectionsComplete') || 'false');
    addToCartButton.disabled = !complete;
  }

  function init() {
    updateSubscriptionPrice();
    updateRadioColors();
    setAddToCartButtonData();
    getCartToken().then(token => { cartToken = token; });
    updateAddToCartEnabled();

    document.querySelectorAll('input[name="purchase-type"]').forEach(function (radio) {
      radio.addEventListener('change', updateRadioColors);
      radio.addEventListener('change', setAddToCartButtonData);
    });

    window.addEventListener('pack-selections-updated', function () {
      updateAddToCartEnabled();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>