<div class="add-to-cart-section">
  <div class="form12_block w-form">
    <form id="wf-form-Form-12" name="wf-form-Form-12" data-name="Form 12" method="get"
      data-wf-page-id="67d09b425b66fbbf96d717f2" data-wf-element-id="7e9614c3-7acc-3be3-c92b-60a3a9de60f6">
      <div id="w-node-_7e9614c3-7acc-3be3-c92b-60a3a9de60f7-96d717f2" class="form12_radio-group">
        <label class="form12_radio-2 chosen w-radio {{ section.settings.subscribe_background_color }} {{ section.settings.subscribe_text_color }}">
          <div class="div-block-2 {{section.settings.card_background_color}} {{ section.settings.card_title_color}} {{ section.settings.card_title_font_size }} {{ section.settings.card_title_font_weight }}">{{ section.settings.card_title }}</div>
          <div class="card-text">
            <span class="form12_radio-label w-form-label {{ section.settings.subscribe_font_size }} {{ section.settings.subscribe_font_weight }}" for="Form-12-Option-1">
              {{ section.settings.subscribe_save_text }}
              <div class="price-input">
                <span class="form12_radio-label-span" id="subscription-price"></span>
                <input type="radio" name="purchase-type" value="subscription" class="radio-input" checked>
              </div>
            </span>
            <ul role="list" class="list">
              {% for block in section.blocks %}
                {% if block.type == 'benefit' %}
                  <li class="{{ block.settings.benefit_font_size | default: 'text-md' }} {{ block.settings.benefit_font_weight | default: 'text-fw-bold' }}" {{ block.fluid_attributes }}>{{ block.settings.text }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        </label>
        <label id="w-node-_7e9614c3-7acc-3be3-c92b-60a3a9de6109-96d717f2" class="form12_radio-2 buy-once w-radio {{ section.settings.try_once_background_color }} {{ section.settings.try_once_text_color }}">
          <span class="form12_radio-label notselected w-form-label {{ section.settings.try_once_font_size }} {{ section.settings.try_once_font_weight }}" for="Form-12-Option-2">
            {{ section.settings.try_once_text }}
            <div class="price-input">
              <span class="form12_radio-label-span">{{ enrollment_pack.price }}</span>
              <input type="radio" name="purchase-type" value="once" class="radio-input">
            </div>
          </span>
        </label>
      </div>
    </form>
  </div>

  <div class="product-header1_add-to-cart w-form">
    <form id="email-form" name="email-form" data-name="Email Form" method="get" class="product-header1_default-state"
      data-wf-page-id="67d09b425b66fbbf96d717f2" data-wf-element-id="390f5283-abb6-906b-a60a-f616064a5061">
      <div class="w-layout-hflex flex-block">
        <button type="button" id="add-to-cart-button" data-fluid-open-cart-after-add="true" class="button-2 is-add-to-cart-button w-button {{section.settings.add_to_cart_color}} {{section.settings.add_to_cart_background_color}} {{ section.settings.add_to_cart_font_size }} {{ section.settings.add_to_cart_font_weight }}" onclick="scheduleUpdateCart()">
          {{section.settings.add_to_cart_text }}
        </button>
      </div>
    </form>
  </div>

  {% if section.settings.show_free_shipping %}
    <div class="free-shipping">
      <p class="{{ section.settings.free_shipping_font_size }} {{ section.settings.free_shipping_font_weight }}">{{ section.settings.free_shipping_text }}</p>
    </div>
  {% endif %}

  {% if section.settings.show_payment_methods %}
    <div class="credit-cards">
      {% for block in section.blocks %}
        {% if block.type == 'payment_method' %}
          <div class="payment-card {{ block.settings.card_size | default: 'card-md' }}" {{ block.fluid_attributes }}>
            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.alt }}" class="payment-icon">
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

