{% comment %}
  Content Showcase Section
  Features heading, body text, certification icons, and image
{% endcomment %}

<section class="content-showcase {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_padding_x_mobile | default: 'px-xl' }} {{ section.settings.section_padding_x_desktop | default: 'lg:px-xl' }}">
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="content-showcase-wrapper" {% if section.settings.flip_layout %}data-flip="true"{% endif %}>
      
      <!-- Content Column -->
      <div class="content-column flex flex-col gap-lg">
        
        <!-- Heading -->
        <div class="content-heading {{ section.settings.content_font_family | default: 'font-handwritten' }}">
          <h2 class="{{ section.settings.heading_font_size | default: 'text-5xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_color | default: 'text-secondary' }} {{ section.settings.heading_font_weight | default: 'font-normal' }}">
            {{ section.settings.heading | default: "Powering the goals of millions of people worldwide" }}
          </h2>
        </div>
        
        <!-- Body Text -->
        <div class="content-body {{ section.settings.body_font_family | default: 'font-body' }}">
          <p class="{{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.body_color | default: 'text-secondary' }} {{ section.settings.body_font_weight | default: 'font-normal' }}">
            {{ section.settings.body_text | default: "From busy parents juggling family life to elite athletes pushing their limits, Yoli's science-backed formulas have become the secret weapon in medicine cabinets across the globe." }}
          </p>
        </div>
        
        <!-- Certification Icons -->
        <div class="certification-icons">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'certification' %}
                <div class="certification-item" {{ block.fluid_attributes }}>
              {% if block.settings.icon_image %}
                <img src="{{ block.settings.icon_image | image_url }}" 
                     alt="{{ block.settings.icon_text | default: 'Certification' }}" 
                     style="max-width: 96px; height: auto;">
              {% else %}
                <img src="{{ 'placeholder-image.png' | asset_url }}" 
                     alt="{{ block.settings.icon_text | default: 'Certification' }}"
                     style="max-width: 96px; height: auto;">
              {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
        
      </div>
      
      <!-- Image Column -->
      <div class="image-column">
        {% assign br_tl = section.settings.image_border_top_left | default: "8" %}
        {% assign br_tr = section.settings.image_border_top_right | default: "50" %}
        {% assign br_br = section.settings.image_border_bottom_right | default: "8" %}
        {% assign br_bl = section.settings.image_border_bottom_left | default: "8" %}
        
        {% if section.settings.flip_layout %}
          {% comment %} When flipped, swap left and right borders {% endcomment %}
          {% assign br_tl = section.settings.image_border_top_right | default: "50" %}
          {% assign br_tr = section.settings.image_border_top_left | default: "8" %}
          {% assign br_br = section.settings.image_border_bottom_left | default: "8" %}
          {% assign br_bl = section.settings.image_border_bottom_right | default: "8" %}
        {% endif %}
        
        {% if section.settings.feature_image %}
          <div class="image-wrapper" style="border-radius: {{ br_tl }}px {{ br_tr }}px {{ br_br }}px {{ br_bl }}px;">
            <img src="{{ section.settings.feature_image | image_url }}" 
                 alt="{{ section.settings.feature_image_alt | default: section.settings.heading }}" 
                 class="w-full h-full object-cover">
          </div>
        {% else %}
          <div class="image-wrapper" style="border-radius: {{ br_tl }}px {{ br_tr }}px {{ br_br }}px {{ br_bl }}px;">
            <img src="{{ 'placeholder-image.png' | asset_url }}" 
                 alt="Yoli Products"
                 class="w-full h-full object-cover">
          </div>
        {% endif %}
      </div>
      
    </div>
  </div>
</section>

<style>
  .content-showcase {
    min-height: 400px;
  }
  
  .content-showcase-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3xl);
  }
  
  .content-column {
    max-width: 600px;
    width: 100%;
  }
  
  .image-column {
    width: 100%;
  }
  
  .content-heading {
    line-height: 1;
  }
  
  @media (min-width: 1024px) {
    .content-showcase-wrapper {
      flex-direction: row;
      align-items: center;
    }
    
    .content-column {
      width: 50%;
      max-width: none;
    }
    
    .image-column {
      width: 50%;
      flex-shrink: 0;
    }
    
    .content-heading h2 {
      line-height: 67px;
    }
    
    .content-showcase-wrapper[data-flip="true"] {
      flex-direction: row-reverse;
    }
  }
  
  .certification-icons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xl);
    padding-top: var(--space-md);
  }
  
  .certification-item {
    flex-shrink: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: 0.8;
  }
  
  .certification-item:hover {
    transform: translateY(-4px);
    opacity: 1;
  }
  
  .image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  
  @media (max-width: 1023px) {
    .content-showcase-wrapper {
      gap: var(--space-2xl);
    }
    
    .certification-icons {
      gap: var(--space-lg);
    }
  }
</style>

