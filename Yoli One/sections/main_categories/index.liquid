<link rel="stylesheet" href="{{ 'product-showcase-grid/styles.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'components/pagination/styles.css' | asset_url }}">



<!-- Product Showcase Grid Section -->
<section class="product-showcase-grid {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-3xl' }}" id="product-showcase-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-showcase-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Category Heading -->
      {%- if category and category.title != blank -%}
        <div class="section-heading mb-xl">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading text-center leading-heading">
            {{ category.title }}
          </h2>
        </div>
      {%- endif -%}
      
      <!-- Product Grid with Pagination -->
      {%- if category and category.products and category.products.size > 0 -%}
        {%- paginate category.products by 10 -%}
          <div class="showcase-grid">
            {%- for product in category.products -%}
              <div class="product-card {{ section.settings.card_background | default: 'bg-secondary-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                
                <!-- Product Image Container -->
                <div class="product-image-wrapper">
                  <div class="product-image" data-hover-enabled="false">
                    {%- assign image_url = '' -%}
                    {%- if product.images.size > 0 -%}
                      {%- assign image_url = product.images[0].src -%}
                    {%- elsif product.image -%}
                      {%- assign image_url = product.image | image_url -%}
                    {%- endif -%}
                    
                    {%- if image_url != '' -%}
                      <img src="{{ image_url }}" 
                           alt="{{ product.title | default: 'Product' }}" 
                           loading="lazy"
                           class="product-image-default"
                           data-default-src="{{ image_url }}">
                    {%- else -%}
                      <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy" class="product-image-default">
                    {%- endif -%}
                  </div>
                </div>
                
                <!-- Product Content -->
                <div class="product-content">
                  
                  <!-- Product Info -->
                  <div class="product-info">
                    
                    <!-- Product Name -->
                    {%- if product.title != blank -%}
                    <div class="product-name">
                      <h3 class="{{ section.settings.product_name_font_family | default: 'font-primary' }} {{ section.settings.product_name_font_size | default: 'text-xl' }} {{ section.settings.product_name_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.product_name_font_weight | default: 'font-semibold' }} {{ section.settings.product_name_color | default: 'text-primary' }} leading-heading">
                        {{ product.title }}
                      </h3>
                    </div>
                    {%- endif -%}
                    
                    <!-- Product Description -->
                    {%- if product.description != blank -%}
                    <div class="product-description">
                      <p class="{{ section.settings.product_description_font_family | default: 'font-body' }} {{ section.settings.product_description_font_size | default: 'text-base' }} {{ section.settings.product_description_font_weight | default: 'font-normal' }} {{ section.settings.product_description_color | default: 'text-primary' }} leading-body">
                        {{ product.description | strip_html | truncate: 120 }}
                      </p>
                    </div>
                    {%- endif -%}
                  </div>
                  
                  <!-- Price Section -->
                  <div class="product-pricing">
                    
                    <!-- Price Display -->
                    {%- if product.price != blank -%}
                    <div class="price-wrapper">
                      <span class="current-price {{ section.settings.product_price_font_family | default: 'font-primary' }} {{ section.settings.product_price_font_size | default: 'text-lg' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-normal' }} {{ section.settings.product_price_color | default: 'text-primary' }}">
                        {{ product.price | money }}
                      </span>
                      
                      <!-- Original Price (Optional) -->
                      {%- if product.compare_at_price > product.price -%}
                      <span class="original-price {{ section.settings.product_original_price_font_size | default: 'text-base' }} {{ section.settings.product_original_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_original_price_color | default: 'text-neutral' }}">
                        {{ product.compare_at_price | money }}
                      </span>
                      {%- endif -%}
                    </div>
                    {%- endif -%}
                  </div>
                  
                  <!-- CTAs -->
                  <div class="product-ctas">
                    <!-- Primary CTA (Learn More) -->
                    {%- if section.settings.show_primary_button -%}
                    <a href="{{ product.url | default: '#' }}" class="btn btn-{{ section.settings.primary_button_style | default: 'filled' }}-{{ section.settings.primary_button_color | default: 'primary' }} {{ section.settings.primary_button_size | default: 'btn-md' }}">
                      {{ section.settings.primary_button_text | default: 'Learn More' }}
                    </a>
                    {%- endif -%}
                    
                    <!-- Secondary CTA (Add to Cart) -->
                    {%- if section.settings.show_secondary_link -%}
                    <a href="{{ product.url | default: '#' }}" class="secondary-link {{ section.settings.secondary_link_font_size | default: 'text-base' }} {{ section.settings.secondary_link_color | default: 'text-primary' }}">
                      {{ section.settings.secondary_link_text | default: 'Add to Cart' }}
                    </a>
                    {%- endif -%}
                  </div>
                  
                </div>
                
              </div>
            {%- endfor -%}
          </div>
          
          {%- comment -%} Pagination Component {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <div class="mt-xl">
              {% render 'pagination', 
                paginate: paginate, 
                anchor: '',
                button_font_family: section.settings.pagination_button_font_family,
                button_font_size: section.settings.pagination_button_font_size,
                button_font_weight: section.settings.pagination_button_font_weight,
                button_color: section.settings.pagination_button_color,
                info_font_family: section.settings.pagination_info_font_family,
                info_font_size: section.settings.pagination_info_font_size,
                info_color: section.settings.pagination_info_color
              %}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      {%- elsif category == blank or category.products == blank or category.products.size == 0 -%}
        {%- comment -%} Empty state when category has no products {%- endcomment -%}
        <div class="text-center py-2xl">
          <p class="text-gray-500">{{ section.settings.empty_state_text | default: 'No products found' }}</p>
        </div>
      {%- endif -%}
      
    </div>
  </div>
  
</section>

