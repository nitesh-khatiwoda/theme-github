<link rel="stylesheet" href="{{ 'experts-carousel/styles.css' | asset_url }}">

<!-- Experts Carousel Section -->
<section class="experts-carousel {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}">
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}">
      
      <div class="experts-carousel__layout">
        
        <!-- Left Column: Content -->
        <div class="experts-carousel__content">
          
          <!-- Icon -->
          {% if section.settings.icon != blank %}
            <div class="experts-carousel__icon">
              <img src="{{ section.settings.icon | image_url: width: 80 }}" 
                   alt="Section icon" 
                   style="width: 40px; height: 40px;">
            </div>
          {% endif %}

          <!-- Heading -->
          {% if section.settings.heading != blank %}
            <h2 class="experts-carousel__heading {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-black' }}">
              {{ section.settings.heading }}
            </h2>
          {% endif %}

          <!-- Description -->
          {% if section.settings.description != blank %}
            <p class="experts-carousel__description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
              {{ section.settings.description }}
            </p>
          {% endif %}

          <!-- Bullet Points -->
          {% assign bullet_blocks = section.blocks | where: 'type', 'bullet' %}
          {% if bullet_blocks.size > 0 %}
            <ul class="experts-carousel__bullets">
              {% for block in bullet_blocks %}
                {% if block.settings.title != blank %}
                  <li class="experts-carousel__bullet" {{ block.fluid_attributes }}>
                    <svg class="experts-carousel__bullet-icon {{ section.settings.bullet_icon_color | default: 'text-success' }}" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="8" fill="currentColor"/>
                      <path d="M5 8L7 10L11 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <div>
                      <span class="experts-carousel__bullet-title {{ section.settings.bullet_font_family | default: 'font-body' }} {{ section.settings.bullet_font_size | default: 'text-sm' }} {{ section.settings.bullet_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.bullet_font_weight | default: 'font-semibold' }} {{ section.settings.bullet_color | default: 'text-neutral-dark' }}">{{ block.settings.title }}</span>
                      <br>
                      <span class="experts-carousel__bullet-text {{ section.settings.bullet_font_family | default: 'font-body' }} {{ section.settings.bullet_font_size | default: 'text-sm' }} {{ section.settings.bullet_font_size_desktop | default: 'lg:text-base' }} font-normal {{ section.settings.bullet_color | default: 'text-neutral-dark' }}">{{ block.settings.text }}</span>
                    </div>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endif %}

          <!-- CTA Link -->
          {% if section.settings.show_cta_link %}
            <a href="{{ section.settings.cta_url | default: '#' }}" 
               class="experts-carousel__cta-link {{ section.settings.cta_font_family | default: 'font-body' }} {{ section.settings.cta_font_size | default: 'text-sm' }} {{ section.settings.cta_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.cta_font_weight | default: 'font-semibold' }} {{ section.settings.cta_color | default: 'text-black' }}"
               style="white-space: nowrap;">
              {{ section.settings.cta_text | default: 'Meet our advisors' }}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          {% endif %}

        </div>

        <!-- Right Column: Expert Cards Carousel -->
        {% assign expert_blocks = section.blocks | where: 'type', 'expert' %}
        {% if expert_blocks.size > 0 %}
          <div class="experts-carousel__carousel-column">
            
            <!-- Carousel Track -->
            <div class="experts-carousel__track-container">
              <div class="experts-carousel__track" data-carousel-track="{{ section.id }}">
                {% for block in expert_blocks %}
                  {% if block.type == 'expert' %}
                    <div class="experts-carousel__expert-card" {{ block.fluid_attributes }}>
                      
                      <!-- Expert Photo -->
                      <div class="experts-carousel__photo">
                        {% if block.settings.photo %}
                          <img src="{{ block.settings.photo | image_url: width: 400 }}"
                               alt="{{ block.settings.name | default: 'Expert photo' }}"
                               loading="lazy">
                        {% else %}
                          <img src="{{ 'placeholder-image.png' | asset_url }}"
                               alt="Expert photo placeholder">
                        {% endif %}
                      </div>

                      <!-- Expert Info -->
                      <div class="experts-carousel__info">
                        
                        <!-- Name with Badge -->
                        {% if block.settings.name != blank %}
                          <div class="experts-carousel__name-row">
                            <h3 class="experts-carousel__name {{ section.settings.name_font_family | default: 'font-primary' }} {{ section.settings.name_font_size | default: 'text-base' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.name_font_weight | default: 'font-semibold' }} {{ section.settings.name_color | default: 'text-black' }}">
                              {{ block.settings.name }}
                            </h3>
                            {% if block.settings.show_verified_badge %}
                              <svg class="experts-carousel__verified-badge {{ section.settings.badge_color | default: 'text-primary' }}" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                <path d="M8 0L9.79611 2.85688L13 3.23607L10.5 5.64312L11.0902 8.76393L8 7.23607L4.90983 8.76393L5.5 5.64312L3 3.23607L6.20389 2.85688L8 0Z" fill="currentColor"/>
                              </svg>
                            {% endif %}
                          </div>
                        {% endif %}

                        <!-- Title/Role -->
                        {% if block.settings.title != blank %}
                          <p class="experts-carousel__title {{ section.settings.title_font_family | default: 'font-body' }} {{ section.settings.title_font_size | default: 'text-sm' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-black' }}">
                            {{ block.settings.title }}
                          </p>
                        {% endif %}

                        <!-- Credentials -->
                        {% if block.settings.credentials != blank %}
                          <p class="experts-carousel__credentials {{ section.settings.credentials_font_family | default: 'font-body' }} {{ section.settings.credentials_font_size | default: 'text-sm' }} {{ section.settings.credentials_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.credentials_font_weight | default: 'font-normal' }} {{ section.settings.credentials_color | default: 'text-neutral-dark' }}">
                            {{ block.settings.credentials }}
                          </p>
                        {% endif %}

                        <!-- Institution Logos -->
                        <div class="experts-carousel__institutions">
                          {% if block.settings.institution_1_logo != blank or block.settings.institution_1_text != blank %}
                            <div class="experts-carousel__institution">
                              {% if block.settings.institution_1_logo %}
                                <img src="{{ block.settings.institution_1_logo | image_url: width: 48 }}" 
                                     alt="{{ block.settings.institution_1_text }}"
                                     style="width: 24px; height: 24px; object-fit: contain;">
                              {% endif %}
                              {% if block.settings.institution_1_text != blank %}
                                <span class="{{ section.settings.institution_font_family | default: 'font-body' }} {{ section.settings.institution_font_size | default: 'text-sm' }} {{ section.settings.institution_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.institution_font_weight | default: 'font-normal' }} {{ section.settings.institution_color | default: 'text-neutral-dark' }}">
                                  {{ block.settings.institution_1_text }}
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}

                          {% if block.settings.institution_2_logo != blank or block.settings.institution_2_text != blank %}
                            <div class="experts-carousel__institution">
                              {% if block.settings.institution_2_logo %}
                                <img src="{{ block.settings.institution_2_logo | image_url: width: 48 }}" 
                                     alt="{{ block.settings.institution_2_text }}"
                                     style="width: 24px; height: 24px; object-fit: contain;">
                              {% endif %}
                              {% if block.settings.institution_2_text != blank %}
                                <span class="{{ section.settings.institution_font_family | default: 'font-body' }} {{ section.settings.institution_font_size | default: 'text-sm' }} {{ section.settings.institution_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.institution_font_weight | default: 'font-normal' }} {{ section.settings.institution_color | default: 'text-neutral-dark' }}">
                                  {{ block.settings.institution_2_text }}
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>

                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>

            <!-- Navigation Controls -->
            <div class="experts-carousel__controls">
              <!-- Prev/Next Buttons -->
              <div class="experts-carousel__nav-buttons">
                <button class="experts-carousel__nav experts-carousel__nav--prev" 
                        aria-label="Previous expert"
                        data-carousel-prev="{{ section.id }}">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>

                <button class="experts-carousel__nav experts-carousel__nav--next" 
                        aria-label="Next expert"
                        data-carousel-next="{{ section.id }}">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>

          </div>
        {% endif %}

      </div>

    </div>
  </div>
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const track = document.querySelector(`[data-carousel-track="${sectionId}"]`);
  const prevBtn = document.querySelector(`[data-carousel-prev="${sectionId}"]`);
  const nextBtn = document.querySelector(`[data-carousel-next="${sectionId}"]`);
  
  if (!track || !prevBtn || !nextBtn) return;
  
  const cards = track.querySelectorAll('.experts-carousel__expert-card');
  let currentIndex = 0;
  
  function updateCarousel() {
    const cardWidth = cards[0].offsetWidth;
    const gap = 32; // Matches gap-xl
    const offset = currentIndex * (cardWidth + gap);
    
    track.style.transform = `translateX(-${offset}px)`;
    
    // Update button states
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex >= cards.length - 1;
  }
  
  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  });
  
  nextBtn.addEventListener('click', () => {
    if (currentIndex < cards.length - 1) {
      currentIndex++;
      updateCarousel();
    }
  });
  
  // Reset on resize
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      updateCarousel();
    }, 250);
  });
  
  // Initialize
  updateCarousel();
  
  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });
  
  track.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  });
  
  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        // Swipe left - next
        nextBtn.click();
      } else {
        // Swipe right - prev
        prevBtn.click();
      }
    }
  }
})();
</script>

