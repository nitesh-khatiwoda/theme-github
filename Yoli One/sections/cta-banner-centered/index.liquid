<link rel="stylesheet" href="{{ 'cta-banner-centered/styles.css' | asset_url }}">

<!-- CTA Banner Centered Section -->
<section class="cta-banner-centered {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }}">
  <div class="cta-banner-centered__container">
    <div class="cta-banner-centered__wrapper {{ section.settings.banner_border_radius | default: 'rounded-lg' }}">
      
      <!-- Background Image -->
      <div class="cta-banner-centered__background" {% if section.settings.background_image %}style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');"{% endif %}>
        {% if section.settings.background_image == blank %}
          <img src="{{ 'placeholder-image.png' | asset_url }}" 
               alt="Banner background"
               class="cta-banner-centered__placeholder">
        {% endif %}
      </div>
      
      <!-- Content Overlay -->
      <div class="cta-banner-centered__content">
        
        <!-- Eyebrow -->
        {% if section.settings.eyebrow != blank %}
          <p class="cta-banner-centered__eyebrow {{ section.settings.eyebrow_font_family | default: 'font-body' }} {{ section.settings.eyebrow_font_size | default: 'text-sm' }} {{ section.settings.eyebrow_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.eyebrow_font_weight | default: 'font-normal' }} {{ section.settings.eyebrow_color | default: 'text-white' }}">
            {{ section.settings.eyebrow }}
          </p>
        {% endif %}
        
        <!-- Heading -->
        {% if section.settings.heading != blank %}
          <h2 class="cta-banner-centered__heading {{ section.settings.heading_font_family | default: 'font-body' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }}">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
        
      </div>
      
    </div>
  </div>
</section>

