<!-- Modular Tabs Section -->
<section class="modular-tabs-section {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }} {{ section.settings.background_color }}" 
         id="{{ section.id }}"
         {% if section.settings.background_image != blank %}
         style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
         {% endif %}>
  
  <div class="container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius }} {{ section.settings.container_padding_y_mobile }} {{ section.settings.container_padding_y_desktop }} {{ section.settings.container_padding_x_mobile }} {{ section.settings.container_padding_x_desktop }}"
       {% if section.settings.container_background_image != blank %}
       style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1200 }}');"
       {% endif %}>
    
    <!-- Section Header -->
    {% if section.settings.show_section_header %}
      <div class="section-header {{ section.settings.header_text_align }} {{ section.settings.heading_margin_bottom }}">
        {% if section.settings.section_heading != blank %}
          <div class="heading-wrapper {{ section.settings.heading_margin_bottom }}">
            <h2 class="section-heading {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_desktop }} {{ section.settings.heading_font_weight }} {{ section.settings.heading_line_height }} {{ section.settings.heading_text_color | default: 'text-black' }}">
              {{ section.settings.section_heading }}
            </h2>
          </div>
        {% endif %}
        
        {% if section.settings.section_description != blank %}
          <div class="description-wrapper">
            <p class="section-description {{ section.settings.description_font_size }} {{ section.settings.description_font_size_desktop }} {{ section.settings.description_line_height }} {{ section.settings.description_text_color | default: 'text-neutral' }}">
              {{ section.settings.section_description }}
            </p>
          </div>
        {% endif %}
      </div>
    {% endif %}
    
    <!-- Navigation Tabs -->
    {% if section.settings.show_navigation %}
      <div class="navigation-wrapper">
        
        <!-- Desktop Tab Navigation -->
        <nav class="tab-navigation desktop-tabs {{ section.settings.nav_text_align }}" role="tablist">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'tab_content' %}
                <button class="nav-tab {{ section.settings.nav_font_size }} {{ section.settings.nav_font_weight }} {{ section.settings.nav_text_color }} {{ section.settings.nav_padding }} {{ section.settings.nav_background_color }} {% if forloop.first %}active{% endif %}" 
                        data-tab="tab-{{ forloop.index }}"
                        data-active-bg="{{ section.settings.nav_active_background_color }}"
                        data-active-text="{{ section.settings.nav_active_text_color }}"
                        data-inactive-bg="{{ section.settings.nav_background_color }}"
                        data-inactive-text="{{ section.settings.nav_text_color }}"
                        onclick="switchTab(this, 'tab-{{ forloop.index }}')"
                        role="tab"
                        aria-controls="tabpanel-{{ forloop.index }}"
                        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                        tabindex="0">
                  {{ block.settings.tab_title }}
                </button>
            {% endcase %}
          {% endfor %}
        </nav>
        
        <!-- Mobile/Tablet Dropdown Navigation -->
        <div class="mobile-tab-dropdown">
          <button class="dropdown-toggle {{ section.settings.nav_font_size }} {{ section.settings.nav_font_weight }} {{ section.settings.nav_text_color }} {{ section.settings.nav_padding }} {{ section.settings.nav_active_background_color }}" 
                  onclick="toggleDropdown(this)"
                  aria-expanded="false"
                  aria-haspopup="true">
            <span class="dropdown-text">{{ section.blocks.first.settings.tab_title }}</span>
            <svg class="dropdown-arrow" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <path d="M4.427 6.427L8 10l3.573-3.573a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 1 1 .708-.708z"/>
            </svg>
          </button>
          
          <div class="dropdown-menu {{ section.settings.card_background_color }}" role="menu">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'tab_content' %}
                  <button class="dropdown-item {{ section.settings.nav_font_size }} {{ section.settings.nav_font_weight }} {{ section.settings.nav_text_color }} {{ section.settings.nav_padding }} {% if forloop.first %}active{% endif %}"
                          data-tab="tab-{{ forloop.index }}"
                          data-active-bg="{{ section.settings.nav_active_background_color }}"
                          data-active-text="{{ section.settings.nav_active_text_color }}"
                          data-inactive-bg="{{ section.settings.nav_background_color }}"
                          data-inactive-text="{{ section.settings.nav_text_color }}"
                          onclick="selectDropdownItem(this, 'tab-{{ forloop.index }}')"
                          role="menuitem">
                    {{ block.settings.tab_title }}
                  </button>
              {% endcase %}
            {% endfor %}
          </div>
        </div>
        
      </div>
    {% endif %}
    
    <!-- Tab Content Cards -->
    <div class="tab-content-wrapper">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'tab_content' %}
            <div class="tab-content-card {{ section.settings.card_background_color }} {{ section.settings.card_padding }} {% if forloop.first %}active{% endif %}" 
                 id="tabpanel-{{ forloop.index }}"
                 data-tab="tab-{{ forloop.index }}"
                 data-block-id="{{ block.id }}"
                 role="tabpanel"
                 aria-labelledby="tab-{{ forloop.index }}"
                 {{ block.fluid_attributes }}>
              
              <div class="card-content-grid">
                
                <!-- Text Content -->
                <div class="text-content">
                  
                  <!-- Star Rating -->
                  {% if block.settings.show_rating %}
                    <div class="testimonial-rating {{ section.settings.tag_margin_bottom }}">
                      {% assign rating = block.settings.rating | default: 5 %}
                      {% for i in (1..5) %}
                        <svg class="star-icon" width="24" height="24" viewBox="0 0 24 24" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1">
                          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                        </svg>
                      {% endfor %}
                    </div>
                  {% endif %}
                  
                  <!-- Testimonial Quote -->
                  {% if block.settings.testimonial_text != blank %}
                    <blockquote class="testimonial-quote {{ section.settings.content_description_font_size }} {{ section.settings.content_description_font_size_desktop }} {{ section.settings.content_description_line_height }} {{ block.settings.description_text_color | default: section.settings.content_text_color | default: 'text-neutral-dark' }}">
                      "{{ block.settings.testimonial_text }}"
                    </blockquote>
                  {% endif %}
                  
                  <!-- Author Info -->
                  {% if block.settings.author_name != blank %}
                    <div class="testimonial-author {{ section.settings.content_heading_font_size }} {{ section.settings.content_heading_font_weight }} {{ block.settings.heading_text_color | default: section.settings.content_text_color | default: 'text-black' }}">
                      {{ block.settings.author_name }}
                    </div>
                  {% endif %}
                  
                </div>
                
                <!-- Media Content (Before/After or Single Image) -->
                <div class="media-content">
                  {% if block.settings.media_type == 'before_after' and block.settings.before_image != blank and block.settings.after_image != blank %}
                    <!-- Before/After Images -->
                    <div class="before-after-wrapper {{ section.settings.image_border_radius }}">
                      <div class="before-after-image">
                        <div class="before-after-label before-label">{{ block.settings.before_label | default: 'Before' }}</div>
                        <img src="{{ block.settings.before_image | image_url: width: 600 }}"
                             alt="Before - {{ block.settings.author_name }}"
                             class="content-media"
                             loading="lazy">
                      </div>
                      <div class="before-after-image">
                        <div class="before-after-label after-label">{{ block.settings.after_label | default: 'After' }}</div>
                        <img src="{{ block.settings.after_image | image_url: width: 600 }}"
                             alt="After - {{ block.settings.author_name }}"
                             class="content-media"
                             loading="lazy">
                      </div>
                    </div>
                  {% elsif block.settings.media_type == 'image' and block.settings.content_image != blank %}
                    <!-- Single Image -->
                    <div class="media-wrapper {{ section.settings.image_border_radius }}">
                      <img src="{{ block.settings.content_image | image_url: width: 600 }}"
                           alt="{{ block.settings.author_name }}"
                           class="content-media content-image"
                           loading="lazy">
                    </div>
                  {% else %}
                    <!-- Placeholder -->
                    <div class="media-wrapper {{ section.settings.image_border_radius }}">
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Placeholder media for {{ block.settings.tab_title }}"
                           class="content-media content-image"
                           loading="lazy">
                    </div>
                  {% endif %}
                </div>
                
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    
  </div>
</section>

<!-- Tab Switching JavaScript -->
<script>
  // Switch between tabs
  function switchTab(button, tabId) {
    const section = button.closest('.modular-tabs-section');
    const allTabs = section.querySelectorAll('.nav-tab');
    const allContent = section.querySelectorAll('.tab-content-card');
    
    // Remove active class and colors from all tabs and content
    allTabs.forEach(tab => {
      tab.classList.remove('active');
      tab.setAttribute('aria-selected', 'false');
      
      // Remove active colors
      const activeBg = tab.getAttribute('data-active-bg');
      const activeText = tab.getAttribute('data-active-text');
      if (activeBg) tab.classList.remove(activeBg);
      if (activeText) tab.classList.remove(activeText);
      
      // Restore original inactive colors
      const inactiveBg = tab.getAttribute('data-inactive-bg');
      const inactiveText = tab.getAttribute('data-inactive-text');
      if (inactiveBg && inactiveBg !== '' && !tab.classList.contains(inactiveBg)) {
        tab.classList.add(inactiveBg);
      }
      if (inactiveText && inactiveText !== '' && !tab.classList.contains(inactiveText)) {
        tab.classList.add(inactiveText);
      }
    });
    
    allContent.forEach(content => {
      content.classList.remove('active');
    });
    
    // Add active class to clicked tab and corresponding content
    button.classList.add('active');
    button.setAttribute('aria-selected', 'true');
    
    // Apply active colors
    const activeBg = button.getAttribute('data-active-bg');
    const activeText = button.getAttribute('data-active-text');
    if (activeBg) button.classList.add(activeBg);
    if (activeText) button.classList.add(activeText);
    
    const targetContent = section.querySelector(`.tab-content-card[data-tab="${tabId}"]`);
    if (targetContent) {
      targetContent.classList.add('active');
    }
    
    // Log for analytics
    console.log('Tab switched to:', tabId);
  }
  
  // Switch to tab when block is selected in Shopify theme editor
  function switchToTabByBlockId(blockId) {
    const section = document.querySelector('.modular-tabs-section');
    if (!section) return;
    
    const targetContent = section.querySelector(`.tab-content-card[data-block-id="${blockId}"]`);
    if (!targetContent) return;
    
    const tabId = targetContent.getAttribute('data-tab');
    const targetButton = section.querySelector(`.nav-tab[data-tab="${tabId}"]`);
    
    if (targetButton && tabId) {
      switchTab(targetButton, tabId);
    }
  }
  
  // Toggle dropdown menu
  function toggleDropdown(button) {
    const dropdown = button.closest('.mobile-tab-dropdown');
    const menu = dropdown.querySelector('.dropdown-menu');
    const arrow = dropdown.querySelector('.dropdown-arrow');
    const isOpen = button.getAttribute('aria-expanded') === 'true';
    
    if (isOpen) {
      // Close dropdown
      button.setAttribute('aria-expanded', 'false');
      menu.classList.remove('open');
      arrow.style.transform = 'rotate(0deg)';
    } else {
      // Open dropdown
      button.setAttribute('aria-expanded', 'true');
      menu.classList.add('open');
      arrow.style.transform = 'rotate(180deg)';
    }
  }
  
  // Select dropdown item and switch tab
  function selectDropdownItem(item, tabId) {
    const dropdown = item.closest('.mobile-tab-dropdown');
    const toggle = dropdown.querySelector('.dropdown-toggle');
    const toggleText = toggle.querySelector('.dropdown-text');
    const menu = dropdown.querySelector('.dropdown-menu');
    const arrow = dropdown.querySelector('.dropdown-arrow');
    const section = item.closest('.modular-tabs-section');
    
    // Update dropdown text
    toggleText.textContent = item.textContent;
    
    // Close dropdown
    toggle.setAttribute('aria-expanded', 'false');
    menu.classList.remove('open');
    arrow.style.transform = 'rotate(0deg)';
    
    // Update active states in dropdown
    const allDropdownItems = dropdown.querySelectorAll('.dropdown-item');
    allDropdownItems.forEach(dropdownItem => {
      dropdownItem.classList.remove('active');
      const activeBg = dropdownItem.getAttribute('data-active-bg');
      const activeText = dropdownItem.getAttribute('data-active-text');
      if (activeBg) dropdownItem.classList.remove(activeBg);
      if (activeText) dropdownItem.classList.remove(activeText);
      
      // Restore original inactive colors
      const inactiveBg = dropdownItem.getAttribute('data-inactive-bg');
      const inactiveText = dropdownItem.getAttribute('data-inactive-text');
      if (inactiveBg && inactiveBg !== '' && !dropdownItem.classList.contains(inactiveBg)) {
        dropdownItem.classList.add(inactiveBg);
      }
      if (inactiveText && inactiveText !== '' && !dropdownItem.classList.contains(inactiveText)) {
        dropdownItem.classList.add(inactiveText);
      }
    });
    
    item.classList.add('active');
    const activeBg = item.getAttribute('data-active-bg');
    const activeText = item.getAttribute('data-active-text');
    if (activeBg) item.classList.add(activeBg);
    if (activeText) item.classList.add(activeText);
    
    // Switch tab content (reuse existing function logic)
    const allContent = section.querySelectorAll('.tab-content-card');
    allContent.forEach(content => {
      content.classList.remove('active');
    });
    
    const targetContent = section.querySelector(`.tab-content-card[data-tab="${tabId}"]`);
    if (targetContent) {
      targetContent.classList.add('active');
    }
    
    // Log for analytics
    console.log('Tab switched via dropdown to:', tabId);
  }
  
  // Initialize tabs on page load
  document.addEventListener('DOMContentLoaded', function() {
    const sections = document.querySelectorAll('.modular-tabs-section');
    
    sections.forEach(section => {
      const tabs = section.querySelectorAll('.nav-tab');
      
      // Initialize active tab colors
      const activeTab = section.querySelector('.nav-tab.active');
      if (activeTab) {
        const activeBg = activeTab.getAttribute('data-active-bg');
        const activeText = activeTab.getAttribute('data-active-text');
        if (activeBg) activeTab.classList.add(activeBg);
        if (activeText) activeTab.classList.add(activeText);
      }
      
      // Add keyboard navigation
      tabs.forEach((tab, index) => {
        tab.addEventListener('keydown', function(e) {
          let newIndex = index;
          
          switch(e.key) {
            case 'ArrowLeft':
              e.preventDefault();
              newIndex = index > 0 ? index - 1 : tabs.length - 1;
              break;
            case 'ArrowRight':
              e.preventDefault();
              newIndex = index < tabs.length - 1 ? index + 1 : 0;
              break;
            case 'Home':
              e.preventDefault();
              newIndex = 0;
              break;
            case 'End':
              e.preventDefault();
              newIndex = tabs.length - 1;
              break;
            default:
              return;
          }
          
          const targetTab = tabs[newIndex];
          const tabId = targetTab.getAttribute('data-tab');
          switchTab(targetTab, tabId);
          targetTab.focus();
        });
      });
    });
    
    // Close dropdowns when clicking outside
    document.addEventListener('click', function(e) {
      const dropdowns = document.querySelectorAll('.mobile-tab-dropdown');
      dropdowns.forEach(dropdown => {
        if (!dropdown.contains(e.target)) {
          const toggle = dropdown.querySelector('.dropdown-toggle');
          const menu = dropdown.querySelector('.dropdown-menu');
          const arrow = dropdown.querySelector('.dropdown-arrow');
          
          toggle.setAttribute('aria-expanded', 'false');
          menu.classList.remove('open');
          arrow.style.transform = 'rotate(0deg)';
        }
      });
    });
    
    console.log('Modular tabs section initialized');
  });
  
  // Shopify theme editor integration
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    // Listen for block selection events in the theme editor
    document.addEventListener('shopify:block:select', function(event) {
      const blockId = event.detail.blockId;
      console.log('Block selected in theme editor:', blockId);
      
      // Switch to the corresponding tab
      setTimeout(() => {
        switchToTabByBlockId(blockId);
      }, 100); // Small delay to ensure DOM is ready
    });
    
    // Listen for section load events
    document.addEventListener('shopify:section:load', function(event) {
      if (event.target.classList.contains('modular-tabs-section')) {
        console.log('Modular tabs section loaded in theme editor');
        
        // Re-initialize tabs after section reload
        setTimeout(() => {
          const sections = document.querySelectorAll('.modular-tabs-section');
          sections.forEach(section => {
            const tabs = section.querySelectorAll('.nav-tab');
            
            tabs.forEach((tab, index) => {
              tab.addEventListener('keydown', function(e) {
                let newIndex = index;
                
                switch(e.key) {
                  case 'ArrowLeft':
                    e.preventDefault();
                    newIndex = index > 0 ? index - 1 : tabs.length - 1;
                    break;
                  case 'ArrowRight':
                    e.preventDefault();
                    newIndex = index < tabs.length - 1 ? index + 1 : 0;
                    break;
                  case 'Home':
                    e.preventDefault();
                    newIndex = 0;
                    break;
                  case 'End':
                    e.preventDefault();
                    newIndex = tabs.length - 1;
                    break;
                  default:
                    return;
                }
                
                const targetTab = tabs[newIndex];
                const tabId = targetTab.getAttribute('data-tab');
                switchTab(targetTab, tabId);
                targetTab.focus();
              });
            });
          });
        }, 100);
      }
    });
    
    console.log('Shopify theme editor integration enabled');
  }
</script>

