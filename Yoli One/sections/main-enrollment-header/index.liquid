<link rel="stylesheet" href="{{ 'main-enrollment-header/styles.css' | asset_url }}">

<!-- Enrollment Pack Header Section -->
<section class="enrollment-header {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="enrollment-header-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="enrollment-header-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-md' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="product-layout">
        
        <!-- Left Column: Media Gallery -->
        <div class="media-column">
          
          <!-- Hero Media (Video or Image) -->
          <div class="hero-media">
            {% if section.settings.hero_video != blank %}
              <video autoplay loop muted playsinline>
                <source src="{{ section.settings.hero_video }}" type="video/mp4">
              </video>
            {% elsif section.settings.hero_image != blank %}
              <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" alt="{{ section.settings.hero_image_alt | default: 'Enrollment pack hero' }}" loading="eager" class="clickable-image" data-full-src="{{ section.settings.hero_image | image_url: width: 1600 }}" data-section-id="{{ section.id }}">
            {% elsif images_array.size > 0 %}
              <img src="{{ images_array.first }}" alt="{{ title }}" loading="eager" class="clickable-image" data-full-src="{{ images_array.first }}" data-section-id="{{ section.id }}">
            {% else %}
              <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
            {% endif %}
          </div>
         
          {% assign images_array = images | parse_json %}
          {% if images_array.size > 0 %}
            <div class="gallery-grid">
            {% for image in images_array %}
              <div class="gallery-item">
                <img src="{{ image.url | image_url: width: 500 }}" loading="lazy" class="clickable-image" data-section-id="{{ section.id }}" data-full-src="{{ image.url | image_url: width: 1600 }}">
              </div>
            {% endfor %}
            </div>
          {% endif %}
          
        </div>
        
        <!-- Right Column: Enrollment Pack Info (Sticky) -->
        <div 
          class="info-column"
          id='enrollment-form'
          data-fluid-checkout-group
          data-enrollment-pack='{{ enrollment_pack.id }}'
        >
          <div class="info-sticky">
            
            <!-- Product Title with Code -->
            <div class="product-title-wrapper">
              {% if section.settings.product_code != blank %}
              <div class="product-code-badge">
                <span class="{{ section.settings.code_font_size | default: 'text-base' }} {{ section.settings.code_color | default: 'text-primary' }}">
                  {{ section.settings.product_code }}<sup>{{ section.settings.code_superscript | default: '™' }}</sup>
                </span>
              </div>
              {% endif %}
              
             
              <h1 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-primary' }} leading-heading">
                {{ title }}
              </h1>
             
            </div>
            
            <!-- Rating & Reviews -->
            {% if section.settings.show_rating %}
            <div class="rating-wrapper">
              <div class="stars">
                {% if section.settings.stars_image != blank %}
                  <img src="{{ section.settings.stars_image | image_url: width: 100 | default: 'placeholder-image.png' | asset_url }}" alt="Star rating" loading="lazy" style="width: 88px; height: 16px;">
                {% else %}
                  <div class="flex">
                  {% for i in (1..5) %}
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" class="{{ section.settings.star_color | default: 'text-quaternary' }}">
                      <path d="M9 0L11.0206 6.90983H18.5595L12.7694 11.1803L14.7901 18.0902L9 13.8197L3.20993 18.0902L5.23058 11.1803L-0.559492 6.90983H6.97937L9 0Z"/>
                    </svg>
                  {% endfor %}
                </div>
              {% endif %}
              </div>

              <div class="rating-text">
                <span class="{{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                  {{ section.settings.rating_value | default: '4.8' }} •
                </span>
              </div>
              {% if section.settings.show_reviews_link %}
              <a href="{{ section.settings.reviews_link | default: '#reviews' }}" class="reviews-link {{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                {{ section.settings.reviews_text | default: '18 Reviews' }}
              </a>
              {% endif %}
            </div>
            {% endif %}
            
            <!-- Product Description -->
            {% if description != blank %}
            <div class="product-description">
              <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
                {{ description }}
              </p>
            </div>
            {% endif %}
            
            <!-- Price Section -->
            {% assign membership_product = membership_products.first %}
            {% if membership_product %}
            <div class="price-section">
              <span class="price {{ section.settings.price_font_family | default: 'font-primary' }} {{ section.settings.price_font_size | default: 'text-xl' }} {{ section.settings.price_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.price_font_weight | default: 'font-normal' }} {{ section.settings.price_color | default: 'text-primary' }}">
                {{ membership_product.price }}
              </span>
              
              {% if section.settings.show_new_badge %}
              <span class="new-badge" style="background-color: {{ section.settings.badge_background | default: '#d3fa99' }}">
                <span class="{{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-primary' }}">
                  {{ section.settings.badge_text | default: 'New' }}
                </span>
              </span>
              {% endif %}
            </div>
            {% endif %}
            
            <!-- Enrollment Pack Info -->
            {% if section.settings.enrollment_info != blank %}
            <div class="subscription-info">
              <p class="{{ section.settings.enrollment_info_font_size | default: 'text-sm' }} {{ section.settings.enrollment_info_color | default: 'text-primary' }} leading-body">
                {{ section.settings.enrollment_info }}
              </p>
            </div>
            {% endif %}

            <!-- Included Products Section -->
            {% if subscription_products.size > 0 %}
            <div class="included-products-wrapper">
              <h3 class="{{ section.settings.included_title_font_size | default: 'text-lg' }} {{ section.settings.included_title_color | default: 'text-primary' }} {{ section.settings.included_title_font_weight | default: 'font-semibold' }}">
                {{ section.settings.included_products_title | default: 'Included in this pack:' }}
              </h3>
              
              <div class="included-products-list">
                {% for product in subscription_products %}
                <div class="included-product-card {{ section.settings.card_background | default: 'bg-card-primary' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                  <div class="product-card-image">
                    {% if product.image != blank %}
                      <img src="{{ product.image }}" alt="{{ product.title }}" loading="lazy">
                    {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Product">
                    {% endif %}
                  </div>
                  <div class="product-card-content">
                    <h4 class="{{ section.settings.card_title_font_size | default: 'text-base' }} {{ section.settings.card_title_color | default: 'text-primary' }} {{ section.settings.card_title_font_weight | default: 'font-medium' }}">
                      {{ product.title }}
                    </h4>
                    <p class="product-card-price {{ section.settings.card_price_font_size | default: 'text-sm' }} {{ section.settings.card_price_color | default: 'text-primary' }}">
                      {{ product.price }}
                    </p>
                    {% if section.settings.show_learn_more %}
                    <a href="{{ product.learn_more_path }}" class="learn-more-link {{ section.settings.learn_more_font_size | default: 'text-sm' }} {{ section.settings.learn_more_color | default: 'text-info' }}">
                      {{ section.settings.learn_more_text | default: 'Learn more →' }}
                    </a>
                    {% endif %}
                  </div>
                </div>
                {% endfor %}
              </div>
            </div>
            {% endif %}
            
            <!-- Checkout Button -->
            <div class="btn-section">
              <button
                type="button"
                class='w-full btn btn-{{ section.settings.cart_button_style }}-{{section.settings.cart_button_color }} {{ section.settings.cart_button_size }} {{section.settings.cart_button_font_weight }} {{ section.settings.cart_button_border_radius }}'
                data-fluid-add-enrollment-pack="{{ enrollment_pack.id }}"
              >
                {{ section.settings.button_text | default: 'Checkout' }}
              </button>
            </div>
            
            <!-- Guarantee Text -->
            {% if section.settings.guarantee_text != blank %}
            <div class="guarantee-text">
              <p class="{{ section.settings.guarantee_font_size | default: 'text-sm' }} {{ section.settings.guarantee_color | default: 'text-neutral' }} leading-body">
                {{ section.settings.guarantee_text }}
              </p>
            </div>
            {% endif %}
            
            <!-- Accordions -->
            <div class="accordions-wrapper">
              
              <!-- Benefits Accordion -->
              {% assign benefit_blocks = section.blocks | where: "type", "benefit_item" %}
              {% if benefit_blocks.size > 0 %}
              <div class="accordion-item">
                <button class="accordion-header" onclick="this.parentElement.classList.toggle('active')">
                  <span class="{{ section.settings.accordion_font_size | default: 'text-base' }} {{ section.settings.accordion_color | default: 'text-primary' }}">
                    {{ section.settings.benefits_title | default: 'Benefits*' }}
                  </span>
                  <svg class="accordion-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M19 9L12 16L5 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="accordion-content hidden">
                  <ul class="benefits-list">
                    {% for block in benefit_blocks %}
                      {% if block.settings.benefit_text != blank %}
                      <li class="{{ section.settings.benefit_font_size | default: 'text-base' }} {{ section.settings.benefit_color | default: 'text-primary' }}" {{ block.fluid_attributes }}>
                        {{ block.settings.benefit_text }}
                      </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>
              </div>
              {% endif %}
              
              <!-- Details Accordion -->
              {% if section.settings.show_details %}
              <div class="accordion-item">
                <button class="accordion-header" onclick="this.parentElement.classList.toggle('active')">
                  <span class="{{ section.settings.accordion_font_size | default: 'text-base' }} {{ section.settings.accordion_color | default: 'text-primary' }}">
                    {{ section.settings.details_title | default: 'Details' }}
                  </span>
                  <svg class="accordion-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M19 9L12 16L5 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="accordion-content hidden">
                  {% if section.settings.details_content != blank %}
                  <div class="details-content {{ section.settings.details_font_size | default: 'text-sm' }} {{ section.settings.details_color | default: 'text-primary' }}">
                    {{ section.settings.details_content }}
                  </div>
                  {% endif %}
                </div>
              </div>
              {% endif %}
              
            </div>
            
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
  
  <!-- Sticky Footer (appears on scroll) -->
  {% if section.settings.show_sticky_footer %}
  <div class="sticky-footer" id="stickyFooter-{{ section.id }}">
    <div class="sticky-footer-content">
      <div class="sticky-product-info">
        {% if section.settings.hero_image != blank %}
        <div class="sticky-thumb">
          <img src="{{ section.settings.hero_image | image_url: width: 100 }}" alt="{{ title }}">
        </div>
        {% elsif images_array.size > 0 %}
        <div class="sticky-thumb">
          <img src="{{ images_array.first }}" alt="{{ title }}">
        </div>
        {% endif %}
        <div class="sticky-text">
          {% if section.settings.product_code != blank %}
          <span class="sticky-code {{ section.settings.sticky_code_font_size | default: 'text-sm' }} {{ section.settings.sticky_code_color | default: 'text-primary' }}">
            {{ section.settings.product_code }}<sup>{{ section.settings.code_superscript | default: '™' }}</sup>
          </span>
          {% endif %}
          <h3 class="{{ section.settings.sticky_title_font_size | default: 'text-lg' }} {{ section.settings.sticky_title_color | default: 'text-primary' }} leading-heading">
            {{ title }}
          </h3>
        </div>
      </div>
      <div class="sticky-cta">
        <button
          class='btn btn-{{ section.settings.cart_button_style }}-{{section.settings.cart_button_color }} {{ section.settings.sticky_button_size | default: 'btn-md' }} {{section.settings.cart_button_font_weight }} {{ section.settings.cart_button_border_radius }}'
          type='button'
          data-fluid-add-enrollment-pack="{{ enrollment_pack.id }}"
        >
          {{ section.settings.button_text | default: 'Checkout' }}
        </button>
      </div>
    </div>
  </div>
  {% endif %}
  
  <!-- Image Modal/Lightbox -->
  <div class="image-modal" id="imageModal-{{ section.id }}">
    <button class="modal-close" aria-label="Close modal" data-section-id="{{ section.id }}">&times;</button>
    <div class="modal-content product-gallery">
      <div class='splide main-slider'>
        <div class='splide__track'>
          <ul class='splide__list'>
            {% if section.settings.hero_image != blank %}
              <li class='splide__slide'>
                <div class="modal-main-image">
                  <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" alt="{{ section.settings.hero_image_alt | default: 'Enrollment pack hero' }}" loading="eager">
                </div>
              </li>
            {% endif %}
            {% if images_array.size > 0 %}
              {% for image in images_array %}
                <li class='splide__slide'>
                  <div class="modal-main-image">
                   <img src='{{ image.url }}' alt=''>
                  </div>
                </li>
              {% endfor %}
            {% endif %}
          </ul>
        </div>
      </div>

      <div  class='splide thumbnail-slider modal-thumbnails'>
        <div class='splide__track'>
          <ul class='splide__list'>
            {% if section.settings.hero_image != blank %}
              <li class='splide__slide'>
                <div class="modal-thumb">
                  <img src="{{ section.settings.hero_image}}" alt="{{ section.settings.hero_image_alt | default: 'Enrollment pack hero' }}">
                </div>
              </li>
            {% endif %}
            {% for image in images_array %}
              <li class='splide__slide'>
                <div class="modal-thumb">
                  <img src='{{ image.url }}' alt=''>
                </div>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
     
    </div>
  </div>
  
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  
  // Sticky Footer functionality
  const stickyFooter = document.getElementById('stickyFooter-' + sectionId);
  const productSection = document.getElementById('enrollment-header-' + sectionId);
  
  if (stickyFooter && productSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            stickyFooter.classList.remove('visible');
          } else {
            stickyFooter.classList.add('visible');
          }
        });
      },
      {
        threshold: 0,
        rootMargin: '-100px 0px 0px 0px'
      }
    );
    
    observer.observe(productSection);
  }
})();
</script>

<script>
  function slider() {
    if ($('.main-slider').length) {
      document.querySelectorAll('.product-gallery').forEach(function (gallery) {
        const mainSliderEl = gallery.querySelector('.main-slider');
        const thumbnailSliderEl = gallery.querySelector('.thumbnail-slider');
        if (!mainSliderEl) return;
        if (mainSliderEl.classList.contains('is-initialized')) return;
        const main = new Splide(mainSliderEl, {
          arrows: false,
          pagination: false,
          rewind: true,
        });
        if (thumbnailSliderEl) {
          const thumbnails = new Splide(thumbnailSliderEl, {
            start: 0,
            perPage: 3,
            gap: 12,
            rewind: true,
            pagination: false,
            arrows: false,
            isNavigation: true,
            mediaQuery: "min",
            fixedWidth: 80,
            fixedHeight: 80,
            breakpoints: {
              576: {
                perPage: 4
              },
            },
          });
          main.sync(thumbnails);
          thumbnails.mount();
          main.mount();
        }else {
          main.mount();
        }
      });
    }
  }
  document.addEventListener('DOMContentLoaded', function () {
    slider();
  })
</script>

{% schema %}
{
