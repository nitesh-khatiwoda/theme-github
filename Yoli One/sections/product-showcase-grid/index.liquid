<link rel="stylesheet" href="{{ 'product-showcase-grid/styles.css' | asset_url }}">

<!-- Product Showcase Grid Section -->
<section class="product-showcase-grid {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-3xl' }}" id="product-showcase-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-showcase-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading (Optional) -->
      {% if section.settings.heading != blank %}
      <div class="section-heading mb-xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading text-center leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Product Grid -->
      {% if section.blocks.size > 0 %}
      <div class="showcase-grid">
        {% for block in section.blocks %}
          {% if block.type == 'product_card' %}
          
          <div class="product-card {{ section.settings.card_background | default: 'bg-secondary-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}" {{ block.fluid_attributes }}>
            
            <!-- Product Image Container -->
            <div class="product-image-wrapper">
              <div class="product-image" 
                   data-hover-enabled="{% if block.settings.product_image_hover != blank %}true{% else %}false{% endif %}">
                {% if block.settings.product_image != blank %}
                  <img src="{{ block.settings.product_image | image_url: width: 400 }}" 
                       alt="{{ block.settings.product_name | default: 'Product' }}" 
                       loading="lazy"
                       class="product-image-default"
                       data-default-src="{{ block.settings.product_image | image_url: width: 400 }}"
                       {% if block.settings.product_image_hover != blank %}
                       data-hover-src="{{ block.settings.product_image_hover | image_url: width: 400 }}"
                       {% endif %}>
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder" loading="lazy" class="product-image-default">
                {% endif %}
              </div>
              
              <!-- New Badge (Optional) -->
              {% if block.settings.show_new_badge %}
              <div class="new-badge {{ block.settings.badge_background_color | default: 'bg-neutral-dark' }}">
                <span class="{{ section.settings.badge_text_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-white' }}">
                  {{ block.settings.badge_text | default: 'New' }}
                </span>
              </div>
              {% endif %}
            </div>
            
            <!-- Product Content -->
            <div class="product-content">
              
              <!-- Product Info -->
              <div class="product-info">
                
                <!-- Product Name -->
                {% if block.settings.product_name != blank %}
                <div class="product-name">
                  <h3 class="{{ block.settings.name_font_family | default: 'font-primary' }} {{ block.settings.name_font_size | default: 'text-xl' }} {{ block.settings.name_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.name_font_weight | default: 'font-semibold' }} {{ block.settings.name_color | default: 'text-primary' }} leading-heading">
                    {{ block.settings.product_name }}
                  </h3>
                </div>
                {% endif %}
                
                <!-- Product Description -->
                {% if block.settings.product_description != blank %}
                <div class="product-description">
                  <p class="{{ block.settings.description_font_family | default: 'font-body' }} {{ block.settings.description_font_size | default: 'text-base' }} {{ block.settings.description_font_weight | default: 'font-normal' }} {{ block.settings.description_color | default: 'text-primary' }} leading-body">
                    {{ block.settings.product_description }}
                  </p>
                </div>
                {% endif %}
              </div>
              
              <!-- Price Section -->
              <div class="product-pricing">
                
                <!-- Bundle Badge (Optional) -->
                {% if block.settings.show_bundle_badge %}
                <div class="bundle-badge {{ block.settings.bundle_badge_color | default: 'bg-success' }}">
                  <span class="{{ block.settings.bundle_badge_font_size | default: 'text-xs' }} {{ block.settings.bundle_badge_text_color | default: 'text-primary' }}">
                    {{ block.settings.bundle_badge_text | default: 'Bundle + Save 25%' }}
                  </span>
                </div>
                {% endif %}
                
                <!-- Price Display -->
                {% if block.settings.product_price != blank %}
                <div class="price-wrapper">
                  <span class="current-price {{ block.settings.price_font_family | default: 'font-primary' }} {{ block.settings.price_font_size | default: 'text-lg' }} {{ block.settings.price_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.price_font_weight | default: 'font-normal' }} {{ block.settings.price_color | default: 'text-primary' }}">
                    {{ block.settings.product_price }}
                  </span>
                  
                  <!-- Original Price (Optional) -->
                  {% if block.settings.show_original_price and block.settings.original_price != blank %}
                  <span class="original-price {{ block.settings.original_price_font_size | default: 'text-base' }} {{ block.settings.original_price_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.original_price_color | default: 'text-neutral' }}">
                    {{ block.settings.original_price }}
                  </span>
                  {% endif %}
                </div>
                {% endif %}
              </div>
              
              <!-- CTAs -->
              <div class="product-ctas">
                <!-- Primary CTA (Learn More) -->
                {% if block.settings.show_primary_button %}
                <a href="{{ block.settings.primary_button_url | default: '#' }}" class="btn btn-{{ section.settings.primary_button_style | default: 'filled' }}-{{ section.settings.primary_button_color | default: 'primary' }} {{ section.settings.primary_button_size | default: 'btn-md' }}">
                  {{ block.settings.primary_button_text | default: 'Learn More' }}
                </a>
                {% endif %}
                
                <!-- Secondary CTA (Add to Cart) -->
                {% if block.settings.show_secondary_link %}
                <a href="{{ block.settings.secondary_link_url | default: '#' }}" class="secondary-link {{ block.settings.secondary_link_font_size | default: 'text-base' }} {{ block.settings.secondary_link_color | default: 'text-primary' }}">
                  {{ block.settings.secondary_link_text | default: 'Add to Cart' }}
                </a>
                {% endif %}
              </div>
              
            </div>
            
          </div>
          
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

<script>
// Product Showcase Grid - Hover Image Swap
document.addEventListener('DOMContentLoaded', function() {
  const productImages = document.querySelectorAll('.product-showcase-grid .product-image[data-hover-enabled="true"] img[data-hover-src]');

  productImages.forEach(img => {
    const defaultSrc = img.getAttribute('data-default-src');
    const hoverSrc = img.getAttribute('data-hover-src');

    if (hoverSrc) {
      const productCard = img.closest('.product-card');
      
      productCard.addEventListener('mouseenter', () => {
        img.src = hoverSrc;
      });

      productCard.addEventListener('mouseleave', () => {
        img.src = defaultSrc;
      });
    }
  });
});
</script>

