<link rel="stylesheet" href="{{ 'best-sellers-carousel/styles.css' | asset_url }}">

<section 
  class="best-sellers-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="best-sellers-carousel-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <!-- Header Container (broken out, no container wrapper) -->
  
  <div class="best-sellers-carousel-header-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
    {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
    <div class="{{ section.settings.container_layout_width | default: 'container' }}">
      <!-- Header with Title and Shop All Button -->
      {% if section.settings.title != blank or section.settings.show_shop_all_button %}
        <div class="best-sellers-carousel-header">
          <div class="best-sellers-carousel-header-content">
          {% if section.settings.title != blank %}
          <div class="best-sellers-carousel-title-wrapper">
            <h2 class="best-sellers-carousel-title {{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color | default: 'text-black' }}">
              {{ section.settings.title }}
            </h2>
          </div>
          {% endif %}
          
          {% if section.settings.show_shop_all_button %}
          <a href="{{ section.settings.shop_all_url | default: '#' }}" 
             class="btn btn-{{ section.settings.shop_all_button_style | default: 'filled' }}-{{ section.settings.shop_all_button_color | default: 'black' }} {{ section.settings.shop_all_button_size | default: 'btn-md' }} {{ section.settings.shop_all_button_font_weight | default: 'font-medium' }} font-body {{ settings.button_border_radius | default: 'rounded' }}">
            {{ section.settings.shop_all_button_text | default: 'Shop All' }}
          </a>
          {% endif %}
        </div>
        </div>
      {% endif %}
    </div>
  </div>
  
  <!-- Carousel Container (broken out, same structure as header) -->
  {% if section.blocks.size > 0 %}
    <div class="{{ section.settings.container_layout_width | default: 'container' }}">
      <div class="best-sellers-carousel-wrapper-container">
        <style>
          #best-sellers-carousel-{{ section.id }} .best-sellers-carousel-item {
            width: {{ section.settings.card_width_mobile | default: 280 }}px;
          }
          @media (min-width: 640px) {
            #best-sellers-carousel-{{ section.id }} .best-sellers-carousel-item {
              width: {{ section.settings.card_width_tablet | default: 320 }}px;
            }
          }
          @media (min-width: 1024px) {
            #best-sellers-carousel-{{ section.id }} .best-sellers-carousel-item {
              width: {{ section.settings.card_width_desktop | default: 360 }}px;
            }
          }
        </style>
        <div class="best-sellers-carousel-wrapper">
        
        <!-- Carousel Container -->
        <div class="best-sellers-carousel-container {% unless section.settings.clip_overflow %}best-sellers-carousel-no-clip{% endunless %}" data-carousel-container="{{ section.id }}">
              
          <!-- Carousel Track -->
          <div class="best-sellers-carousel-track {{ section.settings.carousel_card_gap | default: 'gap-md' }}" data-carousel-track="{{ section.id }}">
            
            {%- comment -%} BLOCK-BASED PRODUCTS - Each block represents one product {%- endcomment -%}
            {% for block in section.blocks %}
              {% if block.type == 'product_item' %}
                {%- assign product_slug = block.settings.product_slug -%}
                {%- assign product = blank -%}
                
                {%- if product_slug != blank -%}
                  {%- comment -%} Look up product by slug or ID in products array {%- endcomment -%}
                  {%- for p in products -%}
                    {%- if p.slug == product_slug or p.id == product_slug or p.id == product_slug | plus: 0 -%}
                      {%- assign product = p -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                
                {%- if product != blank -%}
                <div class="best-sellers-carousel-item" data-product-item="{{ section.id }}-{{ forloop.index0 }}" {{ block.fluid_attributes }}>
                  <a href="{{ product.url | default: '#' }}" class="best-sellers-product-link">
                    <div class="best-sellers-product-card {{ section.settings.product_card_border_radius | default: 'rounded-lg' }}">
                      
                      <!-- Product Image -->
                      <div class="best-sellers-product-image-wrapper">
                        {% if product.image_url != blank %}
                          <img
                            class="best-sellers-product-image"
                            src="{{ product.image_url }}"
                            alt="{{ product.title | default: 'Product' }}"
                            loading="lazy"
                            style="box-shadow: none !important;">
                        {% else %}
                          <img src="{{ 'placeholder-image.png' | asset_url }}"
                              alt="Placeholder"
                              loading="lazy"
                              class="best-sellers-product-image"
                              style="box-shadow: none !important;">
                        {% endif %}
                      </div>
                      
                      <!-- Product Info -->
                      <div class="best-sellers-product-info">
                        {% assign rating_pos = block.settings.rating_position | default: 'top' %}
                        
                        <!-- Rating and Reviews (Top Position) -->
                        {% if section.settings.show_stars and rating_pos == 'top' %}
                        <div class="best-sellers-product-rating">
                          <div class="best-sellers-stars-rating stars-size-{{ section.settings.star_size | default: 'medium' }}">
                            {% assign star_rating = block.settings.star_rating | default: 5 %}
                            {% assign full_stars = star_rating | floor %}
                            {% assign empty_stars = 5 | minus: full_stars %}
                            
                            {% if full_stars > 0 %}
                              {% for i in (1..full_stars) %}
                                <span class="best-sellers-star star-full {{ section.settings.star_color_filled | default: 'text-warning' }}">{{ section.settings.star_character | default: '★' }}</span>
                              {% endfor %}
                            {% endif %}
                            
                            {% if empty_stars > 0 %}
                              {% for i in (1..empty_stars) %}
                                <span class="best-sellers-star star-empty {{ section.settings.star_color_empty | default: 'text-neutral-light' }}">{{ section.settings.star_character | default: '★' }}</span>
                              {% endfor %}
                            {% endif %}
                          </div>
                          {% if block.settings.review_count != blank %}
                          <span class="best-sellers-review-text {{ section.settings.rating_text_font_family | default: 'font-body' }} {{ section.settings.rating_text_font_size | default: 'text-sm' }} {{ section.settings.rating_text_color | default: 'text-neutral-dark' }}">
                            {{ star_rating }} • ({{ block.settings.review_count }} Reviews)
                          </span>
                          {% endif %}
                        </div>
                        {% endif %}
                        
                        <!-- Product Title -->
                        {% if product.title != blank %}
                        <div class="best-sellers-product-title {{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-xl' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.product_title_font_weight | default: 'font-bold' }} {{ section.settings.product_title_color | default: 'text-black' }}">
                          {{ product.title }}
                        </div>
                        {% endif %}
                        
                        <!-- Product Description -->
                        {% if product.description != blank or block.settings.product_description != blank %}
                        <div class="best-sellers-product-description {{ section.settings.product_description_font_family | default: 'font-body' }} {{ section.settings.product_description_font_size | default: 'text-sm' }} {{ section.settings.product_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.product_description_font_weight | default: 'font-normal' }} {{ section.settings.product_description_color | default: 'text-neutral-dark' }}">
                          {{ product.description | default: block.settings.product_description }}
                        </div>
                        {% endif %}
                        
                        <!-- Rating and Reviews (Above Price Position) -->
                        {% if section.settings.show_stars and rating_pos == 'above_price' %}
                        <div class="best-sellers-product-rating">
                          <div class="best-sellers-stars-rating stars-size-{{ section.settings.star_size | default: 'medium' }}">
                            {% assign star_rating = block.settings.star_rating | default: 5 %}
                            {% assign full_stars = star_rating | floor %}
                            {% assign empty_stars = 5 | minus: full_stars %}
                            
                            {% if full_stars > 0 %}
                              {% for i in (1..full_stars) %}
                                <span class="best-sellers-star star-full {{ section.settings.star_color_filled | default: 'text-warning' }}">{{ section.settings.star_character | default: '★' }}</span>
                              {% endfor %}
                            {% endif %}
                            
                            {% if empty_stars > 0 %}
                              {% for i in (1..empty_stars) %}
                                <span class="best-sellers-star star-empty {{ section.settings.star_color_empty | default: 'text-neutral-light' }}">{{ section.settings.star_character | default: '★' }}</span>
                              {% endfor %}
                            {% endif %}
                          </div>
                          {% if block.settings.review_count != blank %}
                          <span class="best-sellers-review-text {{ section.settings.rating_text_font_family | default: 'font-body' }} {{ section.settings.rating_text_font_size | default: 'text-sm' }} {{ section.settings.rating_text_color | default: 'text-neutral-dark' }}">
                            {{ star_rating }} • ({{ block.settings.review_count }} Reviews)
                          </span>
                          {% endif %}
                        </div>
                        {% endif %}
                        
                        <!-- Product Price -->
                        {% if product.price != blank %}
                        <div class="best-sellers-product-price {{ section.settings.product_price_font_family | default: 'font-body' }} {{ section.settings.product_price_font_size | default: 'text-base' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} {{ section.settings.product_price_color | default: 'text-neutral-dark' }}">
                          {{ product.currency_symbol }}{{ product.price }}
                        </div>
                        {% endif %}
                        
                      </div>
                      
                      <!-- Add to Cart Button -->
                      {% if block.settings.show_add_to_cart_button %}
                      <div class="best-sellers-add-to-cart-wrapper">
                        {% if block.settings.add_to_cart_button_url != blank %}
                          <a href="{{ block.settings.add_to_cart_button_url }}" 
                            class="btn btn-{{ block.settings.add_to_cart_button_style | default: 'filled' }}-{{ block.settings.add_to_cart_button_color | default: 'black' }} {{ block.settings.add_to_cart_button_size | default: 'btn-md' }} {{ block.settings.add_to_cart_button_font_weight | default: 'font-medium' }} font-body {{ section.settings.add_to_cart_button_border_radius | default: settings.button_border_radius | default: 'rounded-md' }} w-full best-sellers-add-to-cart-btn"
                            onclick="event.stopPropagation(); event.preventDefault();">
                            {{ block.settings.add_to_cart_button_text | default: 'Add to Cart' }}
                          </a>
                        {% else %}
                          <button type="button"
                                  class="btn btn-{{ block.settings.add_to_cart_button_style | default: 'filled' }}-{{ block.settings.add_to_cart_button_color | default: 'black' }} {{ block.settings.add_to_cart_button_size | default: 'btn-md' }} {{ block.settings.add_to_cart_button_font_weight | default: 'font-medium' }} font-body {{ section.settings.add_to_cart_button_border_radius | default: settings.button_border_radius | default: 'rounded-md' }} w-full best-sellers-add-to-cart-btn"
                                  onclick="event.stopPropagation();">
                            {{ block.settings.add_to_cart_button_text | default: 'Add to Cart' }}
                          </button>
                        {% endif %}
                      </div>
                      {% endif %}
                    </div>
                  </a>
                </div>
                {%- endif -%}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      </div>
    </div>
  {% endif %}
  
  <!-- Navigation Controls Container (Same structure as header) -->
  {% if section.blocks.size > 0 %}
    {% if section.settings.show_navigation_controls %}
    <div class="{{ section.settings.container_layout_width | default: 'container' }}">
      <div class="best-sellers-carousel-controls-container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-md' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-lg' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}">
        <div class="best-sellers-carousel-controls {% if section.settings.controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
          <div class="best-sellers-carousel-nav-buttons">
            <button 
              type="button"
              class="best-sellers-carousel-nav-btn best-sellers-carousel-prev {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
              data-carousel-prev="{{ section.id }}"
              aria-label="Previous page">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            
            <button 
              type="button"
              class="best-sellers-carousel-nav-btn best-sellers-carousel-next {{ section.settings.nav_button_background | default: 'bg-white' }} {{ section.settings.nav_button_color | default: 'text-black' }}"
              data-carousel-next="{{ section.id }}"
              aria-label="Next page">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
          
          <!-- Progress Indicator -->
          {% if section.settings.show_progress_dots %}
          <div class="best-sellers-carousel-progress" data-carousel-progress="{{ section.id }}">
            <!-- Dots will be generated by JavaScript -->
          </div>
          {% endif %}
        </div>
      </div>
    </div>
    {% endif %}
  {% endif %}
</section>

<script>
(function() {
  try {
    // Wait for DOM to be fully loaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCarousel);
    } else {
      initCarousel();
    }
    
    function initCarousel() {
      try {
  const sectionId = '{{ section.id }}';
  const container = document.querySelector(`[data-carousel-container="${sectionId}"]`);
  const track = document.querySelector(`[data-carousel-track="${sectionId}"]`);
  const prevBtn = document.querySelector(`[data-carousel-prev="${sectionId}"]`);
  const nextBtn = document.querySelector(`[data-carousel-next="${sectionId}"]`);
  const progressContainer = document.querySelector(`[data-carousel-progress="${sectionId}"]`);
  
        if (!container || !track) {
          console.warn('Best Sellers Carousel: Container or track not found');
          return;
        }
        
        // Navigation buttons are optional (can be hidden via settings)
        const hasNavButtons = prevBtn && nextBtn;
  
  const productItems = track.querySelectorAll('.best-sellers-carousel-item');
        if (productItems.length === 0) {
          console.warn('Best Sellers Carousel: No product items found');
          return;
        }
  
  let currentIndex = 0;
  let currentPage = 0;
  let productsPerPage = parseInt('{{ section.settings.products_per_page_desktop | default: 4 }}');
  
  // Calculate products per page based on actual visible cards in container
  function updateProductsPerPage() {
    const firstItem = productItems[0];
    if (!firstItem || !container) {
      // Fallback to settings if elements not ready
      if (window.innerWidth >= 1024) {
        productsPerPage = parseInt('{{ section.settings.products_per_page_desktop | default: 4 }}');
      } else if (window.innerWidth >= 640) {
        productsPerPage = parseInt('{{ section.settings.products_per_page_tablet | default: 2 }}');
      } else {
        productsPerPage = parseInt('{{ section.settings.products_per_page_mobile | default: 1 }}');
      }
      return;
    }
    
    // Calculate based on actual container and card widths
    const containerWidth = container.offsetWidth;
    const cardWidth = firstItem.offsetWidth;
    const gap = parseInt(getComputedStyle(track).gap) || 16;
    
    // Calculate how many full cards fit in the visible container
    productsPerPage = Math.floor((containerWidth + gap) / (cardWidth + gap));
    productsPerPage = Math.max(1, productsPerPage); // At least 1
  }
  
  // Calculate total pages
  function getTotalPages() {
    return Math.ceil(productItems.length / productsPerPage);
  }
  
  // Animate to specific card index (moves one card at a time)
  function animateToIndex(newIndex) {
    const maxIndex = productItems.length - productsPerPage;
    if (newIndex < 0 || newIndex > maxIndex) return;
    
    currentIndex = newIndex;
    
    // Get actual item width from first item (set by CSS)
    const firstItem = productItems[0];
    if (!firstItem) return;
    
    const itemWidth = firstItem.offsetWidth;
    const gap = parseInt(getComputedStyle(track).gap) || 16;
    
    // Calculate scroll distance based on single card movement
    const scrollDistance = currentIndex * (itemWidth + gap);
    
    track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
    track.style.transform = `translateX(-${scrollDistance}px)`;
    
    // Update currentPage for progress dots
    currentPage = Math.floor(currentIndex / productsPerPage);
    
    updateButtons();
    updateProgressDots();
  }
  
  // Animate to page (for progress dots)
  function animateToPage(newPage) {
    const totalPages = getTotalPages();
    if (newPage < 0 || newPage >= totalPages) return;
    
    const targetIndex = newPage * productsPerPage;
    animateToIndex(targetIndex);
  }
  
  function updateButtons() {
    if (!hasNavButtons) return;
    
    const maxIndex = productItems.length - productsPerPage;
    
    // Update previous button
    if (currentIndex === 0) {
      prevBtn.disabled = true;
      prevBtn.setAttribute('aria-disabled', 'true');
      prevBtn.style.opacity = '0.4';
      prevBtn.style.cursor = 'not-allowed';
    } else {
      prevBtn.disabled = false;
      prevBtn.setAttribute('aria-disabled', 'false');
      prevBtn.style.opacity = '0.7';
      prevBtn.style.cursor = 'pointer';
    }
    
    // Update next button
    if (currentIndex >= maxIndex) {
      nextBtn.disabled = true;
      nextBtn.setAttribute('aria-disabled', 'true');
      nextBtn.style.opacity = '0.4';
      nextBtn.style.cursor = 'not-allowed';
    } else {
      nextBtn.disabled = false;
      nextBtn.setAttribute('aria-disabled', 'false');
      nextBtn.style.opacity = '0.7';
      nextBtn.style.cursor = 'pointer';
    }
  }
  
  function updateProgressDots() {
    if (!progressContainer) return;
    
    // Clear existing dots
    progressContainer.innerHTML = '';
    
    // Create one dot per product item
    for (let i = 0; i < productItems.length; i++) {
      const dot = document.createElement('button');
      dot.className = 'best-sellers-carousel-progress-dot';
      // The active dot is the one representing the first visible card
      if (i === currentIndex) {
        dot.classList.add('is-active');
      }
      dot.setAttribute('data-index', i);
      dot.setAttribute('aria-label', `Go to product ${i + 1}`);
      dot.style.cursor = 'pointer';
      dot.addEventListener('click', function() {
        // Clamp to max scrollable index
        const maxIndex = productItems.length - productsPerPage;
        const targetIndex = Math.min(i, maxIndex);
        animateToIndex(targetIndex);
      });
      progressContainer.appendChild(dot);
    }
  }
  
  // Navigation event listeners - move one card at a time
  if (hasNavButtons) {
    prevBtn.addEventListener('click', function() {
      if (currentIndex > 0) {
        animateToIndex(currentIndex - 1);
      }
    });
    
    nextBtn.addEventListener('click', function() {
      const maxIndex = productItems.length - productsPerPage;
      if (currentIndex < maxIndex) {
        animateToIndex(currentIndex + 1);
      }
    });
  }
  
  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  track.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  
  track.addEventListener('touchend', function(e) {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  }, { passive: true });
  
  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    const maxIndex = productItems.length - productsPerPage;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0 && currentIndex < maxIndex) {
        // Swipe left - next
        animateToIndex(currentIndex + 1);
      } else if (diff < 0 && currentIndex > 0) {
        // Swipe right - previous
        animateToIndex(currentIndex - 1);
      }
    }
  }
  
  // Handle resize
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function() {
      updateProductsPerPage();
      const maxIndex = productItems.length - productsPerPage;
      if (currentIndex > maxIndex) {
        currentIndex = Math.max(0, maxIndex);
      }
      updateProgressDots();
      animateToIndex(currentIndex);
    }, 250);
  });
  
  // Initialize
  updateProductsPerPage();
  updateButtons();
  updateProgressDots();
  animateToIndex(0);
        
      } catch (e) {
        console.error('Best Sellers Carousel initialization error:', e);
      }
    }
  } catch (e) {
    console.error('Best Sellers Carousel script error:', e);
  }
})();
</script>

{% schema %}
{
  "name": "Best Sellers Carousel",
  "tag": "section",
  "class": "best-sellers-carousel-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop our best sellers"
    },
    {
      "type": "select",
      "id": "title_font_family",
      "label": "Title Font Family",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-handwritten", "label": "Handwritten" },
        { "value": "font-serif", "label": "Serif" }
      ],
      "default": "font-primary"
    },
    {
      "type": "select",
      "id": "title_font_size",
      "label": "Title Font Size (Mobile)",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "text-xl", "label": "Extra Large" },
        { "value": "text-2xl", "label": "2X Large" },
        { "value": "text-3xl", "label": "3X Large" },
        { "value": "text-4xl", "label": "4X Large" },
        { "value": "text-5xl", "label": "5X Large" },
        { "value": "text-6xl", "label": "6X Large" },
        { "value": "text-7xl", "label": "7X Large" },
        { "value": "text-8xl", "label": "8X Large" },
        { "value": "text-9xl", "label": "9X Large" }
      ],
      "default": "text-2xl"
    },
    {
      "type": "select",
      "id": "title_font_size_desktop",
      "label": "Title Font Size (Desktop)",
      "options": [
        { "value": "lg:text-xs", "label": "Extra Small" },
        { "value": "lg:text-sm", "label": "Small" },
        { "value": "lg:text-base", "label": "Base" },
        { "value": "lg:text-lg", "label": "Large" },
        { "value": "lg:text-xl", "label": "Extra Large" },
        { "value": "lg:text-2xl", "label": "2X Large" },
        { "value": "lg:text-3xl", "label": "3X Large" },
        { "value": "lg:text-4xl", "label": "4X Large" },
        { "value": "lg:text-5xl", "label": "5X Large" },
        { "value": "lg:text-6xl", "label": "6X Large" },
        { "value": "lg:text-7xl", "label": "7X Large" },
        { "value": "lg:text-8xl", "label": "8X Large" },
