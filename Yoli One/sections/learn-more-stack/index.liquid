<!-- FAQ Accordion Section -->
<section class="faq-accordion {{ section.settings.background_color | default: 'bg-secondary-light' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="faq-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="faq-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Two Column Layout -->
      <div class="learn-more-layout {% if section.settings.layout == 'stacked' %}learn-more-layout--stacked{% elsif section.settings.layout == 'stacked_2col' %}learn-more-layout--stacked learn-more-layout--stacked-2col{% endif %}">
        
        <!-- Left Column - Text Content -->
        <div class="learn-more-text">
          {% if section.settings.heading != blank or section.settings.description != blank %}
          {% assign text_align = section.settings.text_alignment | default: 'left' %}
          <div class="faq-heading {{ section.settings.heading_spacing_bottom_mobile | default: 'mb-lg' }} {{ section.settings.heading_spacing_bottom_desktop | default: 'lg:mb-0' }}" style="text-align: {{ text_align }};">
            {% if section.settings.heading != blank %}
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="letter-spacing: -0.03em;">
              {{ section.settings.heading }}
            </h2>
            {% endif %}
            {% if section.settings.description != blank %}
            <div class="faq-description mt-md {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-black' }} leading-body">
              {{ section.settings.description }}
            </div>
            {% endif %}
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button %}
          <div class="faq-cta mt-lg">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text | default: 'Try Lorem Risk-Free Today' }}
            </a>
          </div>
          {% endif %}
        </div>
        
        <!-- Right Column - FAQ Cards -->
        {% if section.blocks.size > 0 %}
        <div class="learn-more-faqs">
          <div class="faq-grid {{ section.settings.faq_gap_mobile | default: 'gap-md' }} {{ section.settings.faq_gap_desktop | default: 'lg:gap-md' }}">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' and section.settings.show_faq_items %}
          
          {% assign border_color = section.settings.item_border_color | default: 'black' %}
          {% if border_color == 'black' %}
            {% assign border_color_value = 'var(--clr-black)' %}
          {% elsif border_color == 'white' %}
            {% assign border_color_value = 'var(--clr-white)' %}
          {% elsif border_color == 'primary' %}
            {% assign border_color_value = 'var(--clr-primary)' %}
          {% elsif border_color == 'secondary' %}
            {% assign border_color_value = 'var(--clr-secondary)' %}
          {% elsif border_color == 'tertiary' %}
            {% assign border_color_value = 'var(--clr-tertiary)' %}
          {% elsif border_color == 'quaternary' %}
            {% assign border_color_value = 'var(--clr-quaternary)' %}
          {% elsif border_color == 'success' %}
            {% assign border_color_value = 'var(--clr-success)' %}
          {% elsif border_color == 'warning' %}
            {% assign border_color_value = 'var(--clr-warning)' %}
          {% elsif border_color == 'error' %}
            {% assign border_color_value = 'var(--clr-error)' %}
          {% elsif border_color == 'info' %}
            {% assign border_color_value = 'var(--clr-info)' %}
          {% elsif border_color == 'neutral' %}
            {% assign border_color_value = 'var(--clr-neutral)' %}
          {% elsif border_color == 'neutral-light' %}
            {% assign border_color_value = 'var(--clr-neutral-light)' %}
          {% elsif border_color == 'neutral-dark' %}
            {% assign border_color_value = 'var(--clr-neutral-dark)' %}
          {% else %}
            {% assign border_color_value = 'var(--clr-black)' %}
          {% endif %}
          <div class="faq-item {{ section.settings.item_background_color | default: 'bg-secondary-light' }} {{ section.settings.item_border_radius | default: 'rounded-md' }} {% if section.settings.border_style == 'bottom' %}faq-item--bottom-border{% endif %}" {{ block.fluid_attributes }} style="{% if section.settings.border_style == 'all' %}border: 1px solid {{ border_color_value }};{% elsif section.settings.border_style == 'bottom' %}border-bottom: 1px solid {{ border_color_value }};{% endif %}padding-left: {% if section.settings.border_style == 'bottom' %}0{% else %}{{ section.settings.item_padding_left | default: 20 }}px{% endif %}; padding-right: {{ section.settings.item_padding_right | default: 20 }}px;">
            
            <!-- Question Button -->
            <button class="faq-question" type="button" aria-expanded="false">
              <!-- Image -->
              {% if block.settings.image != blank %}
              <div class="faq-item-image">
                <img src="{{ block.settings.image | image_url: width: 80 }}" alt="{{ block.settings.image.alt | default: block.settings.question }}" class="{{ block.settings.image_border_radius | default: 'rounded-full' }}" />
              </div>
              {% endif %}
              
              <span class="faq-question-text {{ section.settings.question_font_family | default: 'font-primary' }} {{ section.settings.question_font_size | default: 'text-lg' }} {{ section.settings.question_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.question_font_weight | default: 'font-medium' }} {{ section.settings.question_color | default: 'text-black' }}">
                {{ block.settings.question | default: 'Question goes here?' }}
              </span>
              
              <!-- Icon -->
              {% if section.settings.icon_type == 'chevron' %}
              <!-- Chevron Icon -->
              <span class="faq-icon faq-icon-chevron {{ section.settings.question_color | default: 'text-black' }}">
                <svg class="icon-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {% elsif section.settings.icon_type == 'regular_plus' %}
              <!-- Regular Plus/Minus Icon (no square) -->
              <span class="faq-icon faq-icon-regular-plus {{ section.settings.question_color | default: 'text-black' }}">
                <svg class="icon-plus" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <svg class="icon-minus" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
              {% else %}
              <!-- Plus/Minus Icon (with square) -->
              <span class="faq-icon faq-icon-plus {{ section.settings.question_color | default: 'text-black' }}">
                <svg class="icon-plus" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="26" height="26" rx="2.5" stroke="currentColor"/>
                  <line x1="13.5" y1="6" x2="13.5" y2="21" stroke="currentColor" stroke-width="2"/>
                  <line x1="6" y1="13.5" x2="21" y2="13.5" stroke="currentColor" stroke-width="2"/>
                </svg>
                <svg class="icon-minus" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="26" height="26" rx="2.5" stroke="currentColor"/>
                  <line x1="6" y1="13.5" x2="21" y2="13.5" stroke="currentColor" stroke-width="2"/>
                </svg>
              </span>
              {% endif %}
            </button>
            
            <!-- Answer Panel -->
            <div class="faq-answer">
              <div class="faq-answer-content">
                
                <!-- Full Width Image Above Text -->
                {% if block.settings.full_width_image != blank and block.settings.full_width_image_position == 'above' %}
                <div class="faq-full-width-image faq-full-width-image--above">
                  <img src="{{ block.settings.full_width_image | image_url: width: 1200 }}" alt="{{ block.settings.full_width_image.alt | default: 'Full width image' }}" />
                </div>
                {% endif %}
                
                <!-- Text with Side Image -->
                <div class="faq-text-with-image {% if block.settings.side_image != blank %}faq-text-with-image--has-side{% endif %} {% if block.settings.side_image_position == 'right' %}faq-text-with-image--image-right{% else %}faq-text-with-image--image-left{% endif %}">
                  
                  <!-- Side Image Left -->
                  {% if block.settings.side_image != blank and block.settings.side_image_position == 'left' %}
                  <div class="faq-side-image faq-side-image--left" style="width: {{ block.settings.side_image_width | default: 40 }}%;">
                    <img src="{{ block.settings.side_image | image_url: width: 800 }}" alt="{{ block.settings.side_image.alt | default: 'Side image' }}" />
                  </div>
                  {% endif %}
                  
                  <!-- Text Content -->
                  <div class="faq-text-content">
                    <p class="{{ section.settings.answer_font_family | default: 'font-body' }} {{ section.settings.answer_font_size | default: 'text-base' }} {{ section.settings.answer_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.answer_font_weight | default: 'font-normal' }} {{ section.settings.answer_color | default: 'text-black' }} leading-body">
                      {{ block.settings.answer | default: 'Answer goes here.' }}
                    </p>
                  </div>
                  
                  <!-- Side Image Right -->
                  {% if block.settings.side_image != blank and block.settings.side_image_position == 'right' %}
                  <div class="faq-side-image faq-side-image--right" style="width: {{ block.settings.side_image_width | default: 40 }}%;">
                    <img src="{{ block.settings.side_image | image_url: width: 800 }}" alt="{{ block.settings.side_image.alt | default: 'Side image' }}" />
                  </div>
                  {% endif %}
                  
                </div>
                
                <!-- Full Width Image Below Text -->
                {% if block.settings.full_width_image != blank and block.settings.full_width_image_position == 'below' %}
                <div class="faq-full-width-image faq-full-width-image--below">
                  <img src="{{ block.settings.full_width_image | image_url: width: 1200 }}" alt="{{ block.settings.full_width_image.alt | default: 'Full width image' }}" />
                </div>
                {% endif %}
                
              </div>
            </div>
            
          </div>
          
          {% endif %}
          
          {% if block.type == 'card_grid_item' and section.settings.show_card_grid_items %}
          
          {% assign border_color = section.settings.item_border_color | default: 'black' %}
          {% if border_color == 'black' %}
            {% assign border_color_value = 'var(--clr-black)' %}
          {% elsif border_color == 'white' %}
            {% assign border_color_value = 'var(--clr-white)' %}
          {% elsif border_color == 'primary' %}
            {% assign border_color_value = 'var(--clr-primary)' %}
          {% elsif border_color == 'secondary' %}
            {% assign border_color_value = 'var(--clr-secondary)' %}
          {% elsif border_color == 'tertiary' %}
            {% assign border_color_value = 'var(--clr-tertiary)' %}
          {% elsif border_color == 'quaternary' %}
            {% assign border_color_value = 'var(--clr-quaternary)' %}
          {% elsif border_color == 'success' %}
            {% assign border_color_value = 'var(--clr-success)' %}
          {% elsif border_color == 'warning' %}
            {% assign border_color_value = 'var(--clr-warning)' %}
          {% elsif border_color == 'error' %}
            {% assign border_color_value = 'var(--clr-error)' %}
          {% elsif border_color == 'info' %}
            {% assign border_color_value = 'var(--clr-info)' %}
          {% elsif border_color == 'neutral' %}
            {% assign border_color_value = 'var(--clr-neutral)' %}
          {% elsif border_color == 'neutral-light' %}
            {% assign border_color_value = 'var(--clr-neutral-light)' %}
          {% elsif border_color == 'neutral-dark' %}
            {% assign border_color_value = 'var(--clr-neutral-dark)' %}
          {% else %}
            {% assign border_color_value = 'var(--clr-black)' %}
          {% endif %}
          <div class="faq-item {{ section.settings.item_background_color | default: 'bg-secondary-light' }} {{ section.settings.item_border_radius | default: 'rounded-md' }} {% if section.settings.border_style == 'bottom' %}faq-item--bottom-border{% endif %}" {{ block.fluid_attributes }} style="{% if section.settings.border_style == 'all' %}border: 1px solid {{ border_color_value }};{% elsif section.settings.border_style == 'bottom' %}border-bottom: 1px solid {{ border_color_value }};{% endif %}padding-left: {% if section.settings.border_style == 'bottom' %}0{% else %}{{ section.settings.item_padding_left | default: 20 }}px{% endif %}; padding-right: {{ section.settings.item_padding_right | default: 20 }}px;">
            
            <!-- Question Button -->
            <button class="faq-question" type="button" aria-expanded="false">
              <!-- Image -->
              {% if block.settings.image != blank %}
              <div class="faq-item-image">
                <img src="{{ block.settings.image | image_url: width: 80 }}" alt="{{ block.settings.image.alt | default: block.settings.question }}" class="{{ block.settings.image_border_radius | default: 'rounded-full' }}" />
              </div>
              {% endif %}
              
              <span class="faq-question-text {{ section.settings.question_font_family | default: 'font-primary' }} {{ section.settings.question_font_size | default: 'text-lg' }} {{ section.settings.question_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.question_font_weight | default: 'font-medium' }} {{ section.settings.question_color | default: 'text-black' }}">
                {{ block.settings.question | default: 'Question goes here?' }}
              </span>
              
              <!-- Icon -->
              {% if section.settings.icon_type == 'chevron' %}
              <!-- Chevron Icon -->
              <span class="faq-icon faq-icon-chevron {{ section.settings.question_color | default: 'text-black' }}">
                <svg class="icon-chevron" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {% elsif section.settings.icon_type == 'regular_plus' %}
              <!-- Regular Plus/Minus Icon (no square) -->
              <span class="faq-icon faq-icon-regular-plus {{ section.settings.question_color | default: 'text-black' }}">
                <svg class="icon-plus" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <svg class="icon-minus" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
              {% else %}
              <!-- Plus/Minus Icon (with square) -->
              <span class="faq-icon faq-icon-plus {{ section.settings.question_color | default: 'text-black' }}">
                <svg class="icon-plus" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="26" height="26" rx="2.5" stroke="currentColor"/>
                  <line x1="13.5" y1="6" x2="13.5" y2="21" stroke="currentColor" stroke-width="2"/>
                  <line x1="6" y1="13.5" x2="21" y2="13.5" stroke="currentColor" stroke-width="2"/>
                </svg>
                <svg class="icon-minus" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="26" height="26" rx="2.5" stroke="currentColor"/>
                  <line x1="6" y1="13.5" x2="21" y2="13.5" stroke="currentColor" stroke-width="2"/>
                </svg>
              </span>
              {% endif %}
            </button>
            
            <!-- Card Grid Panel -->
            <div class="faq-answer">
              <div class="faq-answer-content">
                
                <!-- Full Width Image at Top -->
                {% if block.settings.show_full_width_image and block.settings.full_width_image != blank and block.settings.full_width_image_position == 'top' %}
                <div class="card-grid-full-width-image card-grid-full-width-image--top {{ block.settings.full_width_image_border_radius | default: 'rounded-none' }}">
                  <img src="{{ block.settings.full_width_image | image_url: width: 1200 }}" alt="{{ block.settings.full_width_image.alt | default: 'Full width image' }}" />
                </div>
                {% endif %}
                
                <!-- Description with Side Image -->
                {% if block.settings.show_description or block.settings.show_side_image %}
                <div class="card-grid-description-wrapper {% if block.settings.show_side_image and block.settings.side_image != blank %}card-grid-description-wrapper--has-side-image{% endif %}">
                  
                  <!-- Side Image -->
                  {% if block.settings.show_side_image and block.settings.side_image != blank %}
                  <div class="card-grid-side-image" style="width: {{ block.settings.side_image_width | default: 40 }}%;">
                    <img src="{{ block.settings.side_image | image_url: width: 800 }}" alt="{{ block.settings.side_image.alt | default: 'Side image' }}" />
                  </div>
                  {% endif %}
                  
                  <!-- WYSIWYG Description -->
                  {% if block.settings.show_description and block.settings.description != blank %}
                  <div class="card-grid-description {{ section.settings.answer_font_family | default: 'font-body' }} {{ section.settings.answer_font_size | default: 'text-base' }} {{ section.settings.answer_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.answer_font_weight | default: 'font-normal' }} {{ section.settings.answer_color | default: 'text-black' }}" style="{% if block.settings.show_side_image and block.settings.side_image != blank %}flex: 1; min-width: 0;{% endif %}">
                    {{ block.settings.description }}
                  </div>
                  {% endif %}
                  
                </div>
                {% endif %}
                
                <!-- Full Width Image Under Description -->
                {% if block.settings.show_full_width_image and block.settings.full_width_image != blank and block.settings.full_width_image_position == 'under_description' %}
                <div class="card-grid-full-width-image card-grid-full-width-image--under-description {{ block.settings.full_width_image_border_radius | default: 'rounded-none' }}">
                  <img src="{{ block.settings.full_width_image | image_url: width: 1200 }}" alt="{{ block.settings.full_width_image.alt | default: 'Full width image' }}" />
                </div>
                {% endif %}
                
                <div class="card-grid-container">
                  <div class="card-grid">
                    {% if block.settings.show_card_1 %}
                    <div class="card-grid-item">
                      {% if block.settings.card_1_logo != blank %}
                      <div class="card-grid-logo">
                        <img src="{{ block.settings.card_1_logo | image_url: width: 200 }}" alt="{{ block.settings.card_1_logo.alt | default: 'Card logo' }}" />
                      </div>
                      {% endif %}
                      {% if block.settings.card_1_text != blank %}
                      <div class="card-grid-text {{ section.settings.answer_font_family | default: 'font-body' }} {{ section.settings.answer_font_size | default: 'text-base' }} {{ section.settings.answer_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.answer_font_weight | default: 'font-normal' }} {{ section.settings.answer_color | default: 'text-black' }}">
                        {{ block.settings.card_1_text }}
                      </div>
                      {% endif %}
                      {% if block.settings.card_1_button_text != blank %}
                      <div class="card-grid-button">
                        <a href="{{ block.settings.card_1_button_url | default: '#' }}" class="btn btn-{{ block.settings.card_1_button_style | default: 'filled' }}-{{ block.settings.card_1_button_color | default: 'primary' }} {{ block.settings.card_1_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}" style="cursor: pointer;">
