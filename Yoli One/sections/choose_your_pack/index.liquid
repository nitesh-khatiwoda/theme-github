<div class="choose-your-pack-section">
  {% if section.settings.show_title %}
  <h2 class="section-title {{ section.settings.title_font_family }} {{ section.settings.title_font_size }} {{ section.settings.title_font_size_mobile }} {{ section.settings.title_font_weight }} {{ section.settings.title_text_color }}">{{ section.settings.title_text }}</h2>
  {% endif %}
  <div class="button-content eina-1-font">
    {% if section.settings.show_buttons %}
    <a href="/{{ share_guid }}/enrollments/1nVHTpRorDvGN1eXJtXEfN6a" class="button-pack {{ section.settings.transform_button_bg_color }} {{ section.settings.transform_button_text_color }}" id="transform-pack">
      <h4>1</h4>
      <h6 class="btn-label {{ section.settings.transform_button_font_family }} {{ section.settings.transform_button_font_size }} {{ section.settings.transform_button_font_size_mobile }} {{ section.settings.transform_button_font_weight }}">{{ section.settings.transform_button_text }}</h6>
    </a>
    <a href="/{{ share_guid }}/enrollments/aENA7VyztXbPdvXHaEsp4DbB" class="button-pack {{ section.settings.share_button_bg_color }} {{ section.settings.share_button_text_color }}" id="share-pack">
      <h4>2</h4>
      <h6 class="btn-label {{ section.settings.share_button_font_family }} {{ section.settings.share_button_font_size }} {{ section.settings.share_button_font_size_mobile }} {{ section.settings.share_button_font_weight }}">{{ section.settings.share_button_text }}</h6>
    </a>
    <a href="/{{ share_guid }}/enrollments/4V7kFTCGAdc5nFSKVfDLjhuo" class="button-pack {{ section.settings.launch_button_bg_color }} {{ section.settings.launch_button_text_color }}" id="launch-pack">
      <h4>3</h4>
      <h6 class="btn-label {{ section.settings.launch_button_font_family }} {{ section.settings.launch_button_font_size }} {{ section.settings.launch_button_font_size_mobile }} {{ section.settings.launch_button_font_weight }}">{{ section.settings.launch_button_text }}</h6>
    </a>
    {% endif %}
  </div>
  <div class="selector-group padding-0">
    <!-- Dynamic Product List based on tags or variants -->
    <div class="product-list margin-0" id="included">
      <div class="product-item">
        <div class="product-description-content">
          <img src="https://ik.imagekit.io/fluid/filestack-migration/filestack_vopqYiBsQheCq6gKQzpw_w_V3-JAghd" alt="" class="yoli-icon">
          <div class="product-content-info">
            <p class="product-title non-uppercase">Included in pack</p>
          </div>
        </div>
        <div class="total-box">
          <div class="total-row">
            <span class="section-total" id="included-total"><strong></strong></span>
          </div>
          <button class="product-button" onclick="toggleCustomize('included')">
            <span class="dropdown-title">What's included</span>
            <svg class="dropdown-icon" id="included-dropdown-icon" width="12" height="8" viewBox="0 0 12 8" fill="none">
              <path d="M6 8L0 0H12L6 8Z" fill="currentColor" />
            </svg>
          </button>
        </div>
      </div>
      <div class="products" id="included-products" hidden>
        {% for product in enrollment_pack.membership_products[0].product_bundles %}
          {% case product.bundled_variant_id %}
            {% when 63544 %} <!-- Pure -->
              <div class="products-item">
                <div class="product-item-description">
                  <img src="{{ product.image_url }}" alt="{{ product.title }}" class="yoli-icon">
                  <p>{{ product.title }}</p>
