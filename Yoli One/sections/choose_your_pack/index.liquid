<script>
  document.addEventListener('DOMContentLoaded', function () {
    const currentPack = getCurrentPackToken();

    const packMapping = {
      '1nVHTpRorDvGN1eXJtXEfN6a': 'transform-pack',
      'aENA7VyztXbPdvXHaEsp4DbB': 'share-pack',
      '4V7kFTCGAdc5nFSKVfDLjhuo': 'launch-pack'
    };

    const buttonId = packMapping[currentPack];

    if (buttonId) {
      const button = document.getElementById(buttonId);
      if (button) {
        document.querySelectorAll('.button-pack').forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        updateIncludedTotal(buttonId);
        updateSectionTotals();
      }
    }
    initializeAllProducts();
  });

  function getCurrentPackToken() {
    const currentPack = window.location.pathname.split('/').pop();
    return currentPack;
  }

  function toggleCustomize(type) {
    const productList = document.querySelector(`#${type}`);
    const productsDiv = document.querySelector(`#${type}-products`);
    const dropdownIcon = document.querySelector(`#${type}-dropdown-icon`);

    const shouldShow = productsDiv.hasAttribute('hidden') || productsDiv.style.display === 'none';

    productsDiv.style.display = shouldShow ? 'block' : 'none';
    productsDiv.toggleAttribute('hidden', !shouldShow);
    dropdownIcon && dropdownIcon.classList.toggle('rotated', shouldShow);

    if (!shouldShow) productList.style.backgroundColor = '';
  }

  window.selectedProductsCart = {};

  function initializeAllProducts() {
    setDefaultBundleProducts();
    
    document.querySelectorAll('.products-item[data-variant-id]').forEach(item => {
      const variantId = item.getAttribute('data-variant-id');
      const quantity = parseInt(item.querySelector('.qty-number').textContent) || 0;
      
      window.selectedProductsCart[variantId] = {
        variant_id: variantId,
        quantity: quantity
      };
    });
    
    localStorage.setItem('selectedProductsCart', JSON.stringify(window.selectedProductsCart));
  }

  function saveProductToCart(variantId, quantity) {
    (quantity > 0) ? (window.selectedProductsCart[variantId] = { variant_id: variantId, quantity: quantity}) : delete window.selectedProductsCart[variantId];
    
    localStorage.setItem('selectedProductsCart', JSON.stringify(window.selectedProductsCart));
  }

  function changeQuantity(button, change) {
    const container = button.parentElement;
    const qtyElement = container.querySelector('.qty-number');
    let currentQty = parseInt(qtyElement.textContent);
    let newQty = currentQty + change;
    const minQty = 0;

    let section = button.closest('.products');
    const limits = getPackLimits();
    let maxQty = 8;

    if (section && section.id === 'flavors-products') maxQty = limits.flavors;
    if (section && section.id === 'essential-products') maxQty = limits.essential;

    if (newQty < minQty) newQty = minQty;

    const sectionTotal = section ? getSectionTotal(`#${section.id}`) : 0;

    if (change > 0 && sectionTotal >= maxQty) return;
    if (newQty !== currentQty) {
      qtyElement.textContent = newQty;
      
      const productItem = button.closest('.products-item');
      const variantId = productItem.getAttribute('data-variant-id');

      if (variantId) {
        saveProductToCart(variantId, newQty);
      }
    }
    updateSectionTotals();
  }

  function getSectionTotal(sectionSelector) {
    let total = 0;
    const qtyElements = document.querySelectorAll(`${sectionSelector} .qty-number`);
    qtyElements.forEach(element => {
      total += parseInt(element.textContent);
    });
    return total;
  }

  function updateSectionControls(sectionSelector, totalLabelId, total, max) {
    document.getElementById(totalLabelId).textContent = `${total} of ${max} selected`;
    document.querySelectorAll(`${sectionSelector} .qty-btn.plus`).forEach(btn => {
      btn.disabled = total >= max;
    });
  }

  function updateTotalColor(totalLabelId, total) {
    const label = document.getElementById(totalLabelId);
    if (label) label.style.color = total > 0 ? '#0047A4' : '#A40000';
  }

  function updateButtonStates(sectionSelector, total, max) {
    document.querySelectorAll(`${sectionSelector} .qty-btn.plus`).forEach(btn => {
      btn.disabled = total >= max;
      btn.classList.toggle('disabled', btn.disabled);
    });

    document.querySelectorAll(`${sectionSelector} .qty-btn.minus`).forEach(btn => {
      const qty = parseInt(btn.parentElement.querySelector('.qty-number').textContent) || 0;
      btn.disabled = qty === 0;
      btn.classList.toggle('disabled', btn.disabled);
    });
  }

  function setDefaultBundleProducts() {
    const productsList = {
      '1nVHTpRorDvGN1eXJtXEfN6a': [
        { variant_id: 63544, quantity: 1 },
        { variant_id: 63136, quantity: 2 },
        { variant_id: 63717, quantity: 1 },
        { variant_id: 63641, quantity: 1 },
        { variant_id: 63728, quantity: 1 }
      ],
      'aENA7VyztXbPdvXHaEsp4DbB': [
        { variant_id: 63544, quantity: 2 },
        { variant_id: 63136, quantity: 4 },
        { variant_id: 63717, quantity: 2 },
        { variant_id: 63641, quantity: 1 },
        { variant_id: 63728, quantity: 1 }
      ],
      '4V7kFTCGAdc5nFSKVfDLjhuo': [
        { variant_id: 63544, quantity: 4 },
        { variant_id: 63136, quantity: 8 },
        { variant_id: 63717, quantity: 4 },
        { variant_id: 63641, quantity: 1 },
        { variant_id: 63728, quantity: 1 }
      ]
    };

    const productToken = getCurrentPackToken();
    const products = productsList[productToken];

    if (products) {
      products.forEach(product => {
        saveProductToCart(product.variant_id, product.quantity);
      });
    }
  }

  function updateSectionTotals() {
    const limits = getPackLimits();

    const flavorsTotal = getSectionTotal('#flavors-products');
    updateSectionControls('#flavors-products', 'flavors-total', flavorsTotal, limits.flavors);
    updateTotalColor('flavors-total', flavorsTotal);
    updateButtonStates('#flavors-products', flavorsTotal, limits.flavors);

    const essentialTotal = getSectionTotal('#essential-products');
    updateSectionControls('#essential-products', 'essential-total', essentialTotal, limits.essential);
    updateTotalColor('essential-total', essentialTotal);
    updateButtonStates('#essential-products', essentialTotal, limits.essential);

    const isComplete = (flavorsTotal === limits.flavors) && (essentialTotal === limits.essential);
    localStorage.setItem('packSelectionsComplete', JSON.stringify(isComplete));
    window.dispatchEvent(new CustomEvent('pack-selections-updated', { detail: { isComplete } }));
  }

  function getPackLimits() {
    const activeButton = document.querySelector('.button-pack.active');
    const limitsById = {
      'transform-pack': { essential: 2, flavors: 2 },
      'share-pack': { essential: 4, flavors: 4 },
      'launch-pack': { essential: 8, flavors: 8 }
    };

    return limitsById[activeButton?.id] || { essential: 2, flavors: 2 };
  }

  function updateIncludedTotal(buttonId) {
    const elements = {
      pure: document.getElementById('pure-quantity'),
      alkalete: document.getElementById('alkalete-quantity'),
      resolve: document.getElementById('resolve-quantity'),
      blender: document.getElementById('blender-quantity'),
      workbook: document.getElementById('workbook-quantity'),
      included: document.getElementById('included-total')
    };

    const presets = {
      'transform-pack': { included: '6 of 6 included', pure: 1, alkalete: 2, resolve: 1, blender: 1, workbook: 1 },
      'share-pack': { included: '10 of 10 included', pure: 2, alkalete: 4, resolve: 2, blender: 1, workbook: 1 },
      'launch-pack': { included: '18 of 18 included', pure: 4, alkalete: 8, resolve: 4, blender: 1, workbook: 1 }
    };

    const preset = presets[buttonId];
    if (!preset) return;

    elements.pure.innerHTML = `x${preset.pure} (total)`;
    elements.alkalete.innerHTML = `x${preset.alkalete} (total)`;
    elements.resolve.innerHTML = `x${preset.resolve} (total)`;
    elements.blender.innerHTML = `x${preset.blender} (total)`;
    elements.workbook.innerHTML = `x${preset.workbook} (total)`;
    elements.included.innerHTML = preset.included;
  }
</script>

