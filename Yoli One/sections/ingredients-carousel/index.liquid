<link rel="stylesheet" href="{{ 'ingredients-carousel/styles.css' | asset_url }}">

<!-- Ingredients Carousel Section -->
<section class="ingredients-carousel {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="ingredients-carousel__container">
    <div class="ingredients-carousel__wrapper {{ section.settings.wrapper_background | default: 'bg-neutral-light' }} {{ section.settings.wrapper_border_radius | default: 'rounded-lg' }}">
      
      <!-- Top Header Section -->
      <div class="ingredients-carousel__header">
        
        <!-- Left: Heading & Description -->
        <div class="ingredients-carousel__text-wrapper">
          {% if section.settings.heading != blank %}
            <h2 class="ingredients-carousel__heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-primary' }}">
              {{ section.settings.heading }}
            </h2>
          {% endif %}
          
          {% if section.settings.description != blank %}
            <p class="ingredients-carousel__description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-sm' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }}">
              {{ section.settings.description }}
            </p>
          {% endif %}
        </div>
        
        <!-- Right: View All Link -->
        {% if section.settings.show_link and section.settings.link_text != blank %}
          <div class="ingredients-carousel__link-wrapper">
            <a href="{{ section.settings.link_url | default: '#' }}" class="ingredients-carousel__link {{ section.settings.link_font_family | default: 'font-body' }} {{ section.settings.link_font_size | default: 'text-xs' }} {{ section.settings.link_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.link_font_weight | default: 'font-normal' }} {{ section.settings.link_color | default: 'text-warning' }}">
              {{ section.settings.link_text }}
            </a>
          </div>
        {% endif %}
        
      </div>
      
      <!-- Ingredient Cards Carousel -->
      {% assign ingredient_blocks = section.blocks | where: 'type', 'ingredient' %}
      {% if ingredient_blocks.size > 0 %}
        <div class="ingredients-carousel__carousel-wrapper">
          <div class="ingredients-carousel__track-container">
            <div class="ingredients-carousel__track" id="ingredients-track-{{ section.id }}">
              
              {% for block in ingredient_blocks %}
                <div class="ingredients-carousel__card" {{ block.fluid_attributes }}>
                  
                  <!-- Card Background (white rounded) -->
                  <div class="ingredients-carousel__card-bg {{ section.settings.card_background | default: 'bg-white' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                    
                    <!-- Ingredient Image (floats above) -->
                    <div class="ingredients-carousel__image-wrapper">
                      {% if block.settings.ingredient_image != blank %}
                        <img src="{{ block.settings.ingredient_image | image_url: width: 400 }}" 
                             alt="{{ block.settings.image_alt | default: block.settings.ingredient_name }}"
                             class="ingredients-carousel__image"
                             loading="lazy">
                      {% else %}
                        <img src="{{ 'placeholder-image.png' | asset_url }}" 
                             alt="Ingredient placeholder"
                             class="ingredients-carousel__image">
                      {% endif %}
                    </div>
                    
                    <!-- Card Text Content -->
                    <div class="ingredients-carousel__card-content">
                      {% if block.settings.ingredient_name != blank %}
                        <h3 class="ingredients-carousel__ingredient-name {{ section.settings.ingredient_name_font_family | default: 'font-body' }} {{ section.settings.ingredient_name_font_size | default: 'text-sm' }} {{ section.settings.ingredient_name_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.ingredient_name_font_weight | default: 'font-semibold' }} {{ section.settings.ingredient_name_color | default: 'text-primary' }}">
                          {{ block.settings.ingredient_name }}
                        </h3>
                      {% endif %}
                      
                      {% if block.settings.ingredient_description != blank %}
                        <p class="ingredients-carousel__ingredient-description {{ section.settings.ingredient_description_font_family | default: 'font-body' }} {{ section.settings.ingredient_description_font_size | default: 'text-xs' }} {{ section.settings.ingredient_description_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.ingredient_description_font_weight | default: 'font-normal' }} {{ section.settings.ingredient_description_color | default: 'text-primary' }}">
                          {{ block.settings.ingredient_description }}
                        </p>
                      {% endif %}
                    </div>
                    
                  </div>
                  
                </div>
              {% endfor %}
              
            </div>
          </div>
        </div>
      {% endif %}
      
    </div>
  </div>
</section>

<script>
(function() {
  // Smooth horizontal scrolling for ingredients carousel
  function initIngredientsCarousel() {
    const tracks = document.querySelectorAll('[id^="ingredients-track-"]');
    
    tracks.forEach(function(track) {
      let isDown = false;
      let startX;
      let scrollLeft;
      
      track.addEventListener('mousedown', function(e) {
        isDown = true;
        track.style.cursor = 'grabbing';
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      });
      
      track.addEventListener('mouseleave', function() {
        isDown = false;
        track.style.cursor = 'grab';
      });
      
      track.addEventListener('mouseup', function() {
        isDown = false;
        track.style.cursor = 'grab';
      });
      
      track.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 2;
        track.scrollLeft = scrollLeft - walk;
      });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initIngredientsCarousel);
  } else {
    initIngredientsCarousel();
  }
})();
</script>

