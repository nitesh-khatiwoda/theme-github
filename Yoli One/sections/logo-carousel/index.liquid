<link rel="stylesheet" href="{{ 'logo-carousel/styles.css' | asset_url }}">

<section 
  class="logo-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="logo-carousel-container container">
    <div class="logo-carousel-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Heading (Optional) -->
      {% if section.settings.heading != blank %}
      <div class="logo-carousel-heading mb-lg">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-lg' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Logo Carousel Wrapper -->
      <div class="logo-carousel-wrapper">
        <div class="logo-carousel-track {% if section.settings.scroll_direction == 'right' %}scroll-right{% else %}scroll-left{% endif %}">
          
          <!-- First Set of Logos -->
          <div class="logo-set">
            {% for block in section.blocks %}
              {% if block.type == 'logo' %}
              <div class="logo-item" {{ block.fluid_attributes }}>
                {% if block.settings.logo_image != blank %}
                  <img src="{{ block.settings.logo_image | image_url: width: 200 }}" alt="{{ block.settings.logo_alt | default: 'Logo' }}" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Logo placeholder" loading="lazy">
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          
          <!-- Duplicate Set for Seamless Loop -->
          <div class="logo-set" aria-hidden="true">
            {% for block in section.blocks %}
              {% if block.type == 'logo' %}
              <div class="logo-item">
                {% if block.settings.logo_image != blank %}
                  <img src="{{ block.settings.logo_image | image_url: width: 200 }}" alt="{{ block.settings.logo_alt | default: 'Logo' }}" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Logo placeholder" loading="lazy">
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .logo-carousel-section {
    --animation-speed: {{ section.settings.animation_speed | default: 30 }}s;
    --logo-height: {{ section.settings.logo_max_height | default: 50 }}px;
  }
</style>

