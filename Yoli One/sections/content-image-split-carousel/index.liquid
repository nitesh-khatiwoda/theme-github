<link rel="stylesheet" href="{{ 'content-image-split-carousel/styles.css' | asset_url }}">

<section 
  class="content-image-split-carousel {{ section.settings.background_color | default: 'bg-tertiary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="content-image-split-carousel-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="container">
    <div class="content-image-split-carousel-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="split-layout {% if section.settings.flip_layout %}split-layout--flipped{% endif %}">
        
        <!-- Content Column -->
        <div class="content-column">
          {% if section.settings.heading != blank %}
          <div class="heading-wrapper">
            <h2 class="heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-secondary' }}">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          {% if section.settings.body_text != blank %}
          <div class="body-wrapper">
            <p class="body-text {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.body_font_weight | default: 'font-normal' }} {{ section.settings.body_color | default: 'text-secondary' }}">
              {{ section.settings.body_text }}
            </p>
          </div>
          {% endif %}
          
          {% if section.settings.show_button %}
          <div class="button-wrapper">
            <a href="{{ section.settings.button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'secondary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} font-body">
              {{ section.settings.button_text | default: 'Get Started' }}
            </a>
          </div>
          {% endif %}
        </div>
        
        <!-- Image Carousel Column -->
        {% if section.blocks.size > 0 %}
        <div class="carousel-column">
          <div class="image-carousel">
            {% for block in section.blocks %}
              {% if block.type == 'carousel_image' %}
              <div class="carousel-item" {{ block.fluid_attributes }}>
                {% if block.settings.image != blank %}
                  <img 
                    src="{{ block.settings.image | image_url: width: 800 }}" 
                    alt="{{ block.settings.image_alt | default: 'Carousel image' }}"
                    loading="lazy">
                {% else %}
                  <img 
                    src="{{ 'placeholder-image.png' | asset_url }}" 
                    alt="Placeholder">
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</section>

