<!-- Featured Products Carousel Section -->
<section class="featured-products-carousel {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}">
  <div class="{{section.settings.container_layout-width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-lg' }}">
      
      <!-- Header Row -->
      <div class="featured-products-carousel__header">
        
        <!-- Heading with Colored Text -->
        <div class="featured-products-carousel__heading-wrapper">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-black' }}">
            {%- if section.settings.heading_part1 != blank -%}
              <span>{{ section.settings.heading_part1 }}</span>
            {%- endif -%}
            {%- if section.settings.heading_part2 != blank -%}
              <span class="{{ section.settings.heading_accent_color | default: 'text-primary' }}">{{ section.settings.heading_part2 }}</span>
            {%- endif -%}
          </h2>
        </div>

        <!-- CTA Button -->
        {%- if section.settings.show_button -%}
          <div class="featured-products-carousel__button-wrapper">
            <a href="{{ section.settings.button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-semibold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text | default: 'Shop now' }}
            </a>
          </div>
        {%- endif -%}

      </div>

      <!-- Carousel Wrapper -->
        <div class="featured-products-carousel__wrapper">
          
          <!-- Carousel Track -->
          <div class="featured-products-carousel__track-container">
            <div class="featured-products-carousel__track" data-carousel-track="{{ section.id }}">
            
            {%- assign collection_name = section.settings.selected_collection | downcase | strip -%}
            {%- assign found_collection = false -%}
            
            {%- for c in collections -%}
              {%- if c.title | downcase | strip == collection_name -%}
                {%- assign found_collection = true -%}
                
                {%- if c.products.size > 0 -%}
                  {%- for product in c.products -%}
                    <a href="{{ product.url | default: '#' }}" 
                       class="featured-products-carousel__card {{ section.settings.card_background_color | default: 'bg-neutral-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                    
                      <!-- Card Image with Hover -->
                      <div class="featured-products-carousel__card-image-wrapper">
                        {%- if product.images.first.src != blank -%}
                          <img src="{{ product.images.first.src }}"
                               alt="{{ product.title | default: 'Product' }}"
                               class="featured-products-carousel__card-image featured-products-carousel__card-image--default"
                               loading="lazy">
                        {%- else -%}
                          <img src="{{ 'placeholder-image.png' | asset_url }}"
                               alt="Placeholder"
                               class="featured-products-carousel__card-image featured-products-carousel__card-image--default">
                        {%- endif -%}
                        
                        {%- if product.images[1].src != blank -%}
                          <img src="{{ product.images[1].src }}"
                               alt="{{ product.title | default: 'Product' }}"
                               class="featured-products-carousel__card-image featured-products-carousel__card-image--hover"
                               loading="lazy">
                        {%- endif -%}
                      </div>

                      <!-- Card Content -->
                      <div class="featured-products-carousel__card-content">
                        
                        <!-- Product Title -->
                        <h3 class="featured-products-carousel__card-title {{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-base' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_title_font_weight | default: 'font-semibold' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                          {{ product.title | default: 'Product Title' }}
                        </h3>

                        <!-- Product Price -->
                        <div class="featured-products-carousel__card-price {{ section.settings.card_price_font_family | default: 'font-body' }} {{ section.settings.card_price_font_size | default: 'text-lg' }} {{ section.settings.card_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.card_price_font_weight | default: 'font-semibold' }} {{ section.settings.card_price_color | default: 'text-black' }}">
                          {{ product.price | default: '$0.00' }}
                      </div>

                        <!-- Product Rating -->
                        {%- if section.settings.show_ratings and product.ratings -%}
                          <div class="featured-products-carousel__card-rating">
                            <div class="featured-products-carousel__stars">
                              {%- assign rating = product.ratings | round -%}
                              {%- for i in (1..5) -%}
                                {%- if i <= rating -%}
                                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                                  </svg>
                                {%- else -%}
                                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                                  </svg>
                                {%- endif -%}
                              {%- endfor -%}
                            </div>
                            {%- if product.reviews.size > 0 -%}
                              <span class="featured-products-carousel__review-count {{ section.settings.card_review_font_family | default: 'font-body' }} {{ section.settings.card_review_font_size | default: 'text-xs' }} {{ section.settings.card_review_color | default: 'text-neutral-dark' }}">
                                ({{ product.reviews.size }})
                              </span>
                            {%- endif -%}
                          </div>
                        {%- endif -%}

                        <!-- Product Description -->
                        {%- if section.settings.show_descriptions and product.short_description != blank -%}
                          <p class="featured-products-carousel__card-description {{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-sm' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_description_font_weight | default: 'font-light' }} {{ section.settings.card_description_color | default: 'text-neutral-dark' }}">
                            {{ product.short_description }}
                          </p>
                        {%- endif -%}
                        
                      </div>

                    </a>
                  {%- endfor -%}
                {%- else -%}
                  <!-- No products in collection -->
                  <div class="featured-products-carousel__card {{ section.settings.card_background_color | default: 'bg-neutral-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                    <div class="featured-products-carousel__card-image-wrapper">
                        <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="No products"
                           class="featured-products-carousel__card-image featured-products-carousel__card-image--default">
                    </div>
                    <div class="featured-products-carousel__card-content">
                      <h3 class="featured-products-carousel__card-title {{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-base' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_title_font_weight | default: 'font-semibold' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                        No products found
                      </h3>
                    </div>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            
            {%- unless found_collection -%}
              <!-- Collection not found -->
              <div class="featured-products-carousel__card {{ section.settings.card_background_color | default: 'bg-neutral-light' }} {{ section.settings.card_border_radius | default: 'rounded-lg' }}">
                <div class="featured-products-carousel__card-image-wrapper">
                  <img src="{{ 'placeholder-image.png' | asset_url }}" 
                       alt="Collection not found"
                       class="featured-products-carousel__card-image featured-products-carousel__card-image--default">
                  </div>
                <div class="featured-products-carousel__card-content">
                  <h3 class="featured-products-carousel__card-title {{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-base' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_title_font_weight | default: 'font-semibold' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                    Collection "{{ section.settings.selected_collection }}" not found
                  </h3>
            </div>
          </div>
            {%- endunless -%}
            
          </div>
        </div>

        </div>

        <!-- Navigation Buttons (Below Cards, Right Aligned) -->
        <div class="featured-products-carousel__nav-wrapper">
          <button class="featured-products-carousel__nav featured-products-carousel__nav--prev" 
                  aria-label="Previous slide"
                  data-carousel-prev="{{ section.id }}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button class="featured-products-carousel__nav featured-products-carousel__nav--next" 
                  aria-label="Next slide"
                  data-carousel-next="{{ section.id }}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

    </div>
  </div>
</section>

<link rel="stylesheet" href="{{ 'featured-products-carousel/styles.css' | asset_url }}">

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const track = document.querySelector(`[data-carousel-track="${sectionId}"]`);
  const prevBtn = document.querySelector(`[data-carousel-prev="${sectionId}"]`);
  const nextBtn = document.querySelector(`[data-carousel-next="${sectionId}"]`);
  
  if (!track || !prevBtn || !nextBtn) return;
  
  const cards = track.querySelectorAll('.featured-products-carousel__card');
  let currentIndex = 0;
  
  function getVisibleCards() {
    if (window.innerWidth >= 1024) return 4;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }
  
  function updateCarousel() {
    const visibleCards = getVisibleCards();
    const cardWidth = cards[0].offsetWidth;
    const gap = 16; // Matches --space-lg
    const offset = currentIndex * (cardWidth + gap);
    
    track.style.transform = `translateX(-${offset}px)`;
    
    // Update button states
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex >= cards.length - visibleCards;
  }
  
  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  });
  
  nextBtn.addEventListener('click', () => {
    const visibleCards = getVisibleCards();
    if (currentIndex < cards.length - visibleCards) {
      currentIndex++;
      updateCarousel();
    }
  });
  
  // Reset on resize
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      currentIndex = 0;
      updateCarousel();
    }, 250);
  });
  
  // Initialize
  updateCarousel();
  
  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });
  
  track.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  });
  
  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        // Swipe left - next
        nextBtn.click();
      } else {
        // Swipe right - prev
        prevBtn.click();
      }
    }
  }
})();
</script>

