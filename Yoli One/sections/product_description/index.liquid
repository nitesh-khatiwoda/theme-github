<div class="pack-description">
  <!-- Rating Section -->
  {% if section.settings.show_reviews %}
    <div class="rating-section" data-fluid-element="CQsJ0R4Z">
      {% assign product = products[0] %}
      <script>
        console.log('product:', {{ product | json }});
      </script>
      {% if product.ratings and product.ratings > 0 %}
        <div class="stars {{ section.settings.stars_color | default: 'stars-yellow' }} {{ section.settings.stars_size | default: 'stars-md' }}" data-fluid-element="I2yYs5XY">
          {% for i in (1..product.ratings) %}
            <svg class="star-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.787 1.401 8.168L12 18.896 4.665 23.166l1.401-8.168L.132 9.211l8.2-1.193z"/></svg>
          {% endfor %}
          {% assign blank_stars = 5 | minus: product.ratings %}
          {% for i in (1..blank_stars) %}
            <svg class="star-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.787 1.401 8.168L12 18.896 4.665 23.166l1.401-8.168L.132 9.211l8.2-1.193z"/></svg>
          {% endfor %}
        </div>
      {% else %}
        <div class="stars {{ section.settings.stars_color | default: 'stars-yellow' }} {{ section.settings.stars_size | default: 'stars-md' }}" data-fluid-element="tb6xOYDA">
          {% for i in (1..5) %}
            <svg class="star-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 .587l3.668 7.431 8.2 1.193-5.934 5.787 1.401 8.168L12 18.896 4.665 23.166l1.401-8.168L.132 9.211l8.2-1.193z"/></svg>
          {% endfor %}
        </div>
      {% endif %}
      <div class="rating-text eina-2-font {{ section.settings.rating_text_font_size }} {{ section.settings.rating_text_font_size_mobile }} {{ section.settings.rating_text_font_weight }} {{ section.settings.rating_text_color }}" data-fluid-element="RgilW3z0">500,000+ Happy Partners</div>
    </div>
  {% endif %}
  
  <!-- Product Title -->
  <h1 class="product-title title heading-color heading-letter-spacing {{ section.settings.product_title_font_size }} {{ section.settings.product_title_font_size_mobile }} {{ section.settings.product_title_font_weight }}" data-fluid-element="dusXK6mr">{{ enrollment_pack.title }}</h1>
  
  <!-- Product Subtitle -->
  <p class="product-subtitle {{ section.settings.product_subtitle_font_size }} {{ section.settings.product_subtitle_font_size_mobile }} {{ section.settings.product_subtitle_font_weight }}" data-fluid-element="mk6wUW4V">{{ section.settings.subtitle }}</p>
  
  <!-- Product Description -->
  <div class="product-description {{ section.settings.product_description_font_size }} {{ section.settings.product_description_font_size_mobile }} {{ section.settings.product_description_font_weight }}" data-fluid-element="tEPj37VY">
    {{ enrollment_pack.description }}
  </div>
</div>

