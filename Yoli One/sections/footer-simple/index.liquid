<link rel="stylesheet" href="{{ 'main_footer/styles.css' | asset_url }}">

{%- style -%}
  footer.site-footer {
    background-color: {{ section.settings.footer_bg_color | default: '#161716' }};
  }

  footer.site-footer .footer-cta-section {
    background-color: {{ section.settings.cta_bg_color | default: '#323429' }};
  }
{%- endstyle -%}

{% unless request.page_type == 'medium' or request.page_type == 'library' %}   
  <!-- New Footer Design -->
  <footer class="site-footer">
    <div class="footer-container">
      
      <!-- Left Section: Main Footer Content -->
      <div class="footer-main-content">
        <div class="footer-inner">
          
          <!-- Navigation Columns -->
          <div class="footer-nav-columns">
            
            <!-- Column 1 -->
            {% if section.settings.menu_column_1 and section.settings.menu_column_1.menu_items %}
            <div class="footer-column">
              {% for item in section.settings.menu_column_1.menu_items %}
                <div class="footer-link">
                  <a href="{{ item.url }}">{{ item.title }}</a>
                </div>
              {% endfor %}
            </div>
            {% endif %}
            
            <!-- Column 2 -->
            {% if section.settings.menu_column_2 and section.settings.menu_column_2.menu_items %}
            <div class="footer-column">
              {% for item in section.settings.menu_column_2.menu_items %}
                <div class="footer-link">
                  <a href="{{ item.url }}">{{ item.title }}</a>
                </div>
              {% endfor %}
            </div>
            {% endif %}
            
            <!-- Column 3 -->
            {% if section.settings.menu_column_3 and section.settings.menu_column_3.menu_items %}
            <div class="footer-column">
              {% for item in section.settings.menu_column_3.menu_items %}
                <div class="footer-link {% if item.title contains 'Privacy' or item.title contains 'privacy' %}has-badge{% endif %}">
                  <a href="{{ item.url }}">{{ item.title }}</a>
                  {% if item.title contains 'Privacy' or item.title contains 'privacy' %}
                    <span class="footer-badge">{{ section.settings.privacy_badge_text | default: 'updated' }}</span>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
            {% endif %}
            
          </div>
          
          <!-- Social Media Icons -->
          <div class="footer-social-icons">
            <a href="{{ section.settings.social_facebook | default: '#' }}" aria-label="Facebook" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="white"/>
                </svg>
              </a>
            <a href="{{ section.settings.social_instagram | default: '#' }}" aria-label="Instagram" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M16 4H8C5.23858 4 3 6.23858 3 9V17C3 19.7614 5.23858 22 8 22H16C18.7614 22 21 19.7614 21 17V9C21 6.23858 18.7614 4 16 4ZM19.25 17C19.2445 18.7926 17.7926 20.2445 16 20.25H8C6.20735 20.2445 4.75549 18.7926 4.75 17V9C4.75549 7.20735 6.20735 5.75549 8 5.75H16C17.7926 5.75549 19.2445 7.20735 19.25 9V17ZM16.75 9.25C17.3023 9.25 17.75 8.80228 17.75 8.25C17.75 7.69772 17.3023 7.25 16.75 7.25C16.1977 7.25 15.75 7.69772 15.75 8.25C15.75 8.80228 16.1977 9.25 16.75 9.25ZM12 8.5C9.51472 8.5 7.5 10.5147 7.5 13C7.5 15.4853 9.51472 17.5 12 17.5C14.4853 17.5 16.5 15.4853 16.5 13C16.5027 11.8057 16.0294 10.6596 15.1849 9.81508C14.3404 8.97057 13.1943 8.49733 12 8.5ZM9.25 13C9.25 14.5188 10.4812 15.75 12 15.75C13.5188 15.75 14.75 14.5188 14.75 13C14.75 11.4812 13.5188 10.25 12 10.25C10.4812 10.25 9.25 11.4812 9.25 13Z" fill="white"/>
                </svg>
              </a>
            <a href="{{ section.settings.social_pinterest | default: '#' }}" aria-label="Pinterest" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z" fill="white"/>
                </svg>
              </a>
            <a href="{{ section.settings.social_twitter | default: '#' }}" aria-label="Twitter" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="white"/>
                </svg>
              </a>
          </div>
          
          <!-- Certification Logos -->
          <div class="footer-certifications">
            {% if section.settings.certification_1_image %}
              <a href="{{ section.settings.certification_1_url | default: '#' }}" class="certification-logo">
                <img src="{{ section.settings.certification_1_image | image_url: width: 164 }}" alt="{{ section.settings.certification_1_alt | default: 'Certification' }}" loading="lazy">
              </a>
            {% endif %}
            {% if section.settings.certification_2_image %}
              <a href="{{ section.settings.certification_2_url | default: '#' }}" class="certification-logo">
                <img src="{{ section.settings.certification_2_image | image_url: width: 164 }}" alt="{{ section.settings.certification_2_alt | default: 'Certification' }}" loading="lazy">
              </a>
            {% endif %}
          </div>
          
          <!-- Bottom Section -->
          <div class="footer-bottom">
            <div class="footer-legal-text">
              <p class="copyright">© {{ 'now' | date: '%Y' }} {{ section.settings.company_name | default: company.name }}</p>
              <a href="{{ section.settings.sitemap_url | default: '/pages/sitemap' }}" class="footer-bottom-link">Site map</a>
              <a href="{{ section.settings.privacy_choices_url | default: '#' }}" class="footer-bottom-link">Your privacy choices</a>
            </div>
            
            <!-- Disclaimer Box -->
            <div class="footer-disclaimer">
              <p>{{ section.settings.disclaimer_text | default: '*These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure or prevent any disease.' }}</p>
            </div>
          </div>
          
        </div>
      </div>
      
      <!-- Right Section: CTA -->
      <div class="footer-cta-section">
        <div class="footer-cta-content">
          <h2 class="footer-cta-heading">{{ section.settings.cta_heading | default: 'Lorem Ipsum' }}</h2>
          <a href="{{ section.settings.cta_button_url | default: '#' }}" class="footer-cta-button">
            {{ section.settings.cta_button_text | default: 'Lorem Ipsum' }}
          </a>
        </div>
      </div>
      
    </div>
  </footer>
{% endunless %}

{% schema %}
{
  "name": "footer-simple",
  "settings": [
    {
      "type": "header",
      "content": "Footer Colors"
    },
    {
      "type": "color_background",
      "id": "footer_bg_color",
      "label": "Footer Background Color",
      "default": "#161716"
    },
    {
      "type": "color_background",
      "id": "cta_bg_color",
      "label": "CTA Section Background Color",
      "default": "#323429"
    },
    {
      "type": "header",
      "content": "Navigation Columns"
    },
    {
      "type": "link_list",
      "id": "menu_column_1",
      "label": "Column 1 Menu",
      "default": ""
    },
    {
      "type": "link_list",
      "id": "menu_column_2",
      "label": "Column 2 Menu",
      "default": ""
    },
    {
      "type": "link_list",
      "id": "menu_column_3",
      "label": "Column 3 Menu",
      "default": ""
    },
    {
      "type": "text",
      "id": "privacy_badge_text",
      "label": "Privacy Badge Text",
      "default": "updated",
      "info": "Badge shown next to Privacy policy link"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "header",
      "content": "Certifications"
    },
    {
      "type": "image_picker",
      "id": "certification_1_image",
      "label": "Certification Logo 1"
    },
    {
      "type": "url",
      "id": "certification_1_url",
      "label": "Certification 1 URL"
    },
    {
      "type": "text",
      "id": "certification_1_alt",
      "label": "Certification 1 Alt Text",
      "default": "B Corporation"
    },
    {
      "type": "image_picker",
      "id": "certification_2_image",
      "label": "Certification Logo 2"
    },
    {
      "type": "url",
      "id": "certification_2_url",
      "label": "Certification 2 URL"
    },
    {
      "type": "text",
      "id": "certification_2_alt",
      "label": "Certification 2 Alt Text",
      "default": "Climate Neutral"
    },
    {
      "type": "header",
      "content": "Footer Bottom"
    },
    {
      "type": "text",
      "id": "company_name",
      "label": "Company Name",
      "default": "Your Company Inc"
    },
    {
      "type": "url",
      "id": "sitemap_url",
      "label": "Site Map URL",
      "default": "/pages/sitemap"
    },
    {
      "type": "url",
      "id": "privacy_choices_url",
      "label": "Privacy Choices URL"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "*These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure or prevent any disease."
    },
    {
      "type": "header",
      "content": "CTA Section"
    },
    {
      "type": "textarea",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Lorem Ipsum"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Lorem Ipsum"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "CTA Button URL"
    }
  ]
}
{% endschema %}
