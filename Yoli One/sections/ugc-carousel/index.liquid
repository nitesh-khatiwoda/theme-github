<link rel="stylesheet" href="{{ 'ugc-carousel/styles.css' | asset_url }}">

<!-- UGC Carousel Section -->
<section class="ugc-carousel {{ section.settings.background_color | default: 'bg-page' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="ugc-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="ugc-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header -->
      <div class="ugc-header">
        <div class="header-left">
          {% if section.settings.heading != blank or section.settings.heading_highlight != blank %}
          <div class="ugc-heading">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
              {% if section.settings.heading != blank %}{{ section.settings.heading }}{% endif %}
              {% if section.settings.heading_highlight != blank %}
              <span class="{{ section.settings.highlight_color | default: 'text-accent' }}">{{ section.settings.heading_highlight }}</span>
              {% endif %}
              {% if section.settings.heading_suffix != blank %}{{ section.settings.heading_suffix }}{% endif %}
            </h2>
          </div>
          {% endif %}
          
          {% if section.settings.subheading != blank %}
          <div class="ugc-subheading">
            <p class="{{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-base' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-primary' }} leading-body">
              {{ section.settings.subheading }}
            </p>
          </div>
          {% endif %}
        </div>
        
        <div class="header-right">
          {% if section.settings.show_button %}
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
            {{ section.settings.button_text | default: 'Join now' }}
          </a>
          {% endif %}
        </div>
      </div>
      
      <!-- Carousel -->
      {% if section.blocks.size > 0 %}
      <div class="ugc-carousel-wrapper">
        <div class="ugc-carousel-track" data-ugc-track>
          {% for block in section.blocks %}
            {% if block.type == 'testimonial' %}
            <div class="ugc-card" {{ block.fluid_attributes }}>
              
              <div class="ugc-card-image {{ section.settings.card_border_radius | default: 'rounded' }}">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.author | default: 'Member' }}" loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
                {% endif %}
                
                <!-- Quote Overlay -->
                <div class="ugc-quote-overlay {{ section.settings.quote_bg | default: 'bg-card-primary' }} {{ section.settings.quote_overlay_border_radius | default: 'rounded' }}">
                  <div class="quote-mark {{ section.settings.quote_color | default: 'text-accent' }}">"</div>
                  <div class="quote-content">
                    <p class="{{ section.settings.quote_font_family | default: 'font-body' }} {{ section.settings.quote_font_size | default: 'text-base' }} {{ section.settings.quote_font_weight | default: 'font-normal' }} {{ section.settings.quote_color | default: 'text-accent' }} leading-body">
                      {{ block.settings.quote }}
                    </p>
                    <p class="quote-author {{ section.settings.author_font_family | default: 'font-body' }} {{ section.settings.author_font_size | default: 'text-sm' }} font-semibold {{ section.settings.author_color | default: 'text-accent' }}">
                      {{ block.settings.author }}
                    </p>
                  </div>
                </div>
              </div>
              
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      
      <!-- Navigation Arrows (Below carousel, right aligned) -->
      <div class="carousel-nav">
        <button class="nav-btn nav-prev" aria-label="Previous" data-ugc-prev>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="nav-btn nav-next" aria-label="Next" data-ugc-next>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

<script>
  // UGC Carousel Functionality
  (function() {
    const track = document.querySelector('[data-ugc-track]');
    const prevBtn = document.querySelector('[data-ugc-prev]');
    const nextBtn = document.querySelector('[data-ugc-next]');
    
    if (!track || !prevBtn || !nextBtn) return;
    
    let currentPosition = 0;
    const cardWidth = 437.33 + 20; // card width + gap
    const visibleCards = 3; // Show 3 cards at a time
    const totalCards = track.children.length;
    const maxPosition = -(cardWidth * (totalCards - visibleCards));
    
    function updatePosition() {
      track.style.transform = `translateX(${currentPosition}px)`;
      
      // Update button states
      prevBtn.style.opacity = currentPosition === 0 ? '0.6' : '1';
      nextBtn.style.opacity = currentPosition <= maxPosition ? '0.6' : '1';
    }
    
    prevBtn.addEventListener('click', () => {
      if (currentPosition < 0) {
        currentPosition += cardWidth;
        if (currentPosition > 0) currentPosition = 0;
        updatePosition();
      }
    });
    
    nextBtn.addEventListener('click', () => {
      if (currentPosition > maxPosition) {
        currentPosition -= cardWidth;
        if (currentPosition < maxPosition) currentPosition = maxPosition;
        updatePosition();
      }
    });
    
    updatePosition();
  })();
</script>

