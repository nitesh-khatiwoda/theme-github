<link rel="stylesheet" href="{{ 'faq-accordion/styles.css' | asset_url }}">

<!-- FAQ Accordion Section -->
<section class="faq-accordion {{ section.settings.background_color | default: 'bg-secondary-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-lg' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="faq-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="faq-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.heading != blank %}
      <div class="faq-heading mb-lg text-center">
        <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="letter-spacing: -0.03em;">
          {{ section.settings.heading }}
        </h2>
      </div>
      {% endif %}
      
      <!-- FAQ Grid -->
      {% if section.blocks.size > 0 %}
      <div class="faq-grid mb-xl">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
          
          <div class="faq-item {{ section.settings.item_background_color | default: 'bg-secondary-light' }}" {{ block.fluid_attributes }} style="border: 1px solid {{ section.settings.item_border_color | default: '#000000' }}; border-radius: {{ section.settings.item_border_radius | default: '13' }}px;">
            
            <!-- Question Button -->
            <button class="faq-question" type="button" aria-expanded="false">
              <span class="{{ block.settings.question_font_size | default: 'text-lg' }} {{ block.settings.question_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.question_font_weight | default: 'font-medium' }} {{ block.settings.question_color | default: 'text-black' }}">
                {{ block.settings.question | default: 'Question goes here?' }}
              </span>
              
              <!-- Plus/Minus Icon -->
              <span class="faq-icon">
                <svg class="icon-plus" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="26" height="26" rx="2.5" stroke="currentColor"/>
                  <line x1="13.5" y1="6" x2="13.5" y2="21" stroke="currentColor" stroke-width="2"/>
                  <line x1="6" y1="13.5" x2="21" y2="13.5" stroke="currentColor" stroke-width="2"/>
                </svg>
                <svg class="icon-minus" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0.5" y="0.5" width="26" height="26" rx="2.5" stroke="currentColor"/>
                  <line x1="6" y1="13.5" x2="21" y2="13.5" stroke="currentColor" stroke-width="2"/>
                </svg>
              </span>
            </button>
            
            <!-- Answer Panel -->
            <div class="faq-answer">
              <div class="faq-answer-content">
                <p class="{{ block.settings.answer_font_size | default: 'text-base' }} {{ block.settings.answer_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.answer_font_weight | default: 'font-normal' }} {{ block.settings.answer_color | default: 'text-black' }} leading-body">
                  {{ block.settings.answer | default: 'Answer goes here.' }}
                </p>
              </div>
            </div>
            
          </div>
          
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
      <!-- CTA Section -->
      <div class="faq-cta text-center">
        
        <!-- CTA Button -->
        {% if section.settings.show_button %}
        <div class="mb-sm">
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
            {{ section.settings.button_text | default: 'Try Lorem Risk-Free Today' }}
          </a>
        </div>
        {% endif %}
        
      </div>
      
    </div>
  </div>
  
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize all FAQ accordions
  const faqItems = document.querySelectorAll('#faq-{{ section.id }} .faq-item');
  
  faqItems.forEach(item => {
    const button = item.querySelector('.faq-question');
    const answer = item.querySelector('.faq-answer');
    
    if (button && answer) {
      button.addEventListener('click', function() {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        // Toggle current item
        button.setAttribute('aria-expanded', !isExpanded);
        item.classList.toggle('is-open');
        
        if (!isExpanded) {
          // Open
          answer.style.maxHeight = answer.scrollHeight + 'px';
        } else {
          // Close
          answer.style.maxHeight = '0px';
        }
      });
    }
  });
});
</script>

