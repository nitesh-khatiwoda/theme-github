<link rel="stylesheet" href="{{ 'testimonials-videos-grid/styles.css' | asset_url }}">



{% comment %} Count visible blocks {% endcomment %}
{% assign visible_block_count = 0 %}
{% for block in section.blocks %}
  {% if block.type == 'testimonial' %}
    {% assign visible_block_count = visible_block_count | plus: 1 %}
  {% elsif block.type == 'video_card' and section.settings.hide_video_blocks != true %}
    {% assign visible_block_count = visible_block_count | plus: 1 %}
  {% endif %}
{% endfor %}

{% comment %} Calculate actual column counts (capped by visible items) {% endcomment %}
{% assign cols_mobile = section.settings.columns_mobile | default: 1 %}
{% assign cols_tablet = section.settings.columns_tablet | default: 2 %}
{% assign cols_desktop = section.settings.columns_desktop | default: 4 %}

{% if visible_block_count < cols_mobile %}{% assign cols_mobile = visible_block_count %}{% endif %}
{% if visible_block_count < cols_tablet %}{% assign cols_tablet = visible_block_count %}{% endif %}
{% if visible_block_count < cols_desktop %}{% assign cols_desktop = visible_block_count %}{% endif %}

<!-- Testimonials & Videos Grid Section -->
<section class="carousel-section testimonials-videos-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}}  {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="testimonials-videos-grid-{{ section.id }}" {% if section.settings.background_image %}style="background-image: url('{{ section.settings.background_image | image_url }}');"{% endif %}>

  <!-- Gradient Overlays -->
  {% if section.settings.show_top_gradient %}
  <div class="gradient-overlay gradient-overlay--top" style="--gradient-color: var(--clr-{{ section.settings.top_gradient_color | default: 'black' }}); --gradient-height: {{ section.settings.top_gradient_height | default: 150 }}px;"></div>
  {% endif %}
  {% if section.settings.show_bottom_gradient %}
  <div class="gradient-overlay gradient-overlay--bottom" style="--gradient-color: var(--clr-{{ section.settings.bottom_gradient_color | default: 'black' }}); --gradient-height: {{ section.settings.bottom_gradient_height | default: 150 }}px;"></div>
  {% endif %}

  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="testimonials-videos-carousel-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}style="background-image: url('{{ section.settings.container_background_image | image_url }}');"{% endif %}>

      <!-- Section Heading -->
      {% if section.settings.show_heading and section.settings.heading != blank %}
      <div class="section-heading text-{{ section.settings.heading_alignment | default: 'center' }} mb-xl lg:mb-2xl">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }}">
          {{ section.settings.heading }}
        </h2>
        {% if section.settings.description != blank %}
        <div class="section-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
      </div>
      {% endif %}

      <!-- Grid -->
     size: {{  section.blocks.size}}
      {% if section.blocks.size > 0 %}
      <div class="testimonial-carousel cards-grid layout-masonry-- mobile-scroll-- {% if section.settings.content_based_height %}content-based-height{% endif %}" data-cols-mobile="{{ cols_mobile }}" data-cols-tablet="{{ cols_tablet }}" data-cols-desktop="{{ cols_desktop }}" data-carousel-item="{{ section.settings.carousel_item}}">
        {% for block in section.blocks %}
          
           
            <!-- Testimonial Card -->
            {% assign card_padding = section.settings.testimonial_card_padding | default: 'medium' %}
            {% case card_padding %}
              {% when 'small' %}
                {% assign padding_classes = 'pt-md lg:pt-lg pb-md lg:pb-lg px-md lg:px-lg' %}
              {% when 'medium' %}
                {% assign padding_classes = 'pt-lg lg:pt-xl pb-lg lg:pb-xl px-lg lg:px-xl' %}
              {% when 'large' %}
                {% assign padding_classes = 'pt-xl lg:pt-2xl pb-xl lg:pb-2xl px-xl lg:px-2xl' %}
              {% else %}
                {% assign padding_classes = 'pt-lg lg:pt-xl pb-lg lg:pb-xl px-lg lg:px-xl' %}
            {% endcase %}
            {% if section.settings.hide_video_blocks %}
              {% assign card_class = "enable-min-height" %}
            {% else %}
               {% assign card_class = "enable-fix-height" %}
            {% endif %}
            <div class="carousel-wrappper">
              <div class="testimonial-card {{card_class}} {{ section.settings.testimonial_card_background | default: 'bg-neutral-light' }} {{ section.settings.testimonial_card_border_radius | default: 'rounded-md' }} {{ padding_classes }} {% if section.settings.show_card_shadows %}card-with-shadow{% endif %}" {{ block.fluid_attributes }}>

                <!-- Stars Rating -->
                {% if section.settings.show_stars %}
                <div class="stars-rating stars-size-{{ section.settings.star_size | default: 'medium' }}">
                  {% assign star_rating = block.settings.star_rating | default: 5 %}
                  {% assign full_stars = star_rating | floor %}
                  {% assign empty_stars = 5 | minus: full_stars %}

                  {% comment %} Full stars {% endcomment %}
                  {% if full_stars > 0 %}
                    {% for i in (1..full_stars) %}
                      <span class="star star-full {{ section.settings.star_color_filled | default: 'text-warning' }}">{{ section.settings.star_character | default: '★' }}</span>
                    {% endfor %}
                  {% endif %}

                  {% comment %} Empty stars {% endcomment %}
                  {% if empty_stars > 0 %}
                    {% for i in (1..empty_stars) %}
                      <span class="star star-empty {{ section.settings.star_color_empty | default: 'text-neutral-light' }}">{{ section.settings.star_character | default: '★' }}</span>
                    {% endfor %}
                  {% endif %}
                </div>
                {% endif %}

                <!-- Review Text -->
                {% if block.settings.review_text != blank %}
                <p class="review-text {{ section.settings.review_font_family | default: 'font-body' }} {{ section.settings.review_font_size | default: 'text-lg' }} {{ section.settings.review_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.review_font_weight | default: 'font-normal' }} {{ section.settings.review_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.review_text }}
                  </p>
                {% endif %}

                <!-- Author Info -->
                {% if block.settings.author_name != blank or block.settings.author_avatar != blank %}
                <div class="testimonial-author">
                  {% if block.settings.author_avatar != blank %}
                  <div class="testimonial-author-avatar">
                    <img src="{{ block.settings.author_avatar | image_url: width: 80 }}" alt="{{ block.settings.author_name | default: 'Author' }}" class="author-avatar-image">
                  </div>
                  {% endif %}
                  {% if block.settings.author_name != blank %}
                  <span class="testimonial-author-name {{ section.settings.name_font_family | default: 'font-body' }} {{ section.settings.name_font_size | default: 'text-base' }} {{ section.settings.name_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.name_font_weight | default: 'font-semibold' }} {{ section.settings.name_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.author_name }}
                  </span>
                  {% endif %}
                </div>
                {% endif %}

              </div>
            </div>
            
            {% unless section.settings.hide_video_blocks %}
            <!-- Video Card -->
              <div class="carousel-wrapper">
                <div class="video-card {{ section.settings.video_card_background | default: 'bg-black' }} {{ section.settings.video_card_border_radius | default: 'rounded-md' }} {% if section.settings.show_card_shadows %}card-with-shadow{% endif %}" {{ block.fluid_attributes }}>

                <!-- Video Content -->
                <div class="video-thumbnail-wrapper">
                {% if block.settings.video_url != blank %}
                  <video
                    class="video-element"
                    autoplay
                    muted
                    loop
                    playsinline
                    {% if block.settings.poster_image %}poster="{{ block.settings.poster_image | image_url: width: 600 }}"{% endif %}
                  >
                    <source src="{{ block.settings.video_url }}" type="video/mp4">
                  </video>
                {% elsif block.settings.poster_image != blank %}
                  <img src="{{ block.settings.poster_image | image_url: width: 600 }}"
                        alt="{{ block.settings.title | default: 'Video thumbnail' }}"
                        class="video-thumbnail"
                        loading="lazy">

                  <!-- Play Button Overlay -->
                  {% if section.settings.show_play_button %}
                  <div class="play-button-overlay">
                    <svg class="play-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6.66667 4.16667L15.8333 10L6.66667 15.8333V4.16667Z" fill="currentColor"/>
                    </svg>
                  </div>
                  {% endif %}
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}"
                        alt="Add video URL to display video"
                        class="video-thumbnail"
                        loading="lazy">

                  <!-- Play Button Overlay (placeholder only) -->
                  {% if section.settings.show_play_button %}
                  <div class="play-button-overlay">
                    <svg class="play-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6.66667 4.16667L15.8333 10L6.66667 15.8333V4.16667Z" fill="currentColor"/>
                    </svg>
                  </div>
                  {% endif %}
                {% endif %}
              </div>

              </div>
            </div>
            {% endunless %}
        {% endfor %}
      </div>


      <div class="mobile-scroll-nav {% if section.settings.mobile_scroll_controls_layout == 'dots_left' %}controls-layout-reversed{% endif %}">
        <div class="scroll-arrows">
          <button class="scroll-arrow scroll-arrow-prev {{ section.settings.mobile_nav_button_background | default: 'bg-white' }} {{ section.settings.mobile_nav_button_color | default: 'text-black' }}" aria-label="Previous slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <button class="scroll-arrow scroll-arrow-next {{ section.settings.mobile_nav_button_background | default: 'bg-white' }} {{ section.settings.mobile_nav_button_color | default: 'text-black' }}" aria-label="Next slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
        {% if section.settings.show_mobile_scroll_dots %}
          {% assign dots_class ="" %}
        {% else %}
          {% assign dots_class ="hidden" %}
        {% endif %}
        <div class="scroll-dots {{ dots_class}}"></div>
      </div>
      {% endif %}

    </div>
  </div>

</section>
 <script>
        
    function carousel() {
      var numSlick = 0;
      const carouselSelector = $('.testimonial-carousel');
  
      // Destroy previous instance
      carouselSelector.each(function () {
        if ($(this).hasClass('slick-initialized')) {
          $(this).slick('unslick');
        }
      });
      
      
      $(carouselSelector).each(function(){
        var carousel_item = $(this).data('carousel-item')
        numSlick++;
        $(this).closest(".carousel-section").find(".scroll-dots").addClass("scroll-dots-"+ numSlick);
        $(this).closest(".carousel-section").find(".scroll-arrow-prev").addClass("scroll-arrow-prev-"+ numSlick);
        $(this).closest(".carousel-section").find(".scroll-arrow-next").addClass("scroll-arrow-next-"+ numSlick);
        $(this).slick({
          infinite: true,
          slidesToShow: 1, 
          slidesToScroll: 1,
          initialSlide: 0,
          dots: true,
          arrows: true,
          mobileFirst: true,
          centerMode: true,
          centerPadding: '60px',
          
          prevArrow: $('.scroll-arrow-prev-'+numSlick),
          nextArrow: $('.scroll-arrow-next-'+numSlick),
          appendDots: $('.scroll-dots-'+numSlick),
          responsive: [
            {
              breakpoint: 600,
              settings: { 
               slidesToShow: 2,
              }
            },
            {
              breakpoint: 768,
              settings: { 
                 centerPadding: '120px',
                 slidesToShow: 2
              }
            },
            {
              breakpoint: 1024,
              settings: { 
                slidesToShow: carousel_item,
                centerPadding: '120px'
              }
            }
          ]
        });
      });
      
    }
    document.addEventListener("DOMContentLoaded", function(){
      carousel();
    });
  
  
</script>

