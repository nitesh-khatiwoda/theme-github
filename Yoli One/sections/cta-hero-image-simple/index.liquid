              <h2 class="heading-cycle-item cta-hero-image-simple-heading-text {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }}" style="line-height: 1;">
                {{ section.settings.heading_3 }}
