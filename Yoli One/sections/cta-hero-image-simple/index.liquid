          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-white' }}" style="line-height: 1.5;">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
        
        <!-- Buttons -->
        {% if section.settings.show_button or section.settings.show_secondary_button %}
        <div class="cta-hero-image-simple-buttons cta-hero-image-simple-buttons--{{ section.settings.button_position | default: 'left' }}">
          {% if section.settings.show_secondary_button and section.settings.button_position == 'right' %}
          <div class="cta-hero-image-simple-button">
            <a href="{{ section.settings.secondary_button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.secondary_button_style | default: 'outline' }}-{{ section.settings.secondary_button_color | default: 'white' }} {{ section.settings.secondary_button_size | default: 'btn-md' }} {{ section.settings.secondary_button_font_weight | default: 'font-medium' }} font-body {{ settings.button_border_radius | default: 'rounded-md' }}">
