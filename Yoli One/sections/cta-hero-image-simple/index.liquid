            <div class="heading-cycle-container" data-cycle-duration="{{ section.settings.heading_cycle_duration | default: 3 }}">
              {% if section.settings.heading_1 != blank %}
              <h2 class="heading-cycle-item active cta-hero-image-simple-heading-text {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }}" style="line-height: 1;">
                {{ section.settings.heading_1 }}
              </h2>
              {% endif %}
              {% if section.settings.heading_2 != blank %}
              <h2 class="heading-cycle-item cta-hero-image-simple-heading-text {{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-white' }}" style="line-height: 1;">
                {{ section.settings.heading_2 }}
