                <h2 class="top-heading-cycle-item opacity-0 active cta-hero-image-simple-heading-text {{ section.settings.top_heading_font_family | default: 'font-primary' }} {{ section.settings.top_heading_font_size | default: 'text-2xl' }} {{ section.settings.top_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.top_heading_font_weight | default: 'font-bold' }} {{ section.settings.top_heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ section.settings.top_heading_1 }}
                </h2>
                {% endif %}
                {% if section.settings.top_heading_2 != blank %}
                <h2 class="top-heading-cycle-item opacity-0 cta-hero-image-simple-heading-text {{ section.settings.top_heading_font_family | default: 'font-primary' }} {{ section.settings.top_heading_font_size | default: 'text-2xl' }} {{ section.settings.top_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.top_heading_font_weight | default: 'font-bold' }} {{ section.settings.top_heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ section.settings.top_heading_2 }}
                </h2>
                {% endif %}
                {% if section.settings.top_heading_3 != blank %}
                <h2 class="top-heading-cycle-item opacity-0 cta-hero-image-simple-heading-text {{ section.settings.top_heading_font_family | default: 'font-primary' }} {{ section.settings.top_heading_font_size | default: 'text-2xl' }} {{ section.settings.top_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.top_heading_font_weight | default: 'font-bold' }} {{ section.settings.top_heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ section.settings.top_heading_3 }}
                </h2>
                {% endif %}
                {% if section.settings.top_heading_4 != blank %}
                <h2 class="top-heading-cycle-item opacity-0 cta-hero-image-simple-heading-text {{ section.settings.top_heading_font_family | default: 'font-primary' }} {{ section.settings.top_heading_font_size | default: 'text-2xl' }} {{ section.settings.top_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.top_heading_font_weight | default: 'font-bold' }} {{ section.settings.top_heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ section.settings.top_heading_4 }}
                </h2>
                {% endif %}
                {% if section.settings.top_heading_5 != blank %}
                <h2 class="top-heading-cycle-item opacity-0 cta-hero-image-simple-heading-text {{ section.settings.top_heading_font_family | default: 'font-primary' }} {{ section.settings.top_heading_font_size | default: 'text-2xl' }} {{ section.settings.top_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.top_heading_font_weight | default: 'font-bold' }} {{ section.settings.top_heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ section.settings.top_heading_5 }}
                </h2>
                {% endif %}
                {% if section.settings.top_heading_6 != blank %}
                <h2 class="top-heading-cycle-item opacity-0 cta-hero-image-simple-heading-text {{ section.settings.top_heading_font_family | default: 'font-primary' }} {{ section.settings.top_heading_font_size | default: 'text-2xl' }} {{ section.settings.top_heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.top_heading_font_weight | default: 'font-bold' }} {{ section.settings.top_heading_color | default: 'text-white' }}" style="line-height: 1;">
                  {{ section.settings.top_heading_6 }}
