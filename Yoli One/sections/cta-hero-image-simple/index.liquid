            {% when '2' %}
              {% assign selected_heading = section.settings.heading_2 %}
            {% when '3' %}
              {% assign selected_heading = section.settings.heading_3 %}
            {% when '4' %}
              {% assign selected_heading = section.settings.heading_4 %}
            {% when '5' %}
              {% assign selected_heading = section.settings.heading_5 %}
            {% when '6' %}
