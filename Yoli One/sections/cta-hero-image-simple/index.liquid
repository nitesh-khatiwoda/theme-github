              {% when '1' %}
                {% assign selected_top_heading = section.settings.top_heading_1 %}
              {% when '2' %}
                {% assign selected_top_heading = section.settings.top_heading_2 %}
              {% when '3' %}
                {% assign selected_top_heading = section.settings.top_heading_3 %}
              {% when '4' %}
                {% assign selected_top_heading = section.settings.top_heading_4 %}
              {% when '5' %}
                {% assign selected_top_heading = section.settings.top_heading_5 %}
              {% when '6' %}
                {% assign selected_top_heading = section.settings.top_heading_6 %}
