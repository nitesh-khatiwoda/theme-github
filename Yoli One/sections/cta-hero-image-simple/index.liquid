<link rel="stylesheet" href="{{ 'cta-hero-image-simple/styles.css' | asset_url }}">

<!-- CTA Hero Image Simple Section -->
<section class="cta-hero-image-simple {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="cta-hero-image-simple-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}" style="--section-bg-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"{% endif %}>
  
  {% assign layout_width = section.settings.layout_width | default: 'full_width' %}
  {% assign height_mode = section.settings.height_mode | default: 'tall' %}
  {% assign base_height = section.settings.section_height | default: 500 %}
  {% if height_mode == 'double' %}
    {% assign final_height = base_height | times: 2 %}
  {% elsif height_mode == 'tall' %}
    {% assign final_height = base_height | times: 1.3 %}
  {% else %}
    {% assign final_height = base_height %}
  {% endif %}
  
  <!-- Hero Image/Video - Always Full Width -->
  <div class="cta-hero-image-simple-image-wrapper{% if height_mode == 'double' %} cta-hero-image-simple-image-wrapper--double{% elsif height_mode == 'tall' %} cta-hero-image-simple-image-wrapper--tall{% endif %}" style="min-height: {{ final_height }}px; --base-height: {{ base_height }}px; --tall-height: {{ final_height }}px;">
    {% if section.settings.video_url != blank %}
      <!-- Background Video -->
      <video
        class="cta-hero-image-simple-video cta-hero-image-simple-image--{{ section.settings.image_fit | default: 'cover' }}"
        autoplay
        muted
        loop
        playsinline
        style="object-fit: {{ section.settings.image_fit | default: 'cover' }};"
        {% if section.settings.hero_image %}poster="{{ section.settings.hero_image | image_url }}"{% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4" />
        {% if section.settings.hero_image %}
          <!-- Fallback to poster image if video fails to load -->
          <img 
            src="{{ section.settings.hero_image | image_url: width: 1200 }}" 
            alt="{{ section.settings.hero_image_alt | default: section.settings.heading | default: 'Hero image' }}"
            loading="lazy"
            class="cta-hero-image-simple-image cta-hero-image-simple-image--{{ section.settings.image_fit | default: 'cover' }}"
          >
        {% endif %}
      </video>
    {% elsif section.settings.hero_image != blank %}
      <!-- Background Image -->
      <img 
        src="{{ section.settings.hero_image | image_url: width: 1200 }}" 
        alt="{{ section.settings.hero_image_alt | default: section.settings.heading | default: 'Hero image' }}"
        loading="lazy"
        class="cta-hero-image-simple-image cta-hero-image-simple-image--{{ section.settings.image_fit | default: 'cover' }}"
      >
    {% else %}
      <!-- Placeholder Image -->
      <!-- <img 
        src="{{ 'placeholder-image.png' | asset_url }}" 
        alt="Hero image placeholder"
        loading="lazy"
        class="cta-hero-image-simple-image cta-hero-image-simple-image--{{ section.settings.image_fit | default: 'cover' }}"
      > -->
    {% endif %}
    
    <!-- Content Overlay -->
      {% assign horizontal_align = section.settings.content_alignment_horizontal | default: 'center' %}
      {% assign vertical_align = section.settings.content_alignment_vertical | default: 'center' %}
      {% assign text_justify = section.settings.text_justification | default: 'inherit' %}
      {% assign padding_x_mobile = section.settings.content_padding_x_mobile | default: 'px-lg' %}
      {% assign padding_x_tablet = section.settings.content_padding_x_tablet | default: 'md:px-xl' %}
      {% assign padding_x_desktop = section.settings.content_padding_x_desktop | default: 'lg:px-2xl' %}
      <div class="cta-hero-image-simple-content {% if layout_width == 'inline' %}cta-hero-image-simple-content--inline{% endif %} {{ padding_x_mobile }} {{ padding_x_tablet }} {{ padding_x_desktop }}{% if horizontal_align != 'center' %} cta-hero-image-simple-content--{{ horizontal_align }}{% endif %}{% if vertical_align != 'center' %} cta-hero-image-simple-content--{{ vertical_align }}{% endif %}{% if text_justify != 'inherit' %} cta-hero-image-simple-content--justify-{{ text_justify }}{% endif %}">
        
        <!-- Text Container Wrapper -->
        {% assign text_width_mobile = section.settings.text_container_width_mobile | default: 100 %}
        {% assign text_width_desktop = section.settings.text_container_width_desktop | default: 770 %}
        {% if horizontal_align == 'left' %}
          {% assign text_margin = 'margin-left: 0; margin-right: auto;' %}
        {% elsif horizontal_align == 'right' %}
          {% assign text_margin = 'margin-left: auto; margin-right: 0;' %}
        {% else %}
          {% assign text_margin = 'margin: 0 auto;' %}
        {% endif %}
        {% if layout_width == 'inline' %}
        <div class="container">
        {% endif %}
        <div class="cta-hero-image-simple-text-container " style="--text-width-mobile: {{ text_width_mobile }}%; --text-width-desktop: {{ text_width_desktop }}px; {{ text_margin }}">
        
        <!-- Top Heading -->
        {% if section.settings.show_top_heading %}
          {% assign top_heading_selection = section.settings.top_heading_selection | default: '1' %}
          
          {% if top_heading_selection == 'cycle' %}
            <!-- Cycling Mode - Show all headings with fade effect -->
            <div class="cta-hero-image-simple-heading mb-md">
              <div class="top-heading-cycle-container" data-cycle-duration="{{ section.settings.top_heading_cycle_duration | default: 3 }}">
