        {% endif %}
        
      </div>
  </div>
  
  
</section>

<!-- Heading Cycle Effect (Top and Main) -->
<script>
(function() {
  // Handle both top heading and main heading cycle containers
  const containers = document.querySelectorAll('.top-heading-cycle-container, .heading-cycle-container');
  
  containers.forEach(container => {
    const items = container.querySelectorAll('.top-heading-cycle-item, .heading-cycle-item');
    if (items.length <= 1) return;
    
    const duration = parseInt(container.dataset.cycleDuration) * 1000 || 3000;
    const fadeTime = 600; // Match CSS transition duration (0.6s)
    let currentIndex = 0;
    
    function cycleHeadings() {
      // Step 1: Fade out current heading
      items[currentIndex].classList.remove('active');
      
      // Step 2: After fade out completes, fade in next heading
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % items.length;
        items[currentIndex].classList.add('active');
      }, fadeTime);
    }
    
    // Start cycling (duration + fade out time + fade in time)
    setInterval(cycleHeadings, duration + fadeTime);
  });
})();
</script>

<!-- Parallax scroll effect for background images -->
<script>
(function() {
  const sectionId = 'cta-hero-image-simple-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const backgroundElements = Array.from(section.querySelectorAll('.cta-hero-image-simple-image, .cta-hero-image-simple-video'));
  if (backgroundElements.length === 0) return;
  
  // Parallax intensity - more noticeable movement
  const parallaxIntensity = 0.04;
  
  function updateParallax() {
    const scrollY = window.pageYOffset || document.documentElement.scrollTop;
    const windowHeight = window.innerHeight;
    
    backgroundElements.forEach(bg => {
      const imageWrapper = bg.closest('.cta-hero-image-simple-image-wrapper');
      if (!imageWrapper) return;
      
      const rect = imageWrapper.getBoundingClientRect();
      const wrapperTop = rect.top + scrollY;
      const wrapperHeight = rect.height;
      
      // Calculate how much of the wrapper is visible
      const wrapperCenter = wrapperTop + wrapperHeight / 2;
      const viewportCenter = scrollY + windowHeight / 2;
      
      // Distance from viewport center to wrapper center
      const distance = viewportCenter - wrapperCenter;
      
      // Initial offset to start images higher
      const initialOffset = -30;
      let translateY = initialOffset + (distance * parallaxIntensity);
      
      // Clamp to prevent too much downward movement - keep it within reasonable bounds
      translateY = Math.max(initialOffset, Math.min(initialOffset + 30, translateY));
    
    });
  }
  
  // Use requestAnimationFrame for smooth performance
  let ticking = false;
  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateParallax();
        ticking = false;
      });
      ticking = true;
    }
  }
  
  // Initial call
  updateParallax();
  
  // Listen to scroll events
  window.addEventListener('scroll', onScroll, { passive: true });
  
  // Update on resize
  window.addEventListener('resize', updateParallax, { passive: true });
})();
</script>

{% schema %}
{
  "name": "CTA Hero Image Simple",
  "tag": "section",
  "class": "cta-hero-image-simple-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Media"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Hero Video URL",
      "info": "Paste a direct .mp4 URL (e.g., https://ik.imagekit.io/fluid/.../video.mp4). Video will be used instead of image if provided."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image (Poster/Fallback)",
      "info": "Used as poster image for video or as fallback if no video is provided"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero Image Alt Text"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image Fit",
      "options": [
        { "value": "cover", "label": "Cover (Fill)" },
        { "value": "contain", "label": "Contain (Fit)" },
        { "value": "fill", "label": "Fill (Stretch)" },
        { "value": "none", "label": "None (Original Size)" },
        { "value": "scale-down", "label": "Scale Down" }
      ],
      "default": "cover",
      "info": "Cover fills the container (may crop). Contain fits entire image (may show gaps). Fill stretches to fill. None keeps original size. Scale Down scales down if needed."
    },
    {
      "type": "header",
      "content": "Top Heading"
    },
    {
      "type": "checkbox",
      "id": "show_top_heading",
      "label": "Show Top Heading",
      "default": false
    },
    {
      "type": "select",
      "id": "top_heading_selection",
      "label": "Select Top Heading",
      "options": [
        { "value": "1", "label": "Heading 1" },
        { "value": "2", "label": "Heading 2" },
        { "value": "3", "label": "Heading 3" },
        { "value": "4", "label": "Heading 4" },
        { "value": "5", "label": "Heading 5" },
        { "value": "6", "label": "Heading 6" },
        { "value": "cycle", "label": "Cycle Through All" }
      ],
      "default": "1",
      "info": "Choose which heading text to display, or cycle through all"
    },
    {
      "type": "range",
      "id": "top_heading_cycle_duration",
      "label": "Cycle Duration (seconds)",
      "min": 1,
      "max": 10,
