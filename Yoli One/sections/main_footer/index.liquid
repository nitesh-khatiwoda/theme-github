<link rel="stylesheet" href="{{ 'main_footer/styles.css' | asset_url }}">
{% unless request.page_type == 'medium' or request.page_type == 'library' %}
<footer
  class="footer-simple {{ section.settings.background_color | default: 'bg-black' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}"
  id="footer-{{ section.id }}"
  {{ section.fluid_attributes }}
  {% if section.settings.background_image != blank and section.settings.video_url == blank %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>

  <!-- Background Video -->
  {% if section.settings.video_url != blank %}
  <div class="footer-video-wrapper">
    <video
      class="footer-background-video"
      autoplay
      muted
      loop
      playsinline
      {% if section.settings.background_image %}poster="{{ section.settings.background_image | image_url }}"{% endif %}
    >
      <source src="{{ section.settings.video_url }}" type="video/mp4" />
    </video>
  </div>
  {% endif %}

  <!-- Background Gradient Overlay -->
  {% if section.settings.show_gradient_overlay %}
  <div class="footer-gradient-overlay"></div>
  {% endif %}

  {% assign layout_width = section.settings.container_layout_width | default: 'container' %}

  <div class="{{layout_width}}">
    <div class="footer-simple-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>


    <!-- Main Content Area -->
    <div class="footer-main-content">

      <!-- Top Section: Content and Links -->
      <div class="footer-top-section">

        <!-- Left: Logo, Heading, Body, Button -->
        <div class="footer-content-column">

          <!-- Logo -->
          <div class="footer-logo-wrapper">
            {% if section.settings.logo_image %}
              <img
                src="{{ section.settings.logo_image | image_url: width: 400 }}"
                alt="{{ section.settings.logo_alt | default: 'Logo' }}"
                class="footer-logo"
                loading="lazy">
            {% else %}
              <div class="footer-logo-placeholder"></div>
            {% endif %}
          </div>

          <!-- Heading -->
          {% if section.settings.heading != blank %}
            <h2 class="footer-heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }}">
              {{ section.settings.heading }}
            </h2>
          {% endif %}

          <!-- Body Text -->
          {% if section.settings.body_text != blank %}
            <div class="footer-body {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.body_font_weight | default: 'font-normal' }} {{ section.settings.body_color | default: 'text-white' }}">
              {{ section.settings.body_text }}
            </div>
          {% endif %}

          <!-- Button -->
          {% if section.settings.show_button %}
            <a
              href="{{ section.settings.button_url | default: '#' }}"
              class="footer-button btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'white' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} font-body {{ settings.button_border_radius | default: 'rounded-full' }}">
              {{ section.settings.button_text | default: 'Learn about our mission' }}
            </a>
          {% endif %}

        </div>

        <!-- Right: Link Columns -->
        <div class="footer-links-columns">
           {% for block in section.blocks %}
            {% case block.type %}
              {% when 'footer_menu_block' %}
                <div class="footer-link-column" {{ block.fluid_attributes }}>
                  {% if section.settings.heading != blank %}
                    <div class="footer-link-title {{ section.settings.link_title_font_family | default: 'font-body' }} {{ section.settings.link_title_font_size | default: 'text-base' }} {{ section.settings.link_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.link_title_font_weight | default: 'font-bold' }} {{ section.settings.link_title_color | default: 'text-white' }}">
                      {{ block.settings.heading }}
                    </div>
                  {% endif %}

                  {% if block.settings.footer_menu and block.settings.footer_menu.size > 0 %}
                    {% for item in block.settings.footer_menu.menu_items %}
                      <a href="{{ item.url | default: '#' }}" class="footer-link {{ section.settings.link_font_family | default: 'font-body' }} {{ section.settings.link_font_size | default: 'text-sm' }} {{ section.settings.link_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.link_font_weight | default: 'font-bold' }} {{ section.settings.link_color | default: 'text-white' }}" style="white-space: nowrap;">
                        {{ item.title }}
                      </a>
                    {% endfor %}
                {% endif %}
                </div>
                
            {% endcase %}
          {% endfor %}
        </div>

      </div>

      <!-- Bottom Section: Logo, Profile Images, Divider, Copyright, Social Icons -->
      <div class="footer-bottom-section">

        <!-- Logo and Profile Images Row -->
        <div class="footer-bottom-top">

          <!-- Bottom Logo -->
          <div class="footer-bottom-logo-wrapper">
            {% if section.settings.bottom_logo_image %}
              <img
                src="{{ section.settings.bottom_logo_image | image_url: width: 200 }}"
                alt="{{ section.settings.bottom_logo_alt | default: 'Logo' }}"
                class="footer-bottom-logo"
                loading="lazy">
            {% else %}
              <div class="footer-bottom-logo-placeholder"></div>
            {% endif %}
          </div>



        </div>

        <!-- Divider -->
        <div class="footer-divider {{ section.settings.divider_color | default: 'bg-neutral-dark' }}"></div>

        <!-- Copyright and Social Icons Row -->
        <div class="footer-bottom-bottom">

          <!-- Copyright -->
          {% if section.settings.copyright_text != blank %}
            <div class="footer-copyright {{ section.settings.copyright_font_family | default: 'font-body' }} {{ section.settings.copyright_font_size | default: 'text-sm' }} {{ section.settings.copyright_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.copyright_font_weight | default: 'font-normal' }} {{ section.settings.copyright_color | default: 'text-neutral-dark' }}">
              {{ section.settings.copyright_text }}
            </div>
          {% endif %}

          <!-- Social Icons -->
          <div class="footer-social-icons">
            {% if section.settings.social_facebook_url != blank %}
              <a href="{{ section.settings.social_facebook_url }}" aria-label="Facebook" class="footer-social-icon {{ section.settings.social_icon_color | default: 'text-white' }}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="currentColor"/>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.social_instagram_url != blank %}
              <a href="{{ section.settings.social_instagram_url }}" aria-label="Instagram" class="footer-social-icon {{ section.settings.social_icon_color | default: 'text-white' }}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M16 4H8C5.23858 4 3 6.23858 3 9V17C3 19.7614 5.23858 22 8 22H16C18.7614 22 21 19.7614 21 17V9C21 6.23858 18.7614 4 16 4ZM19.25 17C19.2445 18.7926 17.7926 20.2445 16 20.25H8C6.20735 20.2445 4.75549 18.7926 4.75 17V9C4.75549 7.20735 6.20735 5.75549 8 5.75H16C17.7926 5.75549 19.2445 7.20735 19.25 9V17ZM16.75 9.25C17.3023 9.25 17.75 8.80228 17.75 8.25C17.75 7.69772 17.3023 7.25 16.75 7.25C16.1977 7.25 15.75 7.69772 15.75 8.25C15.75 8.80228 16.1977 9.25 16.75 9.25ZM12 8.5C9.51472 8.5 7.5 10.5147 7.5 13C7.5 15.4853 9.51472 17.5 12 17.5C14.4853 17.5 16.5 15.4853 16.5 13C16.5027 11.8057 16.0294 10.6596 15.1849 9.81508C14.3404 8.97057 13.1943 8.49733 12 8.5ZM9.25 13C9.25 14.5188 10.4812 15.75 12 15.75C13.5188 15.75 14.75 14.5188 14.75 13C14.75 11.4812 13.5188 10.25 12 10.25C10.4812 10.25 9.25 11.4812 9.25 13Z" fill="currentColor"/>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.social_pinterest_url != blank %}
              <a href="{{ section.settings.social_pinterest_url }}" aria-label="Pinterest" class="footer-social-icon {{ section.settings.social_icon_color | default: 'text-white' }}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z" fill="currentColor"/>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.social_linkedin_url != blank %}
              <a href="{{ section.settings.social_linkedin_url }}" aria-label="LinkedIn" class="footer-social-icon {{ section.settings.social_icon_color | default: 'text-white' }}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" fill="currentColor"/>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.social_youtube_url != blank %}
              <a href="{{ section.settings.social_youtube_url }}" aria-label="YouTube" class="footer-social-icon {{ section.settings.social_icon_color | default: 'text-white' }}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="currentColor"/>
                </svg>
              </a>
            {% endif %}
          </div>

        </div>

      </div>

    </div>

  {% if layout_width == 'full_width' %}
    </div>
  {% else %}
    </div>

  {% endif %}
</footer>
{%endunless%}

{% schema %}
