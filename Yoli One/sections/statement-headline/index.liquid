<link rel="stylesheet" href="{{ 'statement-headline/styles.css' | asset_url }}">

<!-- Statement Headline Section -->
<section class="statement-headline {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}"
         id="statement-headline-{{ section.id }}"
         {% if section.settings.background_image %}style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}'); background-size: cover; background-position: center;"{% endif %}>
  
  <div class="statement-headline__container {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}"
           {% if section.settings.container_background_image %}style="background-image: url('{{ section.settings.container_background_image | image_url: width: 1600 }}'); background-size: cover; background-position: center;"{% endif %}>
    
    <div class="statement-headline__content {{ section.settings.content_max_width | default: 'max-w-4xl' }}">
      
      <!-- Heading -->
      {% if section.settings.heading != blank %}
        <h2 class="statement-headline__heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-6xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-primary' }}">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      
      <!-- Subheading -->
      {% if section.settings.subheading != blank %}
        <p class="statement-headline__subheading {{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-base' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-primary' }}">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
      
      <!-- Button -->
      {% if section.settings.show_button %}
        <a href="{{ section.settings.button_url | default: '#' }}" 
           class="statement-headline__button btn font-body btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} {{ settings.button_border_radius | default: 'rounded' }}">
          {{ section.settings.button_text | default: 'Learn More' }}
        </a>
      {% endif %}
      
    </div>
    
  </div>
</section>

