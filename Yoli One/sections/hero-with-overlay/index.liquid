<link rel="stylesheet" href="{{ 'hero-with-overlay/styles.css' | asset_url }}">

<section 
  class="hero-with-overlay {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="hero-with-overlay-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="hero-overlay" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.4 }});"></div>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="hero-with-overlay-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="hero-content" style="max-width: {{ section.settings.content_max_width | default: 768 }}px; margin: 0 auto;">
        
        <!-- Main Heading -->
        {% if section.settings.heading != blank %}
        <div class="heading-wrapper">
          <h1 class="heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }}">
            {{ section.settings.heading }}
          </h1>
        </div>
        {% endif %}
        
        <!-- Subheading -->
        {% if section.settings.subheading != blank %}
        <div class="subheading-wrapper">
          <div class="subheading {{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-base' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-white' }}">
            {{ section.settings.subheading }}
          </div>
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</section>

