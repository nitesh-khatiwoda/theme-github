<!-- Features Icons Section -->
<section class="features-icons {{ section.settings.background_color | default: 'bg-secondary' }} {{ section.settings.section_padding_y_mobile | default: 'py-lg' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="features-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="features-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Heading Section -->
      <div class="features-header text-center mb-3xl">
        
        <!-- Eyebrow Text -->
        {% if section.settings.eyebrow != blank %}
        <div class="mb-xs">
          <p class="{{ section.settings.eyebrow_font_size | default: 'text-base' }} {{ section.settings.eyebrow_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.eyebrow_font_weight | default: 'font-normal' }} {{ section.settings.eyebrow_color | default: 'text-black' }} leading-body">
            {{ section.settings.eyebrow }}
          </p>
        </div>
        {% endif %}
        
        <!-- Main Heading -->
        {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
        <div class="features-heading">
          <h2 class="{{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-black' }} uppercase leading-heading" style="line-height: 1.1; letter-spacing: -0.03em;">
            {% if section.settings.heading_line_1 != blank %}
              {{ section.settings.heading_line_1 }}<br>
            {% endif %}
            {% if section.settings.heading_line_2 != blank %}
              {{ section.settings.heading_line_2 }}
            {% endif %}
          </h2>
        </div>
        {% endif %}
        
      </div>
      
      <!-- Features Grid -->
      {% if section.blocks.size > 0 %}
      <div class="features-grid">
        {% for block in section.blocks %}
          {% if block.type == 'feature_card' %}
          
          <div class="feature-card {{ section.settings.card_background_color | default: 'bg-quaternary' }}" {{ block.fluid_attributes }} style="border-radius: {{ section.settings.card_border_radius | default: '13' }}px;">
            
            <!-- Icon Badge -->
            <div class="feature-icon-badge {{ section.settings.icon_badge_background | default: 'bg-black' }}" style="width: {{ section.settings.icon_badge_size | default: '112' }}px; height: {{ section.settings.icon_badge_size | default: '112' }}px;">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | image_url: width: 70 }}" alt="{{ block.settings.title }}" style="width: {{ section.settings.icon_size | default: '65' }}px; height: auto;">
              {% else %}
                <!-- Default placeholder icon -->
                <svg width="{{ section.settings.icon_size | default: '65' }}" height="{{ section.settings.icon_size | default: '65' }}" viewBox="0 0 65 65" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.icon_color | default: 'text-secondary' }}">
                  <circle cx="32.5" cy="32.5" r="28" stroke="currentColor" stroke-width="2"/>
                  <circle cx="32.5" cy="32.5" r="10" fill="currentColor"/>
                </svg>
              {% endif %}
            </div>
            
            <!-- Card Content -->
            <div class="feature-card-content">
              
              <!-- Title -->
              {% if block.settings.title != blank %}
              <div class="feature-title mb-sm">
                <h3 class="{{ block.settings.title_font_size | default: 'text-lg' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-xl' }} {{ block.settings.title_font_weight | default: 'font-medium' }} {{ block.settings.title_color | default: 'text-black' }} text-center leading-heading">
                  {{ block.settings.title }}
                </h3>
              </div>
              {% endif %}
              
              <!-- Description -->
              {% if block.settings.description != blank %}
              <div class="feature-description">
                <p class="{{ block.settings.description_font_size | default: 'text-base' }} {{ block.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.description_font_weight | default: 'font-normal' }} {{ block.settings.description_color | default: 'text-black' }} text-center leading-body">
                  {{ block.settings.description }}
                </p>
              </div>
              {% endif %}
              
            </div>
            
          </div>
          
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

