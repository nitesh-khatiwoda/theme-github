<!-- Content Image Split Flexible Section -->
<section class="content-image-split-logos {% if section.settings.use_gradient_background %}gradient-bg{% else %}{{ section.settings.background_color | default: 'bg-white' }}{% endif %} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="content-image-split-logos-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}" style="background-image: url('{{ section.settings.background_image | image_url }}');"{% endif %}>
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}" style="background-image: url('{{ section.settings.container_background_image | image_url }}');"{% endif %}>
      
      <div class="content-image-split-logos__grid {% if section.settings.flip_layout %}content-image-split-logos__grid--flipped{% endif %}">
        
        {% assign logo_position = section.settings.logo_position | default: 'content' %}
        
        <!-- Image Column -->
        <div class="content-image-split-logos__image-column {% if section.settings.hide_main_image %}content-image-split-logos__image-column--no-image{% endif %}">
          {% assign image_fit_mode = section.settings.image_fit_mode | default: 'fill' %}
          {% assign image_height = section.settings.image_height | default: 400 %}
          {% assign br_tl = section.settings.round_top_left_radius | default: 'rounded-none' %}
          {% assign br_tr = section.settings.round_top_right_radius | default: 'rounded-none' %}
          {% assign br_bl = section.settings.round_bottom_left_radius | default: 'rounded-none' %}
          {% assign br_br = section.settings.round_bottom_right_radius | default: 'rounded-none' %}
          
          {% if br_tl == 'rounded-none' %}
            {% assign br_tl = '0' %}
          {% elsif br_tl == 'rounded-sm' %}
            {% assign br_tl = 'var(--radius-sm)' %}
          {% elsif br_tl == 'rounded' %}
            {% assign br_tl = 'var(--radius-base)' %}
          {% elsif br_tl == 'rounded-md' %}
            {% assign br_tl = 'var(--radius-md)' %}
          {% elsif br_tl == 'rounded-lg' %}
            {% assign br_tl = 'var(--radius-lg)' %}
          {% elsif br_tl == 'rounded-xl' %}
            {% assign br_tl = 'var(--radius-xl)' %}
          {% elsif br_tl == 'rounded-2xl' %}
            {% assign br_tl = 'var(--radius-2xl)' %}
          {% elsif br_tl == 'rounded-3xl' %}
            {% assign br_tl = 'var(--radius-3xl)' %}
          {% elsif br_tl == 'rounded-4xl' %}
            {% assign br_tl = 'var(--radius-4xl)' %}
          {% elsif br_tl == 'rounded-full' %}
            {% assign br_tl = '9999px' %}
          {% endif %}
          
          {% if br_tr == 'rounded-none' %}
            {% assign br_tr = '0' %}
          {% elsif br_tr == 'rounded-sm' %}
            {% assign br_tr = 'var(--radius-sm)' %}
          {% elsif br_tr == 'rounded' %}
            {% assign br_tr = 'var(--radius-base)' %}
          {% elsif br_tr == 'rounded-md' %}
            {% assign br_tr = 'var(--radius-md)' %}
          {% elsif br_tr == 'rounded-lg' %}
            {% assign br_tr = 'var(--radius-lg)' %}
          {% elsif br_tr == 'rounded-xl' %}
            {% assign br_tr = 'var(--radius-xl)' %}
          {% elsif br_tr == 'rounded-2xl' %}
            {% assign br_tr = 'var(--radius-2xl)' %}
          {% elsif br_tr == 'rounded-3xl' %}
            {% assign br_tr = 'var(--radius-3xl)' %}
          {% elsif br_tr == 'rounded-4xl' %}
            {% assign br_tr = 'var(--radius-4xl)' %}
          {% elsif br_tr == 'rounded-full' %}
            {% assign br_tr = '9999px' %}
          {% endif %}
          
          {% if br_bl == 'rounded-none' %}
            {% assign br_bl = '0' %}
          {% elsif br_bl == 'rounded-sm' %}
            {% assign br_bl = 'var(--radius-sm)' %}
          {% elsif br_bl == 'rounded' %}
            {% assign br_bl = 'var(--radius-base)' %}
          {% elsif br_bl == 'rounded-md' %}
            {% assign br_bl = 'var(--radius-md)' %}
          {% elsif br_bl == 'rounded-lg' %}
            {% assign br_bl = 'var(--radius-lg)' %}
          {% elsif br_bl == 'rounded-xl' %}
            {% assign br_bl = 'var(--radius-xl)' %}
          {% elsif br_bl == 'rounded-2xl' %}
            {% assign br_bl = 'var(--radius-2xl)' %}
          {% elsif br_bl == 'rounded-3xl' %}
            {% assign br_bl = 'var(--radius-3xl)' %}
          {% elsif br_bl == 'rounded-4xl' %}
            {% assign br_bl = 'var(--radius-4xl)' %}
          {% elsif br_bl == 'rounded-full' %}
            {% assign br_bl = '9999px' %}
          {% endif %}
          
          {% if br_br == 'rounded-none' %}
            {% assign br_br = '0' %}
          {% elsif br_br == 'rounded-sm' %}
            {% assign br_br = 'var(--radius-sm)' %}
          {% elsif br_br == 'rounded' %}
            {% assign br_br = 'var(--radius-base)' %}
          {% elsif br_br == 'rounded-md' %}
            {% assign br_br = 'var(--radius-md)' %}
          {% elsif br_br == 'rounded-lg' %}
            {% assign br_br = 'var(--radius-lg)' %}
          {% elsif br_br == 'rounded-xl' %}
            {% assign br_br = 'var(--radius-xl)' %}
          {% elsif br_br == 'rounded-2xl' %}
            {% assign br_br = 'var(--radius-2xl)' %}
          {% elsif br_br == 'rounded-3xl' %}
            {% assign br_br = 'var(--radius-3xl)' %}
          {% elsif br_br == 'rounded-4xl' %}
            {% assign br_br = 'var(--radius-4xl)' %}
          {% elsif br_br == 'rounded-full' %}
            {% assign br_br = '9999px' %}
          {% endif %}
          
          {% unless section.settings.hide_main_image %}
          <div class="content-image-split-logos__image-wrapper" 
               style="height: {{ image_height }}px; border-radius: {{ br_tl }} {{ br_tr }} {{ br_br }} {{ br_bl }}; overflow: hidden; background-color: {{ section.settings.image_background_color | default: 'transparent' }};">
            {% if section.settings.image %}
                <img 
                  src="{{ section.settings.image | image_url: width: 1200 }}" 
                   alt="{{ section.settings.image_alt | default: section.settings.heading }}"
                   loading="lazy"
                  class="content-image-split-logos__image content-image-split-logos__image--{{ image_fit_mode }}"
                  style="box-shadow: none !important;"
                >
            {% else %}
                <img 
                  src="{{ 'placeholder-image.png' | asset_url }}" 
                   alt="Placeholder"
                   loading="lazy"
                  class="content-image-split-logos__image content-image-split-logos__image--{{ image_fit_mode }}"
                  style="box-shadow: none !important;"
                >
            {% endif %}
          </div>
          {% endunless %}
          
          <!-- Logos (Image Column) -->
          {% if section.settings.show_logos and section.blocks.size > 0 and logo_position == 'image' %}
            {% assign logo_size_mobile = section.settings.logo_size_mobile | default: '56' %}
            {% assign logo_size_desktop = section.settings.logo_size_desktop | default: logo_size_mobile %}
            <div class="content-image-split-logos__logos content-image-split-logos__logos--image {% if section.settings.hide_main_image %}content-image-split-logos__logos--no-image{% endif %}">
              {% for block in section.blocks %}
                {% if block.type == 'logo' %}
                  <div class="content-image-split-logos__logo {% if block.settings.show_text %}content-image-split-logos__logo--with-text{% endif %}" {{ block.fluid_attributes }}>
                    <div class="content-image-split-logos__logo-wrapper" 
                         style="--logo-size-mobile: {{ logo_size_mobile }}px; --logo-size-desktop: {{ logo_size_desktop }}px;">
                    {% if block.settings.logo_image %}
                        <img src="{{ block.settings.logo_image | image_url: width: logo_size_desktop }}"
                           alt="{{ block.settings.logo_alt | default: 'Logo' }}"
                           loading="lazy"
                           class="content-image-split-logos__logo-img">
                    {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Placeholder logo"
                           loading="lazy"
                           class="content-image-split-logos__logo-img">
                    {% endif %}
                    </div>
                    {% if block.settings.show_text %}
                    <div class="content-image-split-logos__logo-text {{ block.settings.text_color | default: 'text-neutral-dark' }}">
                      {% if block.settings.logo_title != blank %}
                        <p class="content-image-split-logos__logo-title font-body font-semibold {{ block.settings.title_font_size | default: 'text-base' }}">{{ block.settings.logo_title }}</p>
                      {% endif %}
                      {% if block.settings.logo_description != blank %}
                        <p class="content-image-split-logos__logo-description font-body font-normal {{ block.settings.description_font_size | default: 'text-sm' }}">{{ block.settings.logo_description }}</p>
                      {% endif %}
                    </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <!-- Content Column -->
        {% assign content_align = section.settings.content_alignment | default: 'left' %}
        <div class="content-image-split-logos__content-column content-image-split-logos__content-column--align-{{ content_align }}">
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
            <div class="content-image-split-logos__heading-wrapper mb-lg">
              <h2 class="content-image-split-logos__heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}">
                {{ section.settings.heading }}
              </h2>
            </div>
          {% endif %}

          <!-- Description -->
          {% if section.settings.description != blank %}
            <div class="content-image-split-logos__description-wrapper mb-2xl">
              <p class="content-image-split-logos__description {{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
                {{ section.settings.description }}
              </p>
            </div>
          {% endif %}

          <!-- Logos (Content Column) -->
          {% if section.settings.show_logos and section.blocks.size > 0 and logo_position == 'content' %}
            {% assign logo_size_mobile = section.settings.logo_size_mobile | default: '56' %}
            {% assign logo_size_desktop = section.settings.logo_size_desktop | default: logo_size_mobile %}
            <div class="content-image-split-logos__logos content-image-split-logos__logos--content content-image-split-logos__logos--align-{{ content_align }}">
              {% for block in section.blocks %}
                {% if block.type == 'logo' %}
                  <div class="content-image-split-logos__logo {% if block.settings.show_text %}content-image-split-logos__logo--with-text{% endif %}" {{ block.fluid_attributes }}>
                    <div class="content-image-split-logos__logo-wrapper" 
                         style="--logo-size-mobile: {{ logo_size_mobile }}px; --logo-size-desktop: {{ logo_size_desktop }}px;">
                    {% if block.settings.logo_image %}
                        <img src="{{ block.settings.logo_image | image_url: width: logo_size_desktop }}"
                           alt="{{ block.settings.logo_alt | default: 'Logo' }}"
                           loading="lazy"
                           class="content-image-split-logos__logo-img">
                    {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}"
                           alt="Placeholder logo"
                           loading="lazy"
                           class="content-image-split-logos__logo-img">
                    {% endif %}
                    </div>
                    {% if block.settings.show_text %}
                    <div class="content-image-split-logos__logo-text {{ block.settings.text_color | default: 'text-neutral-dark' }}">
                      {% if block.settings.logo_title != blank %}
                        <p class="content-image-split-logos__logo-title font-body font-semibold {{ block.settings.title_font_size | default: 'text-base' }}">{{ block.settings.logo_title }}</p>
                      {% endif %}
                      {% if block.settings.logo_description != blank %}
                        <p class="content-image-split-logos__logo-description font-body font-normal {{ block.settings.description_font_size | default: 'text-sm' }}">{{ block.settings.logo_description }}</p>
                      {% endif %}
                    </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          <!-- CTA Button (appears below logos) -->
          {% if section.settings.show_button %}
            {% assign logos_visible = false %}
            {% if section.settings.show_logos and section.blocks.size > 0 and logo_position == 'content' %}
              {% assign logos_visible = true %}
            {% endif %}
            <div class="content-image-split-logos__button-wrapper {% unless logos_visible %}content-image-split-logos__button-wrapper--no-logos{% endunless %} content-image-split-logos__button-wrapper--align-{{ content_align }}">
              <a href="{{ section.settings.button_url | default: '#' }}" 
                 class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} font-body {{ settings.button_border_radius | default: 'rounded' }}"
                 style="cursor: pointer;">
                {{ section.settings.button_text | default: 'Learn More' }}
              </a>
            </div>
          {% endif %}

        </div>

      </div>

    </div>
  </div>
  
  {% if section.settings.show_bottom_fade %}
  <div class="content-image-split-logos__bottom-fade" 
       style="height: {{ section.settings.bottom_fade_height | default: 80 }}px; 
              background: linear-gradient(to bottom, transparent, {{ section.settings.bottom_fade_color | default: 'var(--clr-neutral-light)' }});"></div>
  {% endif %}
</section>

<script>
(function() {
  const sectionId = 'content-image-split-logos-{{ section.id }}';
  
  function initScrollAnimation() {
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px'
    });
    
    observer.observe(section);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimation);
  } else {
    initScrollAnimation();
  }
  
  // Re-init on Shopify theme editor updates
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initScrollAnimation();
      }
    });
  }
})();
</script>

