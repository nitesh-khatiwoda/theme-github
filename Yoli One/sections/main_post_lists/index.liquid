<section 
    class="blog-posts-{{ section.id }} {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
    {% if section.settings.background_image %}
      data-bg="{{ section.settings.background_image | image_url }}"
    {% endif %}
  >
    <div class="{{section.settings.container_layout_width | default : 'container'}}">
      {% if section.settings.title != blank %}
        <div class="title-section">
          <div class="title-wrapper flex-1 mb-lg">
            <h3 class="section-title capitalize {{ section.settings.title_font_family }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color }}">
              {{ section.settings.title }}
            </h3>
          </div>
        </div>
      {% endif %}
      {%- paginate posts by 10 -%}
       <div class="post-list-section">
         {% if posts.size > 0 %}
           <div class="post-list grid grid-cols-1  gap-lg mt-xl">
             {% for post in posts %}
                 <a href="{{ post.preview_url }}" class="blog-card {{ section.settings.post_card_background }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}">
                  <div class="post-image-link">
                   <div class="post-image {{ section.settings.image_border_radius | default: 'rounded-xl' }}">
                     {% assign image_url = '' %}
                     {% if post.image_url %}
                       {% assign image_url = post.image_url %}
                     {% elsif post.image %}
                       {% assign image_url = post.image | image_url %}
                     {% elsif post.images.size > 0 %}
                       {% assign image_url = post.images[0].src %}
                     {% endif %}
  
                     {% if image_url != '' %}
                       <img src="{{ image_url }}"
                         alt="{{ post.title }}"
                         class="image-cover" />
                     {% else %}
                       <div class="h-full w-full flex items-center justify-center bg-gray-100">
                         <span class="text-gray-400">No image available</span>
                       </div>
                     {% endif %}
                   </div>
                  </div>
                   <div class="desc px-md py-md">
                     <div class="post-title text-hover-effect line-clamp-2 {{ section.settings.post_title_font_family }} {{ section.settings.post_title_font_size | default: 'text-base' }} {{ section.settings.post_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.post_title_font_weight | default: 'font-semibold' }} {{ section.settings.post_title_color }}">
                       {{ post.title }}
                     </div>
                     {% if section.settings.show_post_description %}
                       <div class="post-desc line-clamp-2 {{ section.settings.post_desc_font_size | default: 'text-sm' }} {{ section.settings.post_desc_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.post_desc_font_weight | default: 'font-normal' }} {{ section.settings.post_desc_color }} mt-sm">
                         {% if post.summary %}
                           {{ post.summary | unescape }}
                         {% elsif post.description %}
                           {{ post.description | unescape }}
                         {% endif %}
                       </div>
                     {% endif %}
                   </div>
                 </a>
               {% endfor %}
             </div>
           {% else %}
             <div class="text-center py-2xl">
               <p class="text-gray-500">{{ section.settings.empty_state_text | default: 'No posts found' }}</p>
             </div>
           {% endif %}
         </div>
         {%- if paginate.pages > 1 -%}
           <div class="mt-12">
             {% render 'pagination', paginate: paginate, anchor: '' %}
           </div>
         {%- endif -%}
       {% endpaginate %}
       
    </div>
  </section>
  
