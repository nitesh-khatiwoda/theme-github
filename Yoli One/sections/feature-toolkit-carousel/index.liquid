<!-- Feature Toolkit Carousel Section -->
<section class="feature-toolkit-carousel {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}">
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="inner-container {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-lg' }}">
      
      <!-- Header Row -->
      <div class="feature-toolkit-carousel__header">
        
        <!-- Heading with Colored Text -->
        <div class="feature-toolkit-carousel__heading-wrapper">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-black' }}">
            {% if section.settings.heading_part1 != blank %}
              <span>{{ section.settings.heading_part1 }}</span>
            {% endif %}
            {% if section.settings.heading_part2 != blank %}
              <span class="{{ section.settings.heading_accent_color | default: 'text-primary' }}">{{ section.settings.heading_part2 }}</span>
            {% endif %}
          </h2>
        </div>

        <!-- CTA Button -->
        {% if section.settings.show_button %}
          <div class="feature-toolkit-carousel__button-wrapper">
            <a href="{{ section.settings.button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-semibold' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text | default: 'Join now' }}
            </a>
          </div>
        {% endif %}

      </div>

      <!-- Carousel Wrapper -->
      {% if section.blocks.size > 0 %}
        <div class="feature-toolkit-carousel__wrapper">
          
          <!-- Carousel Track -->
          <div class="feature-toolkit-carousel__track-container">
            <div class="feature-toolkit-carousel__track" data-carousel-track="{{ section.id }}">
              {% for block in section.blocks %}
                {% if block.type == 'feature_card' %}
                  <div class="feature-toolkit-carousel__card {{ section.settings.card_background_color | default: 'bg-neutral-light' }}" {{ block.fluid_attributes }}>
                    
                    <!-- Card Title -->
                    {% if block.settings.title != blank %}
                      <div class="feature-toolkit-carousel__card-title">
                        <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.card_title_font_weight | default: 'font-semibold' }} {{ section.settings.card_title_color | default: 'text-black' }}">
                          {{ block.settings.title }}
                        </h3>
                      </div>
                    {% endif %}

                    <!-- Card Image -->
                    <div class="feature-toolkit-carousel__card-image">
                      {% if block.settings.image %}
                        <img src="{{ block.settings.image | image_url: width: 400 }}"
                             alt="{{ block.settings.image_alt | default: block.settings.title }}"
                             loading="lazy">
                      {% else %}
                        <img src="{{ 'placeholder-image.png' | asset_url }}"
                             alt="Placeholder">
                      {% endif %}
                    </div>

                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>

        </div>

        <!-- Navigation Buttons (Below Cards, Right Aligned) -->
        <div class="feature-toolkit-carousel__nav-wrapper">
          <button class="feature-toolkit-carousel__nav feature-toolkit-carousel__nav--prev" 
                  aria-label="Previous slide"
                  data-carousel-prev="{{ section.id }}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button class="feature-toolkit-carousel__nav feature-toolkit-carousel__nav--next" 
                  aria-label="Next slide"
                  data-carousel-next="{{ section.id }}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {% endif %}

    </div>
  </div>
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const track = document.querySelector(`[data-carousel-track="${sectionId}"]`);
  const prevBtn = document.querySelector(`[data-carousel-prev="${sectionId}"]`);
  const nextBtn = document.querySelector(`[data-carousel-next="${sectionId}"]`);
  
  if (!track || !prevBtn || !nextBtn) return;
  
  const cards = track.querySelectorAll('.feature-toolkit-carousel__card');
  let currentIndex = 0;
  
  function getVisibleCards() {
    if (window.innerWidth >= 1024) return 4;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }
  
  function updateCarousel() {
    const visibleCards = getVisibleCards();
    const cardWidth = cards[0].offsetWidth;
    const gap = 16; // Matches --space-lg
    const offset = currentIndex * (cardWidth + gap);
    
    track.style.transform = `translateX(-${offset}px)`;
    
    // Update button states
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex >= cards.length - visibleCards;
  }
  
  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  });
  
  nextBtn.addEventListener('click', () => {
    const visibleCards = getVisibleCards();
    if (currentIndex < cards.length - visibleCards) {
      currentIndex++;
      updateCarousel();
    }
  });
  
  // Reset on resize
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      currentIndex = 0;
      updateCarousel();
    }, 250);
  });
  
  // Initialize
  updateCarousel();
  
  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });
  
  track.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  });
  
  function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        // Swipe left - next
        nextBtn.click();
      } else {
        // Swipe right - prev
        prevBtn.click();
      }
    }
  }
})();
</script>

