<link rel="stylesheet" href="{{ 'sub-page-hero-collage/styles.css' | asset_url }}">

<!-- Sub Page Hero Collage Section -->
<section class="sub-page-hero-collage {{ section.settings.background_color | default: 'bg-primary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="container">
    <div class="sub-page-hero-collage__inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Split Layout Container -->
      <div class="sub-page-hero-collage__split {% if section.settings.flip_layout %}sub-page-hero-collage__split--flipped{% endif %}">
        
        <!-- Content Side -->
        <div class="sub-page-hero-collage__content-side">
          <div class="sub-page-hero-collage__content">
            
            <!-- Heading -->
            {% if section.settings.heading != blank %}
              <div class="sub-page-hero-collage__heading">
                <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-white' }}">
                  {{ section.settings.heading }}
                </h1>
              </div>
            {% endif %}

            <!-- Subheading -->
            {% if section.settings.subheading != blank %}
              <div class="sub-page-hero-collage__subheading">
                <p class="{{ section.settings.subheading_font_family | default: 'font-body' }} {{ section.settings.subheading_font_size | default: 'text-lg' }} {{ section.settings.subheading_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.subheading_font_weight | default: 'font-normal' }} {{ section.settings.subheading_color | default: 'text-white' }}">
                  {{ section.settings.subheading }}
                </p>
              </div>
            {% endif %}

            <!-- CTA Button -->
            {% if section.settings.show_button %}
              <div class="sub-page-hero-collage__cta">
                <a href="{{ section.settings.button_url | default: '#' }}" 
                   class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
                  {{ section.settings.button_text | default: 'Learn More' }}
                </a>
              </div>
            {% endif %}

          </div>
        </div>

        <!-- Collage Side -->
        <div class="sub-page-hero-collage__collage-side">
          {% if section.blocks.size > 0 %}
            <div class="sub-page-hero-collage__grid">
              {% for block in section.blocks %}
                {% if block.type == 'image' %}
                  <div class="sub-page-hero-collage__grid-item" {{ block.fluid_attributes }}>
                    {% if block.settings.image != blank %}
                      <img src="{{ block.settings.image | image_url: width: 600 }}" 
                           alt="{{ block.settings.image_alt | default: 'Collage image' }}"
                           loading="lazy">
                    {% else %}
                      <img src="{{ 'placeholder-image.png' | asset_url }}" 
                           alt="Placeholder image">
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>

      </div>

    </div>
  </div>

</section>

