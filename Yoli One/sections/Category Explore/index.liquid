<section  class="section_banner11 section_category">
    <div class="container-large">
      <div class="padding-section-large category">
        <div class="layout375_component">
          <div class="margin-bottom margin-0">
            <div class="text-align-center">
              <div  class="max-width-large align-center">
                <div class="margin-bottom margin-small align-center">
                  <h2 class="{{ section.settings.heading_style }}">{{ section.settings.heading }}</h2>
                </div>
                <p class="{{ section.settings.description_text_size }}">{{ section.settings.description }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div data-w-id="497c8224-bca9-32e6-16cf-1b14b8fddaef" >
      <div class="splide hm-category-slider">
        <div class="splide__track hm-category-slider-track">
          <div class="splide__list hm-category-slider-list">
            {% assign collections_limit = section.settings.collections_limit | default: 10 %}
            {% for collection in collections %}
              {% if collection.products.size > 0 %}
                <div class="splide__slide hm-category-slider-slider">
                  <a trigger-hm-catg=""
                     data-menu-category="{{ collection.title }}" 
                     href="/collections/{{ collection.handle }}" 
                     class="brix---team-v9-wrapper-2 w-block">
                    {% if collection.image %}
                      <img src="{{ collection.image | img_url: '600x400', crop: 'center' }}" 
                           srcset="{{ collection.image | img_url: '300x200', crop: 'center' }} 300w,
                                   {{ collection.image | img_url: '600x400', crop: 'center' }} 600w,
                                   {{ collection.image | img_url: '900x600', crop: 'center' }} 900w"
                           sizes="(max-width: 600px) 300px,
                                  (max-width: 900px) 600px,
                                  900px"
                           alt="{{ collection.title }}" 
                           class="brix---avatar-image"
                           loading="lazy"
                           width="600"
                           height="400">
                    {% elsif section.settings.default_collection_image %}
                      <img src="{{ section.settings.default_collection_image }}"
                           srcset="{{ section.settings.default_collection_image }} 300w,
                                   {{ section.settings.default_collection_image }} 600w,
                                   {{ section.settings.default_collection_image }} 900w"
                           sizes="(max-width: 600px) 300px,
                                  (max-width: 900px) 600px,
                                  900px"
                           alt="{{ collection.title }}" 
                           class="brix---avatar-image"
                           loading="lazy"
                           width="600"
                           height="400">
                    {% else %}
                      <img src="https://placehold.co/600x400"
                           
                           alt="{{ collection.title }}" 
                           class="brix---avatar-image"
                           loading="lazy"
                           width="600"
                           height="400">
                    {% endif %}
                    <div class="category-overlay heading-custom">
                      <h3 class="heading-custom">{{ collection.title }}</h3>
                    </div>
                  </a>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div data-w-id="eeecaa70-194f-91c2-3475-2fec865ca029" style="margin-top: 20px" class="margin-bottom margin-xsmall">
      <div class="text-align-center">
        <div class="max-width-large align-center">
          <div class="margin-bottom margin-small gap">
            <p class="text-size-medium-3 align-center">{{ section.settings.bottom_text }}</p>
          </div>
        </div>
      </div>
      <div class="button-group is-center">
        <a
            first-level-menu-trigger
            href="#"
            class="button-3 second-button black w-button"
          >
            {{ section.settings.button_text }}
        </a>
      </div>
    </div>
  </section>

{% schema %}
{
  "name": "Category Explore",
  "tag": "section",
  "class": "section_category",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "default_category_image",
      "label": "Default Category Image",
      "info": "Used when a category has no image. Recommended size: 600x400 pixels"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Ready to Find Your Perfect Routine?"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Style",
      "options": [
        {
          "value": "heading-style-h1",
          "label": "H1"
        },
        {
          "value": "heading-style-h2",
          "label": "H2"
        },
        {
          "value": "heading-style-h3",
          "label": "H3"
        },
        {
          "value": "heading-style-h4",
          "label": "H4"
        },
        {
          "value": "heading-style-h5",
          "label": "H5"
        }
      ],
      "default": "heading-style-h2"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Zallevo is your one-stop shop for total wellness. Hover and select a curated category below to explore products designed to work in harmony."
    },
    {
      "type": "select",
      "id": "description_text_size",
      "label": "Description Text Size",
      "options": [
        {
          "value": "text-size-tiny",
          "label": "Tiny"
        },
        {
          "value": "text-size-small",
          "label": "Small"
        },
        {
          "value": "text-size-medium",
          "label": "Medium"
        },
        {
          "value": "text-size-large",
          "label": "Large"
        },
        {
          "value": "text-size-xlarge",
          "label": "Extra Large"
        }
      ],
      "default": "text-size-medium"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "Not sure where to start? Our complete collection has a solution for every goal."
    },
    {
      "type": "select",
      "id": "bottom_text_size",
      "label": "Bottom Text Size",
      "options": [
       
        {
          "value": "text-size-medium",
          "label": "Medium"
        },
        {
          "value": "text-size-medium-2",
          "label": "Medium 2"
        },
        
        {
          "value": "text-size-medium-3",
          "label": "Medium 3"
        },
        
        {
          "value": "text-size-medium-4",
          "label": "Medium 4"
        },
        {
          "value": "text-size-medium-5",
          "label": "Medium 5"
        },
        {
          "value": "text-size-medium-6",
          "label": "Medium 6"
        },
        {
          "value": "text-size-medium-7",
          "label": "Medium 7"
        },
        {
          "value": "text-size-medium-8",
          "label": "Medium 8"
        },
        {
          "value": "text-size-medium-9",
          "label": "Medium 9"
        },
        
        {
          "value": "text-size-medium-10",
          "label": "Medium 10"
        }
        
      ],
      "default": "text-size-medium-3"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore All Wellness Paths"
    },
    {
      "type": "range",
      "id": "categories_limit",
      "label": "Number of Categories to Show",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 10,
      "info": "Maximum number of categories to display"
    }
  ],
  "presets": [
    {
      "name": "Category Explore",
      "category": "Content Sections",
      "settings": {
        "categories_limit": 10,
        "heading": "Ready to Find Your Perfect Routine?",
        "description": "Zallevo is your one-stop shop for total wellness. Hover and select a curated category below to explore products designed to work in harmony.",
        "bottom_text": "Not sure where to start? Our complete collection has a solution for every goal.",
        "button_text": "Explore All Wellness Paths"
      }
    }
  ]
}
{% endschema %}

