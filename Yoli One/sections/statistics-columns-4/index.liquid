
<link rel="stylesheet" href="{{ 'statistics-columns-4/styles.css' | asset_url }}">

<!-- Statistics Columns Section -->
{% assign overlay_opacity = section.settings.card_overlay_opacity | default: 80 | divided_by: 100.0 %}
{% assign text_opacity = section.settings.card_text_opacity | default: 80 | divided_by: 100.0 %}
{% assign card_height_mobile = section.settings.card_height_mobile | default: '338' %}
{% assign card_height_desktop = section.settings.card_height_desktop | default: '700' %}

<section class="statistics-columns-4 {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}}  {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="statistics-columns-4-{{ section.id }}" style="--overlay-opacity: {{ overlay_opacity }}; --text-opacity: {{ text_opacity }}; --card-height-mobile: {{ card_height_mobile }}px; --card-height-desktop: {{ card_height_desktop }}px;" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  {% assign layout_width = section.settings.layout_width | default: 'inline' %}
  {% if layout_width == 'full_width' %}
    <div class="statistics-columns-4-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} layout-full-width" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
  {% elsif layout_width == 'wide' %}
    <div class="statistics-columns-4-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} layout-wide" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
  {% else %}
  <div class="container">
    <div class="statistics-columns-4-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
  {% endif %}
      
      <!-- Section Heading -->
      {% if section.settings.heading != blank %}
      <div class="section-heading section-heading--side-by-side text-{{ section.settings.heading_alignment | default: 'center' }} mb-xl lg:mb-2xl">
        <div class="section-heading__title">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-primary' }}">
            {{ section.settings.heading }}
          </h2>
        </div>
        {% if section.settings.description != blank %}
        <div class="section-heading__description section-description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral-dark' }}">
            {{ section.settings.description }}
          </p>
        </div>
        {% endif %}
      </div>
      {% endif %}
      
      <!-- Grid -->
      {% if section.blocks.size > 0 %}
      {% assign column_gap = section.settings.column_gap | default: 'xl' %}
      {% case column_gap %}
        {% when 'xs' %}{% assign gap_value = 'var(--space-xs)' %}
        {% when 'sm' %}{% assign gap_value = 'var(--space-sm)' %}
        {% when 'md' %}{% assign gap_value = 'var(--space-md)' %}
        {% when 'lg' %}{% assign gap_value = 'var(--space-lg)' %}
        {% when 'xl' %}{% assign gap_value = 'var(--space-xl)' %}
        {% when '2xl' %}{% assign gap_value = 'var(--space-2xl)' %}
        {% when '3xl' %}{% assign gap_value = 'var(--space-3xl)' %}
        {% else %}{% assign gap_value = 'var(--space-xl)' %}
      {% endcase %}
      <div class="cards-grid layout-columns {% if section.settings.content_based_height %}content-based-height{% endif %}" data-section-id="{{ section.id }}" style="--column-gap: {{ gap_value }}; gap: var(--column-gap);">
        {% for block in section.blocks reversed %}
          {% case block.type %}
            {% when 'featured_card' %}
              <!-- Featured Card -->
              {% assign border_radius = block.settings.border_radius | default: 'rounded-md' %}
              {% assign background_color = block.settings.background_color | default: 'bg-neutral-light' %}
              {% assign bg_image = '' %}
              {% if block.settings.background_image != blank %}
                {% assign bg_image = block.settings.background_image | image_url %}
              {% endif %}
              <div class="featured-card card-height-700 {{ background_color }} {{ border_radius }}" 
                   data-column="1" 
                   data-order="0"
                   {{ block.fluid_attributes }}>
                {% if bg_image != blank %}
                <div class="featured-card-background" style="background-image: url('{{ bg_image }}');"></div>
                {% endif %}
                {% if block.settings.show_overlay %}
                <div class="featured-card-overlay"></div>
                {% endif %}
                {% if block.settings.show_overline and block.settings.overline_text != blank %}
                <div class="featured-card-overline">
                  <span class="{{ section.settings.card_overline_font_family | default: 'font-body' }} {{ section.settings.card_overline_font_size | default: 'text-base' }} {{ section.settings.card_overline_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_overline_font_weight | default: 'font-medium' }} {{ section.settings.card_overline_color | default: 'text-neutral-dark' }}">{{ block.settings.overline_text }}</span>
                </div>
                {% endif %}
                <div class="featured-card-content p-lg">
                {% if block.settings.show_icon and block.settings.icon_image != blank %}
                {% assign icon_size = block.settings.icon_size | default: 'md' %}
                  <div class="featured-card-icon icon-size-{{ icon_size }}">
                  <img src="{{ block.settings.icon_image | image_url }}" alt="{{ block.settings.icon_image.alt | default: 'Icon' }}" class="icon-image">
                </div>
                {% endif %}
                  <!-- Animated Statistic Number -->
                  <div class="featured-card-statistic" data-count-to="{{ block.settings.statistic_number | default: '0' }}" data-count-duration="{{ block.settings.statistic_duration | default: 2 }}">
                    {% if block.settings.statistic_prefix != blank %}<span class="statistic-prefix {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">{{ block.settings.statistic_prefix }}</span>{% endif %}<span class="statistic-number {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">0</span>{% if block.settings.statistic_suffix != blank %}<span class="statistic-suffix {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">{{ block.settings.statistic_suffix }}</span>{% endif %}
                  </div>
                  
                  {% if block.settings.show_text and block.settings.text != blank %}
                  {% if section.settings.show_card_divider %}
                  <hr class="featured-card-divider">
                  {% endif %}
                  <div class="featured-card-text {{ section.settings.card_text_font_family | default: 'font-body' }} {{ section.settings.card_text_font_size | default: 'text-base' }} {{ section.settings.card_text_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_text_font_weight | default: 'font-normal' }} {{ section.settings.card_text_color | default: 'text-neutral-dark' }}">
                    {{ block.settings.text }}
                </div>
                {% endif %}
                </div>
              </div>
            {% when 'split_card' %}
              <!-- Split Card -->
              {% assign border_radius = block.settings.border_radius | default: 'rounded-md' %}
              {% assign background_color = block.settings.background_color | default: 'bg-neutral-light' %}
              {% assign gap_size = block.settings.gap_size | default: '24' %}
              {% assign total_height = section.settings.card_height_desktop | default: 700 | plus: 0 %}
              {% assign card_height = total_height | minus: gap_size | divided_by: 2 %}
              {% assign top_bg_image = '' %}
              {% assign bottom_bg_image = '' %}
              {% if block.settings.top_card_background_image != blank %}
                {% assign top_bg_image = block.settings.top_card_background_image | image_url %}
              {% endif %}
              {% if block.settings.bottom_card_background_image != blank %}
                {% assign bottom_bg_image = block.settings.bottom_card_background_image | image_url %}
              {% endif %}
              <div class="split-card card-height-700" 
                   data-column="1" 
                   data-order="0"
                   style="--split-gap: {{ gap_size }}px;"
                   {{ block.fluid_attributes }}>
                <div class="split-card-top {{ background_color }} {{ border_radius }}">
                  {% if top_bg_image != blank %}
                  <div class="split-card-background" style="background-image: url('{{ top_bg_image }}');"></div>
                  {% endif %}
                  {% if block.settings.show_top_overlay %}
                  <div class="split-card-overlay"></div>
                  {% endif %}
                  {% if block.settings.show_top_overline and block.settings.top_overline_text != blank %}
                  <div class="split-card-overline">
                    <span class="{{ section.settings.card_overline_font_family | default: 'font-body' }} {{ section.settings.card_overline_font_size | default: 'text-base' }} {{ section.settings.card_overline_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_overline_font_weight | default: 'font-medium' }} {{ section.settings.card_overline_color | default: 'text-neutral-dark' }}">{{ block.settings.top_overline_text }}</span>
                  </div>
                  {% endif %}
                  <div class="split-card-content p-lg">
                    {% if block.settings.show_top_icon and block.settings.top_card_icon_image != blank %}
                    {% assign top_icon_size = block.settings.top_card_icon_size | default: 'md' %}
                    <div class="split-card-icon icon-size-{{ top_icon_size }}">
                      <img src="{{ block.settings.top_card_icon_image | image_url }}" alt="{{ block.settings.top_card_icon_image.alt | default: 'Icon' }}" class="icon-image">
                    </div>
                    {% endif %}
                    {% assign show_st_title = block.settings.show_split_top_title %}
                    {% if show_st_title == nil %}{% assign show_st_title = true %}{% endif %}
                    {% if show_st_title %}
                      {% assign split_top_mode = block.settings.split_top_title_mode | default: '1' %}
                      {% assign st_title_1 = block.settings.split_top_text_1 | default: 'Top Card Title' %}
                      {% assign st_title_2 = block.settings.split_top_text_2 %}
                      {% assign st_title_3 = block.settings.split_top_text_3 %}
                      {% assign st_title_4 = block.settings.split_top_text_4 %}
                      {% assign st_title_5 = block.settings.split_top_text_5 %}
                      {% assign st_title_6 = block.settings.split_top_text_6 %}
                      
                      {% if split_top_mode == 'cycle' %}
                        <!-- Cycling Mode -->
                        <div class="split-card-title-cycle-container" data-cycle-duration="{{ block.settings.split_top_title_duration | default: 3 }}">
                          {% if st_title_1 != blank %}
                          <h2 class="split-card-title-cycle-item active {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ st_title_1 }}
                          </h2>
                          {% endif %}
                          {% if st_title_2 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ st_title_2 }}
                          </h2>
                          {% endif %}
                          {% if st_title_3 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ st_title_3 }}
                          </h2>
                          {% endif %}
                          {% if st_title_4 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ st_title_4 }}
                          </h2>
                          {% endif %}
                          {% if st_title_5 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ st_title_5 }}
                          </h2>
                          {% endif %}
                          {% if st_title_6 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ st_title_6 }}
                          </h2>
                          {% endif %}
                        </div>
                      {% else %}
                        <!-- Single Title Mode -->
                        {% case split_top_mode %}
                          {% when '1' %}
                            {% assign split_top_selected = st_title_1 %}
                          {% when '2' %}
                            {% assign split_top_selected = st_title_2 %}
                          {% when '3' %}
                            {% assign split_top_selected = st_title_3 %}
                          {% when '4' %}
                            {% assign split_top_selected = st_title_4 %}
                          {% when '5' %}
                            {% assign split_top_selected = st_title_5 %}
                          {% when '6' %}
                            {% assign split_top_selected = st_title_6 %}
                        {% endcase %}
                        {% if split_top_selected == blank %}{% assign split_top_selected = st_title_1 %}{% endif %}
                        <h2 class="split-card-title {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                          {{ split_top_selected }}
                        </h2>
                      {% endif %}
                    {% endif %}
                    {% if block.settings.show_top_text and block.settings.top_card_text != blank %}
                    {% if section.settings.show_card_divider %}
                    <hr class="split-card-divider">
                    {% endif %}
                    <div class="split-card-text {{ section.settings.card_text_font_family | default: 'font-body' }} {{ section.settings.card_text_font_size | default: 'text-base' }} {{ section.settings.card_text_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_text_font_weight | default: 'font-normal' }} {{ section.settings.card_text_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.top_card_text }}
                    </div>
                    {% endif %}
                  </div>
                </div>
                <div class="split-card-gap" style="height: {{ gap_size }}px;"></div>
                <div class="split-card-bottom {{ background_color }} {{ border_radius }}">
                  {% if bottom_bg_image != blank %}
                  <div class="split-card-background" style="background-image: url('{{ bottom_bg_image }}');"></div>
                  {% endif %}
                  {% if block.settings.show_bottom_overlay %}
                  <div class="split-card-overlay"></div>
                  {% endif %}
                  {% if block.settings.show_bottom_overline and block.settings.bottom_overline_text != blank %}
                  <div class="split-card-overline">
                    <span class="{{ section.settings.card_overline_font_family | default: 'font-body' }} {{ section.settings.card_overline_font_size | default: 'text-base' }} {{ section.settings.card_overline_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_overline_font_weight | default: 'font-medium' }} {{ section.settings.card_overline_color | default: 'text-neutral-dark' }}">{{ block.settings.bottom_overline_text }}</span>
                  </div>
                  {% endif %}
                  <div class="split-card-content p-lg">
                    {% if block.settings.show_bottom_icon and block.settings.bottom_card_icon_image != blank %}
                    {% assign bottom_icon_size = block.settings.bottom_card_icon_size | default: 'md' %}
                    <div class="split-card-icon icon-size-{{ bottom_icon_size }}">
                      <img src="{{ block.settings.bottom_card_icon_image | image_url }}" alt="{{ block.settings.bottom_card_icon_image.alt | default: 'Icon' }}" class="icon-image">
                    </div>
                    {% endif %}
                    {% assign show_sb_title = block.settings.show_split_bottom_title %}
                    {% if show_sb_title == nil %}{% assign show_sb_title = true %}{% endif %}
                    {% if show_sb_title %}
                      {% assign split_bottom_mode = block.settings.split_bottom_title_mode | default: '1' %}
                      {% assign sb_title_1 = block.settings.split_bottom_text_1 | default: 'Bottom Card Title' %}
                      {% assign sb_title_2 = block.settings.split_bottom_text_2 %}
                      {% assign sb_title_3 = block.settings.split_bottom_text_3 %}
                      {% assign sb_title_4 = block.settings.split_bottom_text_4 %}
                      {% assign sb_title_5 = block.settings.split_bottom_text_5 %}
                      {% assign sb_title_6 = block.settings.split_bottom_text_6 %}
                      
                      {% if split_bottom_mode == 'cycle' %}
                        <!-- Cycling Mode -->
                        <div class="split-card-title-cycle-container" data-cycle-duration="{{ block.settings.split_bottom_title_duration | default: 3 }}">
                          {% if sb_title_1 != blank %}
                          <h2 class="split-card-title-cycle-item active {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ sb_title_1 }}
                          </h2>
                          {% endif %}
                          {% if sb_title_2 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ sb_title_2 }}
                          </h2>
                          {% endif %}
                          {% if sb_title_3 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ sb_title_3 }}
                          </h2>
                          {% endif %}
                          {% if sb_title_4 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ sb_title_4 }}
                          </h2>
                          {% endif %}
                          {% if sb_title_5 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ sb_title_5 }}
                          </h2>
                          {% endif %}
                          {% if sb_title_6 != blank %}
                          <h2 class="split-card-title-cycle-item {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                            {{ sb_title_6 }}
                          </h2>
                          {% endif %}
                        </div>
                      {% else %}
                        <!-- Single Title Mode -->
                        {% case split_bottom_mode %}
                          {% when '1' %}
                            {% assign split_bottom_selected = sb_title_1 %}
                          {% when '2' %}
                            {% assign split_bottom_selected = sb_title_2 %}
                          {% when '3' %}
                            {% assign split_bottom_selected = sb_title_3 %}
                          {% when '4' %}
                            {% assign split_bottom_selected = sb_title_4 %}
                          {% when '5' %}
                            {% assign split_bottom_selected = sb_title_5 %}
                          {% when '6' %}
                            {% assign split_bottom_selected = sb_title_6 %}
                        {% endcase %}
                        {% if split_bottom_selected == blank %}{% assign split_bottom_selected = sb_title_1 %}{% endif %}
                        <h2 class="split-card-title {{ section.settings.card_title_font_family | default: 'font-serif' }} {{ section.settings.card_title_font_size | default: 'text-5xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-7xl' }} {{ section.settings.card_title_font_weight | default: 'font-bold' }} {{ section.settings.card_title_color | default: 'text-neutral-dark' }}">
                          {{ split_bottom_selected }}
                        </h2>
                      {% endif %}
                    {% endif %}
                    {% if block.settings.show_bottom_text and block.settings.bottom_card_text != blank %}
                    {% if section.settings.show_card_divider %}
                    <hr class="split-card-divider">
                    {% endif %}
                    <div class="split-card-text {{ section.settings.card_text_font_family | default: 'font-body' }} {{ section.settings.card_text_font_size | default: 'text-base' }} {{ section.settings.card_text_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_text_font_weight | default: 'font-normal' }} {{ section.settings.card_text_color | default: 'text-neutral-dark' }}">
                      {{ block.settings.bottom_card_text }}
                    </div>
                    {% endif %}
                  </div>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
