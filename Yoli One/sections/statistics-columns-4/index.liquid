<!-- Title Cycle Effect for Featured Cards and Split Cards -->
<script>
(function() {
  // Handle both featured card and split card title cycling
  const containers = document.querySelectorAll('.featured-card-title-cycle-container, .split-card-title-cycle-container');
  
  containers.forEach((container, index) => {
    const items = container.querySelectorAll('.featured-card-title-cycle-item, .split-card-title-cycle-item');
    if (items.length <= 1) return;
    
    const duration = parseInt(container.dataset.cycleDuration) * 1000 || 3000;
    const fadeTime = 600;
    let currentIndex = 0;
    
    function cycleTitles() {
      items[currentIndex].classList.remove('active');
      
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % items.length;
        items[currentIndex].classList.add('active');
      }, fadeTime);
    }
    
    // Offset timing for each container (stagger by 800ms per container)
    const offsetDelay = index * 800;
    
    setTimeout(() => {
      setInterval(cycleTitles, duration + fadeTime);
    }, offsetDelay);
  });
})();
</script>

<!-- Count-Up Animation for Statistic Numbers -->
<script>
(function() {
  function initStatisticAnimation() {
    const sectionId = 'statistics-columns-4-{{ section.id }}';
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    // Find all statistic elements
    const statistics = section.querySelectorAll('.featured-card-statistic');
    if (statistics.length === 0) return;
    
    // Use IntersectionObserver to trigger animation when visible
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.dataset.animated) {
          entry.target.dataset.animated = 'true';
          animateStatistic(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    
    statistics.forEach(stat => observer.observe(stat));
  }
  
  // Helper function to parse numbers that may have commas or other formatting
  function parseFormattedNumber(str) {
    if (!str || str === '') return 0;
    // Remove commas and other non-numeric characters except decimal point and minus sign
    const cleaned = String(str).replace(/[^0-9.-]/g, '');
    const parsed = parseFloat(cleaned);
    return isNaN(parsed) ? 0 : parsed;
  }
  
  function animateStatistic(container) {
    const numberElement = container.querySelector('.statistic-number');
    if (!numberElement) return;
    
    const targetNumber = parseFormattedNumber(container.dataset.countTo);
    const duration = parseFloat(container.dataset.countDuration) || 2;
    const startTime = performance.now();
    
    // If target is 0, just display 0
    if (targetNumber === 0) {
      numberElement.textContent = '0';
      return;
    }
    
    // Set initial value to 0
    numberElement.textContent = '0';
    
    function updateNumber(currentTime) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / (duration * 1000), 1);
      
      // Ease-out cubic for smooth deceleration
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      
      const currentValue = Math.round(targetNumber * easedProgress);
      numberElement.textContent = currentValue.toLocaleString();
      
      if (progress < 1) {
        requestAnimationFrame(updateNumber);
      } else {
        numberElement.textContent = targetNumber.toLocaleString();
      }
    }
    
    requestAnimationFrame(updateNumber);
  }
  
  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStatisticAnimation);
  } else {
    initStatisticAnimation();
  }
})();
</script>

<script>
(function() {
  function distributeCardsHorizontally() {
    const sectionId = 'statistics-columns-4-{{ section.id }}';
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const cardsGrid = section.querySelector('.cards-grid.layout-columns');
    if (!cardsGrid) return;
    
    // Get all cards
    const cards = Array.from(cardsGrid.querySelectorAll('.testimonial-card, .video-card, .featured-card, .split-card'));
    if (cards.length === 0) return;
    
    // Determine column count based on screen size
    let columnCount = 3;
    if (window.innerWidth <= 1023) {
      columnCount = 1;
    }
    
    // Clear existing column structure if already processed
    if (cardsGrid.dataset.processed === 'true') {
      // Restore original cards
      cards.forEach(card => {
        cardsGrid.appendChild(card);
      });
    }
    
    // Helper function to get card height
    function getCardHeight(card) {
      // Check for card-height class (e.g., card-height-329, card-height-690)
      const heightClass = Array.from(card.classList).find(cls => cls.startsWith('card-height-'));
      if (heightClass) {
        return parseInt(heightClass.replace('card-height-', '')) || 0;
      }
      // For split-card, use computed height (includes both cards + gap)
      if (card.classList.contains('split-card')) {
        return card.offsetHeight || 0;
      }
      // Fallback to computed height if no class
      return card.offsetHeight || 0;
    }
    
    // Find the tallest card
    let tallestCard = cards[0];
    let tallestHeight = getCardHeight(cards[0]);
    
    cards.forEach(card => {
      const height = getCardHeight(card);
      if (height > tallestHeight) {
        tallestHeight = height;
        tallestCard = card;
      }
    });
    
    // Separate tallest card from the rest
    const remainingCards = cards.filter(card => card !== tallestCard);
    
    // Get gap value from CSS custom property or fallback to default
    const gapValue = getComputedStyle(cardsGrid).getPropertyValue('--column-gap') || 'var(--space-xl)';
    
    // Create column containers
    const columns = [];
    for (let i = 0; i < columnCount; i++) {
      const column = document.createElement('div');
      column.className = 'column-container';
      column.style.display = 'flex';
      column.style.flexDirection = 'column';
      column.style.gap = gapValue;
      column.style.flex = '1';
      column.style.minWidth = '0';
      columns.push(column);
    }
    
    // Clear grid and add columns
    cardsGrid.innerHTML = '';
    cardsGrid.style.display = 'flex';
    cardsGrid.style.flexDirection = 'row';
    cardsGrid.style.gap = gapValue;
    columns.forEach(column => cardsGrid.appendChild(column));
    
    // Place tallest card at the top of the left column (column 0)
    columns[0].appendChild(tallestCard);
    
    // Distribute remaining cards starting from column 1 (skip column 0)
    // Fill columns 1 and 2 first, then go back to column 0 if needed
    remainingCards.forEach((card, index) => {
      // Start from column 1, then column 2, then back to column 1, etc.
      // Only go to column 0 after columns 1 and 2 have been filled
      let columnIndex;
      if (columnCount === 1) {
        columnIndex = 0;
      } else {
        // For 2+ columns, fill columns 1 and 2 first (skip column 0)
        const availableColumns = columnCount - 1; // Exclude column 0
        columnIndex = (index % availableColumns) + 1; // Start from column 1
      }
      columns[columnIndex].appendChild(card);
    });
    
    // Mark as processed
    cardsGrid.dataset.processed = 'true';
  }
  
  // Run on load and resize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', distributeCardsHorizontally);
  } else {
    distributeCardsHorizontally();
  }
  
  // Debounced resize handler
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(distributeCardsHorizontally, 250);
  });
})();

// Parallax scroll effect for background images
(function() {
  const sectionId = 'statistics-columns-4-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const backgroundElements = Array.from(section.querySelectorAll('.featured-card-background, .split-card-background'));
  if (backgroundElements.length === 0) return;
  
  // Assign different parallax intensities to each card for variation
  // Reduced intensities for less movement
  const parallaxIntensities = [0.02, 0.03, 0.025, 0.035, 0.02, 0.04, 0.025, 0.03]; // Reduced variations
  backgroundElements.forEach((bg, index) => {
    bg.dataset.parallaxIntensity = parallaxIntensities[index % parallaxIntensities.length];
  });
  
  function updateParallax() {
    const scrollY = window.pageYOffset || document.documentElement.scrollTop;
    const windowHeight = window.innerHeight;
    
    backgroundElements.forEach(bg => {
      const card = bg.closest('.featured-card, .split-card-top, .split-card-bottom');
      if (!card) return;
      
      const rect = card.getBoundingClientRect();
      const cardTop = rect.top + scrollY;
      const cardHeight = rect.height;
      
      // Calculate how much of the card is visible
      const cardCenter = cardTop + cardHeight / 2;
      const viewportCenter = scrollY + windowHeight / 2;
      
      // Distance from viewport center to card center
      const distance = viewportCenter - cardCenter;
      
      // Get card-specific parallax intensity (reduced for less movement)
      const parallaxIntensity = parseFloat(bg.dataset.parallaxIntensity) || 0.025;
      
      // Initial offset to start images higher
      const initialOffset = -30;
      let translateY = initialOffset + (distance * parallaxIntensity);
      
      // Clamp to prevent too much downward movement - keep it within reasonable bounds
      translateY = Math.max(initialOffset, Math.min(initialOffset + 20, translateY));
      
      // Apply transform - base scale of 1.4 (140% zoom) + initial offset + subtle parallax translation
      // The scale is centered, so images stay properly positioned
      bg.style.transform = `scale(1.4) translate3d(0, ${translateY}px, 0)`;
    });
  }
  
  // Use requestAnimationFrame for smooth performance
  let ticking = false;
  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateParallax();
        ticking = false;
      });
      ticking = true;
    }
  }
  
  // Initial call
  updateParallax();
  
  // Listen to scroll events
  window.addEventListener('scroll', onScroll, { passive: true });
  
  // Update on resize
  window.addEventListener('resize', updateParallax, { passive: true });
})();

// Staggered fade-in and slide-up animation for cards
(function() {
  const sectionId = 'statistics-columns-4-{{ section.id }}';
  const section = document.getElementById(sectionId);
  if (!section) return;
  
  const cardsGrid = section.querySelector('.cards-grid.layout-columns');
  if (!cardsGrid) return;
  
  // Wait for cards to be distributed into columns
  function initAnimation() {
    const featuredCards = Array.from(cardsGrid.querySelectorAll('.featured-card'));
    const splitCards = Array.from(cardsGrid.querySelectorAll('.split-card'));
    
    // Collect all cards to animate (featured cards + split card parts)
    const allCardsToAnimate = [];
    
    // Add featured cards
    featuredCards.forEach(card => {
      allCardsToAnimate.push({ element: card, delay: 0 });
    });
    
    // Add split card top and bottom parts separately
    splitCards.forEach(splitCard => {
      const topCard = splitCard.querySelector('.split-card-top');
      const bottomCard = splitCard.querySelector('.split-card-bottom');
      
      if (topCard) {
        allCardsToAnimate.push({ element: topCard, delay: 0 });
      }
      if (bottomCard) {
        allCardsToAnimate.push({ element: bottomCard, delay: 0 });
      }
    });
    
    if (allCardsToAnimate.length === 0) return;
    
    // Intersection Observer to trigger animation when section comes into view
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1 // Trigger when 10% of section is visible
    };
    
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Stagger the animation for each card
          allCardsToAnimate.forEach((card, index) => {
            setTimeout(() => {
              card.element.classList.add('animate-in');
            }, index * 100); // 100ms delay between each card
          });
          
          // Unobserve after animation is triggered
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    
    // Start observing the section
    observer.observe(section);
  }
  
  // Wait for card distribution to complete, then initialize animation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(initAnimation, 500); // Wait for card distribution
    });
  } else {
    setTimeout(initAnimation, 500); // Wait for card distribution
  }
})();
</script>

