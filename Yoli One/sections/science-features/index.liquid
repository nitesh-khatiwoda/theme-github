<link rel="stylesheet" href="{{ 'science-features/styles.css' | asset_url }}">

<!-- Science Features Section -->
<section class="science-features {{ section.settings.background_color | default: 'bg-success' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="science-features__inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Main Heading -->
      {% if section.settings.heading != blank %}
        <div class="science-features__heading">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-white' }}">
            {{ section.settings.heading }}
          </h2>
        </div>
      {% endif %}

      <!-- Description -->
      {% if section.settings.description != blank %}
        <div class="science-features__description">
          <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-white' }}">
            {{ section.settings.description }}
          </p>
        </div>
      {% endif %}

      <!-- Features Grid -->
      {% if section.blocks.size > 0 %}
        <div class="science-features__grid">
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              <div class="science-features__card" {{ block.fluid_attributes }}>
                
                <!-- Icon -->
                <div class="science-features__icon {{ section.settings.icon_background_color | default: 'bg-secondary' }}">
                  {% if block.settings.icon != blank %}
                    <img src="{{ block.settings.icon | image_url: width: 200 }}" 
                         alt="{{ block.settings.icon_alt | default: block.settings.title }}">
                  {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" 
                         alt="{{ block.settings.icon_alt | default: 'Feature icon' }}">
                  {% endif %}
                </div>

                <!-- Title -->
                {% if block.settings.title != blank %}
                  <div class="science-features__card-title">
                    <h3 class="{{ section.settings.card_title_font_family | default: 'font-primary' }} {{ section.settings.card_title_font_size | default: 'text-xl' }} {{ section.settings.card_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.card_title_font_weight | default: 'font-semibold' }} {{ section.settings.card_title_color | default: 'text-white' }}">
                      {{ block.settings.title }}
                    </h3>
                  </div>
                {% endif %}

                <!-- Description -->
                {% if block.settings.description != blank %}
                  <div class="science-features__card-description">
                    <p class="{{ section.settings.card_description_font_family | default: 'font-body' }} {{ section.settings.card_description_font_size | default: 'text-base' }} {{ section.settings.card_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_description_font_weight | default: 'font-normal' }} {{ section.settings.card_description_color | default: 'text-white' }}">
                      {{ block.settings.description }}
                    </p>
                  </div>
                {% endif %}

              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

    </div>
  </div>

</section>

