<link rel="stylesheet" href="{{ 'logos-showcase-auto/styles.css' | asset_url }}">

<!-- Logos Showcase Auto Section -->
<section 
  class="logos-showcase-auto {{ section.settings.background_color | default: 'bg-neutral' }} {{section.settings.padding_top_mobile}} {{section.settings.padding_bottom_mobile}} {{section.settings.padding_x_mobile}}  lg:{{section.settings.padding_top_desktop}} lg:{{section.settings.padding_bottom_desktop}} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="logos-showcase-{{ section.id }}"
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="logos-showcase-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }} {% unless section.settings.show_heading and section.settings.heading != blank %}no-heading{% endunless %}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Heading -->
      {% if section.settings.show_heading and section.settings.heading != blank %}
      <div class="logos-showcase-heading mb-lg" style="max-width: 100%; margin: 0 auto; text-align: center;">
        <h1 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-2xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-black' }}" style="line-height: 1;">
          {{ section.settings.heading }}
        </h1>
      </div>
      {% endif %}
      
      <!-- Carousel Wrapper -->
      <div class="logos-showcase-carousel-wrapper">
        <div class="logos-showcase-carousel-container">
          <div class="logos-showcase-carousel-track" id="carousel-track-{{ section.id }}" data-loop="true">
            {% for block in section.blocks %}
              {% if block.type == 'logo' %}
              <div class="logos-showcase-carousel-item" {{ block.fluid_attributes }}>
                <div class="logos-showcase-logo-wrapper">
                  {% if block.settings.logo_image != blank %}
                    <img 
                      src="{{ block.settings.logo_image | image_url: width: 200 }}" 
                      alt="{{ block.settings.logo_alt | default: 'Logo' }}" 
                      class="logos-showcase-logo {{ block.settings.logo_class | default: 'h-7 w-auto' }}"
                      loading="lazy">
                  {% else %}
                    <img 
                      src="{{ 'placeholder-image.png' | asset_url }}" 
                      alt="Logo placeholder" 
                      class="logos-showcase-logo {{ block.settings.logo_class | default: 'h-7 w-auto' }}"
                      loading="lazy">
                  {% endif %}
                </div>
              </div>
              {% endif %}
            {% endfor %}
            
            <!-- Duplicate set for seamless loop -->
            {% for block in section.blocks %}
              {% if block.type == 'logo' %}
              <div class="logos-showcase-carousel-item" aria-hidden="true">
                <div class="logos-showcase-logo-wrapper">
                  {% if block.settings.logo_image != blank %}
                    <img 
                      src="{{ block.settings.logo_image | image_url: width: 200 }}" 
                      alt="{{ block.settings.logo_alt | default: 'Logo' }}" 
                      class="logos-showcase-logo {{ block.settings.logo_class | default: 'h-7 w-auto' }}"
                      loading="lazy">
                  {% else %}
                    <img 
                      src="{{ 'placeholder-image.png' | asset_url }}" 
                      alt="Logo placeholder" 
                      class="logos-showcase-logo {{ block.settings.logo_class | default: 'h-7 w-auto' }}"
                      loading="lazy">
                  {% endif %}
                </div>
              </div>
              {% endif %}
            {% endfor %}
          </div>
          
          <!-- Fade Gradients -->
          <div class="logos-showcase-fade-left"></div>
          <div class="logos-showcase-fade-right"></div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const track = document.getElementById('carousel-track-' + sectionId);
  
  if (!track) return;
  
  const items = track.querySelectorAll('.logos-showcase-carousel-item');
  if (items.length === 0) return;
  
  const scrollSpeed = {{ section.settings.scroll_speed | default: 1 }};
  const scrollDirection = '{{ section.settings.scroll_direction | default: "left" }}';
  
  // Calculate initial position based on direction
  const itemWidth = items[0].offsetWidth;
  const gap = 80; // mx-10 = 40px on each side = 80px total
  const itemTotalWidth = itemWidth + gap;
  const totalWidth = (items.length / 2) * itemTotalWidth;
  
  let scrollPosition = scrollDirection === 'right' ? totalWidth : 0;
  let animationId = null;
  let isPaused = false;
  
  function autoScroll() {
    if (isPaused) {
      animationId = requestAnimationFrame(autoScroll);
      return;
    }
    
    // Update scroll position based on direction
    if (scrollDirection === 'right') {
      scrollPosition -= scrollSpeed; // Scroll right (negative translateX)
      // Reset when we've scrolled backwards one full set
      if (scrollPosition <= 0) {
        scrollPosition = totalWidth;
      }
    } else {
      scrollPosition += scrollSpeed; // Scroll left (positive translateX)
      // Reset when we've scrolled forward one full set
      if (scrollPosition >= totalWidth) {
        scrollPosition = 0;
      }
    }
    
    track.style.transform = `translateX(-${scrollPosition}px)`;
    animationId = requestAnimationFrame(autoScroll);
  }
  
  // Pause on hover
  const wrapper = track.closest('.logos-showcase-carousel-container');
  if (wrapper) {
    wrapper.addEventListener('mouseenter', function() {
      isPaused = true;
    });
    
    wrapper.addEventListener('mouseleave', function() {
      isPaused = false;
    });
  }
  
  // Start auto-scroll
  autoScroll();
  
  // Handle resize
  let resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function() {
      // Reset scroll position on resize based on direction
      const newItemWidth = items[0].offsetWidth;
      const newItemTotalWidth = newItemWidth + gap;
      const newTotalWidth = (items.length / 2) * newItemTotalWidth;
      scrollPosition = scrollDirection === 'right' ? newTotalWidth : 0;
      track.style.transform = `translateX(-${scrollPosition}px)`;
    }, 250);
  });
})();
</script>

