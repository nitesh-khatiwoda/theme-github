<link rel="stylesheet" href="{{ 'interactive-component.css' | asset_url }}">

<!-- Interactive Component Section -->
<section 
  class="interactive-component {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.padding_top_mobile | default: 'py-xl' }} {{ section.settings.padding_bottom_mobile | default: 'py-xl' }} {{ section.settings.padding_x_mobile | default: 'px-md' }} lg:{{ section.settings.padding_top_desktop | default: 'py-3xl' }} lg:{{ section.settings.padding_bottom_desktop | default: 'py-3xl' }} lg:{{ section.settings.padding_x_desktop | default: 'px-xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="interactive-component-{{ section.id }}"
  data-interactive-component
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout-width | default: 'container'}}">
    <div class="interactive-component-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}"
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Section Heading -->
      {% if section.settings.heading_text != blank %}
      <div class="interactive-heading-wrapper mb-2xl text-center">
        <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }} leading-heading">
          {{ section.settings.heading_text }}
        </h2>
      </div>
      {% endif %}
      
      <!-- Section Description -->
      {% if section.settings.description_text != blank %}
      <div class="interactive-description-wrapper mb-2xl text-center">
        <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-neutral' }} leading-body">
          {{ section.settings.description_text }}
        </p>
      </div>
      {% endif %}
      
      <!-- Interactive Content Blocks -->
      {% if section.blocks.size > 0 %}
      <div class="interactive-blocks-container">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'interactive_item' %}
              <div class="interactive-item" {{ block.fluid_attributes }} data-interactive-item data-item-index="{{ forloop.index0 }}">
                
                <!-- Item Header -->
                <div class="interactive-item-header {{ block.settings.header_background_color | default: 'bg-card-primary' }} {{ block.settings.header_border_color | default: 'border-neutral-light' }} {{ block.settings.header_border_radius | default: 'rounded-lg' }}" 
                     role="button" 
                     tabindex="0"
                     aria-expanded="false"
                     aria-controls="content-{{ block.id }}">
                  
                  <!-- Item Icon (Optional) -->
                  {% if block.settings.show_icon and block.settings.icon_type != blank %}
                  <div class="interactive-item-icon {{ block.settings.icon_color | default: 'text-primary' }}">
                    {% if block.settings.icon_type == 'arrow' %}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% elsif block.settings.icon_type == 'plus' %}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% elsif block.settings.icon_type == 'check' %}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% elsif block.settings.icon_type == 'custom' and block.settings.custom_icon != blank %}
                      <img src="{{ block.settings.custom_icon | image_url: width: 48 }}" alt="{{ block.settings.title }}" loading="lazy">
                    {% endif %}
                  </div>
                  {% endif %}
                  
                  <!-- Item Title -->
                  {% if block.settings.title != blank %}
                  <h3 class="{{ block.settings.title_font_family | default: 'font-primary' }} {{ block.settings.title_font_size | default: 'text-xl' }} {{ block.settings.title_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.title_font_weight | default: 'font-medium' }} {{ block.settings.title_color | default: 'text-neutral-dark' }} leading-heading">
                    {{ block.settings.title }}
                  </h3>
                  {% endif %}
                  
                  <!-- Expand/Collapse Indicator -->
                  <div class="interactive-item-indicator {{ block.settings.indicator_color | default: 'text-neutral-medium' }}">
                    <svg class="indicator-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  
                </div>
                
                <!-- Item Content (Collapsible) -->
                <div class="interactive-item-content {{ block.settings.content_background_color | default: 'bg-white' }} {{ block.settings.content_border_color | default: 'border-neutral-light' }} {{ block.settings.content_border_radius | default: 'rounded-lg' }}" 
                     id="content-{{ block.id }}"
                     aria-hidden="true">
                  
                  <!-- Content Text -->
                  {% if block.settings.content_text != blank %}
                  <div class="interactive-item-content-text {{ block.settings.content_text_font_family | default: 'font-body' }} {{ block.settings.content_text_font_size | default: 'text-base' }} {{ block.settings.content_text_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.content_text_font_weight | default: 'font-normal' }} {{ block.settings.content_text_color | default: 'text-neutral' }} leading-body">
                    {{ block.settings.content_text }}
                  </div>
                  {% endif %}
                  
                  <!-- Content Image (Optional) -->
                  {% if block.settings.content_image != blank %}
                  <div class="interactive-item-content-image">
                    <img src="{{ block.settings.content_image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy" class="w-full {{ block.settings.image_border_radius | default: 'rounded-md' }}">
                  </div>
                  {% endif %}
                  
                  <!-- Content Button (Optional) -->
                  {% if block.settings.show_button and block.settings.button_text != blank %}
                  <div class="interactive-item-content-button mt-lg">
                    <a href="{{ block.settings.button_url | default: '#' }}" 
                       class="btn btn-{{ block.settings.button_style | default: 'filled' }}-{{ block.settings.button_color | default: 'primary' }} {{ block.settings.button_size | default: 'btn-md' }} {{ block.settings.button_font_weight | default: 'font-medium' }} {{ block.settings.button_border_radius | default: 'rounded-lg' }}"
                       {% if block.settings.button_url == blank %}onclick="return false;"{% endif %}>
                      {{ block.settings.button_text }}
                    </a>
                  </div>
                  {% endif %}
                  
                </div>
                
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      {% endif %}
      
      <!-- Section CTA Button -->
      {% if section.settings.show_cta_button and section.settings.cta_button_text != blank %}
      <div class="interactive-cta-wrapper mt-3xl text-center">
        <a href="{{ section.settings.cta_button_url | default: '#' }}" 
           class="btn btn-{{ section.settings.cta_button_style | default: 'filled' }}-{{ section.settings.cta_button_color | default: 'primary' }} {{ section.settings.cta_button_size | default: 'btn-lg' }} {{ section.settings.cta_button_font_weight | default: 'font-medium' }} {{ section.settings.cta_button_border_radius | default: 'rounded-lg' }}"
           {% if section.settings.cta_button_url == blank %}onclick="return false;"{% endif %}>
          {{ section.settings.cta_button_text }}
        </a>
      </div>
      {% endif %}
      
    </div>
  </div>
</section>

<script src="{{ 'interactive-component.js' | asset_url }}" defer></script>

