<link rel="stylesheet" href="{{ 'before-after-carousel/styles.css' | asset_url }}">

<!-- Before After Carousel -->
<section class="before-after-carousel {{ section.settings.background_color | default: 'bg-neutral' }} {{ section.settings.section_padding_y_mobile | default: 'py-md' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-md' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="before-after-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="{{section.settings.container_layout-width | default: 'container'}}">
    <div class="before-after-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-md' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-md' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header Row: Heading + Navigation -->
      <div class="before-after-header-row">
        <!-- Left: Heading -->
        <div class="before-after-heading-col">
          {% if section.settings.heading != blank %}
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-white' }} leading-heading">
            {{ section.settings.heading }}
          </h2>
          {% endif %}
        </div>
        
        <!-- Right: Navigation -->
        <div class="before-after-nav-col">
          <div class="carousel-controls">
            <button class="nav-arrow nav-arrow--prev" data-before-after-prev aria-label="Previous comparison">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="nav-arrow nav-arrow--next" data-before-after-next aria-label="Next comparison">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      
      <div class="before-after-wrapper {% if section.settings.flip_layout %}before-after-wrapper--flipped{% endif %}">
        
        <!-- Carousel -->
        <div class="before-after-slider-carousel">
          <div class="carousel-track" data-before-after-track>
            {% for block in section.blocks %}
              <div class="slider-slide" {{ block.fluid_attributes }}>
                
                <!-- Two Column Layout -->
                <div class="slide-two-column">
                  
                  <!-- Left Column: Testimonial Content -->
                  <div class="slide-left-content">
                    <!-- Star Rating -->
                    {% if section.settings.show_stars %}
                    <div class="star-rating-wrapper">
                      <div class="star-rating {{ section.settings.star_color | default: 'text-warning' }}">
                        {% for i in (1..5) %}
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                          <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/>
                        </svg>
                        {% endfor %}
                      </div>
                    </div>
                    {% endif %}
                    
                    <!-- Quote Text -->
                    {% if block.settings.quote != blank %}
                    <p class="quote-text {{ block.settings.quote_font_family | default: 'font-body' }} {{ block.settings.quote_font_size | default: 'text-xl' }} {{ block.settings.quote_font_size_desktop | default: 'lg:text-2xl' }} {{ block.settings.quote_font_weight | default: 'font-normal' }} {{ block.settings.quote_color | default: 'text-white' }} leading-body">
                      "{{ block.settings.quote }}"
                    </p>
                    {% endif %}
                    
                    <!-- Signature -->
                    {% if block.settings.signature_text != blank %}
                    <p class="signature-text font-handwritten {{ block.settings.signature_font_size | default: 'text-2xl' }} {{ block.settings.signature_font_size_desktop | default: 'lg:text-3xl' }} {{ block.settings.signature_color | default: 'text-white' }}">
                      {{ block.settings.signature_text }}
                    </p>
                    {% endif %}
                    
                    <!-- Author Info -->
                    {% if block.settings.author != blank %}
                    <span class="author-name {{ block.settings.author_font_family | default: 'font-body' }} {{ block.settings.author_font_size | default: 'text-base' }} {{ block.settings.author_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.author_font_weight | default: 'font-semibold' }} {{ block.settings.author_color | default: 'text-white' }}">{{ block.settings.author }}</span>
                    {% endif %}
                  </div>
                  
                  <!-- Right Column: Before/After Image -->
                  <div class="slide-right-content">
                    <div class="before-after-image-container {{ section.settings.photo_border_radius | default: 'rounded' }}" data-slider-container>
                  <!-- Before Image -->
                  <div class="before-image-wrapper">
                    {% if block.settings.before_photo != blank %}
                    <img src="{{ block.settings.before_photo | image_url: width: 1200 }}" alt="Before - {{ block.settings.author }}" class="before-image" loading="lazy">
                    {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Before Placeholder" class="before-image" loading="lazy">
                    {% endif %}
                    {% if section.settings.show_labels %}
                    <div class="image-label image-label--before {{ section.settings.label_font_family | default: 'font-body' }} {{ section.settings.label_font_size | default: 'text-sm' }} {{ section.settings.label_font_weight | default: 'font-semibold' }} {{ section.settings.label_color | default: 'text-white' }}">
                      {{ section.settings.before_label | default: 'Before' }}
                    </div>
                    {% endif %}
                  </div>
                  
                  <!-- After Image (reveals on drag) -->
                  <div class="after-image-wrapper" data-after-wrapper>
                    {% if block.settings.after_photo != blank %}
                    <img src="{{ block.settings.after_photo | image_url: width: 1200 }}" alt="After - {{ block.settings.author }}" class="after-image" loading="lazy">
                    {% else %}
                    <img src="{{ 'placeholder-image.png' | asset_url }}" alt="After Placeholder" class="after-image" loading="lazy">
                    {% endif %}
                    {% if section.settings.show_labels %}
                    <div class="image-label image-label--after {{ section.settings.label_font_family | default: 'font-body' }} {{ section.settings.label_font_size | default: 'text-sm' }} {{ section.settings.label_font_weight | default: 'font-semibold' }} {{ section.settings.label_color | default: 'text-white' }}">
                      {{ section.settings.after_label | default: 'After' }}
                    </div>
                    {% endif %}
                  </div>
                  
                  <!-- Draggable Divider -->
                  <div class="slider-divider" data-slider-divider>
                    <div class="slider-handle">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </div>
                    </div>
                  </div>
                  
                </div><!-- .slide-two-column -->
                
              </div><!-- .slider-slide -->
            {% endfor %}
          </div><!-- .carousel-track -->
        </div><!-- .before-after-slider-carousel -->
        
      </div><!-- .before-after-wrapper -->
      
    </div>
  </div>
</section>

<script>
(function() {
  // Carousel functionality
  const track = document.querySelector('[data-before-after-track]');
  const prevBtn = document.querySelector('[data-before-after-prev]');
  const nextBtn = document.querySelector('[data-before-after-next]');
  if (!track || !prevBtn || !nextBtn) return;
  
  let currentIndex = 0;
  const slides = Array.from(track.children);
  const totalSlides = slides.length;
  
  if (totalSlides === 0) return;
  
  function goToSlide(index) {
    currentIndex = index;
    const slideWidth = slides[0].offsetWidth;
    track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
    
    // Reinitialize sliders for the current slide
    initializeSlider(slides[currentIndex]);
  }
  
  prevBtn.addEventListener('click', () => {
    currentIndex = currentIndex > 0 ? currentIndex - 1 : totalSlides - 1;
    goToSlide(currentIndex);
  });
  
  nextBtn.addEventListener('click', () => {
    currentIndex = currentIndex < totalSlides - 1 ? currentIndex + 1 : 0;
    goToSlide(currentIndex);
  });
  
  // Responsive resize
  window.addEventListener('resize', () => {
    goToSlide(currentIndex);
  });
  
  // Before/After Slider functionality
  function initializeSlider(slideElement) {
    const container = slideElement.querySelector('[data-slider-container]');
    const divider = slideElement.querySelector('[data-slider-divider]');
    const beforeWrapper = container.querySelector('.before-image-wrapper');
    
    if (!container || !divider || !beforeWrapper) return;
    
    let isDragging = false;
    
    function updateSlider(clientX) {
      const rect = container.getBoundingClientRect();
      let offsetX = clientX - rect.left;
      
      // Constrain between 0 and container width
      offsetX = Math.max(0, Math.min(offsetX, rect.width));
      
      const percentage = (offsetX / rect.width) * 100;
      
      // Update positions - clip the BEFORE image to reveal AFTER behind
      beforeWrapper.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
      divider.style.left = `${percentage}%`;
    }
    
    // Mouse events
    divider.addEventListener('mousedown', (e) => {
      isDragging = true;
      e.preventDefault();
    });
    
    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      updateSlider(e.clientX);
    });
    
    document.addEventListener('mouseup', () => {
      isDragging = false;
    });
    
    // Touch events
    divider.addEventListener('touchstart', (e) => {
      isDragging = true;
      e.preventDefault();
    });
    
    document.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const touch = e.touches[0];
      updateSlider(touch.clientX);
    });
    
    document.addEventListener('touchend', () => {
      isDragging = false;
    });
    
    // Click on container to move slider
    container.addEventListener('click', (e) => {
      if (e.target === divider || divider.contains(e.target)) return;
      updateSlider(e.clientX);
    });
  }
  
  // Initialize all sliders
  slides.forEach(slide => initializeSlider(slide));
  
  // Initialize first slide
  goToSlide(0);
})();
</script>

