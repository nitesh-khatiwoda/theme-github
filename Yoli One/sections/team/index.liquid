<link rel="stylesheet" href="{{ 'team/styles.css' | asset_url }}">

<!-- Team Section -->
<section class="team-section {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="team-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="team-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-2xl' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-lg' }} {{ section.settings.container_padding_x_mobile | default: 'px-lg' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-lg' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header -->
      <div class="team-header">
        <div class="header-left">
          {% if section.settings.heading != blank %}
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} text-3xl lg:text-5xl font-semibold leading-heading {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
            {{ section.settings.heading }}
            {% if section.settings.heading_emphasis != blank %}
            <em class="heading-emphasis">{{ section.settings.heading_emphasis }}</em>
            {% endif %}
            {% if section.settings.heading_suffix != blank %}
            {{ section.settings.heading_suffix }}
            {% endif %}
          </h2>
          {% endif %}
        </div>
        
        <div class="header-right">
          {% if section.settings.show_cta_button %}
          <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn-{{ section.settings.cta_button_style | default: 'filled' }}-{{ section.settings.cta_button_color | default: 'primary' }} {{ section.settings.cta_button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
            {{ section.settings.cta_text | default: 'Join our team' }}
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.5 6.5H12M12 6.5L6.5 1M12 6.5L6.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          {% endif %}
        </div>
      </div>
      
      <!-- Subtitle Badge -->
      {% if section.settings.subtitle != blank %}
      <div class="team-subtitle">
        <span class="subtitle-badge text-base font-normal" style="background-color: {{ section.settings.subtitle_bg_color | default: '#d6d6ff' }};">
          {{ section.settings.subtitle }}
        </span>
      </div>
      {% endif %}
      
      <!-- Team Grid -->
      {% if section.blocks.size > 0 %}
      <div class="team-grid">
        {% for block in section.blocks %}
          {% if block.type == 'team_member' %}
          <div class="team-member" {{ block.fluid_attributes }}>
            
            <!-- Photo -->
            {% if block.settings.photo != blank %}
            <div class="member-photo">
              <img src="{{ block.settings.photo | image_url: width: 128 }}" alt="{{ block.settings.name }}" loading="lazy">
            </div>
            {% else %}
            <div class="member-photo member-photo-placeholder {{ section.settings.initials_bg_color | default: 'bg-neutral-light' }}">
              <span class="{{ section.settings.initials_text_color | default: 'text-neutral-dark' }}">{{ block.settings.initials | default: 'TM' }}</span>
            </div>
            {% endif %}
            
            <!-- Info -->
            <div class="member-info">
              {% if block.settings.name != blank %}
              <h3 class="text-xl font-semibold leading-heading member-name leading-heading">
                {{ block.settings.name }}
              </h3>
              {% endif %}
              
              {% if block.settings.title != blank %}
              <p class="text-sm font-normal leading-body member-title leading-body">
                {{ block.settings.title }}
              </p>
              {% endif %}
            </div>
            
          </div>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      
    </div>
  </div>
  
</section>

