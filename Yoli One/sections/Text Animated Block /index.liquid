<section
  class="animated-text-block-section animated-scrollable-text-block-- {{ section.settings.background_color }}"
  id="animated-scrollable-text-block"
>
  <div class="image-wrap">
    <img
      id="bgImage"
      src="{{ section.settings.background_image }}"
      alt="{{ background_image_alt | default: 'bg image' }}"
      class="{{ section.settings.background_fit }}"
    />

  </div>
  {% if section.settings.show_overlay %}
    {% assign overlay_opacity = section.settings.overlay_opacity | default: 40 | divided_by: 100.0 %}
    <div class="overlay" style="background: {{ section.settings.overlay_color | default: '#000000' }}; opacity: {{ overlay_opacity }};"></div>
  {% endif %}
  <div class="{{section.settings.container_layout_width }}">
    <div class="content {{ section.settings.alignment }} {{ section.settings.content_padding_x_mobile }} {{  section.settings.content_padding_x_desktop}} {{ section.settings.content_padding_y_mobile }} {{  section.settings.content_padding_y_desktop}}">
      <!-- Sticky Overline Text -->
      <div>
      {% if section.settings.show_overline and section.settings.overline_text != blank %}
        <div class="section-title  {{ section.settings.overline_font_family }} {{ section.settings.overline_font_size }} {{ section.settings.overline_font_size_desktop  }} {{ section.settings.overline_font_weight }} {{ section.settings.overline_color }} {{ section.settings.overline_text_transform }} {{  section.settings.verline_text_margin_bottom }}">
          {{ section.settings.overline_text }}
        </div>
      {% endif %}
      {% if section.blocks.size > 0 %}
        <div class="stack-viewport" id="stackViewport">
          <div class="stack" id="stack">
            {% for block in section.blocks %}
              {% if block.type == 'text_animated_block' %}
                <div class="heading {{ section.settings.item_font_family }}  {{ section.settings.item_font_size }} {{ section.settings.item_font_size_desktop }} {{ section.settings.item_font_weight }} {{ section.settings.item_text_color }}"  {{ block.fluid_attributes }}>
                  {{ block.settings.text }}
                </div>

              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
      {% if section.settings.button_text != blank and section.settings.button_url != blank %}
          <div class="text-block-effects-footer mt-xl">
            <a href="{{ section.settings.button_url }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text }}
            </a>
          </div>
          {% endif %}
      </div>
    </div>
  </div>
</section>


