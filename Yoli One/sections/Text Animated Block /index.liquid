<script>
document.addEventListener("DOMContentLoaded", () => {
  const section = document.getElementById("animated-scrollable-text-block");
  const img = document.getElementById("bgImage");
  const viewport = document.getElementById("stackViewport");
  const stack = document.getElementById("stack");
  const headings = Array.from(stack.querySelectorAll(".heading"));

  let totalScroll = 0;
  let imgTravel = 0;

  let smoothProgress = 0;
  let targetProgress = 0;

  const clamp = (v, min, max) => Math.max(min, Math.min(max, v));

  function measure() {
    // Reset heading heights
    headings.forEach(h => (h.style.height = "auto"));
    viewport.style.height = "auto";

    // Max heading height
    const maxH = Math.max(...headings.map(h => h.getBoundingClientRect().height)) + 24;
    viewport.style.height = maxH + "px";
    headings.forEach(h => (h.style.height = maxH + "px"));

    // Total stack scroll = distance to show last heading fully
    totalScroll = headings[headings.length - 1].offsetTop;

    // Background travel
    imgTravel = img ? Math.max(0, img.getBoundingClientRect().height - (window.innerHeight - 66)) : 0;

    // Set section height to 100vh - 66px
    section.style.height = `calc(100vh - 66px)`;

    // Make section sticky
    section.style.position = "sticky";
    section.style.top = "66px"; // account for header height
    section.style.left = "0";
    section.style.right = "0";
    section.style.width = "100%";
    section.style.zIndex = "1";
  }

  function applyProgress(p) {
    stack.style.transform = `translate3d(0, ${-totalScroll * p}px, 0)`;
    if(img) img.style.transform = `translate3d(0, ${-imgTravel * p}px, 0)`;
  }

  function animateProgress() {
    smoothProgress += (targetProgress - smoothProgress) * 0.1;
    applyProgress(smoothProgress);

    if(Math.abs(targetProgress - smoothProgress) > 0.001){
      requestAnimationFrame(animateProgress);
    }
  }

  function onScroll() {
    const scroll = window.scrollY;
    const start = section.offsetTop - 66; // adjust for sticky offset
    const end = start + totalScroll;

    if(scroll >= start && scroll <= end){
      targetProgress = clamp((scroll - start) / totalScroll, 0, 1);
      animateProgress();
    } else {
      targetProgress = scroll > end ? 1 : 0;
      animateProgress();
    }
  }

  function init() {
    measure();
    onScroll();

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      clearTimeout(window.__rsz);
      window.__rsz = setTimeout(() => {
        measure();
        onScroll();
      }, 120);
    });
  }

  const start = () => {
    if(img && !img.complete){
      img.addEventListener("load", init, { once: true });
    } else {
      init();
    }
  };

  if(document.fonts && document.fonts.ready){
    document.fonts.ready.then(start);
  } else {
    start();
  }
});
</script>



