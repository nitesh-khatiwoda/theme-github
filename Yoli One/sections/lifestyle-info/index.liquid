<link rel="stylesheet" href="{{ 'lifestyle-info/styles.css' | asset_url }}">

<!-- Lifestyle Info -->
<section 
  class="lifestyle-info {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="lifestyle-info-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="lifestyle-info-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="lifestyle-info-grid {% if section.settings.flip_layout %}lifestyle-info-grid--flipped{% endif %}">
        
        <!-- Left Column: Content -->
        <div class="lifestyle-info-content-column">
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
          <div class="lifestyle-info-heading-wrapper {{ section.settings.heading_body_spacing_mobile | default: 'mb-lg' }} {{ section.settings.heading_body_spacing_desktop | default: 'lg:mb-lg' }}">
            <h2 class="lifestyle-info-heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Body Text -->
          {% if section.settings.body_text != blank %}
          <div class="lifestyle-info-body-wrapper {{ section.settings.body_margin_bottom_mobile | default: 'mb-lg' }} {{ section.settings.body_margin_bottom_desktop | default: 'lg:mb-lg' }}">
            <div class="lifestyle-info-body {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.body_font_weight | default: 'font-normal' }} {{ section.settings.body_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
              {{ section.settings.body_text }}
            </div>
          </div>
          {% endif %}
          
          <!-- Feature Blocks -->
          {% unless section.settings.hide_all_blocks %}
          {% if section.blocks.size > 0 %}
          {% assign blocks_gap_mobile = section.settings.blocks_gap_mobile | default: 'lg' %}
          {% assign blocks_gap_desktop = section.settings.blocks_gap_desktop | default: 'xl' %}
          <div class="lifestyle-info-features lifestyle-info-features--gap-{{ blocks_gap_mobile }} lifestyle-info-features--gap-desktop-{{ blocks_gap_desktop }}{% if section.settings.show_row_dividers %} lifestyle-info-features--with-dividers{% endif %}">
            {% for block in section.blocks %}
              {% if block.type == 'feature_item' %}
              {% assign image_text_gap_mobile = section.settings.image_text_gap_mobile | default: 'md' %}
              {% assign image_text_gap_desktop = section.settings.image_text_gap_desktop | default: 'lg' %}
              <div class="lifestyle-info-feature-item lifestyle-info-feature-item--gap-{{ image_text_gap_mobile }} lifestyle-info-feature-item--gap-desktop-{{ image_text_gap_desktop }} {% if block.settings.hide_icon %}lifestyle-info-feature-item--no-icon{% endif %}" {{ block.fluid_attributes }}>
                
                <!-- Icon -->
                {% unless block.settings.hide_icon %}
                {% assign block_icon_size_mobile = section.settings.icon_size_mobile | default: '32' %}
                {% assign block_icon_size_desktop = section.settings.icon_size_desktop | default: block_icon_size_mobile %}
                <div class="lifestyle-info-feature-icon" style="width: {{ block_icon_size_mobile }}px; height: {{ block_icon_size_mobile }}px; {% if section.settings.icon_size_desktop %}--icon-size-desktop: {{ block_icon_size_desktop }}px;{% endif %}">
                  {% if block.settings.icon != blank %}
                    <img src="{{ block.settings.icon | image_url: width: block_icon_size_desktop | default: block_icon_size_mobile }}" 
                         alt="{{ block.settings.icon_alt | default: block.settings.title }}"
                         loading="lazy"
                         class="lifestyle-info-feature-icon-img"
                         style="box-shadow: none !important; width: 100%; height: 100%; object-fit: contain;">
                  {% else %}
                    <div class="lifestyle-info-feature-icon-placeholder" style="width: 100%; height: 100%;">
                      <svg width="{{ block_icon_size_mobile }}" height="{{ block_icon_size_mobile }}" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="{{ section.settings.icon_color | default: 'text-tertiary' }}" style="width: 100%; height: 100%;">
                        <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2"/>
                        <circle cx="16" cy="16" r="6" fill="currentColor"/>
                      </svg>
                    </div>
                  {% endif %}
                </div>
                {% endunless %}
                
                <!-- Feature Content -->
                <div class="lifestyle-info-feature-content">
                  
                  <!-- Feature Title -->
                  {% if block.settings.title != blank %}
                  <div class="lifestyle-info-feature-title {{ section.settings.feature_title_margin_bottom_mobile | default: 'mb-xs' }} {{ section.settings.feature_title_margin_bottom_desktop | default: 'lg:mb-xs' }}">
                    <h3 class="{{ section.settings.feature_title_font_family | default: 'font-body' }} {{ section.settings.feature_title_font_size | default: 'text-base' }} {{ section.settings.feature_title_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.feature_title_font_weight | default: 'font-bold' }} {{ section.settings.feature_title_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
                      {{ block.settings.title }}
                    </h3>
                  </div>
                  {% endif %}
                  
                  <!-- Feature Description -->
                  {% if block.settings.description != blank %}
                  <div class="lifestyle-info-feature-description">
                    <p class="{{ section.settings.feature_description_font_family | default: 'font-body' }} {{ section.settings.feature_description_font_size | default: 'text-sm' }} {{ section.settings.feature_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.feature_description_font_weight | default: 'font-normal' }} {{ section.settings.feature_description_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
                      {{ block.settings.description }}
                    </p>
                  </div>
                  {% endif %}
                  
                </div>
                
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          {% endunless %}
          
        </div>
        
        <!-- Right Column: Image -->
        {% unless section.settings.hide_main_image %}
        <div class="lifestyle-info-image-column">
          {% assign image_fit_mode = section.settings.image_fit_mode | default: 'fill' %}
          {% assign image_height = section.settings.image_height | default: 600 %}
          {% assign img_radius_tl = section.settings.image_radius_top_left | default: '0' %}
          {% assign img_radius_tr = section.settings.image_radius_top_right | default: '0' %}
          {% assign img_radius_bl = section.settings.image_radius_bottom_left | default: '0' %}
          {% assign img_radius_br = section.settings.image_radius_bottom_right | default: '0' %}
          <div class="lifestyle-info-image-wrapper" 
               style="height: {{ image_height }}px; overflow: hidden; border-radius: {{ img_radius_tl }} {{ img_radius_tr }} {{ img_radius_br }} {{ img_radius_bl }};">
            {% if section.settings.main_image != blank %}
              <img 
                src="{{ section.settings.main_image | image_url: width: 800 }}" 
                alt="{{ section.settings.image_alt | default: section.settings.heading }}"
                loading="lazy"
                class="lifestyle-info-image lifestyle-info-image--{{ image_fit_mode }}"
                style="box-shadow: none !important; border-radius: {{ img_radius_tl }} {{ img_radius_tr }} {{ img_radius_br }} {{ img_radius_bl }};"
              >
            {% else %}
              <img 
                src="{{ 'placeholder-image.png' | asset_url }}" 
                alt="Placeholder"
                loading="lazy"
                class="lifestyle-info-image lifestyle-info-image--{{ image_fit_mode }}"
                style="box-shadow: none !important; border-radius: {{ img_radius_tl }} {{ img_radius_tr }} {{ img_radius_br }} {{ img_radius_bl }};"
              >
            {% endif %}
          </div>
        </div>
        {% endunless %}
        
      </div>
      
    </div>
  </div>
  
</section>

