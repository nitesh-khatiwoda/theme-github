<link rel="stylesheet" href="{{ 'main_product/styles.css' | asset_url }}">
<!-- Product Header 2 Section -->
<section class="product-header-2 {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="product-header-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="container">
    <div class="product-header-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-md' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="product-layout">
        
        <!-- Left Column: Media Gallery with Thumbnails -->
        <div class="media-column">
          
          <!-- Build gallery images array from settings -->
          {% assign gallery_images = '' | split: '' %}
          
          {% if section.settings.gallery_image_1 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_1 %}
          {% endif %}
          {% if section.settings.gallery_image_2 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_2 %}
          {% endif %}
          {% if section.settings.gallery_image_3 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_3 %}
          {% endif %}
          {% if section.settings.gallery_image_4 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_4 %}
          {% endif %}
          {% if section.settings.gallery_image_5 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_5 %}
          {% endif %}
          {% if section.settings.gallery_image_6 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_6 %}
          {% endif %}
          {% if section.settings.gallery_image_7 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_7 %}
          {% endif %}
          {% if section.settings.gallery_image_8 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_8 %}
          {% endif %}
          {% if section.settings.gallery_image_9 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_9 %}
          {% endif %}
          {% if section.settings.gallery_image_10 != blank %}
            {% assign gallery_images = gallery_images | push: section.settings.gallery_image_10 %}
          {% endif %}
          
          {% assign has_gallery_images = false %}
          {% if gallery_images.size > 0 %}
            {% assign has_gallery_images = true %}
          {% endif %}
          
          <div class="product-image-gallery" style="--thumbnail-size: {{ section.settings.thumbnail_size | default: '100px' }}; --main-border-radius: {{ section.settings.main_image_border_radius | default: '16px' }}; --thumb-border-radius: {{ section.settings.thumbnail_border_radius | default: '12px' }}; --gallery-transition: {{ section.settings.gallery_transition_speed | default: '0.4s' }}; --main-aspect-ratio: {{ section.settings.main_image_aspect_ratio | default: '4/5' }};">
            
            <!-- Thumbnail Column (Left Side) -->
            {% if section.settings.show_thumbnails != false %}
            <div class="thumbnail-column {{ section.settings.thumbnail_gap | default: 'gap-sm' }}">
              <!-- Hero/First image thumbnail -->
              {% if section.settings.hero_image != blank %}
                <button class="thumbnail-item active" data-index="0" onclick="switchProductImage(0, '{{ section.id }}')">
                  <img src="{{ section.settings.hero_image | image_url: width: 200 }}" alt="{{ section.settings.hero_image_alt | default: 'Product image 1' }}" loading="eager">
                </button>
              {% elsif product.thumbnail_image != blank %}
                <button class="thumbnail-item active" data-index="0" onclick="switchProductImage(0, '{{ section.id }}')">
                  <img src="{{ product.thumbnail_image | image_url: width: 200 }}" alt="{{ product.title }}" loading="eager">
                </button>
              {% elsif product.image != blank %}
                <button class="thumbnail-item active" data-index="0" onclick="switchProductImage(0, '{{ section.id }}')">
                  <img src="{{ product.image | image_url: width: 200 }}" alt="{{ product.title }}" loading="eager">
                </button>
              {% endif %}
              
              <!-- Gallery thumbnails -->
              {% if has_gallery_images %}
                {% assign thumb_index = 1 %}
                {% for gallery_img in gallery_images %}
                  <button class="thumbnail-item" data-index="{{ thumb_index }}" onclick="switchProductImage({{ thumb_index }}, '{{ section.id }}')">
                    <img src="{{ gallery_img | image_url: width: 200 }}" alt="Product image {{ thumb_index | plus: 1 }}" loading="lazy">
                  </button>
                  {% assign thumb_index = thumb_index | plus: 1 %}
                {% endfor %}
              {% else %}
                <!-- Use product images if no gallery images -->
                {% if product.images.size > 0 %}
                  {% assign thumb_index = 1 %}
                  {% for image in product.images %}
                    {% unless image.attached_to_variant? %}
                      <button class="thumbnail-item" data-index="{{ thumb_index }}" onclick="switchProductImage({{ thumb_index }}, '{{ section.id }}')">
                        <img src="{{ image.src | image_url: width: 200 }}" alt="{{ product.title }}" loading="lazy">
                      </button>
                      {% assign thumb_index = thumb_index | plus: 1 %}
                    {% endunless %}
                  {% endfor %}
                {% endif %}
              {% endif %}
              </div>
            {% endif %}
            
            <!-- Main Image Column (Right Side) -->
            <div class="main-image-column">
              <div class="main-image-wrapper">
                <!-- Hero/First image -->
                {% if section.settings.hero_video != blank %}
                  <div class="main-image-slide active" data-index="0">
                    <video autoplay loop muted playsinline class="main-product-video">
                      <source src="{{ section.settings.hero_video }}" type="video/mp4">
                    </video>
                  </div>
                {% elsif section.settings.hero_image != blank %}
                  <div class="main-image-slide active" data-index="0">
                    <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.hero_image_alt | default: 'Product hero' }}" loading="eager" class="clickable-image" data-full-src="{{ section.settings.hero_image | image_url: width: 1600 }}" data-section-id="{{ section.id }}">
                  </div>
                {% elsif product.thumbnail_image != blank %}
                  <div class="main-image-slide active" data-index="0">
                    <img src="{{ product.thumbnail_image | image_url: width: 1200 }}" alt="{{ product.title }}" loading="eager" class="clickable-image" data-full-src="{{ product.thumbnail_image | image_url: width: 1600 }}" data-section-id="{{ section.id }}">
                  </div>
                {% elsif product.image != blank %}
                  <div class="main-image-slide active" data-index="0">
                    <img src="{{ product.image | image_url: width: 1200 }}" alt="{{ product.title }}" loading="eager" class="clickable-image" data-full-src="{{ product.image | image_url: width: 1600 }}" data-section-id="{{ section.id }}">
                  </div>
                {% else %}
                  <div class="main-image-slide active" data-index="0">
                    <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
              </div>
                {% endif %}
                
                <!-- Gallery images -->
                {% if has_gallery_images %}
                  {% assign slide_index = 1 %}
                  {% for gallery_img in gallery_images %}
                    <div class="main-image-slide" data-index="{{ slide_index }}">
                      <img src="{{ gallery_img | image_url: width: 1200 }}" alt="Product image {{ slide_index | plus: 1 }}" loading="lazy" class="clickable-image" data-section-id="{{ section.id }}" data-full-src="{{ gallery_img | image_url: width: 1600 }}">
                    </div>
                    {% assign slide_index = slide_index | plus: 1 %}
                  {% endfor %}
                {% else %}
                  <!-- Use product images if no gallery images -->
                  {% if product.images.size > 0 %}
                    {% assign slide_index = 1 %}
                    {% for image in product.images %}
                      {% unless image.attached_to_variant? %}
                        <div class="main-image-slide" data-index="{{ slide_index }}">
                          <img src="{{ image.src | image_url: width: 1200 }}" alt="{{ product.title }}" loading="lazy" class="clickable-image" data-section-id="{{ section.id }}" data-full-src="{{ image.src | image_url: width: 1600 }}">
                        </div>
                        {% assign slide_index = slide_index | plus: 1 %}
                      {% endunless %}
                    {% endfor %}
                  {% endif %}
                {% endif %}
            
                <!-- Navigation Arrows -->
                {% if section.settings.show_navigation_arrows != false %}
                <div class="image-nav-arrows">
                  <button class="nav-arrow nav-arrow-prev" onclick="navigateProductImage(-1, '{{ section.id }}')" aria-label="Previous image">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 18l-6-6 6-6"/>
                    </svg>
                  </button>
                  <button class="nav-arrow nav-arrow-next" onclick="navigateProductImage(1, '{{ section.id }}')" aria-label="Next image">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18l6-6-6-6"/>
                    </svg>
                  </button>
                  </div>
                {% endif %}
              </div>
            </div>
            
            </div>
          
        </div>
        
        <!-- Right Column: Product Info (Sticky) -->
        <form 
          class="info-column"
          id='product-form'
          data-fluid-checkout-group
          data-variant='{{ selected_variant_id }}'
        >
          <div class="info-sticky">
            
            <!-- Product Title with Code -->
            <div class="product-title-wrapper">
              {% if section.settings.product_code != blank %}
              <div class="product-code-badge">
                <span class="{{ section.settings.code_font_size | default: 'text-base' }} {{ section.settings.code_color | default: 'text-primary' }}">
                  {{ section.settings.product_code }}<sup>{{ section.settings.code_superscript | default: '™' }}</sup>
                </span>
              </div>
              {% endif %}
              
             
              <h1 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-normal' }} {{ section.settings.title_color | default: 'text-primary' }} leading-heading">
                {{ product.title }}
              </h1>
             
            </div>
            
            <!-- Rating & Reviews -->
            {% if section.settings.show_rating %}
            <div class="rating-wrapper">
              <div class="stars">
                {% if section.settings.stars_image != blank %}
                  <img src="{{ section.settings.stars_image | image_url: width: 100 | default: 'placeholder-image.png' | asset_url }}" alt="Star rating" loading="lazy" style="width: 88px; height: 16px;">
                {% else %}
                  <div class="flex">
                  {% for i in (1..5) %}
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" class="{{ section.settings.star_color | default: 'text-quaternary' }}">
                      <path d="M9 0L11.0206 6.90983H18.5595L12.7694 11.1803L14.7901 18.0902L9 13.8197L3.20993 18.0902L5.23058 11.1803L-0.559492 6.90983H6.97937L9 0Z"/>
                    </svg>
                  {% endfor %}
                </div>
              {% endif %}
              </div>

              <div class="rating-text">
                <span class="{{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                  {{ section.settings.rating_value | default: '4.8' }} •
                </span>
              </div>
              {% if section.settings.show_reviews_link %}
              <a href="{{ section.settings.reviews_link | default: '#reviews' }}" class="reviews-link {{ section.settings.rating_font_size | default: 'text-sm' }} {{ section.settings.rating_color | default: 'text-primary' }}">
                {{ section.settings.reviews_text | default: '18 Reviews' }}
              </a>
              {% endif %}
            </div>
            {% endif %}
            
            <!-- Product Description -->
            {% if product.description != blank %}
            <div class="product-description">
              <p class="{{ section.settings.description_font_family | default: 'font-body' }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.description_font_weight | default: 'font-normal' }} {{ section.settings.description_color | default: 'text-primary' }} leading-body">
                {{ product.description }}
              </p>
            </div>
            {% endif %}
            
            <!-- Price Section -->
            <div class="price-section">
              <span class="price {{ section.settings.price_font_family | default: 'font-primary' }} {{ section.settings.price_font_size | default: 'text-xl' }} {{ section.settings.price_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.price_font_weight | default: 'font-normal' }} {{ section.settings.price_color | default: 'text-primary' }}">
                {{ product.price }}
              </span>
              
              {% if section.settings.show_new_badge %}
              <span class="new-badge" style="background-color: {{ section.settings.badge_background | default: '#d3fa99' }}">
                <span class="{{ section.settings.badge_font_size | default: 'text-xs' }} {{ section.settings.badge_text_color | default: 'text-primary' }}">
                  {{ section.settings.badge_text | default: 'New' }}
                </span>
              </span>
              {% endif %}
            </div>
            
            <!-- Subscription Info -->
            {% if product.subscription_description != blank %}
            <div class="subscription-info">
              <p class="{{ section.settings.subscription_font_size | default: 'text-sm' }} {{ section.settings.subscription_color | default: 'text-primary' }} leading-body">
                {{ product.subscription_description }}
              </p>
            </div>
            {% elsif section.settings.subscription_info != blank %}
            <div class="subscription-info">
              <p class="{{ section.settings.subscription_font_size | default: 'text-sm' }} {{ section.settings.subscription_color | default: 'text-primary' }} leading-body">
                {{ section.settings.subscription_info }}
              </p>
            </div>
            {% endif %}
            {% assign not_purchasable = out_of_stock || available_for_country != true || active != true %}
            {% unless not_purchasable %}
              <div class='subscribe'>
                {% if allow_subscription %}
                  <div class="subscribe-item flex flex-col gap-md">
                    <div class='subscribe-option'>
                      {% if subscription_only %}
                        <input
                          type='radio'
                          checkbox
                          name='fluid-checkout-subscribe'
                          value='subscription'
                          id='subscribe-and-save'
                          checked=''
                        >
                      {% else %}
                        <input
                          type='radio'
                          checkbox
                          name='fluid-checkout-subscribe'
                          value='subscription'
                          id='subscribe-and-save'
                          {% if request.query_parameters.subscribe %}
                            checked
                          {% endif %}
                        >
                      {% endif %}
                      <label for='subscribe-and-save'>
                        <div class='flex justify-between w-full items-center'>
                          <span class="{{ section.settings.subscription_title_font_family }}  {{ section.settings.subscription_title_font_size }} {{ section.settings.subscription_title_font_size_desktop }} {{ section.settings.subscription_title_font_weight }} {{ section.settings.subscription_title_color }}">{{ 'products.product.subscribe' | t }}</span>
                          <p class='purchase-price subscription-price {{ section.settings.product_price_font_family }}  {{ section.settings.product_price_font_size }} {{ section.settings.product_price_font_size_desktop }} {{ section.settings.product_price_font_weight }} {{ section.settings.product_price_color }}'>
                            {{ product.subscription_price }}: {{product}}
                          </p>
                        </div>
                      </label>
                    </div>
                    <ul class="subscribe-features flex flex-col gap-xs {{ section.settings.subscription_list_font_family }}  {{ section.settings.subscription_list_font_size }} {{ section.settings.subscription_list_font_size_desktop }} {{ section.settings.subscription_list_font_weight }} {{ section.settings.subscription_list_color }}">
                      {% assign saved_percentage = product.saved_percentage_on_subscription | plus: 0 %}
                        {% if saved_percentage > 1 %}
                          <li class="flex items-center gap-sm">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M0 12C0 5.37258 5.37258 0 12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12Z" fill="#DCFAE6"></path>
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M17.0964 7.39016L9.93641 14.3002L8.03641 12.2702C7.68641 11.9402 7.13641 11.9202 6.73641 12.2002C6.34641 12.4902 6.23641 13.0002 6.47641 13.4102L8.72641 17.0702C8.94641 17.4102 9.32641 17.6202 9.75641 17.6202C10.1664 17.6202 10.5564 17.4102 10.7764 17.0702C11.1364 16.6002 18.0064 8.41016 18.0064 8.41016C18.9064 7.49016 17.8164 6.68016 17.0964 7.38016V7.39016Z" fill="#079455"></path>
                            </svg>
                            <span>
  
                              {{ 'products.subscribe_feature.subscribe_and_save' | t: save: product.saved_percentage_on_subscription }}
                            </span>
                          </li>
                      {% endif %}
                      <li class="flex items-center gap-sm">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M0 12C0 5.37258 5.37258 0 12 0C18.6274 0 24 5.37258 24 12C24 18.6274 18.6274 24 12 24C5.37258 24 0 18.6274 0 12Z" fill="#DCFAE6"></path>
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M17.0964 7.39016L9.93641 14.3002L8.03641 12.2702C7.68641 11.9402 7.13641 11.9202 6.73641 12.2002C6.34641 12.4902 6.23641 13.0002 6.47641 13.4102L8.72641 17.0702C8.94641 17.4102 9.32641 17.6202 9.75641 17.6202C10.1664 17.6202 10.5564 17.4102 10.7764 17.0702C11.1364 16.6002 18.0064 8.41016 18.0064 8.41016C18.9064 7.49016 17.8164 6.68016 17.0964 7.38016V7.39016Z" fill="#079455"></path>
                        </svg>
                        <span>{{'products.subscribe_feature.update_subscription' | t }}</span>
                      </li>
                    </ul>
                    {% if product.subscription_plans.size > 1 %}
                      <div class="subscription-plans" {% unless request.query_parameters.subscribe %} style="display: none;" {% endunless %}>
                        <div class='custom-select-dropdown product-variant-item'>
                          <label class='font-medium capitalize'>{{ 'products.product.subscripton_plan' | t }}</label>
  
                          <select class='subscription-plans-dropdown option-value custom-theme-select'>
                            {% for subscription_plan in product.subscription_plans%}
                              <option {% if subscription_plan.selected %}selected{% endif %} value='{{ subscription_plan.id }}' data-subscription-price="{{subscription_plan.display_subscription_price}}">{{ subscription_plan.name }}</option>
                            {% endfor %}
                          </select>
                        </div>
                      </div>
                    {% endif %}
  
                  </div>
  
                {% endif %}
                {% unless subscription_only %}
                  <div class="one-time-purchase-section subscribe-item">
                    <div class='subscribe-option'>
                      <input
                        type='radio'
                        checkbox
                        name='fluid-checkout-subscribe'
                        value='regular'
                        id='one-time-purchase'
                        {% unless request.query_parameters.subscribe %}
                          checked
                        {% endunless %}
                      >
                      <label for='one-time-purchase'>
                        <div class='flex justify-between w-full items-center'>
                          <span class="{{ section.settings.subscription_title_font_family }}  {{ section.settings.subscription_title_font_size }} {{ section.settings.subscription_title_font_size_desktop }} {{ section.settings.subscription_title_font_weight }} {{ section.settings.subscription_title_color }}">{{ 'products.product.one_time_purchase' | t }}</span>
                          <p class='purchase-price {{ section.settings.product_price_font_family }}  {{ section.settings.product_price_font_size }} {{ section.settings.product_price_font_size_desktop }} {{ section.settings.product_price_font_weight }} {{ section.settings.product_price_color }}'>{{ product.price }}</p>
                        </div>
                      </label>
                    </div>
                  </div>
                {% endunless %}
              </div>
              {% if limited_stock %}
                <div>
                  {{ 'products.product.limited_stock' | t: quantity: buyable_quantity }}
                </div>
              {% endif %}
            {% else %}
              <div class='error-message'>
                {% if available_for_country != true %}
                  {{ 'products.product.not_available_in_country' | t }}
                {% else %}
                  {% if selected_variant_id == blank %}
                    {{ 'products.product.not_available' | t }}
                    {% if available_values.size < 1 %}
                      {{ 'products.product.change_option' | t }}
                    {% endif %}
                  {% else %}
                    {{ 'products.product.out_of_stock' | t }}
                  {% endif %}
                {% endif %}
              </div>
            {% endunless %}

            <div class='add-to-cart-section flex justify-between items-end gap-sm'>
              <div class='qty-buttons'>
                <div class='qty-wrap'>
                  <span class='qty-dec qty-action-btn' id='decrease_quantity'>-</span>
                  <span class='qty-val' id='quantity'>1</span>
                  <span class='qty-inc qty-action-btn' id='increase_quantity'>+</span>
                  <input hidden value='1' name='fluid-checkout-quantity' {% if product.buyable_quantity %}data-max-quantity="{{ product.buyable_quantity }}"{% endif %} id='fluid-checkout-quantity'>
                </div>
              </div>
              <div class="btn-section flex-1">
                {% if external_url %}
                  <a
                    href='{{ external_url }}'
                    class='btn btn-{{ section.settings.cart_button_style }}-{{section.settings.cart_button_color }} {{ section.settings.cart_button_size }} {{section.settings.cart_button_font_weight }} {{ section.settings.cart_button_border_radius }} w-full'
                  >
                    {{- 'products.product.add_to_cart' | t -}}
                  </a>
                {% elsif not_purchasable %}
                  <button
                    disabled
                    class='btn btn-{{ section.settings.cart_button_style }}-{{section.settings.cart_button_color }} {{ section.settings.cart_button_size }} {{section.settings.cart_button_font_weight }} {{ section.settings.cart_button_border_radius }} w-full disabled'
                  >
                    {{ 'products.product.add_to_cart' | t }}
                  </button>
                {% else %}
                  <button
                    class='btn btn-{{ section.settings.cart_button_style }}-{{section.settings.cart_button_color }} {{ section.settings.cart_button_size }} {{section.settings.cart_button_font_weight }} {{ section.settings.cart_button_border_radius }} w-full'
                    type='button'
                    data-fluid-add-to-cart="{{ selected_variant_id }}"
                    data-fluid-quantity="1"
                    {% if request.query_parameters.subscribe or product.subscription_only %}
                      data-fluid-subscription-plan-id="{{ product.selected_subscription_plan_id }}"
                    {% endif %}
                  >
                    {{ 'products.product.add_to_cart' | t }}
                  </button>
                {% endif %}
              </div>
            </div>
            
            <!-- CTA Button -->
            {% if section.settings.show_cta %}
            <div class="cta-wrapper">
              <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }} w-full">
                {{ section.settings.cta_text | default: 'Start Now' }}
              </a>
            </div>
            {% endif %}
            
            <!-- Guarantee Text -->
            {% if section.settings.guarantee_text != blank %}
            <div class="guarantee-text">
              <p class="{{ section.settings.guarantee_font_size | default: 'text-sm' }} {{ section.settings.guarantee_color | default: 'text-neutral' }} leading-body">
                {{ section.settings.guarantee_text }}
              </p>
            </div>
            {% endif %}
            
            <!-- Accordions -->
            <div class="accordions-wrapper">
              
              <!-- Benefits Accordion -->
              {% assign benefit_blocks = section.blocks | where: "type", "benefit_item" %}
              {% if benefit_blocks.size > 0 %}
              <div class="accordion-item">
                <button class="accordion-header" onclick="this.parentElement.classList.toggle('active')">
                  <span class="{{ section.settings.accordion_font_size | default: 'text-base' }} {{ section.settings.accordion_color | default: 'text-primary' }}">
                    {{ section.settings.benefits_title | default: 'Benefits*' }}
                  </span>
                  <svg class="accordion-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M19 9L12 16L5 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="accordion-content hidden">
                  <ul class="benefits-list">
