<!-- Product Image Gallery JavaScript -->
<script>
(function() {
  const sectionId = '{{ section.id }}';
  
  // Sticky Footer functionality
  const stickyFooter = document.getElementById('stickyFooter-' + sectionId);
  const productSection = document.getElementById('product-header-' + sectionId);
  
  if (stickyFooter && productSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Section is in view, hide sticky footer
            stickyFooter.classList.remove('visible');
          } else {
            // Section is out of view, show sticky footer
            stickyFooter.classList.add('visible');
          }
        });
      },
      {
        threshold: 0,
        rootMargin: '-100px 0px 0px 0px'
      }
    );
    
    observer.observe(productSection);
  }
})();

// Product Image Gallery Functions
window.switchProductImage = function(index, sectionId) {
  const section = document.getElementById('product-header-' + sectionId);
  if (!section) return;
  
  // Update thumbnails
  const thumbnails = section.querySelectorAll('.thumbnail-item');
  thumbnails.forEach((thumb, i) => {
    if (i === index) {
      thumb.classList.add('active');
    } else {
      thumb.classList.remove('active');
    }
  });
  
  // Update main images
  const slides = section.querySelectorAll('.main-image-slide');
  slides.forEach((slide, i) => {
    if (i === index) {
      slide.classList.add('active');
    } else {
      slide.classList.remove('active');
    }
  });
};

window.navigateProductImage = function(direction, sectionId) {
  const section = document.getElementById('product-header-' + sectionId);
  if (!section) return;
  
  const thumbnails = section.querySelectorAll('.thumbnail-item');
  const activeThumb = section.querySelector('.thumbnail-item.active');
  
  if (!activeThumb) return;
  
  const currentIndex = Array.from(thumbnails).indexOf(activeThumb);
  let newIndex = currentIndex + direction;
  
  // Wrap around
  if (newIndex < 0) {
    newIndex = thumbnails.length - 1;
  } else if (newIndex >= thumbnails.length) {
    newIndex = 0;
  }
  
  window.switchProductImage(newIndex, sectionId);
};

// Keyboard navigation
{% if section.settings.enable_keyboard_nav != false %}
document.addEventListener('keydown', function(e) {
  const productSection = document.querySelector('.product-header-2');
  if (!productSection) return;
  
  const sectionId = productSection.id.replace('product-header-', '');
  
  if (e.key === 'ArrowLeft') {
    window.navigateProductImage(-1, sectionId);
  } else if (e.key === 'ArrowRight') {
    window.navigateProductImage(1, sectionId);
  }
});
{% endif %}
</script>
<script>
  function slider() {
    if ($('.main-slider').length) {
      document.querySelectorAll('.product-gallery').forEach(function (gallery) {
        const mainSliderEl = gallery.querySelector('.main-slider');
        const thumbnailSliderEl = gallery.querySelector('.thumbnail-slider');
        if (!mainSliderEl) return;
        if (mainSliderEl.classList.contains('is-initialized')) return;
        const main = new Splide(mainSliderEl, {
          arrows: false,
          pagination: false,
          rewind: true,
        });
        if (thumbnailSliderEl) {
          const thumbnails = new Splide(thumbnailSliderEl, {
            start: 0,
            perPage: 3,
            gap: 12,
            rewind: true,
            pagination: false,
            arrows: false,
            isNavigation: true,
            mediaQuery: "min",
            fixedWidth: 80,
            fixedHeight: 80,
            breakpoints: {
              576: {
                perPage: 4
              },
            },
          });
          main.sync(thumbnails);
          thumbnails.mount();
          main.mount();
        }else {
          main.mount();
        }
      });
    }
  }
  document.addEventListener('DOMContentLoaded', function () {
    slider();
  })
</script>

