<!-- Search logic -->
<script>
(function() {
  // Search result settings
  const showSuggestions = {{ section.settings.search_show_suggestions | default: true }};
  const showResultsHeader = {{ section.settings.search_show_results_header | default: true }};
  const cardStyle = '{{ section.settings.search_card_style | default: "hover-bg" }}';
  const showDescription = {{ section.settings.search_show_description | default: false }};
  const showLoadMoreButton = {{ section.settings.search_show_load_more_button | default: false }};
  const showShopNowButton = {{ section.settings.search_show_shop_now_button | default: false }};
  const showAddToCartButton = {{ section.settings.search_show_add_to_cart_button | default: false }};
  
  // Popular search terms - customize these for your store
  const popularSearchTerms = [
    'Yes',
    'Lean Body',
    'Protein',
    'Greens',
    'Omegas',
    'Probiotics',
    'Energy',
    'Weight Loss'
  ];
  
  // Recent searches localStorage key
  const RECENT_SEARCHES_KEY = 'yoli_recent_searches';
  const MAX_RECENT_SEARCHES = 5;
  
  // Get recent searches from localStorage
  function getRecentSearches() {
    try {
      const stored = localStorage.getItem(RECENT_SEARCHES_KEY);
      return stored ? JSON.parse(stored) : [];
    } catch (e) {
      return [];
    }
  }
  
  // Save a search to recent searches
  function saveRecentSearch(query) {
    if (!query || query.trim().length === 0) return;
    const trimmedQuery = query.trim();
    let searches = getRecentSearches();
    // Remove if already exists (to move to top)
    searches = searches.filter(s => s.toLowerCase() !== trimmedQuery.toLowerCase());
    // Add to beginning
    searches.unshift(trimmedQuery);
    // Limit to max
    searches = searches.slice(0, MAX_RECENT_SEARCHES);
    try {
      localStorage.setItem(RECENT_SEARCHES_KEY, JSON.stringify(searches));
    } catch (e) {
      // localStorage might be full or disabled
    }
  }
  
  // Remove a specific search from recent searches
  function removeRecentSearch(query) {
    let searches = getRecentSearches();
    searches = searches.filter(s => s.toLowerCase() !== query.toLowerCase());
    try {
      localStorage.setItem(RECENT_SEARCHES_KEY, JSON.stringify(searches));
    } catch (e) {}
  }
  
  // Render popular search terms
  function renderPopularTerms() {
    const container = document.getElementById('popular-terms');
    if (!container) return;
    
    container.innerHTML = popularSearchTerms.map(term => 
      `<button class="popular-term-pill" data-term="${term}">${term}</button>`
    ).join('');
  }
  
  // Render recent searches
  function renderRecentSearches() {
    const container = document.getElementById('recent-searches-list');
    if (!container) return;
    
    const searches = getRecentSearches();
    
    if (searches.length === 0) {
      container.innerHTML = '<li class="no-recent-searches">No recent searches</li>';
      return;
    }
    
    container.innerHTML = searches.map(search => `
      <li class="recent-search-item">
        <span class="recent-search-text" data-term="${search}">${search}</span>
        <button class="recent-search-remove" data-term="${search}" aria-label="Remove ${search}">×</button>
      </li>
    `).join('');
  }
  
  // Show/hide default content based on whether there's typed content
  function updateDefaultContentVisibility(hasContent) {
    const defaultContent = document.getElementById('search-default-content');
    if (!defaultContent) return;
    defaultContent.style.display = hasContent ? 'none' : 'block';
  }
  
  function initSearch() {
    let searchTimeout;
    const searchBtn = document.getElementById('search-icon-btn');
    const searchExpanded = document.getElementById('search-expanded');
    const searchInput = document.getElementById('search-input');
    const searchCloseBtn = document.getElementById('search-close-btn');
    const searchResults = document.getElementById('search-results');

    if (!searchExpanded || !searchInput || !searchCloseBtn) return;
    
    // Initialize popular terms and recent searches
    renderPopularTerms();
    renderRecentSearches();

    function openSearch() {
      searchExpanded.classList.add('is-open');
      document.body.style.overflow = 'hidden auto';
      setTimeout(() => searchInput && searchInput.focus(), 50);
      // Refresh recent searches when opening
      renderRecentSearches();
      // Show default content if no input
      updateDefaultContentVisibility(searchInput.value.trim().length > 0);
    }
    
    // Close and keep content (for clicking outside or pressing Escape)
    function closeSearchKeepContent() {
      searchExpanded.classList.remove('is-open');
      document.body.style.overflow = 'auto';
    }
    
    // Close and clear content (for X button)
    function closeSearch() {
      searchExpanded.classList.remove('is-open');
      searchExpanded.classList.remove('has-content');
      searchInput.value = '';
      searchResults.innerHTML = '';
      document.body.style.overflow = 'auto';
      updateDefaultContentVisibility(false);
    }
    
    function isSearchOpen() {
      return searchExpanded.classList.contains('is-open');
    }
    
    // Handle clicking on a search term (popular or recent)
    function performSearch(term) {
      searchInput.value = term;
      searchExpanded.classList.add('has-content');
      updateDefaultContentVisibility(true);
      searchResults.innerHTML = '<div style="text-align: center; padding: 40px;"><div style="font-size: 18px; color: #666;">Searching...</div></div>';
      saveRecentSearch(term);
      searchProducts(term);
    }
    
    // Event delegation for popular terms
    document.getElementById('popular-terms')?.addEventListener('click', function(e) {
      if (e.target.classList.contains('popular-term-pill')) {
        performSearch(e.target.dataset.term);
      }
    });
    
    // Event delegation for recent searches
    document.getElementById('recent-searches-list')?.addEventListener('click', function(e) {
      e.stopPropagation();
      if (e.target.classList.contains('recent-search-text')) {
        performSearch(e.target.dataset.term);
      } else if (e.target.classList.contains('recent-search-remove')) {
        e.preventDefault();
        removeRecentSearch(e.target.dataset.term);
        renderRecentSearches();
      }
    });

    if (searchBtn) {
      searchBtn.addEventListener('click', function(e) {
        e.preventDefault();
        // Toggle search - close if open, open if closed
        if (isSearchOpen()) {
          closeSearchKeepContent();
        } else {
          openSearch();
        }
      });
    }
    searchCloseBtn.addEventListener('click', function(e) {
      e.preventDefault();
      closeSearch();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isSearchOpen()) {
        closeSearchKeepContent();
      }
    });
    // Close when clicking outside the modal
    document.addEventListener('click', function(e) {
      if (isSearchOpen() && !searchExpanded.contains(e.target) && !e.target.closest('#search-icon-btn')) {
        closeSearchKeepContent();
      }
    });

    searchInput.addEventListener('input', function() {
      const query = this.value.trim();
      clearTimeout(searchTimeout);
      if (query.length === 0) {
        searchResults.innerHTML = '';
        searchExpanded.classList.remove('has-content');
        updateDefaultContentVisibility(false);
        return;
      }
      searchExpanded.classList.add('has-content');
      updateDefaultContentVisibility(true);
      searchTimeout = setTimeout(() => { 
        saveRecentSearch(query);
        searchProducts(query); 
      }, 300);
    });
  }

  function searchProducts(query) {
    const searchResults = document.getElementById('search-results');
    if (!searchResults) return;
    searchResults.innerHTML = '<div style="text-align: center; padding: 40px;"><div style="font-size: 18px; color: #666;">Searching...</div></div>';
    fetch(`https://yoli.fluid.app/shop.json?filterrific[search_query]=${encodeURIComponent(query)}&filterrific[sorted_by]=title_asc&count=50`)
      .then(response => response.json())
      .then(data => displayResults(data, query))
      .catch(() => {
        searchResults.innerHTML = '<div style="text-align: center; padding: 40px; color: red;">Error searching products</div>';
      });
  }

  // Store all products and current display count for load more
  let allProducts = [];
  let displayedCount = 0;
  const PRODUCTS_PER_PAGE = 8;
  
  function generateSuggestions(query, products) {
    const baseQuery = query.toLowerCase().trim();
    if (!products || products.length === 0) return [];
    
    const suggestions = new Set();
    
    // 1. Add the query itself
    suggestions.add(baseQuery);
    
    // 2. Add plural/singular variants
    if (baseQuery.endsWith('s')) {
      suggestions.add(baseQuery.slice(0, -1)); // singular
    } else {
      suggestions.add(baseQuery + 's'); // plural
    }
    
    // 3. Extract common word patterns from product titles
    const titles = products.map(p => (p.title || p.name || '').toLowerCase());
    const wordPatterns = {};
    
    titles.forEach(title => {
      // Find phrases that contain the query
      const words = title.split(/\s+/);
      const queryIndex = words.findIndex(w => w.includes(baseQuery));
      
      if (queryIndex !== -1) {
        // Get 1-2 words before the query word
        for (let i = Math.max(0, queryIndex - 2); i <= queryIndex; i++) {
          const phrase = words.slice(i, queryIndex + 1).join(' ');
          if (phrase.length > baseQuery.length && phrase.length < 30) {
            wordPatterns[phrase] = (wordPatterns[phrase] || 0) + 1;
          }
        }
        // Get query word + 1 word after
        if (queryIndex < words.length - 1) {
          const phrase = words.slice(queryIndex, queryIndex + 2).join(' ');
          if (phrase.length > baseQuery.length && phrase.length < 30) {
            wordPatterns[phrase] = (wordPatterns[phrase] || 0) + 1;
          }
        }
      }
    });
    
    // Sort patterns by frequency and add top ones
    const sortedPatterns = Object.entries(wordPatterns)
      .sort((a, b) => b[1] - a[1])
      .map(([phrase]) => phrase);
    
    sortedPatterns.slice(0, 6).forEach(phrase => suggestions.add(phrase));
    
    // 4. Add 1-2 short product titles as specific suggestions
    const shortTitles = titles
      .filter(t => t.includes(baseQuery) && t.length < 40)
      .sort((a, b) => a.length - b.length)
      .slice(0, 2);
    
    shortTitles.forEach(t => suggestions.add(t));
    
    // Convert to array, filter out very short/long, and return top 5
    return [...suggestions]
      .filter(s => s.length >= baseQuery.length && s.length < 50)
      .slice(0, 5);
  }
  
  function renderProductCard(product) {
    const description = product.introduction || product.stripped || product.description || '';
    const imageUrl = product.image_url || product.compressed_image_url || '';
    const badge = product.display_tag ? `<div class="product-badge">${product.display_tag}</div>` : '';
    const variantId = (product.variants && product.variants[0] && product.variants[0].id) ? product.variants[0].id : '';
    
    let priceDisplay = '';
    if (product.variants && product.variants[0]) {
      const variant = product.variants[0];
      const priceValue = variant.price || variant.price_cents / 100 || product.price || product.price_cents / 100;
      if (priceValue) {
        priceDisplay = `<div class="product-price">$${parseFloat(priceValue).toFixed(2)}</div>`;
      }
    }
    
    return `
      <div class="product-card">
        <div class="product-image-container-2">
          <img style="max-width: 100%" src="${imageUrl}" alt="${product.title}" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMzAwIiBoZWlnaHQ9IjMwMCIgdmlld0JveD0iMCAwIDMwMCAzMDAiIGZpbGw9Im5vbmUiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHJlY3Qgd2lkdGg9IjMwMCIgaGVpZ2h0PSIzMDAiIGZpbGw9IiNGOEY5RkEiLz48L3N2Zz4='">
        </div>
        <div class="product-content">
          <div class="product-info">
            ${badge}
            <h3 class="product-title">${product.title}</h3>
            <div class="product-rating-price">
              <div class="product-rating"><span class="stars">★★★★★</span></div>
              ${priceDisplay}
            </div>
            ${showDescription ? `<div class="product-description">${description}</div>` : ''}
          </div>
        </div>
        ${(showShopNowButton || showAddToCartButton) ? `
        <div class="product-actions">
          ${showShopNowButton ? `<a href="/home/shop/${product.slug}" class="btn btn-primary">Shop Now</a>` : ''}
          ${showAddToCartButton && variantId ? `<button class="btn btn-secondary search-add-to-cart" data-fluid-add-to-cart="${variantId}" data-fluid-quantity="1" data-fluid-open-cart-after-add="true">Add to Cart</button>` : ''}
        </div>` : ''}
      </div>
    `;
  }
  
  function loadMoreProducts() {
    const productGrid = document.getElementById('search-product-grid');
    const loadMoreWrapper = document.getElementById('search-load-more-wrapper');
    if (!productGrid) return;
    
    const nextProducts = allProducts.slice(displayedCount, displayedCount + PRODUCTS_PER_PAGE);
    nextProducts.forEach(product => {
      productGrid.insertAdjacentHTML('beforeend', renderProductCard(product));
    });
    displayedCount += nextProducts.length;
    
    // Hide load more button if no more products
    if (displayedCount >= allProducts.length && loadMoreWrapper) {
      loadMoreWrapper.style.display = 'none';
    }
    
    // Rebind add to cart buttons
    bindAddToCartButtons();
  }
  
  function bindAddToCartButtons() {
    const resultsContainer = document.getElementById('search-results');
    const addToCartButtons = resultsContainer.querySelectorAll('.search-add-to-cart');
    addToCartButtons.forEach(button => {
      if (!button.dataset.bound) {
        button.dataset.bound = 'true';
        button.addEventListener('click', function() {
          setTimeout(() => {
            const searchExpanded = document.getElementById('search-expanded');
            const searchInput = document.getElementById('search-input');
            const searchResults = document.getElementById('search-results');
            if (searchExpanded) {
              searchExpanded.classList.remove('is-open');
              if (searchInput) searchInput.value = '';
              if (searchResults) searchResults.innerHTML = '';
              document.body.style.overflow = 'auto';
            }
          }, 100);
        });
      }
    });
  }

  function displayResults(products, query) {
    const resultsContainer = document.getElementById('search-results');
    if (!resultsContainer) return;
    
    if (!products || products.length === 0) {
      resultsContainer.innerHTML = `
        <div style="text-align: center; padding: 40px;"><div style="font-size: 18px; color: #666;">No products found for "${query}"</div></div>
      `;
      return;
    }
    
    // Store products for load more
    products.sort((a, b) => a.title.localeCompare(b.title));
    allProducts = products;
    displayedCount = Math.min(PRODUCTS_PER_PAGE, products.length);
    
    // Generate suggestions from actual product names
    const suggestions = generateSuggestions(query, products);
    let suggestionsHtml = suggestions.map(suggestion => {
      const highlightedSuggestion = suggestion.replace(
        new RegExp(`(${query})`, 'gi'),
        '<strong>$1</strong>'
      );
      return `<a class="search-suggestion-item" href="/shop?q=${encodeURIComponent(suggestion)}">${highlightedSuggestion}</a>`;
    }).join('');
    
    // Generate initial product cards
    const initialProducts = products.slice(0, PRODUCTS_PER_PAGE);
    let productsHtml = initialProducts.map(product => renderProductCard(product)).join('');
    
    // Show load more button if there are more products and setting is enabled
    const hasMore = products.length > PRODUCTS_PER_PAGE;
    const loadMoreHtml = (hasMore && showLoadMoreButton) ? `
      <div class="search-load-more-wrapper" id="search-load-more-wrapper">
        <button class="btn btn-text btn-md" id="search-load-more-btn">Show More</button>
      </div>
    ` : '';
    
    resultsContainer.innerHTML = `
      <div class="search-layout ${!showSuggestions ? 'no-suggestions' : ''} ${!showResultsHeader ? 'no-results-header' : ''}">
        ${showSuggestions ? `
        <div class="search-suggestions">
          <div class="search-suggestions-header">
            <h3 class="search-suggestions-title">Suggestions</h3>
          </div>
          ${suggestionsHtml}
        </div>
        ` : ''}
        <div class="search-products-section">
          ${showResultsHeader ? `
          <div class="search-products-header">
            <h3 class="search-products-title">Results <span class="search-products-count">(${products.length})</span></h3>
            <a href="/shop?q=${encodeURIComponent(query)}" class="search-view-all">View all results</a>
          </div>
          ` : ''}
          <div class="product-results card-style-${cardStyle}" id="search-product-grid">
            ${productsHtml}
          </div>
          ${loadMoreHtml}
        </div>
      </div>
    `;
    
    // Bind load more button
    const loadMoreBtn = document.getElementById('search-load-more-btn');
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', loadMoreProducts);
    }
    
    // Bind add to cart buttons
    bindAddToCartButtons();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
})();
</script>

