{%- style -%}
  /* NAVBAR/HEADER */
  header.site-header {
    padding: {{ section.settings.navbar_vertical_padding_mobile }}px 0;
  }

  @media screen and (min-width: 768px) {
    header.site-header {
      padding: {{ section.settings.navbar_vertical_padding_desktop }}px 0;
    }
  }
  {%- if section.settings.reset_navbar_bg_color != true -%}
    header.site-header:not(.is-floating) {
      background-color: {{ section.settings.navbar_bg_color }};
    }
    header.site-header.is-sticky {
      background-color: {{ section.settings.sticky_navbar_bg_color }};
    }
  {%- endif -%}
    header.site-header.is-sticky {
      border-bottom-width: {{ section.settings.navbar_border_width }}px !important;
    }
  {%- if section.settings.reset_navbar_border_color != true  -%}
    header.site-header.is-sticky{
      border-color: {{ section.settings.navbar_border_color }} !important;
    }
  {%- endif -%}

  /* Navbar Text Color */
  {%- if section.settings.reset_navbar_text_color != true and section.settings.navbar_text_color != blank -%}
    .site-header:not(.is-floating),
    .site-header .primary-menu a,
    .site-header .primary-menu a:hover{
      color: {{ section.settings.navbar_text_color }};
    }
    .site-header .menu-toggle-button span {
      background-color:  {{ section.settings.navbar_text_color }};
    }
  {%- endif -%}

  {%- if section.settings.reset_sticky_navbar_text_color != true and section.settings.sticky_navbar_text_color != blank -%}
    .site-header.is-sticky,
    .site-header.is-sticky .primary-menu a,
    .site-header.is-sticky .primary-menu a:hover,
    .media-header .author-content{
      color: {{ section.settings.sticky_navbar_text_color }};
    }
    .site-header .menu-toggle-button span {
      background-color:  {{ section.settings.sticky_navbar_text_color }};
    }
  {%- endif -%}

  /* Navbar Font Size */
  header.site-header {
    font-size: {{ section.settings.navbar_text_size }}px;
    font-weight: {{ section.settings.navbar_font_weight }};
  }

  {%- if section.settings.reset_save_and_close_text_color != true and section.settings.save_and_close_text_color != blank -%}
    header.site-header .saveLocaleBtn{
      color: {{ section.settings.save_and_close_text_color }};
    }
  {%- endif -%}
  header.site-header .saveLocaleBtn{
    font-size: {{ section.settings.save_and_close_text_size }}px !important;
    font-weight: {{ section.settings.save_and_close_font_weight }} !important
  }
  /* BUTTON */

  {%- if section.settings.reset_primary_button_styles != true -%}
    a.btn.btn-bg-primary {
      border-color: {{ section.settings.primary_button_bg_color }};
      background-color: {{ section.settings.primary_button_background_color }};
      color: {{ section.settings.primary_button_text_color }};
    }
    .site-header.is-sticky a.btn.btn-bg-primary {
      border-color: {{ section.settings.sticky_primary_button_background_color }};
      background-color: {{ section.settings.sticky_primary_button_background_color }};
      color: {{ section.settings.sticky_primary_button_text_color }};
    }
  {%- endif -%}

  /* Search Expanded Component */
  .search-expanded-component {
    position: fixed;
    top: 9.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(-20px);
    width: calc(100% - 32px);
    max-width: 600px;
    background: #fff;
    z-index: 9998;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    border-radius: 16px;
    opacity: 0;
    visibility: hidden;
    transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s ease, top 0.2s ease, max-width 0.3s ease;
  }
  
  .search-expanded-component.has-content {
    max-width: 1100px;
  }
  
  .search-expanded-component.is-open {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    visibility: visible;
  }

  /* Move search up when header is scrolled (top bar hidden) */
  body:has(.site-header.scrolled) .search-expanded-component {
    top: 80px;
  }

  .search-input-wrapper {
    position: relative;
    padding: 16px 24px 12px;
  }

  @media (min-width: 768px) {
    .search-input-wrapper {
      padding: 16px 32px 12px;
    }
  }
  
  .search-input-container {
    position: relative;
    width: 100%;
  }
  
  .search-input-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    color: #888;
    pointer-events: none;
  }

  .search-input-wrapper input {
    width: 100%;
    padding: 12px 50px 12px 48px;
    font-size: 16px;
    border: 1px solid #ddd;
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s;
    background: #fff;
    color: #333;
  }
  .search-input-wrapper input:focus { border-color: #49473e; }
  .search-input-wrapper input:focus + .search-input-icon { color: #49473e; }
  
  /* No border input style */
  .search-expanded-component.no-input-border .search-input-wrapper input {
    border: none;
    padding-left: 28px;
    padding-right: 28px;
  }
  .search-expanded-component.no-input-border .search-input-icon {
    left: 0;
  }
  .search-expanded-component.no-input-border .search-close-btn {
    right: 0;
  }

  .search-close-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    font-size: 24px;
    font-weight: 300;
    color: #888;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    line-height: 1;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .search-close-btn:hover { color: #666; }

  /* Default Search State - Popular Terms & Recent Searches */
  .search-default-content {
    padding: 16px 24px 24px;
  }
  @media (min-width: 768px) {
    .search-default-content {
      padding: 16px 32px 24px;
    }
  }
  
  .search-section-title {
    font-size: 12px;
    font-weight: 500;
    color: #888;
    text-transform: none;
    letter-spacing: 0;
    margin-bottom: 12px;
  }
  
  .popular-terms {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  
  .popular-term-pill {
    display: inline-block;
    padding: 8px 16px;
    background: #f5f5f5;
    border: none;
    border-radius: 100px;
    font-size: 14px;
    color: #333;
    cursor: pointer;
    transition: background 0.2s;
  }
  .popular-term-pill:hover {
    background: #eee;
  }
  
  .recent-searches-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .recent-search-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: none;
  }
  
  .recent-search-text {
    font-size: 15px;
    font-weight: 600;
    color: #333;
    cursor: pointer;
    flex: 1;
    transition: color 0.2s;
  }
  .recent-search-text:hover {
    color: #666;
  }
  
  .recent-search-remove {
    background: none;
    border: none;
    font-size: 18px;
    color: #999;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
    transition: color 0.2s;
  }
  .recent-search-remove:hover {
    color: #333;
  }
  
  .no-recent-searches {
    font-size: 14px;
    color: #999;
    font-style: italic;
  }

  .search-results-dropdown {
    padding: 0;
  }
  
  .search-results-dropdown:not(:empty) {
    padding: 0 24px 0;
  }
  
  .search-results-dropdown .search-layout {
    border-top: 1px solid #ddd;
    padding-top: 24px;
  }
  
  .search-results-dropdown .search-layout.no-results-header {
    border-top: none;
    padding-top: 16px;
  }

  @media (min-width: 768px) {
    .search-results-dropdown:not(:empty) {
      padding: 0 32px 0;
    }
  }
  
  /* Two-column search layout */
  .search-layout {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
  }
  
  .search-layout.no-suggestions {
    grid-template-columns: 1fr;
  }
  
  @media screen and (max-width: 991px) {
    .search-layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
  
  /* Suggestions column */
  .search-suggestions {
    padding-top: 0;
    position: sticky;
    top: 0;
    align-self: start;
  }
  
  .search-suggestions-header {
    margin-bottom: 16px;
  }
  
  .search-suggestions-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #1a1a1a;
    margin: 0;
  }
  
  .search-suggestion-item {
    display: block;
    padding: 8px 0;
    font-size: 14px;
    color: #333;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s;
  }
  
  .search-suggestion-item:hover {
    color: var(--clr-primary, #49473e);
  }
  
  .search-suggestion-item strong {
    font-weight: 600;
  }
  
  /* Products column */
  .search-products-section {
    min-width: 0;
  }
  
  .search-products-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .search-view-all {
    font-size: 13px;
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }
  .search-view-all:hover {
    color: #333;
    text-decoration: underline;
  }
  
  .search-products-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #1a1a1a;
    margin: 0;
  }
  
  .search-products-count {
    font-weight: 400;
    color: #888;
  }

  .product-results {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-bottom: 12px;
    max-height: 50vh;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  
  @media screen and (max-width: 991px) {
    .product-results { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media screen and (max-width: 600px) {
    .product-results { grid-template-columns: 1fr; }
  }
  
  /* Load more section */
  .search-load-more-wrapper {
    display: flex;
    justify-content: center;
    padding: 32px 0 40px;
  }
  .product-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    background: #fff;
    display: flex;
    flex-direction: column;
    height: 100%;
    cursor: pointer;
  }
  .product-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
  
  /* Card style: borderless */
  .product-results.card-style-borderless .product-card {
    border: none;
    box-shadow: none;
  }
  .product-results.card-style-borderless .product-card:hover {
    box-shadow: none;
    transform: none;
  }
  .product-results.card-style-borderless .product-image-container-2 {
    border-radius: 12px;
  }
  .product-results.card-style-borderless .product-image-container-2 img {
    border-radius: 12px;
  }
  .product-results.card-style-borderless .product-actions {
    background: transparent;
    border-top: none;
  }
  
  /* Card style: hover-bg (borderless with hover background) */
  .product-results.card-style-hover-bg .product-card {
    border: none;
    box-shadow: none;
    border-radius: 12px;
    transition: background-color 0.2s ease;
    padding: 15px;
  }
  .product-results.card-style-hover-bg .product-card:hover {
    background-color: #f5f5f5;
    box-shadow: none;
    transform: none;
  }
  .product-results.card-style-hover-bg .product-image-container-2 {
    border-radius: 12px;
  }
  .product-results.card-style-hover-bg .product-image-container-2 img {
    border-radius: 12px;
  }
  .product-results.card-style-hover-bg .product-content {
    padding: 15px 0 0 0;
  }
  .product-results.card-style-hover-bg .product-actions {
    background: transparent;
    border-top: none;
    padding: 15px 0;
  }
  
  .product-image-container-2 { width: 100%; aspect-ratio: 1 / 1; overflow: hidden; background: #f8f9fa; }
  .product-image-container-2 img { width: 100%; height: 100%; object-fit: cover; }
  .product-content { padding: 15px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .product-info { flex: 1; }
  .product-rating-price { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .product-rating { display: flex; align-items: center; gap: 5px; }
  .stars { color: #ffa500; font-size: 14px; }
  .product-badge { display: inline-block; background: #49473e; color: #fff; padding: 4px 8px; border-radius: 4px; font-size: 12px; margin-bottom: 8px; }
  .product-title { font-size: 16px; font-weight: 600; color: #333; margin: 0 0 8px; line-height: 1.4; }
  .product-price { font-size: 16px; font-weight: 400; color: #49473e; }
  .product-description { font-size: 14px; color: #666; line-height: 1.5; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .product-actions { display: flex; gap: 10px; padding: 15px; background: #f9f9f9; border-top: 1px solid #e0e0e0; margin-top: auto; }
  .product-actions .btn { padding: 8px 16px; border-radius: 6px; font-size: 14px; font-weight: 500; text-decoration: none; cursor: pointer; transition: all 0.2s; border: none; text-align: center; flex: 1; }
  .product-actions .btn-primary { background: #49473e; color: #fff; }
  .product-actions .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .product-actions .btn-secondary { background: transparent; color: #49473e; border: 1px solid #49473e; }
  .product-actions .btn-secondary:hover { background: #49473e; color: #fff; }
  
  /* Load more button - text style */
  #search-load-more-btn {
    flex: none;
    width: auto;
    background: transparent;
    border: none;
    color: #666;
    font-weight: 500;
    text-decoration: underline;
    cursor: pointer;
    padding: 8px 16px;
  }
  #search-load-more-btn:hover {
    color: #333;
  }

  @media screen and (max-width: 991px) {
    .search-expanded-component { top: 9.5rem; }
    .search-suggestions { display: none; }
    .search-layout { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

{% capture feature_buttons %}
  {% comment %} Icon-based navigation items {% endcomment %}
  <a href="https://auth.fluid.app/?redirect_url=https://admin.fluid.app" class="nav-icon-btn" aria-label="Account" title="Account">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
  </a>
  
  <button type="button" class="nav-icon-btn" id="search-icon-btn" aria-label="Search" title="Search">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
  </button>
  <button class="cart-pill-btn" data-fluid-cart="open" aria-label="Cart" title="Cart">
    <svg data-fluid-cart="open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="21" r="1"></circle>
      <circle cx="20" cy="21" r="1"></circle>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
    </svg>
    <span data-fluid-cart="open" class="cart-count"id="fluid-cart-count">0</span>
  </button>
{% endcapture %}

{% capture cta_button %}
  {% if section.settings.show_button_one %}
    <a href="{{ section.settings.button_one_url | default: '#' }}" 
       class="btn btn-{{ section.settings.button_one_style | default: 'filled' }}-{{ section.settings.button_one_color | default: 'black' }} {{ section.settings.button_one_size | default: 'btn-sm' }} rounded-full"
       data-floating-style="{{ section.settings.floating_button_one_style | default: 'filled' }}"
       data-floating-color="{{ section.settings.floating_button_one_color | default: 'black' }}"
       data-sticky-style="{{ section.settings.button_one_style | default: 'filled' }}"
       data-sticky-color="{{ section.settings.button_one_color | default: 'black' }}">
      {{ section.settings.button_one_text | default: 'Take the quiz' }}
    </a>
  {% endif %}
{% endcapture %}
{% capture locale_selector %}
    <div class='locale-dropdown-section lang-dropdown hidden'>
     
      <div class="locale-selector-section">
        <div class="locale-selector flex justify-between items-center py-sm  px-sm font-semibold text-md cursor-pointer text-primary">
          <span>{{ section.settings.select_country_label}}</span>
          <span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 1L5 5L9 1"></path>
            </svg>
          </span>
        </div>
        <div class="locale-selector-dropdown-menu hidden">
          <ul class="country-list item-list">
            {% for country in countries %}
              <li class="country-item  px-sm py-sm {% if country.selected %} selected{% endif %}" data-value="{{ country.iso }}">
                <div class="flex items-center gap-sm">
                  <span class="flag-icon fi fi-{{ country.iso }}"></span>
                  <span class="country-name">{{ country.name }}</span>
                </div>
                <span class="icon hidden">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
      <div class="locale-selector-section">
        <div class="locale-selector flex justify-between items-center py-sm px-sm font-semibold text-md cursor-pointer text-primary">
          <span>{{ section.settings.select_language_label}}</span>
          <span>
            <svg  width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 1L5 5L9 1"></path>
            </svg>
          </span>
        </div>
        <div class="locale-selector-dropdown-menu hidden">
          <ul class="language-list item-list">
            {% for option in language_options %}
              <li class="language-item px-sm py-sm {% if option.selected %}selected{% endif %}" data-value="{{ option.iso }}">
                <span class="language">{{ option.locale }}</span>
                 <span class="icon hidden">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </span>
              </li>
            {% endfor %}
          </ul>
        </div>
         
      </div>
      <button class="locale-btn btn btn-filled-primary btn-sm font-medium font-body rounded-full w-full mt-md">{{ section.settings.lang_btn_text}}</button>
      
    </div>
{% endcapture %}
  


{% if request.page_type == 'medium' or request.page_type == 'library' %}
  {% assign header_class = "media-header is-sticky" %}
{% elsif   request.page_type == 'home_page' or request.page_type == 'shop_page' or request.page_type == 'collection_page' or request.page_type == 'join_page'%}
  {% assign header_class = "is-floating" %}
{% else %}
  {% assign header_class = "is-sticky" %}
{% endif %}

<!-- Top Announcement Bar -->
{% if section.settings.show_top_bar %}
<div class="top-announcement-bar {{ section.settings.top_bar_bg_color | default: 'bg-black' }}">
  <div class="container">
    <div class="top-bar-content">
      <!-- Left: Country/Language -->
      <div class="top-bar-left">
        <button class="top-bar-locale-btn show-language-dropdown-menu"  aria-label="Select country and language">
          <span class="top-bar-locale-text {{ section.settings.top_bar_text_color | default: 'text-white' }} text-sm font-body">
             <span>{{ current_country_name  }}</span>
            <span>({{ current_selected_locale | upcase }})</span>
          </span>
          <svg class="top-bar-chevron {{ section.settings.top_bar_text_color | default: 'text-white' }}" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        {{ locale_selector }}
      </div>
      
      <!-- Center: Referrer Info (if referred) or Reviews/Trust Badge -->
      <div class="top-bar-center">
        <!-- Referrer info - hidden by default, shown via JS when cookie exists -->
        <div id="top-bar-referrer" class="top-bar-referrer" style="display: none; align-items: center; gap: 10px;">
          <img id="top-bar-referrer-avatar" src="" alt="" style="width: 28px; height: 28px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.3); display: none;">
          <span id="top-bar-referrer-initials" class="{{ section.settings.top_bar_text_color | default: 'text-white' }}" style="width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.2); display: none; align-items: center; justify-content: center; font-weight: bold; font-size: 11px;"></span>
          <span class="top-bar-referrer-text {{ section.settings.top_bar_text_color | default: 'text-white' }} text-sm font-body">
            {{ 'navbar.shopping_with' | t | default: "You're shopping with" }} <strong id="top-bar-referrer-name"></strong>
          </span>
        </div>
        
        <!-- Reviews - shown by default, hidden via JS when referrer exists -->
        {% if section.settings.show_top_bar_reviews %}
        <div id="top-bar-reviews" class="top-bar-reviews">
          <div class="top-bar-stars">
            <!-- 4 filled stars -->
            {% for i in (1..4) %}
              <svg class="top-bar-star top-bar-star--filled" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
