  });

  // Close mobile menu
  $(document).on("click", "#close-mobile-menu, #body-overlay", function(){
    $('#mobile-menu-section').removeClass('show');
    $('#body-overlay').removeClass('show');
    // Close all dropdowns when closing mobile menu
    $('#mobile-menu-section .nav-megamenu.is-open').removeClass('is-open');
    $('#mobile-menu-section .nav-dropdown.is-open').removeClass('is-open');
  });
  
  // Close mobile menu when resizing to desktop view
  function closeMobileMenuOnResize() {
    if (window.innerWidth >= 1280) {
      $('#mobile-menu-section').removeClass('show');
      $('#body-overlay').removeClass('show');
      // Close all dropdowns when closing mobile menu
      $('#mobile-menu-section .nav-megamenu.is-open').removeClass('is-open');
      $('#mobile-menu-section .nav-dropdown.is-open').removeClass('is-open');
    }
  }
  
  // Debounce resize handler for better performance
  let resizeTimer;
  $(window).on('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(closeMobileMenuOnResize, 250);
  });
  
  // Also check on initial load
  $(document).ready(function() {
    closeMobileMenuOnResize();
  });
</script>

<script>
// Immediate FOUC prevention - runs as soon as script loads
(function() {
  // Ensure locale dropdowns are properly hidden immediately
  const localeDropdowns = document.querySelectorAll('.locale-dropdown-menu');
  
  localeDropdowns.forEach(dropdown => {
    dropdown.style.opacity = '0';
    dropdown.style.visibility = 'hidden';
    dropdown.style.display = 'none';
  });
  
  // Ensure mobile mega menu panels are hidden on load
  const mobileMegamenus = document.querySelectorAll('.mobile-menu-section .nav-megamenu-panel');
  mobileMegamenus.forEach(panel => {
    panel.style.opacity = '0';
    panel.style.visibility = 'hidden';
    panel.style.maxHeight = '0';
    panel.style.padding = '0';
  });
  
  // Re-enable dropdowns after CSS is fully loaded
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(() => {
      localeDropdowns.forEach(dropdown => {
        dropdown.style.display = '';
      });
      // Keep mobile panels hidden unless is-open class is present
      mobileMegamenus.forEach(panel => {
        const megamenu = panel.closest('.nav-megamenu');
        if (!megamenu || !megamenu.classList.contains('is-open')) {
          panel.style.opacity = '0';
          panel.style.visibility = 'hidden';
          panel.style.maxHeight = '0';
          panel.style.padding = '0';
        }
      });
    }, 50);
  });
})();
