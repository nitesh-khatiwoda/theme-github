<!-- Script to show referrer info in top bar when affiliate exists -->
{% if affiliate and affiliate.name != blank %}
<script>
(function() {
  // Get cookie by name
  function getCookie(name) {
    const value = '; ' + document.cookie;
    const parts = value.split('; ' + name + '=');
    if (parts.length === 2) {
      return decodeURIComponent(parts.pop().split(';').shift());
    }
    return null;
  }

  var referrerFound = false;

  function tryShowReferrer() {
    if (referrerFound) return true;
    const affiliateCookie = getCookie('fluid_affiliate');
    if (affiliateCookie) {
      try {
        const affiliate = JSON.parse(affiliateCookie);
        if (affiliate && affiliate.name) {
          displayReferrer(affiliate);
          referrerFound = true;
          return true;
        }
      } catch (e) {
        console.log('Error parsing fluid_affiliate cookie:', e);
      }
    }
    return false;
  }

  function showReferrerInTopBar() {
    // Try immediately
    if (tryShowReferrer()) return;
    // Cookie may not be set yet (first visit via affiliate link), retry up to 5s
    var attempts = 0;
    var maxAttempts = 20;
    var interval = setInterval(function() {
      attempts++;
      if (tryShowReferrer() || attempts >= maxAttempts) {
        clearInterval(interval);
      }
    }, 250);
  }

  function displayReferrer(affiliate) {
    const referrerSection = document.getElementById('top-bar-referrer');
    const reviewsSection = document.getElementById('top-bar-reviews');
    const nameEl = document.getElementById('top-bar-referrer-name');
    const avatarImg = document.getElementById('top-bar-referrer-avatar');
    const avatarInitials = document.getElementById('top-bar-referrer-initials');

    if (referrerSection && nameEl && affiliate.name) {
      // Set name
      nameEl.textContent = affiliate.name;

      // Set avatar (image or initials)
      if (affiliate.image_url) {
        avatarImg.src = affiliate.image_url;
        avatarImg.alt = affiliate.name;
        avatarImg.style.display = 'block';
        if (avatarInitials) avatarInitials.style.display = 'none';
      } else {
        // Use initials from name
        const initials = affiliate.name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
        if (avatarInitials) {
          avatarInitials.textContent = initials;
          avatarInitials.style.display = 'flex';
        }
        avatarImg.style.display = 'none';
      }

      // Show referrer section, hide reviews
      referrerSection.style.display = 'flex';
      if (reviewsSection) {
        reviewsSection.style.display = 'none';
      }
    }
  }

  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', showReferrerInTopBar);
  } else {
    showReferrerInTopBar();
  }
})();
</script>
{% else %}
<script>
  document.cookie = 'fluid_affiliate=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
</script>
{% endif %}

