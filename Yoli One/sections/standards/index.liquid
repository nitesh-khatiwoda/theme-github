<link rel="stylesheet" href="{{ 'standards/styles.css' | asset_url }}">

<!-- Standards -->
<section 
  class="standards {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_top_mobile | default: 'pt-xl' }} {{ section.settings.section_padding_bottom_mobile | default: 'pb-xl' }} {{section.settings.padding_x_mobile}}  {{ section.settings.section_padding_top_desktop | default: 'lg:pt-3xl' }} {{ section.settings.section_padding_bottom_desktop | default: 'lg:pb-3xl' }} lg:{{section.settings.padding_x_desktop}} {{ section.settings.section_border_radius | default: 'rounded-none' }}" 
  id="standards-{{ section.id }}" 
  {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    {% comment %} When image is hidden, content fills full width naturally {% endcomment %}
    <div class="standards-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }}" 
      {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="standards-grid {% if section.settings.flip_layout %}standards-grid--flipped{% endif %}">
        
        <!-- Left Column: Image -->
        {% unless section.settings.hide_main_image %}
        <div class="standards-image-column">
          {% assign image_fit_mode = section.settings.image_fit_mode | default: 'fill' %}
          {% assign image_height = section.settings.image_height | default: 400 %}
          {% assign br_tl = section.settings.round_top_left_radius | default: 'rounded-none' %}
          {% assign br_tr = section.settings.round_top_right_radius | default: 'rounded-none' %}
          {% assign br_bl = section.settings.round_bottom_left_radius | default: 'rounded-none' %}
          {% assign br_br = section.settings.round_bottom_right_radius | default: 'rounded-none' %}
          
          {% if br_tl == 'rounded-none' %}
            {% assign br_tl = '0' %}
          {% elsif br_tl == 'rounded-sm' %}
            {% assign br_tl = 'var(--radius-sm)' %}
          {% elsif br_tl == 'rounded' %}
            {% assign br_tl = 'var(--radius-base)' %}
          {% elsif br_tl == 'rounded-md' %}
            {% assign br_tl = 'var(--radius-md)' %}
          {% elsif br_tl == 'rounded-lg' %}
            {% assign br_tl = 'var(--radius-lg)' %}
          {% elsif br_tl == 'rounded-xl' %}
            {% assign br_tl = 'var(--radius-xl)' %}
          {% elsif br_tl == 'rounded-2xl' %}
            {% assign br_tl = 'var(--radius-2xl)' %}
          {% elsif br_tl == 'rounded-3xl' %}
            {% assign br_tl = 'var(--radius-3xl)' %}
          {% elsif br_tl == 'rounded-4xl' %}
            {% assign br_tl = 'var(--radius-4xl)' %}
          {% elsif br_tl == 'rounded-full' %}
            {% assign br_tl = '9999px' %}
          {% endif %}
          
          {% if br_tr == 'rounded-none' %}
            {% assign br_tr = '0' %}
          {% elsif br_tr == 'rounded-sm' %}
            {% assign br_tr = 'var(--radius-sm)' %}
          {% elsif br_tr == 'rounded' %}
            {% assign br_tr = 'var(--radius-base)' %}
          {% elsif br_tr == 'rounded-md' %}
            {% assign br_tr = 'var(--radius-md)' %}
          {% elsif br_tr == 'rounded-lg' %}
            {% assign br_tr = 'var(--radius-lg)' %}
          {% elsif br_tr == 'rounded-xl' %}
            {% assign br_tr = 'var(--radius-xl)' %}
          {% elsif br_tr == 'rounded-2xl' %}
            {% assign br_tr = 'var(--radius-2xl)' %}
          {% elsif br_tr == 'rounded-3xl' %}
            {% assign br_tr = 'var(--radius-3xl)' %}
          {% elsif br_tr == 'rounded-4xl' %}
            {% assign br_tr = 'var(--radius-4xl)' %}
          {% elsif br_tr == 'rounded-full' %}
            {% assign br_tr = '9999px' %}
          {% endif %}
          
          {% if br_bl == 'rounded-none' %}
            {% assign br_bl = '0' %}
          {% elsif br_bl == 'rounded-sm' %}
            {% assign br_bl = 'var(--radius-sm)' %}
          {% elsif br_bl == 'rounded' %}
            {% assign br_bl = 'var(--radius-base)' %}
          {% elsif br_bl == 'rounded-md' %}
            {% assign br_bl = 'var(--radius-md)' %}
          {% elsif br_bl == 'rounded-lg' %}
            {% assign br_bl = 'var(--radius-lg)' %}
          {% elsif br_bl == 'rounded-xl' %}
            {% assign br_bl = 'var(--radius-xl)' %}
          {% elsif br_bl == 'rounded-2xl' %}
            {% assign br_bl = 'var(--radius-2xl)' %}
          {% elsif br_bl == 'rounded-3xl' %}
            {% assign br_bl = 'var(--radius-3xl)' %}
          {% elsif br_bl == 'rounded-4xl' %}
            {% assign br_bl = 'var(--radius-4xl)' %}
          {% elsif br_bl == 'rounded-full' %}
            {% assign br_bl = '9999px' %}
          {% endif %}
          
          {% if br_br == 'rounded-none' %}
            {% assign br_br = '0' %}
          {% elsif br_br == 'rounded-sm' %}
            {% assign br_br = 'var(--radius-sm)' %}
          {% elsif br_br == 'rounded' %}
            {% assign br_br = 'var(--radius-base)' %}
          {% elsif br_br == 'rounded-md' %}
            {% assign br_br = 'var(--radius-md)' %}
          {% elsif br_br == 'rounded-lg' %}
            {% assign br_br = 'var(--radius-lg)' %}
          {% elsif br_br == 'rounded-xl' %}
            {% assign br_br = 'var(--radius-xl)' %}
          {% elsif br_br == 'rounded-2xl' %}
            {% assign br_br = 'var(--radius-2xl)' %}
          {% elsif br_br == 'rounded-3xl' %}
            {% assign br_br = 'var(--radius-3xl)' %}
          {% elsif br_br == 'rounded-4xl' %}
            {% assign br_br = 'var(--radius-4xl)' %}
          {% elsif br_br == 'rounded-full' %}
            {% assign br_br = '9999px' %}
          {% endif %}
          
          {% assign border_width = section.settings.image_border_width | default: 0 | times: 1 %}
          {% assign border_color = section.settings.image_border_color | default: '#000000' %}
          {% assign border_style = '' %}
          {% if border_width > 0 %}
            {% assign border_style = 'border: ' | append: border_width | append: 'px solid ' | append: border_color | append: ';' %}
          {% endif %}
          <div class="standards-image-wrapper" 
               style="height: {{ image_height }}; border-radius: {{ br_tl }} {{ br_tr }} {{ br_br }} {{ br_bl }}; overflow: hidden; {{ border_style }}">
            {% if section.settings.video_url != blank %}
              <!-- Background Video -->
              <video
                class="standards-video standards-video--{{ image_fit_mode }}"
                autoplay
                muted
                loop
                playsinline
                {% if section.settings.main_image %}poster="{{ section.settings.main_image | image_url: width: 800 }}"{% endif %}
                style="width: 100%; height: 100%; object-fit: {{ image_fit_mode }};"
              >
                <source src="{{ section.settings.video_url }}" type="video/mp4">
              </video>
            {% elsif section.settings.main_image != blank %}
              <img 
                src="{{ section.settings.main_image | image_url: width: 800 }}" 
                alt="{{ section.settings.image_alt | default: section.settings.heading }}"
                loading="lazy"
                class="standards-image standards-image--{{ image_fit_mode }}"
                style="box-shadow: none !important;"
              >
            {% else %}
              <div class="standards-image-placeholder"></div>
            {% endif %}
          </div>
        </div>
        {% endunless %}
        
        <!-- Right Column: Content -->
        {% assign heading_body_alignment = section.settings.heading_body_text_alignment | default: 'left' %}
        {% assign text_align_class = '' %}
        {% if heading_body_alignment == 'left' %}
          {% assign text_align_class = 'text-left' %}
        {% elsif heading_body_alignment == 'center' %}
          {% assign text_align_class = 'text-center' %}
        {% elsif heading_body_alignment == 'right' %}
          {% assign text_align_class = 'text-right' %}
        {% endif %}
        {% assign content_column_class = 'standards-content-column ' | append: text_align_class %}
        {% if section.settings.hide_main_image %}
          {% assign content_column_class = content_column_class | append: ' standards-content-column--no-image' %}
        {% endif %}
        <div class="{{ content_column_class }}">
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
          <div class="standards-heading-wrapper {{ section.settings.heading_body_spacing_mobile | default: 'mb-lg' }} {{ section.settings.heading_body_spacing_desktop | default: 'lg:mb-lg' }}">
            <h2 class="standards-heading {{ section.settings.heading_font_family | default: 'font-handwritten' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
              {{ section.settings.heading | strip_html }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Body Text -->
          {% if section.settings.body_text != blank %}
          <div class="standards-body-wrapper {{ section.settings.body_margin_bottom_mobile | default: 'mb-lg' }} {{ section.settings.body_margin_bottom_desktop | default: 'lg:mb-lg' }}">
            <div class="standards-body {{ section.settings.body_font_family | default: 'font-body' }} {{ section.settings.body_font_size | default: 'text-base' }} {{ section.settings.body_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.body_font_weight | default: 'font-normal' }} {{ section.settings.body_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
              {{ section.settings.body_text }}
            </div>
          </div>
          {% endif %}
          
          <!-- Feature Blocks -->
          {% unless section.settings.hide_all_blocks %}
          {% if section.blocks.size > 0 %}
          {% assign blocks_gap_mobile = section.settings.blocks_gap_mobile | default: 'lg' %}
          {% assign blocks_gap_desktop = section.settings.blocks_gap_desktop | default: 'xl' %}
          {% assign feature_alignment = section.settings.feature_items_alignment | default: 'left' %}
          {% assign feature_justify = section.settings.feature_items_justify | default: 'left' %}
          {% assign mobile_inline_class = '' %}
          {% if section.settings.mobile_inline_layout %}
            {% assign mobile_inline_class = ' standards-features--mobile-inline' %}
          {% endif %}
          <div class="standards-features standards-features--gap-{{ blocks_gap_mobile }} standards-features--gap-desktop-{{ blocks_gap_desktop }} standards-features--align-{{ feature_alignment }} standards-features--justify-{{ feature_justify }}{{ mobile_inline_class }}">
            {% for block in section.blocks %}
              {% if block.type == 'feature_item' %}
              {% assign image_text_gap_mobile = section.settings.image_text_gap_mobile | default: 'md' %}
              {% assign image_text_gap_desktop = section.settings.image_text_gap_desktop | default: 'lg' %}
              <div class="standards-feature-item standards-feature-item--gap-{{ image_text_gap_mobile }} standards-feature-item--gap-desktop-{{ image_text_gap_desktop }} {% if block.settings.image == blank %}standards-feature-item--no-image{% endif %} {% if block.settings.show_heading == false or block.settings.title == blank %}standards-feature-item--no-heading{% endif %} {% if block.settings.description == blank %}standards-feature-item--no-description{% endif %}" {{ block.fluid_attributes }}>
                
                <!-- Image -->
                {% if block.settings.image != blank %}
                {% assign block_image_size_mobile = section.settings.image_size_mobile | default: '96' %}
                {% assign block_image_size_desktop = section.settings.image_size_desktop | default: block_image_size_mobile %}
                {% assign block_image_fit_mode = block.settings.image_fit_mode | default: 'cover' %}
                {% assign block_image_border_radius = block.settings.image_border_radius | default: 'rounded-sm' %}
                {% assign border_width = block.settings.image_border_width | default: 0 | times: 1 %}
                {% assign border_color_class = block.settings.image_border_color | default: 'border-black' %}
                {% assign border_style_type = block.settings.image_border_style | default: 'solid' %}
                
                {% comment %} Convert border radius class to CSS value {% endcomment %}
                {% assign br_value = '0' %}
                {% if block_image_border_radius == 'rounded-sm' %}
                  {% assign br_value = 'var(--radius-sm)' %}
                {% elsif block_image_border_radius == 'rounded' %}
                  {% assign br_value = 'var(--radius-base)' %}
                {% elsif block_image_border_radius == 'rounded-md' %}
                  {% assign br_value = 'var(--radius-md)' %}
                {% elsif block_image_border_radius == 'rounded-lg' %}
                  {% assign br_value = 'var(--radius-lg)' %}
                {% elsif block_image_border_radius == 'rounded-xl' %}
                  {% assign br_value = 'var(--radius-xl)' %}
                {% elsif block_image_border_radius == 'rounded-2xl' %}
                  {% assign br_value = 'var(--radius-2xl)' %}
                {% elsif block_image_border_radius == 'rounded-3xl' %}
                  {% assign br_value = 'var(--radius-3xl)' %}
                {% elsif block_image_border_radius == 'rounded-full' %}
                  {% assign br_value = '9999px' %}
                {% endif %}
                
                {% assign image_border_style = '' %}
                {% if border_width > 0 %}
                  {% assign image_border_style = 'border-width: ' | append: border_width | append: 'px; border-style: ' | append: border_style_type | append: '; border-radius: ' | append: br_value | append: ';' %}
                {% endif %}
                {% assign wrapper_classes = 'standards-feature-image-wrapper' %}
                {% if border_width > 0 and border_color_class != blank %}
                  {% assign wrapper_classes = wrapper_classes | append: ' ' | append: border_color_class %}
                {% endif %}
                <div class="{{ wrapper_classes }}" 
                     style="--image-size-mobile: {{ block_image_size_mobile }}px; --image-size-desktop: {{ block_image_size_desktop }}px; width: var(--image-size-mobile); height: var(--image-size-mobile); {% if border_width > 0 %}{{ image_border_style }}{% endif %}">
                  <img 
                      src="{{ block.settings.image | image_url: width: block_image_size_desktop }}" 
                      alt="{{ block.settings.image_alt | default: block.settings.title }}"
                      loading="lazy"
                      class="standards-feature-image standards-feature-image--{{ block_image_fit_mode }} {{ block_image_border_radius }}"
                      style="box-shadow: none !important;"
                    >
                </div>
                {% endif %}
                
                <!-- Text Content -->
                <div class="standards-feature-content {% if block.settings.show_heading == false or block.settings.title == blank %}standards-feature-content--no-heading{% endif %} {% if block.settings.description == blank %}standards-feature-content--no-description{% endif %}">
                  {% if block.settings.show_heading != false and block.settings.title != blank %}
                  <div class="standards-feature-title-wrapper {% if block.settings.description != blank %}{{ section.settings.block_heading_margin_bottom_mobile | default: 'mb-xs' }} {{ section.settings.block_heading_margin_bottom_desktop | default: 'lg:mb-xs' }}{% endif %}">
                    <h3 class="standards-feature-title {{ section.settings.feature_title_font_family | default: 'font-handwritten' }} {{ section.settings.feature_title_font_size | default: 'text-xl' }} {{ section.settings.feature_title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.feature_title_font_weight | default: 'font-normal' }} {{ section.settings.feature_title_color | default: 'text-neutral-dark' }}" style="line-height: 1;">
                      {{ block.settings.title }}
                    </h3>
                  </div>
                  {% endif %}
                  
                  {% if block.settings.description != blank %}
                  <div class="standards-feature-description-wrapper">
                    <div class="standards-feature-description {{ section.settings.feature_description_font_family | default: 'font-body' }} {{ section.settings.feature_description_font_size | default: 'text-sm' }} {{ section.settings.feature_description_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.feature_description_font_weight | default: 'font-normal' }} {{ section.settings.feature_description_color | default: 'text-neutral-dark' }}" style="line-height: 1.5;">
                      {{ block.settings.description }}
                    </div>
                  </div>
                  {% endif %}
                </div>
                
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          {% endunless %}
          
          <!-- CTA Button -->
          {% if section.settings.show_cta_button %}
          <div class="standards-cta-wrapper mt-lg">
            <a href="{{ section.settings.cta_button_url | default: '#' }}" 
               class="btn btn-{{ section.settings.cta_button_style | default: 'filled' }}-{{ section.settings.cta_button_color | default: 'primary' }} {{ section.settings.cta_button_size | default: 'btn-md' }} {{ section.settings.cta_button_font_weight | default: 'font-normal' }} font-body {{ settings.button_border_radius | default: 'rounded-full' }}">
              {{ section.settings.cta_button_text | default: 'Learn More' }}
            </a>
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

<script>
(function() {
  const sectionId = 'standards-{{ section.id }}';
  
  function initScrollAnimation() {
    const section = document.getElementById(sectionId);
    if (!section) return;
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px'
    });
    
    observer.observe(section);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimation);
  } else {
    initScrollAnimation();
  }
  
  // Re-init on Shopify theme editor updates
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initScrollAnimation();
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Standards",
  "tag": "section",
  "class": "standards",
  "settings": [
    {
      "type": "header",
      "content": "Layout Width (Container)"
    },
    {
      "type": "select",
      "id": "container_layout_width",
      "label": "Layout Width (Container)",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-full", "label": "Full Width (Container Full)" }
      ],
      "default": "container",
      "info": "Choose whether the container is constrained to the width of the page or full width"
    },
    {
      "type": "header",
      "content": "Main Image"
    },
    {
      "type": "checkbox",
      "id": "hide_main_image",
      "label": "Hide Main Image",
      "default": false,
      "info": "When enabled, the main image column will be hidden"
    },
    {
      "type": "select",
      "id": "heading_body_text_alignment",
      "label": "Heading & Body Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "info": "Controls the text alignment of the heading and body text"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image / Video Poster",
      "info": "Used as the main image, or as a poster/thumbnail if a video URL is provided"
    },
    {
      "type": "video_picker",
      "id": "video_url",
      "label": "Video URL (Optional)",
      "info": "Direct video URL (e.g., https://example.com/video.mp4). If provided, video will autoplay muted and loop. The main image above will be used as a poster/thumbnail."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Standards section image"
    },
    {
      "type": "select",
      "id": "image_fit_mode",
      "label": "Image Fit Mode",
      "options": [
        { "value": "fit", "label": "Fit (Show entire image)" },
        { "value": "fill", "label": "Fill (Fill container, may crop)" }
      ],
      "default": "fill",
      "info": "Fit: Shows entire image maintaining aspect ratio. Fill: Fills container, may crop image."
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image Container Height(Tablet)",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 400,
      "info": "Adjust the height of the image container (width stays the same)"
    },
    {
      "type": "header",
      "content": "Image Corner Rounding"
    },
    {
      "type": "select",
      "id": "round_top_left_radius",
      "label": "Top Left Corner Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-sm", "label": "Small" },
        { "value": "rounded", "label": "Base" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-lg", "label": "Large" },
        { "value": "rounded-xl", "label": "Extra Large" },
        { "value": "rounded-2xl", "label": "2X Large" },
        { "value": "rounded-3xl", "label": "3X Large" },
        { "value": "rounded-4xl", "label": "4X Large" },
        { "value": "rounded-full", "label": "Full (Circle)" }
      ],
      "default": "rounded-none"
    },
    {
      "type": "select",
      "id": "round_top_right_radius",
      "label": "Top Right Corner Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-sm", "label": "Small" },
        { "value": "rounded", "label": "Base" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-lg", "label": "Large" },
        { "value": "rounded-xl", "label": "Extra Large" },
        { "value": "rounded-2xl", "label": "2X Large" },
        { "value": "rounded-3xl", "label": "3X Large" },
        { "value": "rounded-4xl", "label": "4X Large" },
        { "value": "rounded-full", "label": "Full (Circle)" }
      ],
      "default": "rounded-none"
    },
    {
      "type": "select",
      "id": "round_bottom_left_radius",
      "label": "Bottom Left Corner Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-sm", "label": "Small" },
        { "value": "rounded", "label": "Base" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-lg", "label": "Large" },
        { "value": "rounded-xl", "label": "Extra Large" },
        { "value": "rounded-2xl", "label": "2X Large" },
        { "value": "rounded-3xl", "label": "3X Large" },
        { "value": "rounded-4xl", "label": "4X Large" },
        { "value": "rounded-full", "label": "Full (Circle)" }
      ],
      "default": "rounded-none"
    },
    {
      "type": "select",
      "id": "round_bottom_right_radius",
      "label": "Bottom Right Corner Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-sm", "label": "Small" },
        { "value": "rounded", "label": "Base" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-lg", "label": "Large" },
        { "value": "rounded-xl", "label": "Extra Large" },
        { "value": "rounded-2xl", "label": "2X Large" },
        { "value": "rounded-3xl", "label": "3X Large" },
        { "value": "rounded-4xl", "label": "4X Large" },
        { "value": "rounded-full", "label": "Full (Circle)" }
