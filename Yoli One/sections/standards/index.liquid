      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "Set to 0 to hide the border"
    },
    {
      "type": "color_background",
      "id": "image_border_color",
      "label": "Border Color",
      "default": "#000000",
      "info": "Choose the color for the image border"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "The Yoli Standard"
    },
    {
