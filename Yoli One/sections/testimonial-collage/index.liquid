<link rel="stylesheet" href="{{ 'testimonial-collage/styles.css' | asset_url }}">

{% comment %} Map card size preset to CSS class {% endcomment %}
{% assign card_size_class = 'testimonial-collage-section--card-md' %}
{% case section.settings.card_size %}
  {% when 'sm' %}
    {% assign card_size_class = 'testimonial-collage-section--card-sm' %}
  {% when 'md' %}
    {% assign card_size_class = 'testimonial-collage-section--card-md' %}
  {% when 'lg' %}
    {% assign card_size_class = 'testimonial-collage-section--card-lg' %}
  {% when 'xl' %}
    {% assign card_size_class = 'testimonial-collage-section--card-xl' %}
{% endcase %}


<!-- Testimonial Collage Section -->
<section class="testimonial-collage-section {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ card_size_class }} {% if section.settings.flip_layout %}testimonial-collage-section--flip{% endif %} {{ section.settings.padding_top_mobile }} {{ section.settings.padding_bottom_mobile }} {{ section.settings.padding_x_mobile }} lg:{{ section.settings.padding_top_desktop }} lg:{{ section.settings.padding_bottom_desktop }} lg:{{ section.settings.padding_x_desktop }}" 
         {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}
         style="--text-section-width: {{ section.settings.text_section_width | default: 50 }}%;">
  
  <!-- Content Side (Text remains in constrained container) -->
  <div class="testimonial-collage__content-wrapper">
    <div class="container">
      <div class="testimonial-collage__inner py-lg lg:py-2xl px-md lg:px-xl">
        <div class="testimonial-collage__content-side">
          <div class="testimonial-collage__content {{ section.settings.content_alignment | default: 'text-left' }}">
            
            <!-- Logo -->
            {% if section.settings.logo != blank %}
              <div class="testimonial-collage__logo">
                <img src="{{ section.settings.logo | image_url: width: 120 }}" 
                     alt="Logo"
                     class="testimonial-collage__logo-img"
                     loading="lazy">
              </div>
            {% endif %}

            <!-- Heading -->
            {% if section.settings.heading != blank %}
              <div class="testimonial-collage__heading">
                <h2 class="{{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-bold' }} {{ section.settings.heading_color | default: 'text-neutral-dark' }}">
                  {{ section.settings.heading }}
                </h2>
              </div>
            {% endif %}

            <!-- Subtext -->
            {% if section.settings.subtext != blank %}
              <div class="testimonial-collage__subtext">
                <p class="{{ section.settings.subtext_font_family | default: 'font-body' }} {{ section.settings.subtext_font_size | default: 'text-base' }} {{ section.settings.subtext_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.subtext_font_weight | default: 'font-normal' }} {{ section.settings.subtext_color | default: 'text-neutral-dark' }}">
                  {{ section.settings.subtext }}
                </p>
              </div>
            {% endif %}

            <!-- CTA Button -->
            {% if section.settings.show_button %}
              <div class="testimonial-collage__cta">
                <a href="{{ section.settings.button_url | default: '#' }}" 
                   class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-medium' }} font-body {{ settings.button_border_radius | default: 'rounded' }}"
                   style="cursor: pointer;">
                  {{ section.settings.button_text | default: 'Learn More' }}
                </a>
              </div>
            {% endif %}

          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Images Side (Bleeds to viewport edge) -->
  <div class="testimonial-collage__images-wrapper">
    <div class="testimonial-collage__images-side">
          {% if section.blocks.size > 0 %}
            {% assign final_direction = section.settings.scroll_direction | default: 'right-to-left' %}
            {% comment %} Calculate how many times to repeat blocks to fill grid evenly (2 rows) {% endcomment %}
            {% assign block_count = section.blocks.size %}
            {% assign remainder = block_count | modulo: 2 %}
            {% assign repeat_count = 1 %}
            {% if remainder != 0 %}
              {% assign repeat_count = 2 %}
            {% endif %}
            <div class="testimonial-collage__track-container testimonial-collage__track-container--{{ final_direction }}" id="testimonial-track-{{ section.id }}">
              <div class="testimonial-collage__track testimonial-collage__track--{{ final_direction }}" style="animation-duration: {{ section.settings.scroll_speed | default: 30 }}s;">
                {% comment %} Create multiple sets of cards for seamless infinite scrolling {% endcomment %}
                {% for i in (1..4) %}
                  <div class="testimonial-collage__grid" {% if i > 1 %}aria-hidden="true"{% endif %}>
                    {% comment %} Repeat blocks if odd count to fill 2-row grid evenly {% endcomment %}
                    {% for r in (1..repeat_count) %}
                    {% for block in section.blocks %}
                      <div class="testimonial-collage__card {{ section.settings.card_border_radius | default: 'rounded-md' }}" {% if i == 1 and r == 1 %}{{ block.fluid_attributes}}{% endif %}>
                        {% if block.settings.image != blank %}
                          <img src="{{ block.settings.image | image_url }}" 
                               alt="{{ block.settings.name | default: 'Testimonial' }}"
                               class="testimonial-collage__card-image testimonial-collage__card-image--fill"
                               loading="lazy"
                               style="box-shadow: none !important;">
                        {% else %}
                          <img src="{{ 'placeholder-image.png' | asset_url }}" 
                               alt="Testimonial"
                               class="testimonial-collage__card-image testimonial-collage__card-image--fill"
                               style="box-shadow: none !important;">
                        {% endif %}
                        
                        <!-- Overlay Gradient -->
                        {% if section.settings.show_card_overlay %}
                          <div class="testimonial-collage__card-overlay"></div>
                        {% endif %}
                        
                        <!-- Card Content -->
                        {% if section.settings.show_card_text %}
                          <div class="testimonial-collage__card-content {{ section.settings.card_text_alignment | default: 'text-left' }}">
                            {% if block.settings.name != blank %}
                              <div class="testimonial-collage__card-name {{ section.settings.card_name_font_family | default: 'font-body' }} {{ section.settings.card_name_font_size | default: 'text-base' }} {{ section.settings.card_name_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.card_name_font_weight | default: 'font-bold' }} {{ section.settings.card_name_color | default: 'text-white' }}">
                                {{ block.settings.name }}
                              </div>
                            {% endif %}
                            
                            {% if block.settings.before_value != blank or block.settings.after_value != blank %}
                              <div class="testimonial-collage__card-metric {{ section.settings.card_metric_font_family | default: 'font-body' }} {{ section.settings.card_metric_font_size | default: 'text-sm' }} {{ section.settings.card_metric_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.card_metric_font_weight | default: 'font-normal' }} {{ section.settings.card_metric_color | default: 'text-white' }}">
                                {% if block.settings.before_value != blank %}{{ block.settings.before_value }}{% endif %}{% if block.settings.before_value != blank and block.settings.after_value != blank %} → {% endif %}{% if block.settings.after_value != blank %}{{ block.settings.after_value }}{% endif %}
                              </div>
                            {% endif %}
                          </div>
                        {% endif %}
                      </div>
                    {% endfor %}
                    {% endfor %}
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}
    </div>
  </div>

</section>


