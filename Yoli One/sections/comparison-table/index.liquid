<link rel="stylesheet" href="{{ 'comparison-table/styles.css' | asset_url }}">

<!-- Comparison Table Section -->
<section class="comparison-table {{ section.settings.background_color | default: 'bg-primary' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  <div class="container">
    <div class="comparison-table-inner {{ section.settings.container_background_color | default: '' }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <!-- Header -->
      <div class="comparison-table__header">
        {% if section.settings.heading != blank %}
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }} {{ section.settings.heading_color | default: 'text-white' }} text-center leading-heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      <!-- Comparison Table -->
      <div class="comparison-table__table-wrapper">
        <table class="comparison-table__table">
          <colgroup>
            <col class="comparison-table__col comparison-table__col--feature">
            <col class="comparison-table__col comparison-table__col--ours">
            <col class="comparison-table__col comparison-table__col--theirs">
          </colgroup>
          
          <!-- Table Header: Product Images -->
          <thead>
            <tr class="comparison-table__header-row">
              <th class="comparison-table__header-cell comparison-table__header-cell--feature">
                <!-- Empty for feature column -->
              </th>
              <th class="comparison-table__header-cell comparison-table__header-cell--ours">
                {% if section.settings.our_product_label != blank %}
                  <div class="comparison-table__product-label">
                    <p class="{{ section.settings.product_label_font_family | default: 'font-body' }} {{ section.settings.product_label_font_size | default: 'text-xs' }} {{ section.settings.product_label_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.product_label_font_weight | default: 'font-normal' }} {{ section.settings.product_label_color | default: 'text-white' }} uppercase tracking-wider text-center">
                      {{ section.settings.our_product_label }}
                    </p>
                  </div>
                {% endif %}
                {% if section.settings.our_product_image %}
                  <div class="comparison-table__product-image">
                    <img src="{{ section.settings.our_product_image | image_url: width: 400 }}"
                         alt="{{ section.settings.our_product_image_alt | default: section.settings.our_product_label }}"
                         loading="lazy"
                         style="box-shadow: none !important;">
                  </div>
                {% else %}
                  <div class="comparison-table__product-image">
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="Placeholder"
                         loading="lazy"
                         style="box-shadow: none !important;">
                  </div>
                {% endif %}
              </th>
              <th class="comparison-table__header-cell comparison-table__header-cell--theirs">
                {% if section.settings.their_product_label != blank %}
                  <div class="comparison-table__product-label">
                    <p class="{{ section.settings.product_label_font_family | default: 'font-body' }} {{ section.settings.product_label_font_size | default: 'text-xs' }} {{ section.settings.product_label_font_size_desktop | default: 'lg:text-xs' }} {{ section.settings.product_label_font_weight | default: 'font-normal' }} {{ section.settings.product_label_color | default: 'text-white' }} uppercase tracking-wider text-center">
                      {{ section.settings.their_product_label }}
                    </p>
                  </div>
                {% endif %}
                {% if section.settings.their_product_image %}
                  <div class="comparison-table__product-image">
                    <img src="{{ section.settings.their_product_image | image_url: width: 400 }}"
                         alt="{{ section.settings.their_product_image_alt | default: section.settings.their_product_label }}"
                         loading="lazy"
                         style="box-shadow: none !important;">
                  </div>
                {% else %}
                  <div class="comparison-table__product-image">
                    <img src="{{ 'placeholder-image.png' | asset_url }}"
                         alt="Placeholder"
                         loading="lazy"
                         style="box-shadow: none !important;">
                  </div>
                {% endif %}
              </th>
            </tr>
          </thead>

          <!-- Table Body: Comparison Rows -->
          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'comparison_row' %}
                <tr class="comparison-table__row" {{ block.fluid_attributes }}>
                  <td class="comparison-table__cell comparison-table__cell--feature">
                    {% if block.settings.feature_text != blank %}
                      <p class="{{ section.settings.feature_font_family | default: 'font-body' }} {{ section.settings.feature_font_size | default: 'text-xs' }} {{ section.settings.feature_font_size_desktop | default: 'lg:text-sm' }} {{ section.settings.feature_font_weight | default: 'font-normal' }} {{ section.settings.feature_color | default: 'text-white' }} uppercase tracking-wider">
                        {{ block.settings.feature_text }}
                      </p>
                    {% endif %}
                  </td>
                  <td class="comparison-table__cell comparison-table__cell--ours">
                    {% if block.settings.ours_has_feature %}
                      <div class="comparison-table__icon comparison-table__icon--check {{ section.settings.icon_color | default: 'text-white' }}">
                        <svg width="35" height="35" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
                          <path d="M8 12L11 15L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                    {% else %}
                      <div class="comparison-table__icon comparison-table__icon--cross {{ section.settings.icon_color | default: 'text-white' }}">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                          <path d="M15 9L9 15M9 9L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </div>
                    {% endif %}
                  </td>
                  <td class="comparison-table__cell comparison-table__cell--theirs">
                    {% if block.settings.theirs_has_feature %}
                      <div class="comparison-table__icon comparison-table__icon--check {{ section.settings.icon_color | default: 'text-white' }}">
                        <svg width="35" height="35" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
                          <path d="M8 12L11 15L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                    {% else %}
                      <div class="comparison-table__icon comparison-table__icon--cross {{ section.settings.icon_color | default: 'text-white' }}">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                          <path d="M15 9L9 15M9 9L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </div>
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>

        </table>
      </div>

      <!-- CTA Button -->
      {% if section.settings.show_button %}
        <div class="comparison-table__button-wrapper">
          <a href="{{ section.settings.button_url | default: '#' }}" 
             class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'white' }} {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_font_weight | default: 'font-normal' }} {{ settings.button_border_radius | default: 'rounded-md' }}" 
             style="white-space: nowrap;">
            {{ section.settings.button_text | default: 'Lorem Ipsum' }}
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</section>

