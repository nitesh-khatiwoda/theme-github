<link rel="stylesheet" href="{{ 'also_bought/styles.css' | asset_url }}">

{%- style -%}
  .also-bought-{{ section.id }} {
    background: {{ section.settings.section_bg_color | default: '#f5f0e8' }};
    --ab-heading-color: {{ section.settings.heading_color | default: '#1a1a1a' }};
    --ab-title-color: {{ section.settings.product_title_color | default: '#1a1a1a' }};
    --ab-desc-color: {{ section.settings.product_desc_color | default: '#666666' }};
    --ab-rating-color: {{ section.settings.rating_text_color | default: '#666666' }};
    --ab-star-filled: {{ section.settings.star_color_filled | default: '#d4a853' }};
    --ab-star-empty: {{ section.settings.star_color_empty | default: '#d1d5db' }};
    --ab-button-bg: {{ section.settings.button_bg_color | default: '#d4a853' }};
    --ab-button-text: {{ section.settings.button_text_color | default: '#1a1a1a' }};
    --ab-button-hover-bg: {{ section.settings.button_hover_bg | default: '#c49a48' }};
    --ab-card-bg: {{ section.settings.card_bg_color | default: '#ffffff' }};
  }
{%- endstyle -%}

<section class="also-bought also-bought-{{ section.id }}">
  <!-- Section Header -->
  {% if section.settings.heading != blank %}
    <h2 class="also-bought-heading {{ section.settings.heading_font_family | default: 'font-serif' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-4xl' }} {{ section.settings.heading_font_weight | default: 'font-normal' }}">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <!-- Products Grid -->
  <div class="also-bought-grid" style="--ab-columns: {{ section.settings.columns_desktop | default: 3 }}; --ab-columns-tablet: {{ section.settings.columns_tablet | default: 2 }}; --ab-columns-mobile: {{ section.settings.columns_mobile | default: 1 }};">
    {% for block in section.blocks %}
      {% if block.type == 'product_card' %}
        {% assign product = block.settings.product %}
        {% assign variant = product.selected_or_first_available_variant %}
        {% assign variant_id = variant.id | default: product.variants.first.id %}
        
        <div class="also-bought-card" {{ block.fluid_attributes }}>
          <!-- Product Image -->
          <div class="also-bought-image-wrapper">
            <a href="{{ product.url | default: block.settings.product_url | default: '#' }}" class="also-bought-image-link">
              {% if product.image_url != blank %}
                <img 
                  src="{{ product.image_url | image_url: width: 600 }}" 
                  alt="{{ product.title | default: block.settings.title }}"
                  class="also-bought-image"
                  loading="lazy"
                >
              {% elsif block.settings.product_image != blank %}
                <img 
                  src="{{ block.settings.product_image | image_url: width: 600 }}" 
                  alt="{{ block.settings.title }}"
                  class="also-bought-image"
                  loading="lazy"
                >
              {% else %}
                <div class="also-bought-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21,15 16,10 5,21"/>
                  </svg>
                </div>
              {% endif %}
            </a>
          </div>

          <!-- Product Info -->
          <div class="also-bought-info">
            <!-- Product Title -->
            <h3 class="also-bought-title {{ section.settings.product_title_font_family | default: 'font-body' }} {{ section.settings.product_title_font_size | default: 'text-lg' }} {{ section.settings.product_title_font_weight | default: 'font-semibold' }}">
              <a href="{{ product.url | default: block.settings.product_url | default: '#' }}">
                {{ product.title | default: block.settings.title | default: 'Product Name' }}
              </a>
            </h3>

            <!-- Product Description -->
            {% if section.settings.show_description %}
              <p class="also-bought-description {{ section.settings.product_desc_font_size | default: 'text-sm' }}">
                {% if block.settings.description != blank %}
                  {{ block.settings.description }}
                {% elsif product.short_description != blank %}
                  {{ product.short_description | truncate: 60 }}
                {% elsif product.description != blank %}
                  {{ product.description | strip_html | truncate: 60 }}
                {% endif %}
              </p>
            {% endif %}

            <!-- Star Rating -->
            {% if section.settings.show_rating %}
              {% assign star_rating = block.settings.star_rating | default: 5.0 %}
              {% assign review_count = block.settings.review_count | default: 0 %}
              
              <div class="also-bought-rating">
                <div class="also-bought-stars">
                  {% assign full_stars = star_rating | floor %}
                  {% assign decimal_part = star_rating | modulo: 1 %}
                  {% assign has_half = false %}
                  {% if decimal_part >= 0.25 and decimal_part < 0.75 %}
                    {% assign has_half = true %}
                  {% elsif decimal_part >= 0.75 %}
                    {% assign full_stars = full_stars | plus: 1 %}
                  {% endif %}
                  {% assign empty_stars = 5 | minus: full_stars %}
                  {% if has_half %}
                    {% assign empty_stars = empty_stars | minus: 1 %}
                  {% endif %}
                  
                  {%- for i in (1..full_stars) -%}
                    <span class="star star-full">★</span>
                  {%- endfor -%}
                  
                  {%- if has_half -%}
                    <span class="star star-half">
                      <span class="star-bg">★</span>
                      <span class="star-fill">★</span>
                    </span>
                  {%- endif -%}
                  
                  {%- if empty_stars > 0 -%}
                    {%- for i in (1..empty_stars) -%}
                      <span class="star star-empty">★</span>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
                
                <span class="also-bought-rating-text">
                  ({{ star_rating }} stars) • {{ review_count }} reviews
                </span>
              </div>
            {% endif %}

            <!-- Add to Cart Button -->
            {% if section.settings.show_add_to_cart %}
              <button 
                type="button"
                class="also-bought-atc-btn {{ section.settings.button_size | default: 'btn-md' }} {{ section.settings.button_border_radius | default: 'rounded-md' }}"
                data-fluid-add-to-cart="{{ variant_id | default: block.settings.variant_id }}"
                data-fluid-quantity="1"
                {% if variant_id == blank and block.settings.variant_id == blank %}disabled{% endif %}
              >
                {{ section.settings.button_text | default: 'ADD TO CART' }}
              </button>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.blocks.size == 0 %}
    <div class="also-bought-empty">
      <p>Add product blocks to display recommendations.</p>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Also Bought Products",
  "tag": "section",
  "class": "also-bought-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Others Like You Also Bought"
    },
    {
      "type": "select",
      "id": "heading_font_family",
      "label": "Heading Font Family",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-serif", "label": "Serif" },
        { "value": "font-handwritten", "label": "Handwritten" }
      ],
      "default": "font-serif"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading Size (Mobile)",
      "options": [
        { "value": "text-xl", "label": "XL" },
        { "value": "text-2xl", "label": "2XL" },
        { "value": "text-3xl", "label": "3XL" },
        { "value": "text-4xl", "label": "4XL" }
      ],
      "default": "text-3xl"
    },
    {
      "type": "select",
      "id": "heading_font_size_desktop",
      "label": "Heading Size (Desktop)",
      "options": [
        { "value": "lg:text-2xl", "label": "2XL" },
        { "value": "lg:text-3xl", "label": "3XL" },
        { "value": "lg:text-4xl", "label": "4XL" },
        { "value": "lg:text-5xl", "label": "5XL" }
      ],
      "default": "lg:text-4xl"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "font-light", "label": "Light" },
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semibold" },
        { "value": "font-bold", "label": "Bold" }
      ],
      "default": "font-normal"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (Tablet)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (Mobile)",
      "min": 1,
      "max": 2,
      "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Product Card Display"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show Description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Star Rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show Add to Cart Button",
      "default": true
    },
    {
      "type": "header",
      "content": "Product Title Styling"
    },
    {
      "type": "select",
      "id": "product_title_font_family",
      "label": "Title Font Family",
      "options": [
        { "value": "font-primary", "label": "Primary" },
        { "value": "font-body", "label": "Body" },
        { "value": "font-serif", "label": "Serif" }
      ],
      "default": "font-body"
    },
    {
      "type": "select",
      "id": "product_title_font_size",
      "label": "Title Font Size",
      "options": [
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "text-xl", "label": "XL" }
      ],
      "default": "text-lg"
    },
    {
      "type": "select",
      "id": "product_title_font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "font-normal", "label": "Normal" },
        { "value": "font-medium", "label": "Medium" },
        { "value": "font-semibold", "label": "Semibold" },
        { "value": "font-bold", "label": "Bold" }
      ],
      "default": "font-semibold"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Description Styling"
    },
    {
      "type": "select",
      "id": "product_desc_font_size",
      "label": "Description Font Size",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" }
      ],
      "default": "text-sm"
    },
    {
      "type": "color",
      "id": "product_desc_color",
      "label": "Description Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Rating Styling"
    },
    {
      "type": "color",
      "id": "star_color_filled",
      "label": "Filled Star Color",
      "default": "#d4a853"
    },
    {
      "type": "color",
      "id": "star_color_empty",
      "label": "Empty Star Color",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "rating_text_color",
      "label": "Rating Text Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Button Styling"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "ADD TO CART"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button Size",
      "options": [
        { "value": "btn-sm", "label": "Small" },
        { "value": "btn-md", "label": "Medium" },
        { "value": "btn-lg", "label": "Large" }
      ],
      "default": "btn-md"
    },
    {
      "type": "select",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-sm", "label": "Small" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-lg", "label": "Large" },
        { "value": "rounded-full", "label": "Full" }
      ],
      "default": "rounded-full"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background",
      "default": "#d4a853"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button Hover Background",
      "default": "#c49a48"
    },
    {
      "type": "header",
      "content": "Section Background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#f5f0e8"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "limit": 6,
      "settings": [
        {
          "type": "header",
          "content": "Product Selection"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "header",
          "content": "Manual Override (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title Override",
          "info": "Leave blank to use product title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description Override",
          "info": "Leave blank to use product description"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Image Override",
          "info": "Leave blank to use product image"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "URL Override",
          "info": "Leave blank to use product URL"
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID Override",
          "info": "For add to cart. Leave blank to use first available variant"
        },
        {
          "type": "header",
          "content": "Rating & Reviews"
        },
        {
          "type": "range",
          "id": "star_rating",
          "label": "Star Rating",
          "min": 1.0,
          "max": 5.0,
          "step": 0.1,
          "default": 4.8
        },
        {
          "type": "number",
          "id": "review_count",
          "label": "Review Count",
          "default": 126
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Also Bought Products",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "title": "Passion",
            "description": "Your energy is our passion.",
            "star_rating": 4.8,
            "review_count": 126
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Pure",
            "description": "Healthy Balanced Gut Health.",
            "star_rating": 4.9,
            "review_count": 142
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Alkalete",
            "description": "Healthy Body pH.",
            "star_rating": 4.7,
            "review_count": 234
          }
        }
      ]
    }
  ]
}
{% endschema %}

