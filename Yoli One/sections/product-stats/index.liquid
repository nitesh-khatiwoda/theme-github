<link rel="stylesheet" href="{{ 'product-stats/styles.css' | asset_url }}">

<!-- Product Stats Section -->
<section class="product-stats {{ section.settings.background_color | default: 'bg-neutral-light' }} {{ section.settings.section_padding_y_mobile | default: 'py-0' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="product-stats-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
  
  <div class="{{section.settings.container_layout_width | default: 'container'}}">
    <div class="product-stats-inner font-body {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-0' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-0' }} {{ section.settings.container_padding_x_mobile | default: 'px-0' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-0' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
      
      <div class="stats-layout {% if section.settings.flip_layout %}stats-layout--flipped{% endif %}">
        
        <!-- Image Column -->
        <div class="image-column">
          {% if section.settings.product_image != blank %}
            <img src="{{ section.settings.product_image | image_url: width: 1200 }}" alt="{{ section.settings.product_image_alt | default: 'Product' }}" loading="lazy">
          {% else %}
            <img src="{{ 'placeholder-image.png' | asset_url }}" alt="Placeholder">
          {% endif %}
        </div>
        
        <!-- Content Column -->
        <div class="content-column">
          
          <!-- Heading -->
          {% if section.settings.heading != blank %}
          <div class="heading-wrapper">
            <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-4xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-medium' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
              {{ section.settings.heading }}
            </h2>
          </div>
          {% endif %}
          
          <!-- Tagline -->
          {% if section.settings.tagline != blank %}
          <div class="tagline-wrapper">
            <p class="{{ section.settings.tagline_font_family | default: 'font-body' }} {{ section.settings.tagline_font_size | default: 'text-base' }} {{ section.settings.tagline_font_size_desktop | default: 'lg:text-base' }} {{ section.settings.tagline_font_weight | default: 'font-normal' }} {{ section.settings.tagline_color | default: 'text-primary' }} leading-body">
              {{ section.settings.tagline }}
            </p>
          </div>
          {% endif %}
          
          <!-- Stats Grid -->
          {% if section.blocks.size > 0 %}
          <div class="stats-grid">
            {% for block in section.blocks %}
              {% if block.type == 'stat_item' %}
              <div class="stat-item" {{ block.fluid_attributes }}>
                {% if block.settings.stat_value != blank %}
                <div class="stat-value">
                  <span class="{{ block.settings.value_font_family | default: 'font-primary' }} {{ block.settings.value_font_size | default: 'text-3xl' }} {{ block.settings.value_font_size_desktop | default: 'lg:text-4xl' }} {{ block.settings.value_font_weight | default: 'font-medium' }} {{ block.settings.value_color | default: 'text-primary' }}">
                    {{ block.settings.stat_value }}
                  </span>
                </div>
                {% endif %}
                
                {% if block.settings.stat_label != blank %}
                <div class="stat-label">
                  <p class="{{ block.settings.label_font_family | default: 'font-body' }} {{ block.settings.label_font_size | default: 'text-base' }} {{ block.settings.label_font_size_desktop | default: 'lg:text-lg' }} {{ block.settings.label_font_weight | default: 'font-medium' }} {{ block.settings.label_color | default: 'text-primary' }} leading-body">
                    {{ block.settings.stat_label }}
                  </p>
                </div>
                {% endif %}
              </div>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
          
          <!-- CTA Button -->
          {% if section.settings.show_button and section.settings.button_text != blank %}
          <div class="button-wrapper">
            <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-{{ section.settings.button_style | default: 'filled' }}-{{ section.settings.button_color | default: 'primary' }} {{ section.settings.button_size | default: 'btn-md' }} {{ settings.button_border_radius | default: 'rounded-md' }}">
              {{ section.settings.button_text }}
            </a>
          </div>
          {% endif %}
          
        </div>
        
      </div>
      
    </div>
  </div>
  
</section>

