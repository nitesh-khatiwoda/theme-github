<section 
  class="collection-products-{{ section.id }} {{ section.settings.background_color }} {{ section.settings.section_padding_y_mobile }} {{ section.settings.section_padding_y_desktop }} {{ section.settings.section_border_radius }}"
  {% if section.settings.background_image %}
    data-bg="{{ section.settings.background_image | image_url }}"
  {% endif %}
>
  <div class="{{section.settings.container_layout_width | default : 'container'}}">
    <div class="title-section">
      <div class="title-wrapper flex-1 mb-lg">
        {% if section.settings.title != blank or collection.title != blank %}
          <h3 class="section-title capitalize {{ section.settings.title_font_family }} {{ section.settings.title_font_size | default: 'text-2xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-3xl' }} {{ section.settings.title_font_weight | default: 'font-bold' }} {{ section.settings.title_color }}">
            {{collection.title }}
          </h3>
          
          {% if collection.description != blank %}
            <p class="section-description mt-sm {{ section.settings.description_font_family }} {{ section.settings.description_font_size | default: 'text-base' }} {{ section.settings.description_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.description_font_weight | default: 'font-medium' }} {{ section.settings.description_color }}">
              {{ collection.description }}
            </p>
          {% endif %}
        {% endif %}
      </div>
    </div>
    {%- paginate collection.products by 10 -%}
     <div class="product-list-section">
       {% assign products = collection.products | default: empty %}
       {% if products != blank %}
         <div class="product-list grid grid-cols-1 xs:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 xl:grid-col-4 gap-lg mt-xl">
           {% for product in products %}
               <a href="{{ product.url }}" class="product-card  {{ section.settings.product_card_background }} {{ section.settings.card_border_radius | default: 'rounded-xl' }}">
                <div class="product-image-link">
                 <div class="product-image {{ section.settings.image_border_radius | default: 'rounded-xl' }}">
                   {% assign image_url = '' %}
                   {% if product.images.size > 0 %}
                     {% assign image_url = product.images[0].src %}
                   {% elsif product.image %}
                     {% assign image_url = product.image | image_url %}
                   {% endif %}

                   {% if image_url != '' %}
                     <img src="{{ image_url }}"
                       alt="{{ product.title }}"
                       class="image-cover" />
                   {% else %}
                     <div class="h-full w-full flex items-center justify-center bg-gray-100">
                       <span class="text-gray-400">No image available</span>
                     </div>
                   {% endif %}
                 </div>
                </div>
                 <div class="desc px-md py-md">
                   <div class="product-title text-hover-effect line-clamp-2 {{ section.settings.product_title_font_family }} {{ section.settings.product_title_font_size | default: 'text-base' }} {{ section.settings.product_title_font_size_desktop | default: 'lg:text-lg' }} {{ section.settings.product_title_font_weight | default: 'font-semibold' }} {{ section.settings.product_title_color }}">
                     {{ product.title }}
                   </div>
                   <div class="product-price {{ section.settings.product_price_font_family }} {{ section.settings.product_price_font_size | default: 'text-base' }} {{ section.settings.product_price_font_size_desktop | default: 'lg:text-xl' }} {{ section.settings.product_price_font_weight | default: 'font-bold' }} {{ section.settings.product_price_color }} pt-sm">
                     {{ product.price | money }}
                   </div>
                 </div>
               </a>
             {% endfor %}
           </div>
         {% else %}
           <div class="text-center py-2xl">
             <p class="text-gray-500">{{ section.settings.empty_state_text | default: 'No products found' }}</p>
           </div>
         {% endif %}
       </div>
       {%- if paginate.pages > 1 -%}
         <div class="mt-12">
           {% render 'pagination', paginate: paginate, anchor: '' %}
         </div>
       {%- endif -%}
     {% endpaginate %}
     
  </div>
</section>

