<!-- Shop by Solution Section -->
<section class="shop-by-solution {{ section.settings.background_color | default: 'bg-white' }} {{ section.settings.section_padding_y_mobile | default: 'py-xl' }} {{ section.settings.section_padding_y_desktop | default: 'lg:py-3xl' }} {{ section.settings.section_border_radius | default: 'rounded-none' }}" id="shop-by-solution-{{ section.id }}" {% if section.settings.background_image %}data-bg="{{ section.settings.background_image | image_url }}"{% endif %}>
    <div class="{{section.settings.container_layout_width | default: 'container'}}">
      <div class="shop-by-solution-inner {{ section.settings.container_background_color }} {{ section.settings.container_border_radius | default: 'rounded-none' }} {{ section.settings.container_padding_y_mobile | default: 'py-lg' }} {{ section.settings.container_padding_y_desktop | default: 'lg:py-2xl' }} {{ section.settings.container_padding_x_mobile | default: 'px-md' }} {{ section.settings.container_padding_x_desktop | default: 'lg:px-xl' }}" {% if section.settings.container_background_image %}data-bg="{{ section.settings.container_background_image | image_url }}"{% endif %}>
        
        <!-- Section Heading -->
        {% if section.settings.heading != blank %}
        <div class="section-heading text-center mb-2xl">
          <h2 class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-3xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-5xl' }} {{ section.settings.heading_font_weight | default: 'font-semibold' }} {{ section.settings.heading_color | default: 'text-primary' }} leading-heading">
            {{ section.settings.heading }}
          </h2>
        </div>
        {% endif %}
        
        <!-- Category Cards Grid -->
        {% assign categories_limit = section.settings.categories_limit | default: 8 %}
        {% if categories.size > 0 %}
        <div class="category-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 {{ section.settings.grid_gap | default: 'gap-lg' }}">
          {% for category in categories limit: categories_limit %}
            <a href="/categories/{{ category.handle | default: category.slug }}" 
               class="category-card relative overflow-hidden"
               style="border-radius: {{ section.settings.card_border_radius | default: 8 }}px; height: {{ section.settings.card_height | default: 320 }}px;">
              
              <!-- Background Image (from category) -->
              <div class="category-bg absolute inset-0 z-0">
                {% if category.image != blank %}
                  <img src="{{ category.image }}" 
                       alt="{{ category.title | default: 'Category' }}"
                       class="w-full h-full object-cover"
                       loading="lazy">
                {% else %}
                  <img src="{{ 'placeholder-image.png' | asset_url }}" 
                       alt="Placeholder"
                       class="w-full h-full object-cover">
                {% endif %}
              </div>
              
              <!-- Overlay (optional) -->
              {% if section.settings.show_overlay %}
              <div class="category-overlay absolute inset-0 z-10" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.3 }});"></div>
              {% endif %}
              
              <!-- Content - Vertically and Horizontally Centered -->
              <div class="category-content absolute inset-0 z-20 flex items-center justify-center px-md">
                <div class="content-wrapper flex flex-col items-center">
                  
                  <!-- Category Title Image (from category) -->
                  {% if category.image != blank %}
                  <div class="category-title-image" style="margin-bottom: {{ section.settings.icon_spacing | default: 16 }}px;">
                    <img src="{{ category.image }}" 
                         alt="{{ category.title }}"
                         style="max-width: {{ section.settings.icon_size | default: 80 }}px; max-height: {{ section.settings.icon_size | default: 80 }}px; width: auto; height: auto; display: block; object-fit: contain;"
                         loading="lazy">
                  </div>
                  {% endif %}
                  
                  <!-- Title -->
                  {% if category.title != blank %}
                  <div class="category-title">
                    <h3 class="{{ section.settings.title_font_family | default: 'font-primary' }} {{ section.settings.title_font_size | default: 'text-xl' }} {{ section.settings.title_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.title_font_weight | default: 'font-semibold' }} {{ section.settings.title_color | default: 'text-white' }} text-center leading-heading" style="white-space: nowrap;">
                      {{ category.title }}
                    </h3>
                  </div>
                  {% endif %}
                  
                </div>
              </div>
              
            </a>
          {% endfor %}
        </div>
        {% else %}
        <!-- Empty State -->
        <div class="empty-categories text-center py-3xl">
          <div class="empty-categories-content">
            <p class="{{ section.settings.heading_font_family | default: 'font-primary' }} {{ section.settings.heading_font_size | default: 'text-xl' }} {{ section.settings.heading_font_size_desktop | default: 'lg:text-2xl' }} {{ section.settings.heading_color | default: 'text-primary' }} mb-lg">
              Categories is empty
            </p>
            <a href="/categories/new" 
               class="inline-block px-lg py-md bg-primary text-white rounded-md hover:bg-primary-dark transition-colors {{ section.settings.heading_font_family | default: 'font-primary' }} font-medium">
              Create Category
            </a>
          </div>
        </div>
        {% endif %}
        
      </div>
    </div>
  </section>
  
