<main class="main-container">
  <div class="product-page">
    <div class="product-container">
      <div class="left-column">
        <div class="section-images">
          {% section 'product_images', id: 'product_images' %}
        </div>

        <div class="section-banner">
          {% section 'launch_enrollment_pack', id: 'launch_enrollment_pack' %}
        </div>
      </div>

      <div class="right-column">
        <div class="section-description">
          {% section 'product_description', id: 'product_description' %}
        </div>
        
        {% if enrollment_pack.available_for_country %}
          <div class="section-customization">
            {% section 'choose_your_vital', id: 'choose_your_vital' %}
            {% section 'add_to_cart', id: 'add_to_cart' %}
          </div>
        {% else %}
          <p class="no-available">This product is not available for you country</p>
        {% endif%}
      </div>
    </div>
  </div>
</main>


{% schema %}
  {
    "sections": {
    "product_images": {
      "type": "product_images"
    },
    "product_description": {
      "type": "product_description"
    },
    "launch_enrollment_pack": {
      "type": "launch_enrollment_pack"
    },
    "add_to_cart": {
      "type": "add_to_cart"
    },
    "choose_your_vital": {
      "type": "choose_your_vital"
    }
    },
    "layout": "theme",
    "order": [
      "product_images",
      "product_description",
      "nature_to_body",
      "quality_promise",
      "launch_enrollment_pack",
      "add_to_cart",
      "choose_your_vital"
    ],
    "name": "Product Page"
  }
{% endschema %}