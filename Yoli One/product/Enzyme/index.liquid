<script>
  (function() {
    function appendInfoColumnToSidebar() {
    
      // Only run on screens above 1024px
      if (window.innerWidth <= 1024) {
        return;
      }
      
      
  
      // Find the product-header-4 section
      const headerSection = document.querySelector('[data-fluid-section="lgp_product_header"]');
      if (!headerSection) {
        return;
      }
  
      // Find the info-column inside the header section
      const infoColumn = headerSection.querySelector('.info-column');
      if (!infoColumn) {
        return;
      }
  
      // Find the sidebar
      const sidebar = document.querySelector('.product-layout-grid-sidebar');
      if (!sidebar) {
        return;
      }
  
      if (sidebar.querySelector('.fluid-sidebar-clone')) return;

      const clonedInfoColumn = infoColumn.cloneNode(true);

      const wrapper = document.createElement('section');
      wrapper.className = 'fluid-sidebar-clone';
      wrapper.setAttribute('data-fluid-section', 'lgp_product_header');
      wrapper.setAttribute('data-fluid-section-type', 'product-header-4');

      wrapper.appendChild(clonedInfoColumn);
      sidebar.appendChild(wrapper);
    }
  
    // Run on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', appendInfoColumnToSidebar);
    } else {
      appendInfoColumnToSidebar();
    }
  
    // Handle window resize - remove if screen becomes smaller than 1024px
    let resizeTimeout;
    window.addEventListener('resize', function() {
      let selectedCard;

      $('.subscription-option-card').each(function () {
        if ($(this).hasClass('selected')) {
          selectedCard = $(this).attr('data-option');
        }
      });
  
      // Check radio only for the matching card
      $('.subscription-option-card').each(function () {
        if ($(this).attr('data-option') == selectedCard) {
          $(this).addClass('selected');
          $(this).find('.subscription-radio').prop('checked', true);
        } else {
          
        }
      });

      
      // Accordion functionality
      const accordions = document.querySelectorAll('.product-layout-grid-sidebar .accordion-item');
      
      accordions.forEach(item => {
        const header = item.querySelector('.accordion-header');
        
        if (header) {
          header.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            // Close all other accordions
            accordions.forEach(otherItem => {
              if (otherItem !== item) {
                otherItem.classList.remove('active');
              }
            });
            
            // Toggle current accordion-item
            item.classList.toggle('active');
          });
        }
      });

      // End Accordion
      
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(function() {
        const sidebar = document.querySelector('.product-layout-grid-sidebar');
        if (sidebar && window.innerWidth <= 1024) {
          const cloneWrapper = sidebar.querySelector('.fluid-sidebar-clone');
          if (cloneWrapper) {
            cloneWrapper.remove();
          }
        } else if (window.innerWidth > 1024) {
          appendInfoColumnToSidebar();
        }
        
      }, 250);
    });
    
  })();
  
  
  </script>

